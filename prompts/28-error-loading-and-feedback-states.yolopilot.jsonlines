                    \"description\": \"The loadComplete event mirrors the load complete event sent by the browser to assistive\\ntechnology when the web page has finished loading.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:2597:                            \"description\": \"address field name, for example GIVEN_NAME.\\nThe full list of supported field names:\\nhttps://source.chromium.org/chromium/chromium/src/+/main:components/autofill/core/browser/field_types.cc;l=38\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3419:            \"description\": \"The Browser domain defines methods and events for browser managing.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3433:                    \"description\": \"The state of the browser window.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3684:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3685:                            \"description\": \"Context to override. When omitted, default browser context is used.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3711:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3712:                            \"description\": \"BrowserContext to override permissions. When omitted, default browser context is used.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3723:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3724:                            \"description\": \"BrowserContext to reset permissions. When omitted, default browser context is used.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3747:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3748:                            \"description\": \"BrowserContext to set download behavior. When omitted, default browser context is used.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3777:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3778:                            \"description\": \"BrowserContext to perform the action in. When omitted, default browser context is used.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3786:                    \"description\": \"Close browser gracefully.\"\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3790:                    \"description\": \"Crashes browser on the main thread.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3831:                    \"description\": \"Returns the command line switches for the browser process if, and only if\\n--enable-automation is on the commandline.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3900:                    \"description\": \"Get position and size of the browser window.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3919:                    \"description\": \"Get the browser window that contains the devtools target.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3944:                    \"description\": \"Set position and/or size of the browser window.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:3961:                    \"description\": \"Set size of the browser contents resizing browser window as necessary.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:4003:                    \"description\": \"Invoke custom browser commands used by telemetry.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:4039:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:4040:                            \"description\": \"BrowserContext to perform the action in. When omitted, default browser\\ncontext is used.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:4737:                            \"description\": \"Whether the property is understood by the browser (implies `true` if absent).\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:5605:                    \"description\": \"Ensures that the given node will have specified pseudo-classes whenever its style is computed by\\nthe browser.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:6411:                    \"description\": \"Fires whenever a MediaQuery result changes (for example, after a browser window has been\\nresized.) The current implementation considers only viewport-dependent media features.\"\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:6779:                    \"description\": \"Sets a sink to be used when the web page requests the browser to choose a\\nsink via Presentation API, Remote Playback API, or Cast SDK.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:11362:                    \"description\": \"Resizes the frame/viewport of the page. Note that this does not affect the frame's container\\n(e.g. browser window). Can be used to produce screenshots of the specified size. Not supported\\non Android.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:11608:            \"description\": \"Defines commands and events for browser extensions.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:11912:                            \"description\": \"Allows callers to disable the promise rejection delay that would\\nnormally happen, if this is unimportant to what's being tested.\\n(step 4 of https://fedidcg.github.io/FedCM/#browser-api-rp-sign-in)\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:11986:            \"description\": \"A domain for letting clients substitute browser's network layer with client code.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:12546:                    \"description\": \"Encoding options for a screenshot.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:12578:                    \"description\": \"Sends a BeginFrame to the target and returns when the frame was completed. Optionally captures a\\nscreenshot from the resulting frame. Requires that the target was created with enabled\\nBeginFrameControl. Designed for use with --run-all-compositor-stages-before-draw, see also\\nhttps://goo.gle/chrome-headless-rendering for more background.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:12594:                            \"description\": \"Whether updates should not be committed and drawn onto the display. False by default. If\\ntrue, only side effects of the BeginFrame will be run, such as layout and animations, but\\nany visual updates may not be visible on the display or in screenshots.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:12599:                            \"name\": \"screenshot\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:12600:                            \"description\": \"If set, a screenshot of the frame will be captured and returned in the response. Otherwise,\\nno screenshot will be captured. Note that capturing a screenshot can fail, for example,\\nduring renderer initialization. In such a case, no screenshot data will be returned.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:12612:                            \"name\": \"screenshotData\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:12613:                            \"description\": \"Base64-encoded image data of the screenshot, if one was requested and successfully taken. (Encoded as a base64 string when passed over JSON)\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:14767:                    \"description\": \"Send events as a list, allowing them to be batched on the browser for less\\ncongestion. If batched, events must ALWAYS be in chronological order.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:15039:                    \"description\": \"Retrieve native memory allocations profile\\ncollected since browser process startup.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:15147:                    \"description\": \"The underlying connection technology that the browser is supposedly using.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:15815:                            \"description\": \"Resource mimeType as determined by the browser.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:15820:                            \"description\": \"Resource charset as determined by the browser (if applicable).\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:16105:                            \"description\": \"The site of the top-level URL the browser was visiting at the start\\nof the request to the endpoint that set the cookie.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:17641:                    \"description\": \"Tells whether clearing browser cache is supported.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:17646:                            \"description\": \"True if browser cache can be cleared.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:17653:                    \"description\": \"Tells whether clearing browser cookies is supported.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:17658:                            \"description\": \"True if browser cookies can be cleared.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:17677:                    \"description\": \"Clears browser cache.\"\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:17681:                    \"description\": \"Clears browser cookies.\"\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:17739:                    \"description\": \"Deletes browser cookies with matching name and url or domain/path/partitionKey pair.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:17955:                    \"description\": \"Returns all browser cookies. Depending on the backend support, will return detailed cookie\\ninformation in the `cookies` field.\\nDeprecated. Use Storage.getCookies instead.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:17991:                    \"description\": \"Returns all browser cookies for the current URL. Depending on the backend support, will return\\ndetailed cookie information in the `cookies` field.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:20835:                    \"name\": \"screenshotRequested\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:20836:                    \"description\": \"Fired when user asks to capture screenshot of some area on the page.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:20875:            \"description\": \"This domain allows interacting with the browser to control PWAs.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:20880:                    \"description\": \"The following types are the replica of\\nhttps://crsrc.org/c/chrome/browser/web_applications/proto/web_app_os_integration_state.proto;drc=9910d3be894c8f142c977ba1023f30a656bc13fc;l=67\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:20920:                    \"description\": \"If user prefers opening the app in browser or an app window.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:20924:                        \"browser\"\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:21040:                    \"description\": \"Changes user settings of the web app identified by its manifestId. If the\\napp was not installed, this command returns an error. Unset parameters will\\nbe ignored; unrecognized values will cause an error.\\n\\nUnlike the ones defined in the manifest files of the web apps, these\\nsettings are provided by the browser and controlled by the users, they\\nimpact the way the browser handling the web apps.\\n\\nSee the comment of each parameter.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:21544:                            \"description\": \"Frame document's mimeType as determined by the browser.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:21602:                            \"description\": \"Resource mimeType as determined by the browser.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:21911:                    \"description\": \"Viewport for capturing screenshot.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:22189:                    \"description\": \"The image definition used in both icon and screenshot.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:22461:                            \"name\": \"screenshots\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:22462:                            \"description\": \"The screenshots used by chromium.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:22827:                    \"description\": \"Capture page screenshot.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:22848:                            \"description\": \"Capture the screenshot of a given region only.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:22854:                            \"description\": \"Capture the screenshot from the surface, rather than the view. Defaults to true.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:22861:                            \"description\": \"Capture the screenshot beyond the viewport. Defaults to false.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:22957:                    \"description\": \"Deletes browser cookie with given name, domain and path.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:23437:                            \"description\": \"If true, browser cache is ignored (as if the user pressed Shift+refresh).\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:23855:                            \"description\": \"Maximum screenshot width.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:23861:                            \"description\": \"Maximum screenshot height.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:24186:                    \"description\": \"Fired when a navigation starts. This event is fired for both\\nrenderer-initiated and browser-initiated navigations. For renderer-initiated\\nnavigations, the event is fired after `frameRequestedNavigation`.\\nNavigation may still be cancelled after the event is issued. Multiple events\\ncan be fired for a single navigation, for example, when a same-document\\nnavigation becomes a cross-document navigation (such as in the case of a\\nframeset).\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:24416:                            \"description\": \"True iff browser is capable showing or acting on the given dialog. When browser has no\\ndialog handler for given target, calling alert while Page domain is engaged will stall\\nthe page execution. Execution can be resumed via calling Page.handleJavaScriptDialog.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:27806:                    \"description\": \"Returns all browser cookies.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:27809:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:27810:                            \"description\": \"Browser context to use when called on the browser endpoint.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:27839:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:27840:                            \"description\": \"Browser context to use when called on the browser endpoint.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:27851:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:27852:                            \"description\": \"Browser context to use when called on the browser endpoint.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:28263:                    \"description\": \"Returns the effective Related Website Sets in use by this profile for the browser\\nsession. The effective Related Website Sets will not change during a browser session.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:28959:                            \"description\": \"The command line string used to launch the browser. Will be the empty string if not\\nsupported.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29019:                            \"description\": \"List of types: https://source.chromium.org/chromium/chromium/src/+/main:content/browser/devtools/devtools_agent_host_impl.cc?ss=chromium&q=f:devtools%20-f:out%20%22::kTypeTab%5B%5D%22\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29062:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29098:                    \"description\": \"The entries in TargetFilter are matched sequentially against targets and\\nthe first entry that matches determines if the target is included or not,\\ndepending on the value of `exclude` field in the entry.\\nIf filter is not specified, the one assumed is\\n[{type: \\\"browser\\\", exclude: true}, {type: \\\"tab\\\", exclude: true}, {}]\\n(i.e. include everything but `browser` and `tab`).\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29169:                    \"description\": \"Attaches to the browser target, only uses flat sessionId mode.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29199:                    \"description\": \"Inject object to the target's main frame that provides a communication\\nchannel with browser target.\\n\\nInjected object will be available as `window[bindingName]`.\\n\\nThe object has the following API:\\n- `binding.send(json)` - a method to send messages over the remote debugging protocol\\n- `binding.onmessage = json => handleMessage(json)` - a callback that will be called for the protocol notifications and command responses.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29258:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29266:                    \"description\": \"Returns all browser contexts created with `Target.createBrowserContext` method.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29269:                            \"name\": \"browserContextIds\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29270:                            \"description\": \"An array of browser context ids.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29278:                            \"description\": \"The id of the default browser context if available.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29327:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29328:                            \"description\": \"The browser context to create the page in.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29368:                            \"description\": \"If specified, the option is used to determine if the new target should\\nbe focused or not. By default, the focus behavior depends on the\\nvalue of the background field. For example, background=false and focus=false\\nwill result in the target tab being opened but the browser window remain\\nunchanged (if it was in the background, it will remain in the background)\\nand background=false with focus=undefined will result in the window being focused.\\nUsing background: true and focus: true is not supported and will result in an error.\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29406:                            \"name\": \"browserContextId\",\ntools/webapp-qa/node_modules/devtools-protocol/json/browser_protocol.json:29724:            \"description\": \"The Tethering d