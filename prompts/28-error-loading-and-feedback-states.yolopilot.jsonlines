{"color": "cyan", "emoji": "\ud83d\udee0\ufe0f", "event_type": "Command Finished", "message": "completed, exit 0: /bin/zsh -lc \"sed -n '1,220p' frontend/src/shared/ui/ToastRegion.tsx\"", "raw_event": {"item": {"aggregated_output": "import type { AppShellToast } from '../../state/appShellStore.ts'\nimport { Badge, Panel, StackedList, StackedListItem } from './primitives.tsx'\n\ntype ToastRegionProps = {\n  toasts: ReadonlyArray<AppShellToast>\n}\n\nfunction getToastTone(tone: AppShellToast['tone']) {\n  if (tone === 'success') {\n    return 'success'\n  }\n\n  if (tone === 'warning') {\n    return 'accent'\n  }\n\n  return 'brand'\n}\n\nexport function ToastRegion({ toasts }: ToastRegionProps) {\n  return (\n    <Panel\n      actions={<Badge tone=\"brand\">{toasts.length}</Badge>}\n      aria-label=\"Future notification dock\"\n      as=\"section\"\n      className=\"toast-region\"\n      eyebrow=\"Toasts\"\n      tone=\"subtle\"\n    >\n      {toasts.length === 0 ? (\n        <p className=\"toast-region__empty\">\n          Workflow notifications, export alerts, and background job updates will\n          dock here.\n        </p>\n      ) : (\n        <StackedList className=\"toast-region__list\">\n          {toasts.map((toast) => (\n            <StackedListItem\n              key={toast.id}\n              className={`toast-region__item toast-region__item--${toast.tone}`}\n              tone={getToastTone(toast.tone)}\n            >\n              <strong>{toast.title}</strong>\n              <p>{toast.body}</p>\n            </StackedListItem>\n          ))}\n        </StackedList>\n      )}\n    </Panel>\n  )\n}\n", "command": "/bin/zsh -lc \"sed -n '1,220p' frontend/src/shared/ui/ToastRegion.tsx\"", "exit_code": 0, "id": "item_5", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 15, "prompt_index": 29, "prompt_name": "28 \u2014 Error, Loading, and Feedback States", "prompt_total": 100}, "times