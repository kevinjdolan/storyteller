{"type":"item.completed","item":{"id":"item_27","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' /Users/kevin/code/storyteller/docs/realtime-events.schema.json\"","aggregated_output":"{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"bundle_schema_version\": 1,\n  \"schemas\": {\n    \"session_event\": {\n      \"$defs\": {\n        \"ChatContentFormat\": {\n          \"enum\": [\n            \"plain_text\",\n            \"markdown\"\n          ],\n          \"title\": \"ChatContentFormat\",\n          \"type\": \"string\"\n        },\n        \"ChatMessageEventPayload\": {\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"content\": {\n              \"minLength\": 1,\n              \"title\": \"Content\",\n              \"type\": \"string\"\n            },\n            \"content_format\": {\n              \"$ref\": \"#/$defs/ChatContentFormat\",\n              \"default\": \"plain_text\"\n            },\n            \"message_id\": {\n              \"minLength\": 1,\n              \"title\": \"Message Id\",\n              \"type\": \"string\"\n            },\n            \"message_role\": {\n              \"$ref\": \"#/$defs/ChatMessageRole\"\n            },\n            \"schema_version\": {\n              \"default\": 1,\n              \"minimum\": 1,\n              \"title\": \"Schema Version\",\n              \"type\": \"integer\"\n            },\n            \"source\": {\n              \"default\": \"chat\",\n              \"title\": \"Source\",\n              \"type\": \"string\"\n            }\n          },\n          \"required\": [\n            \"message_id\",\n            \"message_role\",\n            \"content\"\n          ],\n          \"title\": \"ChatMessageEventPayload\",\n          \"type\": \"object\"\n        },\n        \"ChatMessageRealtimeEvent\": {\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"actor\": {\n              \"$ref\": \"#/$defs/SessionEventActor\"\n            },\n            \"channel\": {\n              \"minLength\": 1,\n              \"title\": \"Channel\",\n              \"type\": \"string\"\n            },\n            \"correlation_id\": {\n              \"anyOf\": [\n                {\n                  \"type\": \"string\"\n                },\n                {\n                  \"type\": \"null\"\n                }\n              ],\n              \"default\": null,\n              \"title\": \"Correlation Id\"\n            },\n            \"created_at\": {\n              \"format\": \"date-time\",\n              \"title\": \"Created At\",\n              \"type\": \"string\"\n            },\n            \"delivery\": {\n              \"$ref\": \"#/$defs/RealtimeDeliveryMode\",\n              \"default\": \"live\"\n            },\n            \"event_id\": {\n              \"minLength\": 1,\n              \"title\": \"Event Id\",\n              \"type\": \"string\"\n            },\n            \"event_log_entry_id\": {\n              \"minLength\": 1,\n              \"title\": \"Event Log Entry Id\",\n              \"type\": \"string\"\n            },\n            \"payload\": {\n              \"$ref\": \"#/$defs/ChatMessageEventPayload\"\n            },\n            \"replayable\": {\n              \"const\": true,\n              \"default\": true,\n              \"title\": \"Replayable\",\n              \"type\": \"boolean\"\n            },\n            \"schema_version\": {\n              \"default\": 1,\n              \"minimum\": 1,\n              \"title\": \"Schema Version\",\n              \"type\": \"integer\"\n            },\n            \"sequence_number\": {\n              \"minimum\": 1,\n              \"title\": \"Sequence Number\",\n              \"type\": \"integer\"\n            },\n            \"session_id\": {\n              \"minLength\": 1,\n              \"title\": \"Session Id\",\n              \"type\": \"string\"\n            },\n            \"stage\": {\n              \"anyOf\": [\n                {\n                  \"$ref\": \"#/$defs/WorkflowStage\"\n                },\n                {\n                  \"type\": \"null\"\n                }\n              ],\n              \"default\": null\n            },\n            \"type\": {\n              \"const\": \"chat.message\",\n              \"default\": \"chat.message\",\n              \"title\": \"Type\",\n              \"type\": \"string\"\n            }\n          },\n          \"required\": [\n            \"session_id\",\n            \"channel\",\n            \"event_id\",\n            \"actor\",\n            \"created_at\",\n            \"sequence_number\",\n            \"event_log_entry_id\",\n            \"payload\"\n          ],\n          \"title\": \"ChatMessageRealtimeEvent\",\n          \"type\": \"object\"\n        },\n        \"ChatMessageRole\": {\n          \"enum\": [\n            \"user\",\n            \"assistant\",\n            \"system\",\n            \"tool\"\n          ],\n          \"title\": \"ChatMessageRole\",\n          \"type\": \"string\"\n        },\n        \"CompositionChunkEventPayload\": {\n          \"additionalProperties\": false,\n          \"properties\": {\n            \"chunk_index\": {\n              \"minimum\": 0,\n              \"title\": \"Chunk Index\",\n              \"type\": \"integer\"\n            },\n            \"chunk_kind\": {\n              \"$ref\": \"#/$defs/CompositionChunkKind\",\n              \"default\": \"delta\"\n            },\n            \"cumulative_character_count\": {\n              \"anyOf\": [\n                {\n                  \"minimum\": 0,\n                  \"type\": \"integer\"\n                },\n                {\n                  \"type\": \"null\"\n                }\n              ],\n              \"default\": null,\n              \"title\": \"Cumulative Character Count\"\n            },\n            \"cumulative_word_count\": {\n              \"anyOf\": [\n                {\n                  \"minimum\": 0,\n                  \"type\": \"integer\"\n                },\n                {\n                  \"type\": \"null\"\n                }\n              ],\n              \"default\": null,\n              \"title\": \"Cumulative Word Count\"\n            },\n            \"is_final_chunk\": {\n              \"default\": false,\n              \"title\": \"Is Final Chunk\",\n              \"type\": \"boolean\"\n            },\n            \"job_id\": {\n              \"minLength\": 1,\n              \"title\": \"Job Id\",\n              \"type\": \"string\"\n            },\n            \"schema_version\": {\n              \"default\": 1,\n              \"minimum\": 1,\n              \"title\": \"Schema Version\",\n              \"type\": \"integer\"\n            },\n            \"segment_id\": {\n              \"minLength\": 1,\n              \"title\": \"Segment Id\",\n              \"type\": \"string\"\n            },\n            \"segment_index\": {\n              \"minimum\": 1,\n              \"title\": \"Segment Index\",\n              \"type\": \"integer\"\n            },\n            \"summary\": {\n              \"anyOf\": [\n                {\n                  \"type\": \"string\"\n                },\n                {\n                  \"type\": \"null\"\n                }\n              ],\n              \"default\": null,\n              \"title\": \"Summary\"\n            },\n            \"text\": {\n              \"anyOf\": [\n                {\n                  \"type\": \"string\"\n                },\n                {\n                  \"type\": \"null\"\n                }\n              ],\n              \"default\": null,\n              \"title\": \"Text\"\n            }\n          },\n          \"required\": [\n            \"job_id\",\n            \"segment_id\",\n            \"segment_index\",\n            \"chunk_index\"\n          ],\n          \"title\": \"CompositionChunkEventPayload\",\n          \"type\": \"object\"\n        },\n","exit_code":0,"status":"completed"}}
