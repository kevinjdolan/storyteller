ert payload[\"agent_context_summary\"].startswith(\"Session title: Moonlit Harbor\")\nbackend/tests/test_session_api.py:204:        in payload[\"snapshot\"][\"agent_context_summary\"]\nbackend/app/models/session.py:169:class RecentSessionSummary(BaseModel):\nbackend/app/models/session.py:185:class SessionSnapshot(BaseModel):\nbackend/app/models/session.py:209:    agent_context_summary: str | None = None\n", "command": "/bin/zsh -lc \"rg -n \\\"agent_context_summary|build_session_agent_context_summary|SessionSnapshot\\\\(|RecentSessionSummary\\\\(\\\" backend/app backend/tests\"", "exit_code": 0, "id": "item_22", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 47, "prompt_index": 37, "prompt_name": "36 \u2014 Conversation Memory and Rolling Summaries", "prompt_total": 100}, "timestap": "2026-04-01T07:07:01-07:00"}
