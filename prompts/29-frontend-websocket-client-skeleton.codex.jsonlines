es/sessions.py:64:        self._event_log = SessionEventLogService(session)\nbackend/app/services/sessions.py:70:        actor: SessionEventActor | None = None,\nbackend/app/services/sessions.py:123:        actor: SessionEventActor | None = None,\nbackend/app/services/sessions.py:462:        progress_percent=row.progress_percent,\nbackend/migrations/README.md:16:- append-only event log entries\nbackend/migrations/versions/20260331_01_initial_storyteller_schema.py:477:            \"progress_percent\",\nbackend/app/models/__init__.py:20:    SessionEventActor,\nbackend/app/models/__init__.py:21:    SessionEventType,\nbackend/app/models/__init__.py:22:    SessionEventView,\nbackend/app/models/__init__.py:31:from app.models.realtime import (\nbackend/app/models/__init__.py:58:    get_realtime_contract_schema_bundle,\nbackend/app/models/__init__.py:136:    \"SessionEventActor\",\nbackend/app/models/__init__.py:137:    \"SessionEventType\",\nbackend/app/models/__init__.py:138:    \"SessionEventView\",\nbackend/app/models/__init__.py:165:    \"get_realtime_contract_schema_bundle\",\nbackend/app/models/session.py:93:    progress_percent: float\nbackend/app/models/events.py:13:class SessionEventType(str, Enum):\nbackend/app/models/events.py:67:class SessionEventActor(BaseModel):\nbackend/app/models/events.py:140:    progress_percent: float | None = None\nbackend/app/models/events.py:149:    progress_percent: float | None = None\nbackend/app/models/events.py:157:SessionEventPayload: TypeAlias = (\nbackend/app/models/events.py:170:    SessionEventType.SESSION_CREATED.value: SessionCreatedEventPayload,\nbackend/app/models/events.py:171:    SessionEventType.WORKFLOW_STAGE_CHANGED.value: WorkflowStageChangedEventPayload,\nbackend/app/models/events.py:172:    SessionEventType.SELECTION_RECORDED.value: SelectionRecordedEventPayload,\nbackend/app/models/events.py:173:    SessionEventType.AI_OUTPUT_RECORDED.value: AIOutputRecordedEventPayload,\nbackend/app/models/events.py:174:    SessionEventType.USER_EDIT_RECORDED.value: UserEditRecordedEventPayload,\nbackend/app/models/events.py:175:    SessionEventType.CHAT_MESSAGE_RECORDED.value: ChatMessageRecordedEventPayload,\nbackend/app/models/events.py:176:    SessionEventType.UI_ACTION_RECORDED.value: UIActionRecordedEventPayload,\nbackend/app/models/events.py:177:    SessionEventType.COMPOSITION_PROGRESS_RECORDED.value: CompositionProgressEventPayload,\nbackend/app/models/events.py:178:    SessionEventType.AUDIO_PROGRESS_RECORDED.value: AudioProgressEventPayload,\nbackend/app/models/events.py:182:class SessionEventView(BaseModel):\nbackend/app/models/events.py:186:    actor: SessionEventActor\nbackend/app/models/events.py:190:    payload: SessionEventPayload | dict[str, Any] | list[Any] | None = None\nbackend/app/models/events.py:197:    events: list[SessionEventView] = Field(default_factory=list)\nbackend/app/models/events.py:217:) -> SessionEventPayload | dict[str, Any] | list[Any] | None:\nbackend/app/models/realtime.py:9:from app.models.events import ChatMessageRole, SessionEventActor, WorkflowStageChangedEventPayload\nbackend/app/models/realtime.py:115:    local_actor: SessionEventActor\nbackend/app/models/realtime.py:164:    progress_percent: float | None = Field(default=None, ge=0, le=100)\nbackend/app/models/realtime.py:207:    actor: SessionEventActor\nbackend/app/models/realtime.py:277:def get_realtime_contract_schema_bundle() -> dict[str, Any]:\nbackend/app/db/models.py:527:    progress_percent: Mapped[float] = mapped_column(\n","exit_code":0,"status":"completed"}}
