ree-form idea and any normalized planning summary derived from it.\\\",\\\"status\\\":\\\"draft\\\",\\\"detail\\\":null,\\\"started_at\\\":null,\\\"completed_at\\\":null,\\\"last_event_summary\\\":null,\\\"last_event_type\\\":null,\\\"last_event_at\\\":null},{\\\"stage\\\":\\\"pitches\\\",\\\"label\\\":\\\"Pitches\\\",\\\"description\\\":\\\"Generate, compare, refine, and accept candidate story directions.\\\",\\\"status\\\":\\\"draft\\\",\\\"detail\\\":null,\\\"started_at\\\":null,\\\"completed_at\\\":null,\\\"last_event_summary\\\":null,\\\"last_event_type\\\":null,\\\"last_event_at\\\":null},{\\\"stage\\\":\\\"characters\\\",\\\"label\\\":\\\"Characters\\\",\\\"description\\\":\\\"Define the accepted character sheet that later planning and writing will reference.\\\",\\\"status\\\":\\\"draft\\\",\\\"detail\\\":null,\\\"started_at\\\":null,\\\"completed_at\\\":null,\\\"last_event_summary\\\":null,\\\"last_event_type\\\":null,\\\"last_event_at\\\":null},{\\\"stage\\\":\\\"beats\\\",\\\"label\\\":\\\"Beat sheet\\\",\\\"description\\\":\\\"Store the accepted Save-the-Cat beat sheet for the session.\\\",\\\"status\\\":\\\"draft\\\",\\\"detail\\\":null,\\\"started_at\\\":null,\\\"completed_at\\\":null,\\\"last_event_summary\\\":null,\\\"last_event_type\\\":null,\\\"last_event_at\\\":null},{\\\"stage\\\":\\\"story_setup\\\",\\\"label\\\":\\\"Story setup\\\",\\\"description\\\":\\\"Store soft planning targets such as word count, runtime, and chapter structure.\\\",\\\"status\\\":\\\"draft\\\",\\\"detail\\\":null,\\\"started_at\\\":null,\\\"completed_at\\\":null,\\\"last_event_summary\\\":null,\\\"last_event_type\\\":null,\\\"last_event_at\\\":null},{\\\"stage\\\":\\\"composition\\\",\\\"label\\\":\\\"Composition\\\",\\\"description\\\":\\\"Write the story durably in segments, with room for interruption and targeted rewrites.\\\",\\\"status\\\":\\\"draft\\\",\\\"detail\\\":null,\\\"started_at\\\":null,\\\"completed_at\\\":null,\\\"last_event_summary\\\":null,\\\"last_event_type\\\":null,\\\"last_event_at\\\":null},{\\\"stage\\\":\\\"audio\\\",\\\"label\\\":\\\"Audio\\\",\\\"description\\\":\\\"Configure narration settings and generate resumable audio artifacts.\\\",\\\"status\\\":\\\"draft\\\",\\\"detail\\\":null,\\\"started_at\\\":null,\\\"completed_at\\\":null,\\\"last_event_summary\\\":null,\\\"last_event_type\\\":null,\\\"last_event_at\\\":null},{\\\"stage\\\":\\\"finalize\\\",\\\"label\\\":\\\"Finalize\\\",\\\"description\\\":\\\"Read, listen, review final assets, and download exports.\\\",\\\"status\\\":\\\"draft\\\",\\\"detail\\\":null,\\\"started_at\\\":null,\\\"completed_at\\\":null,\\\"last_event_summary\\\":null,\\\"last_event_type\\\":null,\\\"last_event_at\\\":null}],\\\"story_brief\\\":null,\\\"selected_pitch\\\":null,\\\"selected_character_sheet\\\":null,\\\"selected_beat_sheet\\\":null,\\\"selected_story_setup\\\":null,\\\"active_composition_job\\\":null,\\\"active_audio_job\\\":null,\\\"latest_story_asset\\\":null,\\\"latest_audio_asset\\\":null}\",\"exit_code\":0,\"status\":\"completed\"}}\nprompts/23-frontend-state-foundation.codex.jsonlines:203:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_30\",\"type\":\"todo_list\",\"items\":[{\"text\":\"Inspect the current frontend state and data loading paths and confirm the existing session/home contracts.\",\"completed\":true},{\"text\":\"Add a server-state foundation with React Query plus thin session query hooks and a shared provider.\",\"completed\":false},{\"text\":\"Add a small local session-runtime store for pending UI actions and live event stream state, then route the workspace through it to avoid prop drilling.\",\"completed\":false},{\"text\":\"Update and expand tests, run frontend verification, and write the required reviewer summary file last.\",\"completed\":false}]}}\nprompts/26-main-pane-stage-scaffold.yolopilot.md:786:      if (snapshot.active_composition_job) {\n","exit_code":0,"status":"completed"}}
