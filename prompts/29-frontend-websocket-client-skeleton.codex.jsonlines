tate,\nfrontend/src/pages/session/SessionWorkspacePage.tsx:577:              runtimeStore.appendChatMessage(\nfrontend/src/pages/session/SessionWorkspacePage.tsx:589:              runtimeStore.appendChatMessage(\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:211:    expect(screen.getByText('Live feed not wired yet')).toBeInTheDocument()\nfrontend/src/features/session/sessionRuntimeStore.ts:38:  connectionState: SessionFeedConnectionState\nfrontend/src/features/session/sessionRuntimeStore.ts:48:  pendingActions: PendingSessionAction[]\nfrontend/src/features/session/sessionRuntimeStore.ts:49:  eventStream: SessionEventStreamState\nfrontend/src/features/session/sessionRuntimeStore.ts:71:  setConnectionState: (connectionState: SessionFeedConnectionState) => void\nfrontend/src/features/session/sessionRuntimeStore.ts:83:    pendingActions: [],\nfrontend/src/features/session/sessionRuntimeStore.ts:84:    eventStream: {\nfrontend/src/features/session/sessionRuntimeStore.ts:85:      connectionState: 'idle',\nfrontend/src/features/session/sessionRuntimeStore.ts:152:        pendingActions: [\nfrontend/src/features/session/sessionRuntimeStore.ts:153:          ...state.pendingActions,\nfrontend/src/features/session/sessionRuntimeStore.ts:164:        pendingActions: state.pendingActions.map((action) =>\nfrontend/src/features/session/sessionRuntimeStore.ts:177:        pendingActions: state.pendingActions.filter(\nfrontend/src/features/session/sessionRuntimeStore.ts:183:      const nextEvents = [...state.eventStream.events, event].slice(\nfrontend/src/features/session/sessionRuntimeStore.ts:189:        pendingActions:\nfrontend/src/features/session/sessionRuntimeStore.ts:191:            ? state.pendingActions.map((action) =>\nfrontend/src/features/session/sessionRuntimeStore.ts:199:            : state.pendingActions,\nfrontend/src/features/session/sessionRuntimeStore.ts:200:        eventStream: {\nfrontend/src/features/session/sessionRuntimeStore.ts:201:          ...state.eventStream,\nfrontend/src/features/session/sessionRuntimeStore.ts:204:            event.sequenceNumber ?? state.eventStream.lastSequenceNumber,\nfrontend/src/features/session/sessionRuntimeStore.ts:209:    setConnectionState: (connectionState) => {\nfrontend/src/features/session/sessionRuntimeStore.ts:212:        eventStream: {\nfrontend/src/features/session/sessionRuntimeStore.ts:213:          ...state.eventStream,\nfrontend/src/features/session/sessionRuntimeStore.ts:214:          connectionState,\nfrontend/src/features/session/SessionWorkspaceProvider.tsx:10:  const [runtimeStore] = useState(createSessionRuntimeStore)\nfrontend/src/features/session/SessionWorkspaceProvider.tsx:16:        runtimeStore,\nfrontend/src/features/session/sessionRuntimeStore.test.ts:13:      pendingActions: [],\nfrontend/src/features/session/sessionRuntimeStore.test.ts:14:      eventStream: {\nfrontend/src/features/session/sessionRuntimeStore.test.ts:15:        connectionState: 'idle',\nfrontend/src/features/session/sessionRuntimeStore.test.ts:46:    expect(store.getState().pendingActions).toEqual([\nfrontend/src/features/session/sessionRuntimeStore.test.ts:56:    expect(store.getState().eventStream.lastEventId).toBe('event-1')\nfrontend/src/features/session/sessionRuntimeStore.test.ts:57:    expect(store.getState().eventStream.lastSequenceNumber).toBe(19)\nfrontend/src/features/session/sessionRuntimeStore.test.ts:78:    expect(store.getState().eventStream.events).toEqual([])\nfrontend/src/features/session/sessionRuntimeStore.test.ts:96:    expect(store.getState().eventStream.connectionState).toBe('connecting')\nfrontend/src/features/session/sessionRuntimeStore.test.ts:97:    expect(store.getState().pendingActions).toEqual([\nfrontend/src/features/session/sessionWorkspaceContext.ts:10:  runtimeStore: SessionRuntimeStore\nfrontend/src/features/session/sessionWorkspaceContext.ts:37:  const { runtimeStore } = useSessionWorkspaceContext()\nfrontend/src/features/session/sessionWorkspaceContext.ts:40:    runtimeStore.subscribe,\nfrontend/src/features/session/sessionWorkspaceContext.ts:41:    () => selector(runtimeStore.getState()),\nfrontend/src/features/session/sessionWorkspaceContext.ts:42:    () => selector(runtimeStore.getState()),\nfrontend/src/features/session/sessionWorkspaceContext.ts:47:  return useSessionRuntimeSelector((state) => state.pendingActions)\nfrontend/src/features/session/sessionWorkspaceContext.ts:55:  return useSessionRuntimeSelector((state) => state.eventStream)\nfrontend/src/features/session/sessionWorkspaceContext.ts:59:  const { runtimeStore } = useSessionWorkspaceContext()\nfrontend/src/features/session/sessionWorkspaceContext.ts:61:  return runtimeStore\nfrontend/src/features/session/chat/SessionChatPane.test.tsx:37:        connectionLabel=\"Live feed connected\"\nfrontend/src/features/session/chat/SessionChatPane.test.tsx:70:        connectionLabel=\"Live feed connected\"\nfrontend/src/features/session/chat/SessionChatPane.test.tsx:106:        connectionLabel=\"Live feed connected\"\n","exit_code":0,"status":"completed"}}
