y: -8s;\n}\n\n.app-header {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) auto minmax(16rem, 22rem);\n  align-items: end;\n  gap: 20px;\n  margin-bottom: 20px;\n}\n\n.app-header__brand-block {\n  min-width: 0;\n}\n\n.app-kicker,\n.eyebrow {\n  margin: 0;\n  font-size: 0.78rem;\n  font-weight: 700;\n  letter-spacing: 0.18em;\n  text-transform: uppercase;\n}\n\n.app-kicker,\n.eyebrow {\n  color: var(--brand-gold);\n}\n\n.eyebrow-muted {\n  color: var(--brand-moss);\n}\n\n.app-brand,\nh1,\nh2,\nh3 {\n  font-family:\n    'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;\n  letter-spacing: -0.02em;\n}\n\n.app-brand {\n  display: block;\n  margin-top: 0.35rem;\n  font-size: clamp(2rem, 3vw, 2.8rem);\n  color: var(--brand-deep);\n}\n\n.app-brand-link {\n  color: inherit;\n  text-decoration: none;\n}\n\n.app-nav {\n  display: inline-flex;\n  align-items: center;\n  justify-self: center;\n  gap: 12px;\n  padding: 8px;\n  border: 1px solid var(--border-soft);\n  border-radius: 999px;\n  background: rgba(255, 252, 247, 0.72);\n  box-shadow: var(--shadow-soft);\n  backdrop-filter: blur(14px);\n}\n\n.app-nav__link {\n  padding: 0.7rem 1rem;\n  border-radius: 999px;\n  color: var(--ink-soft);\n  text-decoration: none;\n  font-weight: 600;\n  transition:\n    background-color 160ms ease,\n    color 160ms ease,\n    transform 160ms ease;\n}\n\n.app-nav__link:hover {\n  color: var(--brand-deep);\n  transform: translateY(-1px);\n}\n\n.app-nav__link--active {\n  background: rgba(39, 68, 100, 0.1);\n  color: var(--brand-deep);\n}\n\n.app-caption {\n  margin: 0;\n  max-width: 24rem;\n  justify-self: end;\n  text-align: right;\n  color: var(--ink-soft);\n}\n\n.app-main {\n  display: grid;\n  gap: 20px;\n}\n\n.app-utility-bar {\n  display: grid;\n  grid-template-columns: 1.05fr 0.95fr;\n  gap: 20px;\n  margin-bottom: 20px;\n}\n\n.connection-indicator,\n.toast-region {\n  padding: 20px 22px;\n  border: 1px solid var(--border-soft);\n  border-radius: 24px;