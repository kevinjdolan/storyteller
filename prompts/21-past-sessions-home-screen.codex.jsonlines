gin-top: 1.6rem;\n}\n\n.primary-link,\n.ghost-link {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-height: 2.85rem;\n  padding: 0.7rem 1rem;\n  border-radius: 999px;\n  border: 1px solid transparent;\n  cursor: pointer;\n  font-weight: 700;\n  text-decoration: none;\n  transition:\n    transform 160ms ease,\n    box-shadow 160ms ease,\n    background-color 160ms ease,\n    color 160ms ease;\n}\n\n.primary-link {\n  background: var(--brand-deep);\n  color: #fbf7f1;\n  box-shadow: 0 18px 32px rgba(39, 68, 100, 0.18);\n}\n\n.primary-link:hover,\n.ghost-link:hover {\n  transform: translateY(-1px);\n}\n\n.ghost-link {\n  border: 1px solid var(--border-soft);\n  background: rgba(255, 255, 255, 0.72);\n  color: var(--brand-deep);\n}\n\n.primary-link:disabled,\n.ghost-link:disabled {\n  cursor: wait;\n  opacity: 0.72;\n  transform: none;\n}\n\n.cta-note {\n  margin: 0;\n  max-width: 28rem;\n  color: var(--ink-soft);\n}\n\n.panel-heading {\n  display: grid;\n  gap: 0.45rem;\n  margin-bottom: 1.2rem;\n}\n\n.panel-heading h2,\n.panel-status h2 {\n  margin: 0;\n  font-size: 1.6rem;\n  color: var(--ink-deep);\n}\n\n.session-list {\n  display: grid;\n  gap: 12px;\n}\n\n.session-item {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 14px;\n  padding: 16px 18px;\n  border-radius: 20px;\n  background: rgba(255, 255, 255, 0.66);\n}\n\n.session-item__actions {\n  display: grid;\n  justify-items: end;\n  gap: 10px;\n}\n\n.session-item h3 {\n  margin: 0 0 0.3rem;\n  font-size: 1.15rem;\n}\n\n.status-chip,\n.status-badge {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  border-radius: 999px;\n  white-space: nowrap;\n  font-size: 0.85rem;\n  font-weight: 700;\n}\n\n.status-chip {\n  padding: 0.55rem 0.85rem;\n  background: rgba(86, 118, 90, 0.12);\n  color: var(--brand-moss);\n}\n\n.status-chip--count {\n  min-width: 2.5rem;\n  background: rgba(39, 68, 100, 0.08);\n  color: var(--brand-deep);\n}\n\n.status-chip--draft {\n  background: rgba(182, 128, 67, 0.16);\n  color: var(--brand-gold);\n}\n\n.status-chip--in-progress {\n  background: rgba(39, 68, 100, 0.1);\n  color: var(--brand-deep);\n}\n\n.status-chip--needs-regeneration {\n  background: rgba(167, 100, 84, 0.15);\n  color: var(--accent-rose);\n}\n\n.status-chip--completed {\n  background: rgba(86, 118, 90, 0.14);\n  color: var(--brand-moss);\n}\n\n.stage-list {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 12px;\n}\n\n.stage-list li,\n.workspace-stage-list li {\n  display: flex;\n  align-items: start;\n  gap: 12px;\n  min-height: 4.5rem;\n  padding: 0.95rem 1rem;\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.68);\n}\n\n.stage-list span,\n.workspace-stage-list span {\n  width: 2rem;\n  height: 2rem;\n  display: inline-grid;\n  place-items: center;\n  border-radius: 999px;\n  background: rgba(39, 68, 100, 0.12);\n  color: var(--brand-deep);\n  font-weight: 700;\n}\n\n.stage-list strong,\n.workspace-stage-list strong {\n  display: block;\n  margin-bottom: 0.25rem;\n}\n\n.status-badge {\n  min-width: 5.75rem;\n  padding: 0.6rem 0.9rem;\n}\n\n.status-badge--loading {\n  background: rgba(182, 128, 67, 0.14);\n  color: var(--brand-gold);\n}\n\n.status-badge--online {\n  background: rgba(86, 118, 90, 0.14);\n  color: var(--brand-moss);\n}\n\n.status-badge--offline {\n  background: rgba(158, 86, 78, 0.14);\n  color: var(--accent-rose);\n}\n\n.app-loading {\n  margin: 0;\n  padding: 20vh 24px;\n  text-align: center;\n  color: var(--ink-soft);\n}\n\n.extension-list,\n.placeholder-list,\n.workspace-stage-list {\n  display: grid;\n  gap: 12px;\n}\n\n.sessions-home__hero {\n  display: grid;\n  gap: 18px;\n}\n\n.session-summary-grid {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 12px;\n}\n\n.session-summary-card,\n.empty-state,\n.session-card,\n.session-group,\n.session-card__meta div {\n  border: 1px solid rgba(39, 68, 10