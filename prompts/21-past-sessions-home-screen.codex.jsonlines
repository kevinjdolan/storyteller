{"type":"item.started","item":{"id":"item_118","type":"command_execution","command":"/bin/zsh -lc \"env STORYTELLER_SECRETS_FILE= STORYTELLER_DATABASE_URL=sqlite+pysqlite:////tmp/storyteller-qa.sqlite3 STORYTELLER_GEMINI_API_KEY=test-gemini-key STORYTELLER_GCS_ENDPOINT=http://127.0.0.1:8568 STORYTELLER_GCS_PROJECT_ID=storyteller-local STORYTELLER_GCS_PUBLIC_URL=http://127.0.0.1:8568 STORYTELLER_GCS_SESSIONS_BUCKET_NAME=storyteller-sessions STORYTELLER_GCS_AUDIO_BUCKET_NAME=storyteller-audio STORYTELLER_GCS_EXPORTS_BUCKET_NAME=storyteller-exports python - <<'PY'\nfrom pathlib import Path\n\nfrom sqlalchemy.orm import sessionmaker\n\nfrom app.db import Base\nfrom app.db.session import make_engine\nfrom app.models import WorkflowStage, WorkflowStageState\nfrom app.services.sessions import SessionService\n\npath = Path('/tmp/storyteller-qa.sqlite3')\nif path.exists():\n    path.unlink()\n\nengine = make_engine('sqlite+pysqlite:////tmp/storyteller-qa.sqlite3')\nBase.metadata.create_all(engine)\nSessionLocal = sessionmaker(bind=engine, autoflush=False, expire_on_commit=False)\n\nwith SessionLocal() as session:\n    service = SessionService(session)\n\n    draft = service.create_session(working_title='Moonlit Ferry Ride')\n    service.update_stage_state(\n        draft.id,\n        stage=WorkflowStage.GENRE,\n        status=WorkflowStageState.COMPLETED,\n        detail='Accepted cozy fantasy.',\n    )\n    service.update_stage_state(\n        draft.id,\n        stage=WorkflowStage.TONE,\n        status=WorkflowStageState.COMPLETED,\n        detail='Accepted gentle wonder.',\n    )\n    service.update_stage_state(\n        draft.id,\n        stage=WorkflowStage.BRIEF,\n        status=WorkflowStageState.IN_PROGRESS,\n        detail='Refining the bedtime brief.',\n    )\n\n    finished = service.create_session(working_title='The Lantern Under the Blanket')\n    for stage in WorkflowStage:\n        service.update_stage_state(\n            finished.id,\n            stage=stage,\n            status=WorkflowStageState.COMPLETED,\n            detail=f'Accepted {stage.value}.',\n        )\n\nprint('seeded', path)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
