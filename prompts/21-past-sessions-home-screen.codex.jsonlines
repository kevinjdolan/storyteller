ght: 700;\n  text-decoration: none;\n  transition:\n    transform 160ms ease,\n    box-shadow 160ms ease,\n    background-color 160ms ease,\n    color 160ms ease;\n}\n\n.primary-link {\n  background: var(--brand-deep);\n  color: #fbf7f1;\n  box-shadow: 0 18px 32px rgba(39, 68, 100, 0.18);\n}\n\n.primary-link:hover,\n.ghost-link:hover {\n  transform: translateY(-1px);\n}\n\n.ghost-link {\n  border: 1px solid var(--border-soft);\n  background: rgba(255, 255, 255, 0.72);\n  color: var(--brand-deep);\n}\n\n.cta-note {\n  margin: 0;\n  max-width: 28rem;\n  color: var(--ink-soft);\n}\n\n.panel-heading {\n  display: grid;\n  gap: 0.45rem;\n  margin-bottom: 1.2rem;\n}\n\n.panel-heading h2,\n.panel-status h2 {\n  margin: 0;\n  font-size: 1.6rem;\n  color: var(--ink-deep);\n}\n\n.session-list {\n  display: grid;\n  gap: 12px;\n}\n\n.session-item {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 14px;\n  padding: 16px 18px;\n  border-radius: 20px;\n  background: rgba(255, 255, 255, 0.66);\n}\n\n.session-item__actions {\n  display: grid;\n  justify-items: end;\n  gap: 10px;\n}\n\n.session-item h3 {\n  margin: 0 0 0.3rem;\n  font-size: 1.15rem;\n}\n\n.status-chip,\n.status-badge {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  border-radius: 999px;\n  white-space: nowrap;\n  font-size: 0.85rem;\n  font-weight: 700;\n}\n\n.status-chip {\n  padding: 0.55rem 0.85rem;\n  background: rgba(86, 118, 90, 0.12);\n  color: var(--brand-moss);\n}\n\n.stage-list {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 12px;\n}\n\n.stage-list li,\n.workspace-stage-list li {\n  display: flex;\n  align-items: start;\n  gap: 12px;\n  min-height: 4.5rem;\n  padding: 0.95rem 1rem;\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.68);\n}\n\n.stage-list span,\n.workspace-stage-list span {\n  width: 2rem;\n  height: 2rem;\n  display: inline-grid;\n  place-items: center;\n  border-radius: 999px;\n  background: rgba(39, 68, 100, 0.12);\n  color: var(--brand-deep);\n  font-weight: 700;\n}\n\n.stage-list strong,\n.workspace-stage-list strong {\n  display: block;\n  margin-bottom: 0.25rem;\n}\n\n.status-badge {\n  min-width: 5.75rem;\n  padding: 0.6rem 0.9rem;\n}\n\n.status-badge--loading {\n  background: rgba(182, 128, 67, 0.14);\n  color: var(--brand-gold);\n}\n\n.status-badge--online {\n  background: rgba(86, 118, 90, 0.14);\n  color: var(--brand-moss);\n}\n\n.status-badge--offline {\n  background: rgba(158, 86, 78, 0.14);\n  color: var(--accent-rose);\n}\n\n.app-loading {\n  margin: 0;\n  padding: 20vh 24px;\n  text-align: center;\n  color: var(--ink-soft);\n}\n\n.extension-list,\n.placeholder-list,\n.workspace-stage-list {\n  display: grid;\n  gap: 12px;\n}\n\n.extension-item {\n  padding: 16px 18px;\n  border-radius: 20px;\n  background: rgba(255, 255, 255, 0.66);\n}\n\n.extension-item code,\n.not-found-page code,\n.workspace-meta dd {\n  font-family:\n    'SFMono-Regular', 'SF Mono', 'Roboto Mono', 'Menlo', 'Consolas', monospace;\n}\n\n.extension-item code {\n  display: inline-block;\n  margin-bottom: 0.45rem;\n  padding: 0.35rem 0.55rem;\n  border-radius: 999px;\n  background: rgba(39, 68, 100, 0.08);\n  color: var(--brand-deep);\n  font-size: 0.9rem;\n  font-weight: 700;\n}\n\n.workspace-page {\n  display: grid;\n  gap: 20px;\n}\n\n.workspace-page__header {\n  display: flex;\n  align-items: end;\n  justify-content: space-between;\n  gap: 18px;\n}\n\n.workspace-page__header h1,\n.not-found-page h1 {\n  margin: 0.45rem 0 0.75rem;\n  font-size: clamp(2.4rem, 5vw, 3.4rem);\n  color: var(--ink-deep);\n}\n\n.workspace-shell {\n  display: grid;\n  grid-template-columns: minmax(18rem, 0.95fr) minmax(0, 1.75fr);\n  gap: 20px;\n}\n\n.workspace-pane {\n  min-height: 100%;\n}\n\n.pane-heading {\n  display: flex;\n  align-items: start;\n  justify-content: space-between;\n  gap: 16px;\n  margin-bottom: 0.8rem;\n}\n\n.pane-heading h2 {\n  margin: 0;\n  font-size: 1.6rem;\n  color: var(--ink-deep);\n}\n\n.placeholder-list {\n  margin-top: 1.2rem;\n}\n\n.placeholder-list li {\n  padding: 0.95rem 1rem;\n  border-left: 3px solid rgba(39, 68, 100, 0.18);\n  border-radius: 16px;\n  background: rgba(255, 255, 255, 0.6);\n}\n\n.workspace-meta {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 12px;\n  margin: 1.2rem 0;\n}\n\n.workspace-meta div {\n  padding: 0.95rem 1rem;\n  border: 1px solid rgba(39, 68, 100, 0.08);\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.62);\n}\n\n.workspace-meta dt {\n  margin-bottom: 0.35rem;\n  font-size: 0.84rem;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n}\n","exit_code":0,"status":"completed"}}
