{"type":"item.completed","item":{"id":"item_4","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' frontend/src/app/router.tsx\"","aggregated_output":"import { createBrowserRouter, type RouteObject } from 'react-router-dom'\nimport { HomePage } from '../pages/home/HomePage.tsx'\nimport { NotFoundPage } from '../pages/not-found/NotFoundPage.tsx'\nimport { SessionWorkspacePage } from '../pages/session/SessionWorkspacePage.tsx'\nimport { AppShell } from './AppShell.tsx'\nimport { routePaths } from './routePaths.ts'\n\nexport const appRoutes: RouteObject[] = [\n  {\n    path: routePaths.home,\n    element: <AppShell />,\n    children: [\n      {\n        index: true,\n        element: <HomePage />,\n      },\n      {\n        path: routePaths.sessionWorkspace,\n        element: <SessionWorkspacePage />,\n      },\n      {\n        path: routePaths.notFound,\n        element: <NotFoundPage />,\n      },\n    ],\n  },\n]\n\nexport const router = createBrowserRouter(appRoutes)\n","exit_code":0,"status":"completed"}}
