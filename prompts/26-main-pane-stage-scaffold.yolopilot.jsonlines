{"color": "cyan", "emoji": "\ud83d\udee0\ufe0f", "event_type": "Command Started", "message": "in progress: /bin/zsh -lc \"mkdir -p .artifacts/webapp-qa && docker compose -f docker-compose.yml exec -T browser sh -lc 'cd /workspace/tools/webapp-qa && node --input-type=module <<\\\"EOF\\\"\nimport puppeteer from \\\"puppeteer\\\";\n\nconst sessionId = \\\"58895f8c-97e2-4d63-b277-428cf4d9489d\\\";\nconst browser = await puppeteer.launch({\n  headless: \\\"new\\\",\n  executablePath: process.env.PUPPETEER_EXECUTABLE_PATH,\n  args: [\\\"--no-sandbox\\\", \\\"--disable-dev-shm-usage\\\"],\n});\n\nasync function assertText(page, text) {\n  await page.waitForFunction(\n    (expected) => document.body.innerText.includes(expected),\n    {},\n    text,\n  );\n}\n\nasync function capture({ path, url, viewport, checks }) {\n  const page = await browser.newPage();\n  await page.setViewport(viewport);\n  await page.goto(url, { waitUntil: \\\"networkidle0\\\" });\n  await page.waitForSelector(\\\"[data-testid='workspace-route']\\\");\n\n  for (const check of checks) {\n    if (check.type === \\\"text\\\") {\n      await assertText(page, check.value);\n      continue;\n    }\n\n    if (check.type === \\\"url\\\") {\n      const currentUrl = page.url();\n      if (\"'!currentUrl.includes(check.value)) {\n        throw new Error(`Expected URL to include ${check.value}, received ${currentUrl}`);\n      }\n    }\n  }\n\n  await page.screenshot({ path, fullPage: false });\n  await page.close();\n}\n\nawait capture({\n  path: \"/workspace/.artifacts/webapp-qa/prompt-26-workspace-desktop.png\",\n  url: `http://frontend:8566/sessions/${sessionId}`,\n  viewport: { width: 1440, height: 960 },\n  checks: [\n    { type: \"text\", value: \"Stage navigator\" },\n    { type: \"text\", value: \"Choose a bedtime genre lane\" },\n    { type: \"text\", value: \"Planned controls\" },\n  ],\n});\n\nawait capture({\n  path: \"/workspace/.artifacts/webapp-qa/prompt-26-workspace-audio-preview.png\",\n  url: