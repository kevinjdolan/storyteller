    select(StorySession)\\n    63\\t            .options(\\n    64\\t                selectinload(StorySession.selected_genre),\\n    65\\t                selectinload(StorySession.selected_tone_profile),\\n    66\\t                selectinload(StorySession.workflow_stage_states).selectinload(\\n    67\\t                    WorkflowStageSnapshot.last_event\\n    68\\t                ),\\n    69\\t            )\\n    70\\t            .where(StorySession.id == session_id)\\n    71\\t        )\\n    72\\t        return self._session.execute(stmt).scalar_one_or_none()\\n    73\\t\\n    74\\t    def get_for_update(self, session_id: str) -> StorySession | None:\\n    75\\t        stmt: Select[tuple[StorySession]] = (\\n    76\\t            select(StorySession)\\n    77\\t            .options(selectinload(StorySession.workflow_stage_states))\\n    78\\t            .where(StorySession.id == session_id)\\n    79\\t        )\\n    80\\t        return self._session.execute(stmt).scalar_one_or_none()\\n    81\\t\\n    82\\t    def get_aggregate(self, session_id: str) -> SessionAggregate | None:\\n    83\\t        story_session = self.get_by_id(session_id)\\n    84\\t        if story_session is None:\\n    85\\t            return None\\n    86\\t\\n    87\\t        return SessionAggregate(\\n    88\\t            session=story_session,\\n    89\\t            active_story_brief=self._get_active_story_brief(session_id),\\n    90\\t            selected_pitch=self._get_selected_pitch(session_id),\\n    91\\t            selected_character_sheet=self._get_selected_character_sheet(session_id),\\n    92\\t            selected_beat_sheet=self._get_selected_beat_sheet(session_id),\\n    93\\t            selected_story_setup=self._get_selected_story_setup(session_id),\\n    94\\t            active_composition_job=self._get_active_composition_job(session_id),\\n    95\\t            active_audio_job=self._get_active_audio_job(session_id),\\n    96\\t            latest_story_asset=self._get_latest_story_asset(session_id),\\n    97\\t            latest_audio_asset=self._get_latest_audio_asset(session_id),\\n    98\\t        )\\n    99\\t\\n   100\\t    def list_recent(self, *, limit: int = 20) -> list[StorySession]:\\n   101\\t        stmt: Select[tuple[StorySession]] = (\\n   102\\t            select(StorySession)\\n   103\\t            .options(\\n   104\\t                selectinload(StorySession.selected_genre),\\n   105\\t                selectinload(StorySession.selected_tone_profile),\\n   106\\t                selectinload(StorySession.workflow_stage_states),\\n   107\\t            )\\n   108\\t            .order_by(StorySession.updated_at.desc(), StorySession.created_at.desc())\\n   109\\t            .limit(limit)\\n   110\\t        )\\n   111\\t        return list(self._session.execute(stmt).scalars().all())\\n   112\\t\\n   113\\t    def _get_active_story_brief(self, session_id: str) -> StoryBrief | None:\\n   114\\t        stmt: Select[tuple[StoryBrief]] = (\\n   115\\t            select(StoryBrief)\\n   116\\t            .where(StoryBrief.session_id == session_id, StoryBrief.is_active.is_(True))\\n   117\\t            .order_by(StoryBrief.revision_number.desc())\\n   118\\t            .limit(1)\\n   119\\t        )\\n   120\\t        return self._session.execute(stmt).scalar_one_or_none()\\n   121\\t\\n   122\\t    def _get_selected_pitch(self, session_id: str) -> Pitch | None:\\n   123\\t        stmt: Select[tuple[Pitch]] = (\\n   124\\t            select(Pitch)\\n   125\\t            .where(Pitch.session_id == session_id, Pitch.is_selected.is_(True))\\n   126\\t            .order_by(Pitch.created_at.desc())\\n   127\\t            .limit(1)\\n   128\\t        )\\n   129\\t        return self._session.execute(stmt).scalar_one_or_none()\\n   130\\t\\n   131\\t    def _get_selected_character_sheet(self, session_id: str) -> CharacterSheet | None:\\n   132\\t        stmt: Select[tuple[CharacterSheet]] = (\\n   133\\t            select(CharacterSheet)\\n   134\\t            .where(CharacterSheet.session_id == session_id, CharacterSheet.is_selected.is_(True))\\n   135\\t            .order_by(CharacterSheet.revision_number.desc())\\n   136\\t            .limit(1)\\n   137\\t        )\\n   138\\t        return self._session.execute(stmt).scalar_one_or_none()\\n   139\\t\\n   140\\t    def _get_selected_beat_sheet(self, session_id: str) -> BeatSheet | None:\\n   141\\t        stmt: Select[tuple[BeatSheet]] = (\\n   142\\t            select(BeatSheet)\\n   143\\t            .where(BeatSheet.session_id == session_id, BeatSheet.is_selected.is_(True))\\n   144\\t            .order_by(BeatSheet.revision_number.desc())\\n   145\\t            .limit(1)\\n   146\\t        )\\n   147\\t        return self._session.execute(stmt).scalar_one_or_none()\\n   148\\t\\n   149\\t    def _get_selected_story_setup(self, session_id: str) -> StorySetup | None:\\n   150\\t        stmt: Select[tuple[StorySetup]] = (\\n   151\\t            select(StorySetup)\\n   152\\t            .where(StorySetup.session_id == session_id, StorySetup.is_selected.is_(True))\\n   153\\t            .order_by(StorySetup.revision_number.desc())\\n   154\\t            .limit(1)\\n   155\\t        )\\n   156\\t        return self._session.execute(stmt).scalar_one_or_none()\\n   157\\t\\n   158\\t    def _get_active_composition_job(self, session_id: str) -> CompositionJob | None:\\n   159\\t        stmt: Select[tuple[CompositionJob]] = (\\n   160\\t            select(CompositionJob)\\n   161\\t            .where(\\n   162\\t                CompositionJob.session_id == session_id,\\n   163\\t                CompositionJob.status.in_(ACTIVE_JOB_STATUSES),\\n   164\\t            )\\n   165\\t            .order_by(CompositionJob.created_at.desc())\\n   166\\t            .limit(1)\\n   167\\t        )\\n   168\\t        return self._session.execute(stmt).scalar_one_or_none()\\n   169\\t\\n   170\\t    def _get_active_audio_job(self, session_id: str) -> AudioJob | None:\\n   171\\t        stmt: Select[tuple[AudioJob]] = (\\n   172\\t            select(AudioJob)\\n   173\\t            .where(\\n   174\\t                AudioJob.session_id == session_id,\\n   175\\t                AudioJob.status.in_(ACTIVE_JOB_STATUSES),\\n   176\\t            )\\n   177\\t            .order_by(AudioJob.created_at.desc())\\n   178\\t            .limit(1)\\n   179\\t        )\\n   180\\t        return self._session.execute(stmt).scalar_one_or_none()\\n   181\\t\\n   182\\t    def _get_latest_story_asset(self, session_id: str) -> ExportAsset | None:\\n   183\\t        stmt: Select[tuple[ExportAsset]] = (\\n   184\\t            select(ExportAsset)\\n   185\\t            .where(\\n   186\\t                ExportAsset.session_id == session_id,\\n   187\\t                ExportAsset.asset_kind.in_(STORY_ASSET_KINDS),\\n   188\\t                ExportAsset.status == AssetStatus.READY,\\n   189\\t            )\\n   190\\t            .order_by(ExportAsset.ready_at.desc(), ExportAsset.created_at.desc())\\n   191\\t            .limit(1)\\n   192\\t        )\\n   193\\t        return self._session.execute(stmt).scalar_one_or_none()\\n   194\\t\\n   195\\t    def _get_latest_audio_asset(self, session_id: str) -> ExportAsset | None:\\n   196\\t        stmt: Select[tuple[ExportAsset]] = (\\n   197\\t            select(ExportAsset)\\n   198\\t            .where(\\n   199\\t                ExportAsset.session_id == session_id,\\n   200\\t                ExportAsset.asset_kind == AssetKind.FINAL_AUDIO,\\n   201\\t                ExportAsset.status == AssetStatus.READY,\\n   202\\t            )\\n   203\\t            .order_by(ExportAsset.ready_at.desc(), ExportAsset.created_at.desc())\\n   204\\t            .limit(1)\\n   205\\t        )\\n   206\\t        return self._session.execute(stmt).scalar_one_or_none()\\n   207\\t\\n   208\\t\\n   209\\tclass WorkflowStageStateRepository:\\n   210\\t    def __init__(self, session: Session):\\n   211\\t        self._session = session\\n   212\\t\\n   213\\t    def ensure_for_session(\\n   214\\t        self,\\n   215\\t        story_session: StorySession,\\n   216\\t    ) -> dict[WorkflowStage, WorkflowStageSnapshot]:\\n   217\\t        stage_map = {row.stage: row for row in story_session.workflow_stage_states}\\n   218\\t\\n   219\\t        for stage in WORKFLOW_STAGE_SEQUENCE:\\n   220\\t            if stage in stage_map:\\n   221\\t                continue\\n   222\\t\\n   223\\t            snapshot = WorkflowStageSnapshot(\\n   224\\t                stage=stage,\\n   225\\t                status=WorkflowStageState.DRAFT,\\n   226\\t            )\\n   227\\t            story_session.workflow_stage_states.append(snapshot)\\n   228\\t            stage_map[stage] = snapshot\\n   229\\t\\n   230\\t        self._session.flush()\\n   231\\t        return stage_map\\n\", \"command\": \"/bin/zsh -lc \\\"nl -ba backend/app/repositories/sessions.py | sed -n '1,260p'\\\"\", \"exit_code\": 0, \"id\": \"item_69\", \"status\": \"completed\", \"type\": \"command_execution\"}, \"type\": \"item.completed\"}, \"task_display_context\": {\"event_number\": 148, \"prompt_index\": 15, \"prompt_name\": \"14 \\u2014 Repository Layer and Session Service\", \"prompt_total\": 100}, \"timestap\": \"2026-03-31T23:33:59-07:00\"}\n./prompts/20-frontend-app-shell-and-routing.yolopilot.jsonlines:23:{\"color\": \"cyan\", \"emoji\": \"\\ud83d\\udee0\\ufe0f\", \"event_type\": \"Command Finished\", \"message\": \"completed, exit 0: /bin/zsh -lc \\\"sed -n '1,260p' frontend/src/features/home/HomeRoute.tsx\\\"\", \"raw_event\": {\"item\": {\"aggregated_output\": \"import { useBackendStatus } from '../system/useBackendStatus.ts'\\nimport { workflowStageDefinitions } from '../session/workflowStages.ts'\\n\\nconst sessionPreview = [\\n  {\\n    title: 'Lanterns Over Juniper Lake',\\n    status: 'Drafting beats',\\n    note: 'Calm mystery with a reassuring finish',\\n  },\\n  {\\n    title: 'The Moss Door in Maple Hollow',\\n    status: 'Ready for narration',\\n    note: 'Whispery woodland adventure for a shorter read-aloud',\\n  },\\n  {\\n    title: 'Cloud Harbor Night Shift',\\n    status: 'In progress',\\n    note: 'Skyport bedtime tale with gentle teamwork stakes',\\n  },\\n] as const\\n\\nconst qualitySignals = [\\n  'Strict TypeScript',\\n  'Router shell',\\n  'ESLint',\\n  'Prettier',\\n  'Vitest',\\n] as const\\n\\nexport function HomeRoute() {\\n  const backendStatus = useBackendStatus()\\n\\n  return (\\n    <section className=\\\"home-grid\\\" aria-label=\\\"Storyteller scaffold overview\\\">\\n      <article className=\\\"panel panel-hero\\\" data-testid=\\\"app-card\\\">\\n        <p className=\\\"eyebrow\\\">Prompt 02 scaffold</p>\\n        <h1>Storyteller</h1>\\n        <p className=\\\"lede\\\">\\n          A calm studio for shaping bedtime stories from first spark to finished\\n          narration.\\n        </p>\\n        <p className=\\\"body-copy\\\">\\n          This placeholder route proves the Vite foundation is running while\\n          keeping the product pointed at its sessions-first, workflow-driven\\n          future.\\n        </p>\\n\\n        <ul className=\\\"tag-list\\\" aria-label=\\\"Frontend quality signals\\\">\\n          {qualitySignals.map((signal) => (\\n            <li key={signal} className=\\\"tag\\\">\\n              {signal}\\n            </li>\\n          ))}\\n        </ul>\\n      </article>\\n\\n      <article className=\\\"panel\\\">\\n        <div className=\\\"panel-heading\\\">\\n          <h2>Past sessions come first</h2>\\n          <p>\\n            The real session list arrives in a later prompt. For now, the home\\n            route already reflects the product contract.\\n          </p>\\n        </div>\\n\\n        <ul className=\\\"session-list\\\">\\n          {sessionPreview.map((session) => (\\n            <li key={session.title} className=\\\"session-item\\\">\\n              <div>\\n                <h3>{session.title}</h3>\\n                <p>{session.note}</p>\\n              </div>\\n              <span className=\\\"status-chip\\\">{session.status}</span>\\n            </li>\\n          ))}\\n        </ul>\\n      </article>\\n\\n      <article className=\\\"panel\\\">\\n        <div className=\\\"panel-heading\\\">\\n          <h2>Story studio path</h2>\\n          <p>\\n            The route shell is intentionally lightweight, but it already mirrors\\n            the staged workflow the product needs.\\n          </p>\\n        </div>\\n\\n        <ol className=\\\"stage-list\\\">\\n          {workflowStageDefinitions.map((stage, index) => (\\n            <li key={stage.id}>\\n              <span>{index + 1}</span>\\n              <strong>{stage.label}</strong>\\n            </li>\\n          ))}\\n        </ol>\\n      </article>\\n\\n      <article className=\\\"panel panel-status\\\">\\n        <div className=\\\"status-header\\\">\\n          <div>\\n            <p className=\\\"eyebrow eyebrow-muted\\\">Backend bridge</p>\\n            <h2>Frontend isolation check</h2>\\n          </div>\\n\\n          <span\\n            className={`status-badge status-badge--${backendStatus.state}`}\\n            data-testid=\\\"backend-state\\\"\\n          >\\n            {backendStatus.label}\\n          </span>\\n        </div>\\n\\n        <p className=\\\"body-copy\\\">{backendStatus.detail}</p>\\n        <p className=\\\"api-message\\\" data-testid=\\\"api-message\\\">\\n          {backendStatus.message}\\n        </p>\\n      </article>\\n    </section>\\n  )\\n}\\n\", \"command\": \"/bin/zsh -lc \\\"sed -n '1,260p' frontend/src/features/home/HomeRoute.tsx\\\"\", \"exit_code\": 0, \"id\": \"item_9\", \"status\": \"completed\", \"type\": \"command_execution\"}, \"type\": \"item.completed\"}, \"task_display_context\": {\"event_number\": 23, \"prompt_index\": 21, \"prompt_name\": \"20 \\u2014 Frontend App Shell and Routing\", \"prompt_total\": 100}, \"timestap\": \"2026-04-01T01:12:08-07:00\"}\n./prompts/20-frontend-app-shell-and-routing.yolopilot.jsonlines:62:{\"color\": \"cyan\", \"emoji\": \"\\ud83d\\udee0\\ufe0f\", \"event_type\": \"Command Finished\", \"message\": \"completed, exit 0: /bin/zsh -lc \\\"sed -n '1,260p' frontend/src/features/session/workflowStages.ts\\\"\", \"raw_event\": {\"item\": {\"aggregated_output\": \"export const WORKFLOW_STAGE_STATES = [\\n  'draft',\\n  'in_progress',\\n  'completed',\\n  'needs_regeneration',\\n] as const\\n\\nexport type WorkflowStageState = (typeof WORKFLOW_STAGE_STATES)[number]\\n\\nexport const workflowStageDefinitions = [\\n  {\\n    id: 'genre',\\n    label: 'Genre',\\n    description:\\n      'Choose the overall bedtime-story lane before the rest of the plan is shaped.',\\n    invalidatesOnEdit: [\\n      'tone',\\n      'brief',\\n      'pitches',\\n      'characters',\\n      'beats',\\n      'composition',\\n      'audio',\\n      'finalize',\\n    ],\\n  },\\n  {\\n    id: 'tone',\\n    label: 'Tone',\\n    description:\\n      'Choose the emotional texture and bedtime-safety posture for the session.',\\n    invalidatesOnEdit: [\\n      'brief',\\n      'pitches',\\n      'characters',\\n      'beats',\\n      'composition',\\n      'audio',\\n      'finalize',\\n    ],\\n  },\\n  {\\n    id: 'brief',\\n    label: 'Story brief',\\n    description:\\n      \\\"Capture the user's free-form idea and any normalized planning summary derived from it.\\\",\\n    invalidatesOnEdit: [\\n      'pitches',\\n      'characters',\\n      'beats',\\n      'composition',\\n      'audio',\\n      'finalize',\\n    ],\\n  },\\n  {\\n    id: 'pitches',\\n    label: 'Pitches',\\n    description:\\n      'Generate, compare, refine, and accept candidate story directions.',\\n    invalidatesOnEdit: [\\n      'characters',\\n      'beats',\\n      'composition',\\n      'audio',\\n      'finalize',\\n    ],\\n  },\\n  {\\n    id: 'characters',\\n    label: 'Characters',\\n    description:\\n      'Define the accepted character sheet that later planning and writing will reference.',\\n    invalidatesOnEdit: ['beats', 'composition', 'audio', 'finalize'],\\n  },\\n  {\\n    id: 'beats',\\n    label: 'Beat sheet',\\n    description: 'Store the accepted Save-the-Cat beat sheet for the session.',\\n    invalidatesOnEdit: ['composition', 'audio', 'finalize'],\\n  },\\n  {\\n    id: 'story_setup',\\n    label: 'Story setup',\\n    description:\\n      'Store soft planning targets such as word count, runtime, and chapter structure.',\\n    invalidatesOnEdit: ['composition', 'audio', 'finalize'],\\n  },\\n  {\\n    id: 'composition',\\n    label: 'Composition',\\n    description:\\n      'Write the story durably in segments, with room for interruption and targeted rewrites.',\\n    invalidatesOnEdit: ['audio', 'finalize'],\\n  },\\n  {\\n    id: 'audio',\\n    label: 'Audio',\\n    description:\\n      'Configure narration settings and generate resumable audio artifacts.',\\n    invalidatesOnEdit: ['finalize'],\\n  },\\n  {\\n    id: 'finalize',\\n    label: 'Finalize',\\n    description: 'Read, listen, review final assets, and download exports.',\\n    invalidatesOnEdit: [],\\n  },\\n] as const\\n\\nexport type WorkflowStageId = (typeof workflowStageDefinitions)[number]['id']\\n\\nexport const WORKFLOW_STAGE_SEQUENCE: ReadonlyArray<WorkflowStageId> =\\n  workflowStageDefinitions.map(({ id }) => id)\\n\\nexport function getInvalidatedStagesAfterEdit(\\n  stageId: WorkflowStageId,\\n): ReadonlyArray<WorkflowStageId> {\\n  const definition = workflowStageDefinitions.find(({ id }) => id === stageId)\\n  return definition?.invalidatesOnEdit ?? []\\n}\\n\\nexport function resolveResumeStage(\\n  stageStates: Partial<Record<WorkflowStageId, WorkflowStageState>>,\\n): WorkflowStageId {\\n  for (const stage of WORKFLOW_STAGE_SEQUENCE) {\\n    if (stageStates[stage] !== 'completed') {\\n      return stage\\n    }\\n  }\\n\\n  return 'finalize'\\n}\\n\", \"command\": \"/bin/zsh -lc \\\"sed -n '1,260p' frontend/src/features/session/workflowStages.ts\\\"\", \"exit_code\": 0, \"id\": \"item_31\", \"status\": \"completed\", \"type\": \"command_execution\"}, \"type\": \"item.completed\"}, \"task_display_context\": {\"event_number\": 62, \"prompt_index\": 21, \"prompt_name\": \"20 \\u2014 Frontend App Shell and Routing\", \"prompt_total\": 100}, \"timestap\": \"2026-04-01T01:16:34-07:00\"}\n./prompts/20-frontend-app-shell-and-routing.yolopilot.jsonlines:69:{\"color\": \"cyan\", \"emoji\": \"\\ud83d\\udee0\\ufe0f\", \"event_type\": \"Command Finished\", \"message\": \"completed, exit 0: /bin/zsh -lc \\\"sed -n '1,260p' frontend/src/pages/session/SessionWorkspacePage.tsx\\\"\", \"raw_event\": {\"item\": {\"aggregated_output\": \"import { Link, useParams } from 'react-router-dom'\\nimport { routePaths } from '../../app/routePaths.ts'\\nimport { workflowStageDefinitions } from '../../features/session/workflowStages.ts'\\n\\nconst chatRailPreview = [\\n  'Conversation history and quick actions will live in the left rail.',\\n  'UI actions will echo back into chat as compact structured messages.',\\n  'Agent summaries during composition and audio jobs will dock here.',\\n] as const\\n\\nexport function SessionWorkspacePage() {\\n  const { sessionId = 'unknown-session' } = useParams()\\n\\n  return (\\n    <section\\n      className=\\\"workspace-page\\\"\\n      aria-label={`Session workspace for ${sessionId}`}\\n    >\\n      <header className=\\\"workspace-page__header\\\">\\n        <div>\\n          <p className=\\\"eyebrow\\\">Session workspace</p>\\n          <h1>Session {sessionId}</h1>\\n          <p className=\\\"body-copy\\\">\\n            This route-scoped shell reserves the left pane for chat and the right\\n            pane for the structured workflow UI.\\n          </p>\\n        </div>\\n\\n        <Link className=\\\"ghost-link\\\" to={routePaths.home}>\\n          Back to sessions\\n        </Link>\\n      </header>\\n\\n      <div className=\\\"workspace-shell\\\" data-testid=\\\"workspace-route\\\">\\n        <aside className=\\\"panel workspace-pane workspace-pane--chat\\\">\\n          <div className=\\\"pane-heading\\\">\\n            <h2>Chat lane</h2>\\n            <span className=\\\"status-chip\\\">1/3 width target</span>\\n          </div>\\n          <p className=\\\"body-copy\\\">\\n            The left rail is reserved for conversation, quick actions, and durable\\n            chat history.\\n          </p>\\n\\n          <ol className=\\\"placeholder-list\\\">\\n            {chatRailPreview.map((entry) => (\\n              <li key={entry}>{entry}</li>\\n            ))}\\n          </ol>\\n        </aside>\\n\\n        <section className=\\\"panel workspace-pane workspace-pane--canvas\\\">\\n          <div className=\\\"pane-heading\\\">\\n            <h2>Workflow canvas</h2>\\n            <span className=\\\"status-chip\\\">Route param bound</span>\\n          </div>\\n          <p className=\\\"body-copy\\\">\\n            The workspace already keys itself off the session route so future data\\n            loaders, stores, and websocket subscriptions can stay session-specific.\\n          </p>\\n\\n          <dl className=\\\"workspace-meta\\\">\\n            <div>\\n              <dt>Session ID</dt>\\n              <dd>{sessionId}</dd>\\n            </div>\\n            <div>\\n              <dt>Active route</dt>\\n              <dd>{`/sessions/${sessionId}`}</dd>\\n            </div>\\n            <div>\\n              <dt>Next prompt</dt>\\n              <dd>Two-pane workflow layout</dd>\\n            </div>\\n          </dl>\\n\\n          <ol className=\\\"workspace-stage-list\\\">\\n            {workflowStageDefinitions.map((stage, index) => (\\n              <li key={stage.id}>\\n                <span>{index + 1}</span>\\n                <div>\\n                  <strong>{stage.label}</strong>\\n                  <p>{stage.description}</p>\\n                </div>\\n              </li>\\n            ))}\\n          </ol>\\n        </section>\\n      </div>\\n    </section>\\n  )\\n}\\n\", \"command\": \"/bin/zsh -lc \\\"sed -n '1,260p' frontend/src/pages/session/SessionWorkspacePage.tsx\\\"\", \"exit_code\": 0, \"id\": \"item_35\", \"status\": \"completed\", \"type\": \"command_execution\"}, \"type\": \"item.completed\"}, \"task_display_context\": {\"event_number\": 69, \"prompt_index\": 21, \"prompt_name\": \"20 \\u2014 Frontend App Shell and Routing\", \"prompt_total\": 100}, \"timestap\": \"2026-04-01T01:19:54-07:00\"}\n./prompts/20-frontend-app-shell-and-routing.yolopilot.jsonlines:146:{\"color\": \"cyan\", \"emoji\": \"\\ud83d\\udee0\\ufe0f\", \"event_type\": \"Command Finished\", \"message\": \"completed, exit 0: /bin/zsh -lc 'git diff -- frontend tools/webapp-qa/examples'\", \"raw_event\": {\"item\": {\"aggregated_output\": \"diff --git a/frontend/README.md b/frontend/README.md\\nindex 47a951b..9eb0d14 100644\\n--- a/frontend/README.md\\n+++ b/frontend/README.md\\n@@ -2,17 +2,32 @@\\n \\n This directory contains the browser application for Storyteller.\\n \\n-The frontend now uses the current Vite React TypeScript baseline as its foundation, then layers in the project-specific shell and tooling required by the prompt pack.\\n+The frontend now uses the current Vite React TypeScript baseline as its foundation, then layers in the app shell, route structure, and shared primitives required by the prompt pack.\\n \\n Key entrypoints:\\n \\n - `src/main.tsx`: browser entrypoint\\n-- `src/app/router.tsx`: minimal route shell for future screens\\n-- `src/features/home/HomeRoute.tsx`: branded placeholder landing route\\n-- `src/shared/api.ts`: typed helper for backend-relative API URLs\\n+- `src/app/router.tsx`: browser-router configuration for the home page, session workspace, and not-found fallback\\n+- `src/app/routePaths.ts`: central path helpers, including the session-workspace URL builder\\n+- `src/app/AppShell.tsx`: global chrome with navigation, connection status, and toast space\\n+- `src/pages/`: route-level screens\\n+- `src/shared/ui/`: reusable shell-level UI primitives\\n+- `src/hooks/`: shared data hooks\\n+- `src/api/`: backend request helpers and service-specific clients\\n+- `src/state/`: app-level state shapes and future store modules\\n - `src/styles/index.css`: global styles and design tokens for the scaffold\\n - `vite.config.ts`: Vite dev server configuration, including the backend proxy\\n \\n+Folder conventions:\\n+\\n+- `src/app/`: router, app shell, route constants, and future global providers\\n+- `src/pages/`: page modules that map directly to routes\\n+- `src/features/`: reusable product-domain logic that can be shared across pages\\n+- `src/shared/ui/`: composable display primitives and chrome\\n+- `src/hooks/`: cross-cutting React hooks that are not owned by a single page\\n+- `src/api/`: fetch wrappers, endpoint clients, and request helpers\\n+- `src/state/`: state models and future global/session store modules\\n+\\n Useful commands:\\n \\n - `npm run dev`: start the Vite dev server on port `8566`\\ndiff --git a/frontend/src/app/AppShell.tsx b/frontend/src/app/AppShell.tsx\\nindex 52839cd..9089d43 100644\\n--- a/frontend/src/app/AppShell.tsx\\n+++ b/frontend/src/app/AppShell.tsx\\n@@ -1,6 +1,20 @@\\n-import { Outlet } from 'react-router-dom'\\n+import { useState } from 'react'\\n+import { Link, NavLink, Outlet, matchPath, useLocation } from 'react-router-dom'\\n+import { useBackendStatus } from '../hooks/useBackendStatus.ts'\\n+import { ConnectionStatusBadge } from '../shared/ui/ConnectionStatusBadge.tsx'\\n+import { ToastRegion } from '../shared/ui/ToastRegion.tsx'\\n+import { createInitialAppShellState } from '../state/appShellStore.ts'\\n+import { buildSessionWorkspacePath, routePaths } from './routePaths.ts'\\n+\\n+const sampleWorkspacePath = buildSessionWorkspacePath('sample-session')\\n \\n export function AppShell() {\\n+  const location = useLocation()\\n+  const backendStatus = useBackendStatus()\\n+  const [shellState] = useState(createInitialAppShellState)\\n+  const workspaceNavIsActive =\\n+    matchPath(routePaths.sessionWorkspace, location.pathname) !== null\\n+\\n   return (\\n     <div className=\\\"app-shell\\\">\\n       <div\\n@@ -12,18 +26,56 @@ export function AppShell() {\\n         aria-hidden=\\\"true\\\"\\n       />\\n \\n-      <header className=\\\"app-header\\\">\\n-        <div>\\n-          <p className=\\\"app-kicker\\\">Bedtime story studio</p>\\n-          <span className=\\\"app-brand\\\">Storyteller</span>\\n-        </div>\\n+      <div className=\\\"app-frame\\\">\\n+        <header className=\\\"app-header\\\">\\n+          <div className=\\\"app-header__brand-block\\\">\\n+            <p className=\\\"app-kicker\\\">Bedtime story studio</p>\\n+            <Link className=\\\"app-brand-link\\\" to={routePaths.home}>\\n+              <span className=\\\"app-brand\\\">Storyteller</span>\\n+            </Link>\\n+          </div>\\n+\\n+          <nav className=\\\"app-nav\\\" aria-label=\\\"Primary\\\">\\n+            <NavLink\\n+              className={({ isActive }) =>\\n+                isActive\\n+                  ? 'app-nav__link app-nav__link--active'\\n+                  : 'app-nav__link'\\n+              }\\n+              end\\n+              to={routePaths.home}\\n+            >\\n+              Sessions\\n+            </NavLink>\\n+            <Link\\n+              className={\\n+                workspaceNavIsActive\\n+                  ? 'app-nav__link app-nav__link--active'\\n+                  : 'app-nav__link'\\n+              }\\n+              to={sampleWorkspacePath}\\n+            >\\n+              Workspace shell\\n+            </Link>\\n+          </nav>\\n+\\n+          <p className=\\\"app-caption\\\">\\n+            Routing, shared chrome, and status surfaces for the staged workflow.\\n+          </p>\\n+        </header>\\n \\n-        <p className=\\\"app-captio