{"type":"item.completed","item":{"id":"item_15","type":"command_execution","command":"/bin/zsh -lc \"sed -n '260,520p' frontend/src/features/session/chat/SessionChatPane.tsx\"","aggregated_output":"        ) : null}\n\n        <div className=\"workspace-chat-composer__footer\">\n          <p className=\"body-copy\">{draft.trim().length}/1200 characters</p>\n          <Button\n            size=\"compact\"\n            type=\"submit\"\n            disabled={composerIsDisabled || draft.trim().length === 0}\n          >\n            {isSubmitting ? (\n              <>\n                <InlineSpinner label=\"Sending message\" />\n                Sending...\n              </>\n            ) : (\n              'Send message'\n            )}\n          </Button>\n        </div>\n      </form>\n    </>\n  )\n}\n","exit_code":0,"status":"completed"}}
