          \"title\": \"ChatToUIExtractedValues\",\ndocs/chat-to-ui-actions.schema.json:125:        \"ChatToUIJobKind\": {\ndocs/chat-to-ui-actions.schema.json:127:          \"title\": \"ChatToUIJobKind\",\ndocs/chat-to-ui-actions.schema.json:229:              \"$ref\": \"#/$defs/ChatToUIJobKind\"\ndocs/chat-to-ui-actions.schema.json:265:              \"$ref\": \"#/$defs/ChatToUIExtractedValues\"\ndocs/chat-to-ui-actions.schema.json:2089:    \"chat_to_ui_action_batch\": {\ndocs/chat-to-ui-actions.schema.json:2180:        \"ChatToUIExtractedValues\": {\ndocs/chat-to-ui-actions.schema.json:2183:          \"title\": \"ChatToUIExtractedValues\",\ndocs/chat-to-ui-actions.schema.json:2186:        \"ChatToUIJobKind\": {\ndocs/chat-to-ui-actions.schema.json:2188:          \"title\": \"ChatToUIJobKind\",\ndocs/chat-to-ui-actions.schema.json:2290:              \"$ref\": \"#/$defs/ChatToUIJobKind\"\ndocs/chat-to-ui-actions.schema.json:2326:              \"$ref\": \"#/$defs/ChatToUIExtractedValues\"\ndocs/chat-to-ui-actions.schema.json:4164:      \"title\": \"ChatToUIActionBatch\",\nbackend/tests/test_intent_parser_service.py:9:    ChatToUIActionType,\nbackend/tests/test_intent_parser_service.py:126:        ChatToUIActionType.REFINE_BEAT_SHEET,\nbackend/tests/test_intent_parser_service.py:127:        ChatToUIActionType.UPDATE_STORY_SETUP,\nbackend/tests/test_intent_parser_service.py:140:    assert history.events[-3].event_type == SessionEventType.CHAT_MESSAGE_RECORDED\nbackend/tests/test_intent_parser_service.py:141:    assert history.events[-2].event_type == SessionEventType.CHAT_INTENT_PARSED\nbackend/tests/test_intent_parser_service.py:145:        ChatToUIActionType.UPDATE_STORY_SETUP\nbackend/tests/test_intent_parser_service.py:147:    assert history.events[-1].event_type == SessionEventType.CHAT_MESSAGE_RECORDED\nbackend/tests/test_intent_parser_service.py:197:    assert history.events[-2].event_type == SessionEventType.CHAT_INTENT_PARSED\nprompts/22-workspace-two-pane-layo