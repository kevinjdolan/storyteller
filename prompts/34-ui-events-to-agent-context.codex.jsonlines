essionSnapshot | null,\n   335\t) {\n   336\t  return buildSessionChatMessagesFromHistory(\n   337\t    {\n   338\t      session_id: event.session_id,\n   339\t      latest_sequence_number: event.sequence_number,\n   340\t      events: [event],\n   341\t    },\n   342\t    snapshot,\n   343\t  )\n   344\t}\n   345\t\n   346\tfunction WorkspaceLoadingState({ sessionId }: { sessionId: string }) {\n   347\t  return (\n   348\t    <section\n   349\t      aria-label={`Session workspace for ${sessionId}`}\n   350\t      className=\"workspace-page\"\n   351\t    >\n   352\t      <header className=\"panel workspace-topbar\" aria-busy=\"true\">\n   353\t        <div className=\"workspace-topbar__copy\">\n   354\t          <p className=\"eyebrow\">Session workspace</p>\n   355\t          <SkeletonBlock className=\"loading-block--title\" />\n   356\t          <SkeletonBlock className=\"loading-block--detail\" />\n   357\t        </div>\n   358\t        <div className=\"workspace-topbar__status\">\n   359\t          {Array.from({ length: 3 }).map((_, index) => (\n   360\t            <div key={index} className=\"workspace-topbar__status-card\">\n   361\t              <SkeletonBlock className=\"loading-block--detail loading-block--short\" />\n   362\t              <SkeletonBlock className=\"loading-block--detail\" />\n   363\t            </div>\n   364\t          ))}\n   365\t        </div>\n   366\t      </header>\n   367\t\n   368\t      <div className=\"workspace-shell\" aria-busy=\"true\">\n   369\t        <article className=\"panel workspace-pane\">\n   370\t          <SkeletonBlock className=\"loading-block--title\" />\n   371\t          <SkeletonBlock className=\"loading-block--detail\" />\n   372\t          <SkeletonBlock className=\"loading-block--detail\" />\n   373\t          <SkeletonBlock className=\"loading-block--detail loading-block--short\" />\n   374\t        </article>\n   375\t        <article className=\"panel workspace-pane\">\n   376\t          <SkeletonBlo