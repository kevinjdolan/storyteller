y = service.load_session_history(snapshot.id)\n   454\t    assert history.latest_sequence_number == 12\n   455\t    assert history.events[-2].event_type == \"workflow.stage_changed\"\n   456\t    assert history.events[-1].event_type == \"content.user_edit.recorded\"\n   457\t\n   458\t\n   459\tdef test_update_stage_state_invalidates_downstream_outputs_after_upstream_edit(db_session) -> None:\n   460\t    service = SessionService(db_session)\n   461\t    snapshot = service.create_session(working_title=\"Regeneration Test\")\n   462\t\n   463\t    for stage in (\n   464\t        WorkflowStage.GENRE,\n   465\t        WorkflowStage.TONE,\n   466\t        WorkflowStage.BRIEF,\n   467\t        WorkflowStage.PITCHES,\n   468\t        WorkflowStage.CHARACTERS,\n   469\t        WorkflowStage.BEATS,\n   470\t        WorkflowStage.STORY_SETUP,\n","exit_code":0,"status":"completed"}}
