</div>\n   320\t          <div className=\"session-summary-card\">\n   321\t            <strong>{loadState === 'ready' ? active.length : '...'}</strong>\n   322\t            <span>Active or needs attention</span>\n   323\t          </div>\n   324\t          <div className=\"session-summary-card\">\n   325\t            <strong>{loadState === 'ready' ? completed.length : '...'}</strong>\n   326\t            <span>Completed stories</span>\n   327\t          </div>\n   328\t        </div>\n   329\t\n   330\t        <div className=\"cta-row\">\n   331\t          <Button\n   332\t            disabled={isCreatingSession}\n   333\t            onClick={() => void handleCreateSession()}\n   334\t          >\n   335\t            {isCreatingSession ? (\n   336\t              <>\n   337\t                <InlineSpinner label=\"Starting a new session\" />\n   338\t                Starting...\n   339\t              </>\n   340\t            ) : (\n   341\t              'Start a new session'\n   342\t            )}\n   343\t          </Button>\n   344\t          <p className=\"cta-note\">\n   345\t            New sessions open directly into the workspace shell so the user can\n   346\t            move from this list into the guided story flow without a blank\n   347\t            editor step.\n   348\t          </p>\n   349\t        </div>\n   350\t        {createError ? (\n   351\t          <FeedbackBanner\n   352\t            actions={\n   353\t              <Button\n   354\t                size=\"compact\"\n   355\t                tone=\"ghost\"\n   356\t                onClick={() => void handleCreateSession()}\n   357\t              >\n   358\t                Try again\n   359\t              </Button>\n   360\t            }\n   361\t            className=\"sessions-home__feedback\"\n   362\t            description=\"The request failed before the workspace could open. The current home screen state is still intact.\"\n   363\t            title={createError}\n   364\t            tone=\"warning\"\n   365\t          />\n   366\t        ) : null}\n   367\t      </Panel>\n   368\t\n   369\t      {loadState === 'loading' ? <HomePageLoadingState /> : null}\n   370\t      {loadState === 'error' ? (\n   371\t        <HomePageErrorState onRetry={handleRetryLoad} />\n   372\t      ) : null}\n   373\t      {loadState === 'ready' && totalSessions === 0 ? (\n   374\t        <EmptySessionsState />\n   375\t      ) : null}\n   376\t      {loadState === 'ready' && totalSessions > 0 ? (\n   377\t        <Panel\n   378\t          as=\"article\"\n   379\t          className=\"sessions-panel\"\n   380\t          description=\"In-progress and completed stories are grouped separately so it is clear whether you should resume work or revisit a finished bedtime story.\"\n","exit_code":0,"status":"completed"}}
