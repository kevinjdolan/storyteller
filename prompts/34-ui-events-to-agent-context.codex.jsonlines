e: 404')) {\n   436\t    return `The session ${sessionId} could not be found in the durable store.`\n   437\t  }\n   438\t\n   439\t  return 'The workspace could not load this session right now. Try again once the backend is reachable.'\n   440\t}\n   441\t\n   442\tfunction getWorkspaceConnectionBanner(connectionState: string): {\n   443\t  description: string\n   444\t  isBusy?: boolean\n   445\t  title: string\n   446\t  tone: FeedbackTone\n   447\t} | null {\n   448\t  if (connectionState === 'open') {\n   449\t    return null\n   450\t  }\n   451\t\n   452\t  if (connectionState === 'connecting' || connectionState === 'reconnecting') {\n   453\t    return {\n   454\t      description:\n   455\t        'The durable session shell is loaded. Live event updates are still reconnecting, so recent confirmations may take a moment to appear.',\n   456\t      isBusy: true,\n   457\t      title: 'Live feed reconnecting',\n   458\t      tone: 'info',\n   459\t    }\n   460\t  }\n   461\t\n   462\t  if (connectionState === 'error') {\n   463\t    return {\n   464\t      description:\n   465\t        'The workspace can still render the saved snapshot, but live confirmations and background progress updates are temporarily unavailable.',\n   466\t      title: 'Live feed unavailable',\n   467\t      tone: 'warning',\n   468\t    }\n   469\t  }\n   470\t\n   471\t  if (connectionState === 'closed') {\n   472\t    return {\n   473\t      description:\n   474\t        'The saved session remains readable, but live runtime updates are paused until the feed reconnects.',\n   475\t      title: 'Live feed paused',\n   476\t      tone: 'warning',\n   477\t    }\n   478\t  }\n   479\t\n   480\t  return {\n   481\t    description:\n   482\t      'The workspace is running from the durable snapshot only. Configure the websocket endpoint to start session-scoped live updates.',\n   483\t    title: 'Live feed idle',\n   484\t    tone: 'info',\n   485\t  }\n   486\t}\n   487\t\n   488\tfunction