{"color": "cyan", "emoji": "\ud83d\udee0\ufe0f", "event_type": "Command Finished", "message": "completed, exit 0: /bin/zsh -lc \"sed -n '1,260p' frontend/src/shared/ui/ToastRegion.tsx\"", "raw_event": {"item": {"aggregated_output": "import type { AppShellToast } from '../../state/appShellStore.ts'\n\ntype ToastRegionProps = {\n  toasts: ReadonlyArray<AppShellToast>\n}\n\nexport function ToastRegion({ toasts }: ToastRegionProps) {\n  return (\n    <section className=\"toast-region\" aria-label=\"Future notification dock\">\n      <div className=\"toast-region__heading\">\n        <p className=\"eyebrow eyebrow-muted\">Toasts</p>\n        <span className=\"toast-region__count\">{toasts.length}</span>\n      </div>\n\n      {toasts.length === 0 ? (\n        <p className=\"toast-region__empty\">\n          Workflow notifications, export alerts, and background job updates will\n          dock here.\n        </p>\n      ) : (\n        <ul className=\"toast-region__list\">\n          {toasts.map((toast) => (\n            <li key={toast.id} className={`toast-region__item toast-region__item--${toast.tone}`}>\n              <strong>{toast.title}</strong>\n              <p>{toast.body}</p>\n            </li>\n          ))}\n        </ul>\n      )}\n    </section>\n  )\n}\n", "command": "/bin/zsh -lc \"sed -n '1,260p' frontend/src/shared/ui/ToastRegion.tsx\"", "exit_code": 0, "id": "item_37", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 72, "prompt_index": 21, "prompt_name": "20 \u2014 Frontend App Shell and Routing", "prompt_total": 100}, "timestap": "2026-04-01T01:19:54-07:00"}
