edback-banner__description\"\u001b[39m\n                \u001b[36m>\u001b[39m\n                  \u001b[0mThe workspace could not load this session right now.\u001b[0m\n                \u001b[36m</p>\u001b[39m\n                \u001b[36m<div\u001b[39m\n                  \u001b[33mclass\u001b[39m=\u001b[32m\"feedback-banner__actions\"\u001b[39m\n                \u001b[36m>\u001b[39m\n                  \u001b[36m<div\u001b[39m\n                    \u001b[33mclass\u001b[39m=\u001b[32m\"cta-row\"\u001b[39m\n                  \u001b[36m>\u001b[39m\n                    \u001b[36m<button\u001b[39m\n                      \u001b[33mclass\u001b[39m=\u001b[32m\"button button--ghost button--compact\"\u001b[39m\n                      \u001b[33mtype\u001b[39m=\u001b[32m\"button\"\u001b[39m\n                    \u001b[36m>\u001b[39m\n                      \u001b[0mRetry\u001b[0m\n                    \u001b[36m</button>\u001b[39m\n                    \u001b[36m<a\u001b[39m\n                      \u001b[33mclass\u001b[39m=\u001b[32m\"button button--ghost button--compact\"\u001b[39m\n                      \u001b[33mdata-discover\u001b[39m=\u001b[32m\"true\"\u001b[39m\n                      \u001b[33mhref\u001b[39m=\u001b[32m\"/\"\u001b[39m\n                    \u001b[36m>\u001b[39m\n                      \u001b[0mReturn home\u001b[0m\n                    \u001b[36m</a>\u001b[39m\n                  \u001b[36m</div>\u001b[39m\n                \u001b[36m</div>\u001b[39m\n              \u001b[36m</section>\u001b[39m\n            \u001b[36m</article>\u001b[39m\n          \u001b[36m</section>\u001b[39m\n        \u001b[36m</main>\u001b[39m\n      \u001b[36m</div>\u001b[39m\n    \u001b[36m</div>\u001b[39m\n  \u001b[36m</div>\u001b[39m\n\u001b[36m</body>\u001b[39m\n ❯ waitForWrapper node_modules/@testing-library/dom/dist/wait-for.js:163:27\n ❯ node_modules/@testing-library/dom/dist/query-helpers.js:86:33\n ❯ src/app/router.test.tsx:216:20\n    214|\n    215|     expect(\n    216|       await 