ped[\"AudioJob | None\"] = relationship(back_populates=\"assets\")\nbackend/app/db/models.py:1248:            \"ix_session_assets_audio_job_id_asset_kind_segment_index\",\nbackend/app/db/models.py:1249:            \"audio_job_id\",\nbackend/app/db/models.py:1251:            \"segment_index\",\nbackend/app/db/models.py:1254:            \"ix_session_assets_composition_job_id_asset_kind_segment_index\",\nbackend/app/db/models.py:1257:            \"segment_index\",\nbackend/app/db/__init__.py:19:    AudioJob,\nbackend/app/db/__init__.py:74:    \"AudioJob\",\nbackend/app/api/v1/routes/sessions.py:471:    \"/{session_id}/audio-settings\",\nbackend/app/api/v1/routes/sessions.py:474:    summary=\"Persist durable audio settings for a story session\",\nbackend/app/api/v1/routes/sessions.py:476:def save_session_audio_settings(\nbackend/app/api/v1/routes/sessions.py:482:        return SessionService(db_session).save_audio_settings(\nbackend/app/api/v1/routes/sessions.py:567:                    \"rewrite_from_segment_index\": payload.restart_from_segment_index,\nbackend/app/api/v1/routes/sessions.py:568:                    \"rewrite_to_segment_index\": payload.rewrite_to_segment_index,\nbackend/app/api/v1/routes/sessions.py:570:                    \"preserve_completed_segments\": False,\nbackend/app/api/v1/routes/sessions.py:574:            restart_from_segment_index = (\nbackend/app/api/v1/routes/sessions.py:575:                payload.restart_from_segment_index\nbackend/app/api/v1/routes/sessions.py:577:                else composition_jobs.resolve_continue_start_segment(session_id)\nbackend/app/api/v1/routes/sessions.py:584:                    \"restart_from_segment_index\": restart_from_segment_index,\nbackend/app/api/v1/routes/sessions.py:768:            rewrite_from_segment_index=payload.rewrite_from_segment_index,\nbackend/app/api/v1/routes/sessions.py:769:            rewrite_to_segment_index=payload.rewrite_to_segment_index,\nbackend/app/api/v1/routes/sessions.py:903:   