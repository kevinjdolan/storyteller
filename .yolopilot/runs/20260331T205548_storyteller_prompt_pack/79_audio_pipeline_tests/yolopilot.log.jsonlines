sult\"\n\n\ndef test_story_workflow_action_router_maps_chat_actions_to_shared_tool_calls() -> None:\n    batch = ChatToUIActionBatch.model_validate(\n        {\n            \"actions\": [\n                {\n                    \"action_type\": \"refine_pitch\",\n", "command": "/bin/zsh -lc \"sed -n '420,520p' backend/tests/test_story_tools.py\"", "exit_code": 0, "id": "item_52", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "run_id": "852e59ae-7e3c-580a-9c17-7f38e0f42b62", "timestamp": "2026-04-03T22:57:03.155293-07:00"}, "run_id": "852e59ae-7e3c-580a-9c17-7f38e0f42b62", "status": "completed", "timestamp": "2026-04-03T22:57:03.155293-07:00"}
