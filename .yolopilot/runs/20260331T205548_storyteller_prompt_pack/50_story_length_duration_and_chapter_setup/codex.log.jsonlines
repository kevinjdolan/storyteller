{"type":"item.completed","item":{"id":"item_41","type":"command_execution","command":"/bin/zsh -lc 'rg -n \"NumberField|SliderField|ToggleField|SelectField|InlineHelp|StickySummaryLayout\" frontend/src/shared/ui/workflow.tsx -S'","aggregated_output":"97:export type SelectFieldOption = {\n103:type SelectFieldProps = Omit<\n112:  options: ReadonlyArray<SelectFieldOption>\n115:export function SelectField({\n125:}: SelectFieldProps) {\n166:type NumberFieldProps = Omit<InputHTMLAttributes<HTMLInputElement>, 'size'> & {\n175:export function NumberField(props: NumberFieldProps) {\n179:type SliderFieldProps = Omit<\n191:export function SliderField({\n201:}: SliderFieldProps) {\n234:type ToggleFieldProps = Omit<\n246:export function ToggleField({\n257:}: ToggleFieldProps) {\n402:type InlineHelpTone = 'info' | 'warning' | 'success'\n404:type InlineHelpProps = Omit<ComponentPropsWithoutRef<'aside'>, 'title'> & {\n406:  tone?: InlineHelpTone\n409:export function InlineHelp({\n415:}: InlineHelpProps) {\n541:type StickySummaryLayoutProps = ComponentPropsWithoutRef<'div'> & {\n545:export function StickySummaryLayout({\n550:}: StickySummaryLayoutProps) {\n","exit_code":0,"status":"completed"}}
