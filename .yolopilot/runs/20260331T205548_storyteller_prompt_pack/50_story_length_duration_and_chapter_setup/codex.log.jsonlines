ontrols now share one persistent surface, with the left lane reserved for conversation and the right canvas reserved for structured editing.\\u001b[0m\\n          \\u001b[36m</p>\\u001b[39m\\n        \\u001b[36m</div>\\u001b[39m\\n        \\u001b[36m<dl\\u001b[39m\\n          \\u001b[33maria-label\\u001b[39m=\\u001b[32m\\\"Session status\\\"\\u001b[39m\\n          \\u001b[33mclass\\u001b[39m=\\u001b[32m\\\"workspace-topbar__status\\\"\\u001b[39m\\n        \\u001b[36m>\\u001b[39m\\n          \\u001b[36m<div\\u001b[39m\\n            \\u001b[33mclass\\u001b[39m=\\u001b[32m\\\"workspace-topbar__status-card\\\"\\u001b[39m\\n          \\u001b[36m>\\u001b[39m\\n            \\u001b[36m<dt>\\u001b[39m\\n              \\u001b[0mCurrent stage\\u001b[0m\\n            \\u001b[36m</dt>\\u001b[39m\\n            \\u001b[36m<dd>\\u001b[39m\\n              \\u001b[36m<span\\u001b[39m\\n                \\u001b[33mclass\\u001b[39m=\\u001b[32m\\\"badge badge--brand\\\"\\u001b[39m\\n              \\u001b[36m>\\u001b[39m\\n                \\u001b[0mBeat sheet\\u001b[0m\\n              \\u001b[36m</span>\\u001b[39m\\n            \\u001b[36m</dd>\\u001b[39m\\n          \\u001b[36m</div>\\u001b[39m\\n          \\u001b[36m<div\\u001b[39m\\n            \\u001b[33mclass\\u001b[39m=\\u001b[32m\\\"workspace-topbar__status-card\\\"\\u001b[39m\\n          \\u001b[36m>\\u001b[39m\\n            \\u001b[36m<dt>\\u001b[39m\\n              \\u001b[0mSave status\\u001b[0m\\n            \\u001b[36m</dt>\\u001b[39m\\n            \\u001b[36m<dd>\\u001b[39m\\n              \\u001b[0mSaved Mar 31, 10:15 PM\\u001b[0m\\n            \\u001b[36m</dd>\\u001b[39m\\n          \\u001b[36m</div>\\u001b[39m\\n          \\u001b[36m<div\\u001b[39m\\n            \\u001b[33mclass\\u001b[39m=\\u001b[32m\\\"workspace-topbar__status-card\\\"\\u001b[39m\\n          \\u001b[36m>\\u001b[39m\\n            \\u001b[36m<dt>\\u001b[39m\\n              \\u001b[0mSession ID\\u001b[0m\\n            \\u001b[36m</dt>\\u001b[39m\\n        