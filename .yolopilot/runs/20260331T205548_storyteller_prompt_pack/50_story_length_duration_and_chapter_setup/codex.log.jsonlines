{"type":"item.started","item":{"id":"item_237","type":"command_execution","command":"/bin/zsh -lc \"./scripts/dev-compose.sh exec -T browser node --input-type=module <<'EOF'\nimport puppeteer from 'puppeteer';\n\nconst sessionId = '8155bbd7-2de7-4d4c-a961-d35485225ed0';\nconst desktopPath = '/workspace/.artifacts/webapp-qa/prompt-50-story-setup-form-desktop.png';\nconst mobilePath = '/workspace/.artifacts/webapp-qa/prompt-50-story-setup-form-mobile.png';\n\nconst browser = await puppeteer.launch({\n  executablePath: process.env.PUPPETEER_EXECUTABLE_PATH,\n  args: ['--no-sandbox', '--disable-setuid-sandbox'],\n  headless: true,\n});\n\ntry {\n  const page = await browser.newPage();\n  const url = \"'`http://frontend:8566/sessions/${sessionId}?stage=story_setup`;\n\n  async function frameForm(viewport, outputPath) {\n    await page.setViewport(viewport);\n    await page.goto(url, { waitUntil: '\"'networkidle2', timeout: 30000 });\n    await page.waitForFunction(\n      () => document.body?.innerText.includes('Planning targets') && document.body?.innerText.includes('Pacing notes'),\n      { timeout: 30000 },\n    );\n    await page.evaluate(() => {\n      const heading = Array.from(document.querySelectorAll('h3')).find(\n        (element) => element.textContent?.trim() === 'Planning targets',\n      );\n      heading?.scrollIntoView({ block: 'start', behavior: 'instant' });\n    });\n    await new Promise((resolve) => setTimeout(resolve, 300));\n    await page.screenshot({ path: outputPath, fullPage: false });\n    console.log(\"'`Saved ${outputPath}`);\n  }\n\n  await frameForm({ width: 1440, height: 900 }, desktopPath);\n  await frameForm({ width: 430, height: 932 }, mobilePath);\n} finally {\n  await browser.close();\n}\nEOF'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
