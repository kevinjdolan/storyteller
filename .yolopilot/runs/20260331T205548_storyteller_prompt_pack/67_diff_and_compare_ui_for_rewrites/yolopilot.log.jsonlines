{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Finished", "message": "completed, exit 0: /bin/zsh -lc \"rg -n \\\"export function TextArea\\\" -n frontend/src/shared/ui/primitives.tsx && sed -n '320,420p' frontend/src/shared/ui/primitives.tsx\"", "raw_event": {"item": {"aggregated_output": "339:export function TextArea({\n          {error}\n        </p>\n      ) : null}\n    </div>\n  )\n}\n\ntype TextAreaProps = Omit<\n  TextareaHTMLAttributes<HTMLTextAreaElement>,\n  'rows'\n> & {\n  className?: string\n  description?: ReactNode\n  error?: ReactNode\n  hideLabel?: boolean\n  label: ReactNode\n  rows?: number\n}\n\nexport function TextArea({\n  'aria-describedby': ariaDescribedBy,\n  className,\n  description,\n  error,\n  hideLabel = false,\n  id,\n  label,\n  rows = 4,\n  ...props\n}: TextAreaProps) {\n  const generatedId = useId()\n  const inputId = id ?? generatedId\n  const descriptionId =\n    description != null ? `${inputId}-description` : undefined\n  const errorId = error != null ? `${inputId}-error` : undefined\n  const describedBy = [ariaDescribedBy, descriptionId, errorId]\n    .filter(Boolean)\n    .join(' ')\n\n  return (\n    <div className={cx('field', error != null && 'field--error', className)}>\n      <label\n        className={cx('field__label', hideLabel && 'visually-hidden')}\n        htmlFor={inputId}\n      >\n        {label}\n      </label>\n      {description != null ? (\n        <p className=\"field__description\" id={descriptionId}>\n          {description}\n        </p>\n      ) : null}\n      <textarea\n        aria-describedby={describedBy || undefined}\n        aria-invalid={error != null || undefined}\n        className=\"text-area\"\n        id={inputId}\n        rows={rows}\n        {...props}\n      />\n      {error != null ? (\n        <p className=\"field__error\" id={errorId} role=\"alert\">\n          {error}\n        </p>\n      ) : null}\n    </div>\n  )\n}\n", "command": "/bin/zsh -lc \"rg -n \\\"export