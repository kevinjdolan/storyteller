  gap: var(--space-2);\n}\n\n.composition-stage__segment-entry {\n  display: flex;\n  justify-content: space-between;\n  gap: var(--space-3);\n  width: 100%;\n  padding: 0.95rem 1rem;\n  border: 1px solid rgba(39, 69, 99, 0.1);\n  border-radius: var(--radius-lg);\n  background: rgba(255, 255, 255, 0.72);\n  color: inherit;\n  text-align: left;\n  transition:\n    border-color 160ms ease,\n    transform 160ms ease,\n    box-shadow 160ms ease;\n}\n\n.composition-stage__segment-entry:hover,\n.composition-stage__segment-entry[data-selected='true'] {\n  border-color: rgba(39, 69, 99, 0.26);\n  box-shadow: 0 14px 28px rgba(39, 69, 99, 0.08);\n  transform: translateY(-1px);\n}\n\n.composition-stage__segment-entry strong,\n.composition-stage__segment-entry span {\n  display: block;\n}\n\n.composition-stage__segment-entry strong {\n  margin-bottom: 0.22rem;\n}\n\n.composition-stage__segment-entry span {\n  color: var(--color-ink-soft);\n  font-size: 0.92rem;\n}\n\n.composition-stage__segment-entry-badges {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.35rem;\n  justify-content: end;\n}\n\n.composition-stage__compare-panel {\n  display: grid;\n  gap: var(--space-4);\n}\n\n.composition-stage__compare-header h4 {\n  margin: 0;\n  font-family: var(--font-family-display);\n  font-size: clamp(1.35rem, 2vw, 1.8rem);\n}\n\n.composition-stage__compare-header p {\n  margin: 0.45rem 0 0;\n  color: var(--color-ink-soft);\n}\n\n.composition-stage__compare-columns {\n  display: grid;\n  gap: var(--space-4);\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n}\n\n.composition-stage__compare-card,\n.composition-stage__history-card {\n  display: grid;\n  gap: var(--space-3);\n  padding: 1rem 1.1rem;\n  border: 1px solid rgba(39, 69, 99, 0.1);\n  border-radius: var(--radius-lg);\n  background: rgba(255, 255, 255, 0.76);\n}\n\n.composition-stage__compare-card--pending {\n  background:\n    linear-gradient(\n      180deg,\n      rgba(255, 244, 225, 0.92),\n      rgba(255, 250, 240, 0.82)\n    ),\n    rgba(255, 255, 255, 0.82);\n  border-color: rgba(169, 116, 60, 0.18);\n}\n\n.composition-stage__compare-card-header,\n.composition-stage__history-card-header {\n  display: flex;\n  justify-content: space-between;\n  gap: var(--space-3);\n  align-items: center;\n}\n\n.composition-stage__compare-card pre {\n  margin: 0;\n  white-space: pre-wrap;\n  line-height: 1.72;\n  font-size: 0.98rem;\n}\n\n.composition-stage__history-list {\n  display: grid;\n  gap: var(--space-3);\n}\n\n.composition-stage__history-card p {\n  margin: 0;\n  color: var(--color-ink-soft);\n}\n\n@keyframes composition-cursor-blink {\n  0%,\n  49% {\n    opacity: 1;\n  }\n\n  50%,\n  100% {\n    opacity: 0;\n  }\n}\n\n@keyframes composition-surface-sweep {\n  0%,\n  12% {\n    transform: translateX(-100%);\n    opacity: 0;\n  }\n\n  24%,\n  44% {\n    transform: translateX(100%);\n    opacity: 1;\n  }\n\n  45%,\n  100% {\n    transform: translateX(100%);\n    opacity: 0;\n  }\n}\n", "command": "/bin/zsh -lc \"sed -n '2540,2765p' frontend/src/styles/index.css\"", "exit_code": 0, "id": "item_65", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 133, "prompt_index": 68, "prompt_name": "67 \u2014 Diff and Compare UI for Rewrites", "prompt_total": 100}, "timestap": "2026-04-02T12:17:21-07:00"}
