{"type":"item.started","item":{"id":"item_301","type":"command_execution","command":"/bin/zsh -lc \"docker compose -f infra/compose/docker-compose.yml exec -T browser node --input-type=module - <<'EOF'\nimport fs from 'node:fs/promises';\nimport puppeteer from 'puppeteer';\n\nconst sessionId = '464fe382-f23a-4f03-9dce-fffc86a4f080';\nconst outputDir = '/workspace/tools/webapp-qa/.artifacts/prompt-70';\nawait fs.mkdir(outputDir, { recursive: true });\n\nconst browser = await puppeteer.launch({\n  headless: true,\n  executablePath: process.env.PUPPETEER_EXECUTABLE_PATH,\n  args: ['--no-sandbox', '--disable-setuid-sandbox'],\n});\n\nasync function scrollAudioStageIntoView(page) {\n  await page.waitForFunction(() => document.body?.innerText.includes('Shape the narration pass before the audio render starts.'));\n  await page.evaluate(() => {\n    const heading = Array.from(document.querySelectorAll('h3')).find((node) =>\n      node.textContent?.includes('Shape the narration pass before the audio render starts.'),\n    );\n    if (heading) {\n      heading.scrollIntoView({ block: 'start', behavior: 'instant' });\n      window.scrollBy(0, -24);\n    }\n  });\n  await page.waitForTimeout(300);\n}\n\nasync function verifyAndShoot({ width, height, name }) {\n  const page = await browser.newPage();\n  page.setDefaultTimeout(20000);\n  await page.setViewport({ width, height });\n  await page.goto(\"'`http://frontend:8566/sessions/${sessionId}`, { waitUntil: '\"'networkidle2' });\n  await page.waitForSelector('[data-testid=\\\"workspace-route\\\"]');\n  await page.waitForFunction(() => document.body?.innerText.includes('About 15 min'));\n  await page.waitForFunction(() => document.body?.innerText.includes('Hearthside'));\n  await page.waitForFunction(() => document.body?.innerText.includes('Night ambience'));\n  await page.waitForFunction(() => document.body?.innerText.includes('Save audio settings'));\n  await scrollAudioStageIntoView(page);\n  await page.screenshot({ path: \"'`${outputDir}/${name}.png`, fullPage: false });\n  await page.close();\n}\n\nawait verifyAndShoot({ width: 1440, height: 960, name: '\"'audio-settings-desktop' });\nawait verifyAndShoot({ width: 430, height: 932, name: 'audio-settings-mobile' });\n\nawait browser.close();\nconsole.log(\"'`${outputDir}/audio-settings-desktop.png`);\nconsole.log(`${outputDir}/audio-settings-mobile.png`);\nEOF'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
