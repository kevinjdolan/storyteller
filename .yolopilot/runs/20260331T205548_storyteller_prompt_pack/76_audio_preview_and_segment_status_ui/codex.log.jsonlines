een;\n  gap: var(--space-3);\n  flex-wrap: wrap;\n}\n\n.genre-selection-card__facts dd,\n.tone-selection-card__facts dd {\n  margin: 0;\n  color: var(--color-ink-strong);\n}\n\n.genre-selection-card__footer,\n.tone-selection-card__footer {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: var(--space-3);\n}\n\n.genre-selection-card__footer p,\n.tone-selection-card__footer p {\n  margin: 0;\n  color: var(--color-ink-soft);\n}\n\n.tone-selection-card__descriptors {\n  display: flex;\n  flex-wrap: wrap;\n  gap: var(--space-2);\n}\n\n.tone-selection-card__motifs {\n  display: grid;\n  gap: var(--space-1);\n  padding: 0.85rem 0.95rem;\n  border-radius: var(--radius-lg);\n  background: rgba(255, 255, 255, 0.7);\n}\n\n.tone-selection-card__motifs span {\n  color: var(--color-ink-muted);\n  font-size: 0.76rem;\n  font-weight: 700;\n  letter-spacing: 0.08em;\n  text-transform: uppercase;\n}\n\n.tone-selection-card__motifs p {\n  margin: 0;\n  color: var(--color-ink-strong);\n}\n\n.inline-help {\n","exit_code":0,"status":"completed"}}
