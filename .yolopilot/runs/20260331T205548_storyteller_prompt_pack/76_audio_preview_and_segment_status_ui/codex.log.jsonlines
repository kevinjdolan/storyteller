{"type":"item.started","item":{"id":"item_218","type":"command_execution","command":"/bin/zsh -lc \"node --input-type=module <<'EOF'\nimport puppeteer from '/Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer/lib/esm/puppeteer/puppeteer.js';\n\nconst chromePath = '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome';\nconst sessionId = '3671e0d9-82a2-41bf-8195-b35b5d950ec2';\nconst url = \"'`http://127.0.0.1:8566/sessions/${sessionId}?stage=audio`;\n\nconst browser = await puppeteer.launch({ headless: true, executablePath: chromePath });\nconst page = await browser.newPage();\nawait page.setViewport({ width: 1440, height: 1200, deviceScaleFactor: 1 });\nawait page.goto(url, { waitUntil: '\"'networkidle2' });\nawait page.waitForSelector('.audio-stage__status-panel');\nconst result = await page.evaluate(() => {\n  const status = document.querySelector('.audio-stage__status-panel');\n  const summary = document.querySelector('.audio-stage__summary');\n  const layout = document.querySelector('.audio-stage__layout');\n  if (\"'!(status instanceof HTMLElement) || !(summary instanceof HTMLElement) || !(layout instanceof HTMLElement)) {\n    return null;\n  }\n  const a = status.getBoundingClientRect();\n  const b = summary.getBoundingClientRect();\n  const overlap = !(a.right <= b.left || b.right <= a.left || a.bottom <= b.top || b.bottom <= a.top);\n  return {\n    overlap,\n    status: { left: a.left, right: a.right, top: a.top, bottom: a.bottom, width: a.width, height: a.height },\n    summary: { left: b.left, right: b.right, top: b.top, bottom: b.bottom, width: b.width, height: b.height },\n    layout: layout.getBoundingClientRect().toJSON(),\n    viewport: { width: window.innerWidth, height: window.innerHeight },\n  };\n});\nconsole.log(JSON.stringify(result, null, 2));\nawait browser.close();\nEOF'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
