e:\n        return None\n\n    normalized = value.strip()\n    return normalized or None\n\n\ndef _normalize_required_text(value: str, *, field_name: str) -> str:\n    normalized = value.strip()\n    if not normalized:\n        raise ValueError(f\"{field_name} must not be empty\")\n    return normalized\n","exit_code":0,"status":"completed"}}
