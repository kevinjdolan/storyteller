rs\",\n  \"license\": \"Apache-2.0\",\n  \"dependencies\": {\n    \"@puppeteer/browsers\": \"2.13.0\",\n    \"chromium-bidi\": \"14.0.0\",\n    \"cosmiconfig\": \"^9.0.0\",\n    \"devtools-protocol\": \"0.0.1581282\",\n    \"puppeteer-core\": \"24.40.0\",\n    \"typed-query-selector\": \"^2.12.1\"\n  },\n  \"devDependencies\": {\n    \"@types/node\": \"^18.17.15\"\n  }\n}\n","exit_code":0,"status":"completed"}}
