{"type":"item.started","item":{"id":"item_177","type":"command_execution","command":"/bin/zsh -lc \"export STORYTELLER_SECRETS_FILE=''; export STORYTELLER_DATABASE_URL='sqlite+pysqlite:////tmp/storyteller-audio-stage-qa.sqlite3'; export STORYTELLER_GEMINI_API_KEY='test-gemini-key'; export STORYTELLER_GCS_ENDPOINT='http://127.0.0.1:8568'; export STORYTELLER_GCS_PROJECT_ID='storyteller-local'; export STORYTELLER_GCS_PUBLIC_URL='http://127.0.0.1:8568'; export STORYTELLER_GCS_SESSIONS_BUCKET_NAME='storyteller-sessions'; export STORYTELLER_GCS_AUDIO_BUCKET_NAME='storyteller-audio'; export STORYTELLER_GCS_EXPORTS_BUCKET_NAME='storyteller-exports'; export STORYTELLER_ENVIRONMENT='development'; export STORYTELLER_HOST='127.0.0.1'; export STORYTELLER_PORT='8565'; export STORYTELLER_RELOAD='false'; PYTHONPATH=backend python - <<'PY'\nfrom datetime import datetime, timezone\nfrom pathlib import Path\n\nfrom sqlalchemy.orm import sessionmaker\n\nfrom app.db import (\n    AssetKind,\n    AssetStatus,\n    AudioJob,\n    Base,\n    JobStatus,\n    NarrationPauseHint,\n    NarrationSegment,\n    NarrationSourceBoundaryKind,\n    SessionAsset,\n    make_engine,\n)\nfrom app.models import WorkflowStage, WorkflowStageState\nfrom app.services.sessions import SessionService\n\nDB_URL = 'sqlite+pysqlite:////tmp/storyteller-audio-stage-qa.sqlite3'\npath = Path('/tmp/storyteller-audio-stage-qa.sqlite3')\nif path.exists():\n    path.unlink()\n\nengine = make_engine(DB_URL)\nBase.metadata.create_all(engine)\nSession = sessionmaker(bind=engine, autoflush=False, expire_on_commit=False)\n\nsession = Session()\nservice = SessionService(session)\nsnapshot = service.create_session(working_title='Audio Preview QA')\n\nfor stage in WorkflowStage:\n    if stage == WorkflowStage.FINALIZE:\n        break\n    status = WorkflowStageState.COMPLETED if stage \"'!= WorkflowStage.AUDIO else WorkflowStageState.IN_PROGRESS\n    service.update_stage_state(\n        snapshot.id,\n        stage=stage,\n        status=status,\n        detail='\"'Ready for audio preview QA.' if stage == WorkflowStage.AUDIO else f'Accepted {stage.value}.',\n    )\n    if stage == WorkflowStage.AUDIO:\n        break\n\naudio_job = AudioJob(\n    session_id=snapshot.id,\n    status=JobStatus.IN_PROGRESS,\n    voice_key='moonbeam',\n    playback_speed=0.95,\n    include_background_music=True,\n    music_profile='string_drift',\n    estimated_duration_seconds=780,\n    current_segment_index=2,\n    config_json={\n        'total_segments': 3,\n        'completed_segments': 1,\n        'progress_percent': 68.0,\n        'current_step': 'Rendering narration segment 2 of 3.',\n        'current_step_index': 2,\n        'total_steps': 6,\n        'latest_asset_kind': AssetKind.AUDIO_SEGMENT.value,\n    },\n)\nsession.add(audio_job)\nsession.flush()\n\nsession.add_all([\n    NarrationSegment(\n        session_id=snapshot.id,\n        audio_job_id=audio_job.id,\n        segment_index=1,\n        status=JobStatus.COMPLETED,\n        source_boundary_kind=NarrationSourceBoundaryKind.CHAPTER,\n        source_outline_card_title='Lantern launch',\n        text_content='Mira set the first lantern on the still water and waited for the harbor to answer in a hush.',\n        word_count=17,\n        text_start_offset=0,\n        text_end_offset=90,\n        pause_after_seconds=3,\n        pause_hint=NarrationPauseHint.CHAPTER_BREAK,\n        completed_at=datetime.now(timezone.utc),\n        metadata_json={'split_reason': 'paragraph_boundary'},\n    ),\n    NarrationSegment(\n        session_id=snapshot.id,\n        audio_job_id=audio_job.id,\n        segment_index=2,\n        status=JobStatus.QUEUED,\n        source_boundary_kind=NarrationSourceBoundaryKind.CHAPTER,\n        source_outline_card_title='Silver bell crossing',\n        text_content='Otis stayed close while the silver bell called from the cove, never letting the mystery sharpen.',\n        word_count=16,\n        text_start_offset=92,\n        text_end_offset=190,\n        pause_after_seconds=0,\n        pause_hint=NarrationPauseHint.NONE,\n        metadata_json={'split_reason': 'sentence_boundary'},\n    ),\n    NarrationSegment(\n        session_id=snapshot.id,\n        audio_job_id=audio_job.id,\n        segment_index=3,\n        status=JobStatus.QUEUED,\n        source_boundary_kind=NarrationSourceBoundaryKind.CHAPTER,\n        source_outline_card_title='Harbor homecoming',\n        text_content='By the final dock, every lantern had found its place and the water settled back into bedtime quiet.',\n        word_count=17,\n        text_start_offset=192,\n        text_end_offset=296,\n        pause_after_seconds=0,\n        pause_hint=NarrationPauseHint.NONE,\n        metadata_json={'split_reason': 'paragraph_boundary'},\n    ),\n])\nsession.flush()\n\nsession.add_all([\n    SessionAsset(\n        session_id=snapshot.id,\n        audio_job_id=audio_job.id,\n        asset_kind=AssetKind.AUDIO_SEGMENT,\n        status=AssetStatus.READY,\n        storage_bucket='storyteller-audio',\n        object_path=f'sessions/{snapshot.id}/audio/jobs/{audio_job.id}/segments/0001.wav',\n        mime_type='audio/wav',\n        segment_index=1,\n        ready_at=datetime.now(timezone.utc),\n    ),\n    SessionAsset(\n        session_id=snapshot.id,\n        audio_job_id=audio_job.id,\n        asset_kind=AssetKind.FINAL_AUDIO,\n        status=AssetStatus.READY,\n        storage_bucket='storyteller-audio',\n        object_path=f'sessions/{snapshot.id}/audio/jobs/{audio_job.id}/final/story.wav',\n        mime_type='audio/wav',\n        ready_at=datetime.now(timezone.utc),\n    ),\n])\nsession.commit()\nprint(snapshot.id)\nsession.close()\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
