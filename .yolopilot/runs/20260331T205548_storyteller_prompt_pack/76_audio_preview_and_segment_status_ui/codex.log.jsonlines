 252, 0.88);\n}\n\n.feedback-banner--success {\n  border-color: rgba(88, 115, 91, 0.18);\n  background: rgba(243, 249, 244, 0.9);\n}\n\n.feedback-banner--warning {\n  border-color: rgba(169, 116, 60, 0.22);\n  background: rgba(252, 247, 241, 0.92);\n}\n  gap: var(--space-2);\n  margin: 0;\n  padding-left: 1.1rem;\n  color: var(--color-ink-strong);\n}\n\n.story-brief-stage__interpretation-panel {\n  display: grid;\n  gap: var(--space-4);\n  padding-top: var(--space-2);\n  border-top: 1px solid rgba(39, 69, 99, 0.1);\n}\n\n.workspace-stage-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: var(--space-3);\n}\n\n.workspace-stage-card {\n  display: grid;\n  gap: var(--space-4);\n  padding: var(--space-4);\n  border-radius: var(--radius-xl);\n}\n\n.workspace-stage-card--current {\n","exit_code":0,"status":"completed"}}
