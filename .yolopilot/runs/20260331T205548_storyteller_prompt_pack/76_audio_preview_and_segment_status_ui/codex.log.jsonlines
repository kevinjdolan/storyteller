{"type":"item.completed","item":{"id":"item_182","type":"command_execution","command":"/bin/zsh -lc \"node --input-type=module - <<'EOF'\nimport puppeteer from 'puppeteer';\nimport fs from 'node:fs/promises';\n\nconst url = 'http://127.0.0.1:8566/sessions/3671e0d9-82a2-41bf-8195-b35b5d950ec2?stage=audio';\nawait fs.mkdir('/Users/kevin/code/storyteller/.artifacts/webapp-qa', { recursive: true });\n\nconst browser = await puppeteer.launch({ headless: 'new' });\n\nfor (const [name, viewport] of Object.entries({\n  desktop: { width: 1440, height: 1400 },\n  mobile: { width: 430, height: 1200 },\n})) {\n  const page = await browser.newPage();\n  await page.setViewport(viewport);\n  await page.goto(url, { waitUntil: 'networkidle2' });\n  await page.waitForFunction(() => document.body.innerText.includes('Segment status'));\n  await page.waitForFunction(() => document.body.innerText.includes('Compiled narration'));\n  const text = await page.evaluate(() => document.body.innerText);\n  if (\"'!text.includes('\"'Generating now')) {\n    throw new Error(\"'`Missing segment activity state on ${name}`);\n  }\n  if (!text.includes('\"'Checkpoint preview clip')) {\n    throw new Error(\"'`Missing preview distinction on ${name}`);\n  }\n  const path = `/Users/kevin/code/storyteller/.artifacts/webapp-qa/prompt-76-audio-stage-${name}.png`;\n  await page.screenshot({ path, fullPage: false });\n  console.log(`${name}:${path}`);\n  await page.close();\n}\n\nawait browser.close();\nEOF'","aggregated_output":"file:///Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer-core/lib/esm/puppeteer/common/CallbackRegistry.js:99\n    #error = new ProtocolError();\n             ^\n\nProtocolError: Page.captureScreenshot timed out. Increase the 'protocolTimeout' setting in launch/connect calls for a higher timeout if needed.\n    at <instance_members_initializer> (file:///Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer-core/lib/esm/puppeteer/common/CallbackRegistry.js:99:14)\n    at new Callback (file:///Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer-core/lib/esm/puppeteer/common/CallbackRegistry.js:103:16)\n    at CallbackRegistry.create (file:///Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer-core/lib/esm/puppeteer/common/CallbackRegistry.js:22:26)\n    at Connection._rawSend (file:///Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer-core/lib/esm/puppeteer/cdp/Connection.js:104:26)\n    at CdpCDPSession.send (file:///Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer-core/lib/esm/puppeteer/cdp/CdpSession.js:71:33)\n    at CdpPage._screenshot (file:///Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer-core/lib/esm/puppeteer/cdp/Page.js:839:62)\n    at CdpPage.screenshot (file:///Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer-core/lib/esm/puppeteer/api/Page.js:1079:41)\n    at async CdpPage.<anonymous> (file:///Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer-core/lib/esm/puppeteer/util/decorators.js:164:24)\n    at async file:///Users/kevin/code/storyteller/tools/webapp-qa/[eval1]:26:3\n\nNode.js v24.14.0\n","exit_code":1,"status":"failed"}}
