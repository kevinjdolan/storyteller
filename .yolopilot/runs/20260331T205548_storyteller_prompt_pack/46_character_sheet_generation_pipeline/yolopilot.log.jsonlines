#/$defs/SessionEventActor\"\ndocs/realtime-events.schema.json:1277:            \"session_id\": {\ndocs/realtime-events.schema.json:1279:              \"title\": \"Session Id\",\ndocs/realtime-events.schema.json:1301:            \"session_id\",\ndocs/realtime-events.schema.json:1326:            \"pitches\",\ndocs/realtime-events.schema.json:1327:            \"characters\",\ndocs/realtime-events.schema.json:1406:              \"$ref\": \"#/$defs/SessionEventActor\"\ndocs/realtime-events.schema.json:1464:            \"session_id\": {\ndocs/realtime-events.schema.json:1466:              \"title\": \"Session Id\",\ndocs/realtime-events.schema.json:1488:            \"session_id\",\ndocs/realtime-events.schema.json:1547:    \"session_subscription_ack\": {\ndocs/realtime-events.schema.json:1568:        \"SessionEventActor\": {\ndocs/realtime-events.schema.json:1590:          \"title\": \"SessionEventActor\",\ndocs/realtime-events.schema.json:1631:          \"$ref\": \"#/$defs/SessionEventActor\"\ndocs/realtime-events.schema.json:1668:        \"session_id\": {\ndocs/realtime-events.schema.json:1670:          \"title\": \"Session Id\",\ndocs/realtime-events.schema.json:1680:        \"session_id\",\ndocs/realtime-events.schema.json:1687:      \"title\": \"SessionSubscriptionAck\",\ndocs/realtime-events.schema.json:1690:    \"session_subscription_request\": {\ndocs/realtime-events.schema.json:1730:        \"session_id\": {\ndocs/realtime-events.schema.json:1732:          \"title\": \"Session Id\",\ndocs/realtime-events.schema.json:1742:        \"session_id\",\ndocs/realtime-events.schema.json:1745:      \"title\": \"SessionSubscriptionRequest\",\nfrontend/src/vite-env.d.ts:4:  readonly VITE_SESSION_EVENTS_WS_URL?: string\nfrontend/src/features/session/SessionStageEditorPreview.tsx:1:import type { SessionSnapshot } from '../../api/sessions.ts'\nfrontend/src/features/session/SessionStageEditorPreview.tsx:17:import type { SessionWorkspaceStageView } from './sessionStageScaffold.ts