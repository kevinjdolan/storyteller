pter\n\n\ndef get_pitch_generation_adapter(request: Request) -> PitchGenerationAdapter:\n    adapter = getattr(request.app.state, \"pitch_generation_adapter\", None)\n    if adapter is None:\n        settings = get_app_settings(request)\n        adapter = GeminiPitchGenerationAdapter(\n            credential=settings.gemini_api_key,\n            model_id=settings.gemini.planning_model,\n        )\n        request.app.state.pitch_generation_adapter = adapter\n\n    return adapter\n", "command": "/bin/zsh -lc \"sed -n '1,260p' backend/app/api/dependencies.py\"", "exit_code": 0, "id": "item_28", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 57, "prompt_index": 47, "prompt_name": "46 \u2014 Character Sheet Generation Pipeline", "prompt_total": 100}, "timestap": "2026-04-01T22:04:14-07:00"}
