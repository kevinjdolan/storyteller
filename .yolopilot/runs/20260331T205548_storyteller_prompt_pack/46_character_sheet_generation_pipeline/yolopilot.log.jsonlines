{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Finished", "message": "completed, exit 0: /bin/zsh -lc 'rg -n \"moonlit-harbor|Lanterns Over Juniper Lake\" -S backend frontend docs tools README.md'", "raw_event": {"item": {"aggregated_output": "tools/webapp-qa/examples/prompt-20-session-route.spec.json:2:  \"url\": \"http://localhost:8566/sessions/moonlit-harbor\",\ntools/webapp-qa/examples/prompt-20-session-route.spec.json:15:      \"text\": \"Session moonlit-harbor\"\ntools/webapp-qa/examples/prompt-20-session-route.spec.json:19:      \"text\": \"/sessions/moonlit-harbor\"\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:15:  id: 'moonlit-harbor',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:16:  display_title: 'Lanterns Over Juniper Lake',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:17:  working_title: 'Lanterns Over Juniper Lake',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:156:          title: 'Lanterns Over Juniper Lake',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:201:    title: 'Lanterns Over Juniper Lake',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:234:  session_id: 'moonlit-harbor',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:239:      session_id: 'moonlit-harbor',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:247:      summary: 'Created session: Lanterns Over Juniper Lake.',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:250:        working_title: 'Lanterns Over Juniper Lake',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:256:      session_id: 'moonlit-harbor',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:276:      session_id: 'moonlit-harbor',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:296:      session_id: 'moonlit-harbor',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:461:    session_id: 'moonlit-harbor',\nfrontend/src/pages/session/SessionWorkspacePage.test.tsx:506:   