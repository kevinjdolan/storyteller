{"aggregated_output": "const apiBaseUrl = (import.meta.env.VITE_API_URL ?? '').replace(/\\/+$/, '')\n\nexport function resolveApiUrl(path: `/${string}`) {\n  return `${apiBaseUrl}${path}`\n}\n\nasync function parseJsonResponse<T>(response: Response): Promise<T> {\n  if (!response.ok) {\n    throw new Error(`Unexpected status code: ${response.status}`)\n  }\n\n  return (await response.json()) as T\n}\n\nexport async function getJson<T>(path: `/${string}`): Promise<T> {\n  const response = await fetch(resolveApiUrl(path))\n\n  return parseJsonResponse<T>(response)\n}\n\nexport async function postJson<T>(\n  path: `/${string}`,\n  body?: unknown,\n): Promise<T> {\n  const response = await fetch(resolveApiUrl(path), {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n    },\n    body: body === undefined ? undefined : JSON.stringify(body),\n  })\n\n  return parseJsonResponse<T>(response)\n}\n", "command": "/bin/zsh -lc \"sed -n '1,220p' frontend/src/api/client.ts\"", "event_type": "shell.file_read_finished", "event_version": "0.0", "exit_code": 0, "raw_event": {"event_type": "codex.raw.file_read_finished", "event_version": "0.0", "raw_event": {"item": {"aggregated_output": "const apiBaseUrl = (import.meta.env.VITE_API_URL ?? '').replace(/\\/+$/, '')\n\nexport function resolveApiUrl(path: `/${string}`) {\n  return `${apiBaseUrl}${path}`\n}\n\nasync function parseJsonResponse<T>(response: Response): Promise<T> {\n  if (!response.ok) {\n    throw new Error(`Unexpected status code: ${response.status}`)\n  }\n\n  return (await response.json()) as T\n}\n\nexport async function getJson<T>(path: `/${string}`): Promise<T> {\n  const response = await fetch(resolveApiUrl(path))\n\n  return parseJsonResponse<T>(response)\n}\n\nexport async function postJson<T>(\n  path: `/${string}`,\n  body?: unknown,\n): Promise<T> {\n  const response = await fetch(resolveApiUrl(path), {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n    },\n    body: body === undefined ? undefined : JSON.stringify(body),\n  })\n\n  return parseJsonResponse<T>(response)\n}\n", "command": "/bin/zsh -lc \"sed -n '1,220p' frontend/src/api/client.ts\"", "exit_code": 0, "id": "item_46", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "run_id": "852e59ae-7e3c-580a-9c17-7f38e0f42b62", "timestamp": "2026-04-02T20:38:38.183271-07:00"}, "run_id": "852e59ae-7e3c-580a-9c17-7f38e0f42b62", "status": "completed", "timestamp": "2026-04-02T20:38:38.183271-07:00"}
