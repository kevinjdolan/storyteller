-header');\nawait page.evaluate(() => { document.querySelector('.finalize-stage__experience')?.scrollIntoView({ block: 'start' }); });\nawait new Promise((resolve) => setTimeout(resolve, 200));\nconst clip = await page.evaluate(() => {\n  const element = document.querySelector('.finalize-stage__experience');\n  if (\"'!element) {\n    return null;\n  }\n  const rect = element.getBoundingClientRect();\n  return { x: Math.max(rect.x, 0), y: Math.max(rect.y, 0), width: rect.width, height: rect.height };\n});\nif (!clip) {\n  throw new Error('\"'Finalize experience panel not found.');\n}\nawait page.screenshot({ path: desktopPath, clip });\nawait browser.close();\nconsole.log(JSON.stringify({ desktopPath }));\nEOF\"", "exit_code": 0, "id": "item_142", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "run_id": "852e59ae-7e3c-580a-9c17-7f38e0f42b62", "timestamp": "2026-04-02T20:56:52.193149-07:00"}, "run_id": "852e59ae-7e3c-580a-9c17-7f38e0f42b62", "status": "completed", "timestamp": "2026-04-02T20:56:52.193149-07:00"}
