dtime_guidelines.py:167:        \"violence_guardrail_included\": \"Violence avoidance\" in prompt,\nbackend/tests/test_bedtime_guidelines.py:168:        \"emotional_repair_included\": \"Emotional repair\" in prompt,\nbackend/tests/test_bedtime_guidelines.py:169:        \"stage_focus_included\": f\"Stage focus for {stage}\" in prompt,\nbackend/tests/test_bedtime_guidelines.py:172:            in prompt\nbackend/tests/test_bedtime_guidelines.py:179:def test_eval_prompt_context_rejects_unsupported_bedtime_preset_key() -> None:\nbackend/tests/test_beat_sheet_generation_service.py:266:    assert model_output[\"prompt_version\"] == \"beat_sheet_generation.v2\"\nbackend/tests/test_pitch_generation_service.py:203:    assert model_output[\"prompt_version\"] == \"pitch_generation.v3\"\nbackend/tests/test_brief_normalization_adapter.py:10:    render_brief_normalization_prompt,\nbackend/tests/test_brief_normalization_adapter.py:37:def test_render_brief_normalization_prompt_includes_structured_rules_and_context() -> None:\nbackend/tests/test_brief_normalization_adapter.py:38:    prompt = render_brief_normalization_prompt(_build_context())\nbackend/tests/test_brief_normalization_adapter.py:40:    assert \"structured planning preferences\" in prompt\nbackend/tests/test_brief_normalization_adapter.py:41:    assert \"bedtime_safety_concerns\" in prompt\nbackend/tests/test_brief_normalization_adapter.py:42:    assert '\"tone_label\": \"Hushed Wonder\"' in prompt\nbackend/tests/test_brief_normalization_adapter.py:43:    assert \"bring each light home before the harbor sleeps\" in prompt\nbackend/tests/test_brief_normalization_adapter.py:131:    assert result.invocation.prompt_version == BRIEF_NORMALIZATION_PROMPT_VERSION\nbackend/app/services/sessions.py:14:    CompositionJob,\nbackend/app/services/sessions.py:2894:        stmt = select(CompositionJob).where(\nbackend/app/services/sessions.py:2895:            CompositionJob.session_id == session_id,\nbackend/app/services/sessions.py:28