_bundle,\n)\nfrom app.models.continuity import (\n    ContinuityBibleData,\n    ContinuityBibleView,\n    ContinuityFact,\n    ContinuityFactCategory,\n)\nfrom app.models.events import (\n    AIOutputKind,\n    AIOutputRecordedEventPayload,\n    AudioProgressEventPayload,\n    ChatIntentParsedEventPayload,\n    ChatMessageRecordedEventPayload,\n    ChatMessageRole,\n    CompositionProgressEventPayload,\n    EventActorType,\n    EventPayload,\n    SelectionKind,\n    SelectionRecordedEventPayload,\n    SessionCreatedEventPayload,\n    SessionEventActor,\n    SessionEventType,\n    SessionEventView,\n    SessionHistoryView,\n    UIActionRecordedEventPayload,\n    UserEditRecordedEventPayload,\n    UserEditTargetKind,\n    WorkflowStageChangedEventPayload,\n    parse_event_payload,\n    serialize_event_payload,\n)\nfrom app.models.intent_parser import (\n    EXPLICIT_CHAT_COMMAND_MODEL_ID,\n    EXPLICIT_CHAT_COMMAND_PROMPT_VERSION,\n    INTENT_PARSER_PROMPT_VERSION,\n    INTENT_PARSER_SCHEMA_VERSION,\n    ExplicitChatCommandId,\n    ExplicitChatCommandRequest,\n    ExplicitChatCommandSource,\n    IntentParserCandidateAction,\n    IntentParserCandidateActionBatch,\n    IntentParserInvocation,\n    IntentParserInvocationResult,\n    IntentParserPromptContext,\n    IntentParserStageContext,\n    IntentParserStatus,\n    IntentParserStructuredOutput,\n    ParseChatIntentRequest,\n    ParsedChatIntentResponse,\n)\nfrom app.models.pitch_generation import (\n    PITCH_GENERATION_PROMPT_VERSION,\n    PITCH_GENERATION_SCHEMA_VERSION,\n    ExistingSelectedPitchContext,\n    GeneratedPitchCandidate,\n    PitchBatchEvaluation,\n    PitchBatchEvaluationCriterion,\n    PitchGenerationInvocation,\n    PitchGenerationInvocationResult,\n    PitchGenerationPromptContext,\n    PitchGenerationResult,\n    PitchGenerationStructuredOutput,\n    normalize_optional_pitch_text,\n)\nfrom app.models.realtime import (\n    ChatContentFormat,\n    ChatMessageEventPayload,\n    ChatMessageRealtimeEvent,\n    CompositionChunkEventPayload,\n    CompositionChunkKind,\n    CompositionChunkRealtimeEvent,\n    ErrorNotificationEventPayload,\n    ErrorNotificationRealtimeEvent,\n    ErrorSeverity,\n    JobKind,\n    JobProgressEventPayload,\n    JobProgressRealtimeEvent,\n    JobStatusEventPayload,\n    JobStatusRealtimeEvent,\n    RealtimeDeliveryMode,\n    RealtimeEventType,\n    RealtimeJobStatus,\n    RealtimeReplayStrategy,\n    SessionRealtimeEvent,\n    SessionSubscriptionAck,\n    SessionSubscriptionRequest,\n    UIActionEchoEventPayload,\n    UIActionEchoRealtimeEvent,\n    UIActionEchoResult,\n    WorkflowStageChangedRealtimeEvent,\n    build_session_channel_name,\n    get_realtime_contract_schema_bundle,\n)\nfrom app.models.session import (\n    AudioJobView,\n    BeatSheetBeatView,\n    BeatSheetEditView,\n    BeatSheetView,\n    CharacterProfileView,\n    CharacterSheetBatchView,\n    CharacterSheetView,\n    CompositionJobView,\n    ConversationMemorySnapshotView,\n    ConversationMemorySummaryData,\n    ConversationMemoryWorkflow,\n    CreateSessionRequest,\n    EditSessionBeatSheetBeatRequest,\n    EditSessionBeatSheetRequest,\n    EditSessionStoryOutlineCardRequest,\n    ExportAssetView,\n    GenerateSessionBeatSheetRequest,\n    GenerateSessionCharacterSheetsRequest,\n    GenerateSessionPitchesRequest,\n    PitchBatchView,\n    PitchView,\n    PlanArtifactRefView,\n    PlanRevisionView,\n    RecentSessionSummary,\n    RecordSessionUIActionRequest,\n    RefineSessionBeatSheetRequest,\n    RefineSessionCharacterSheetRequest,\n    RefineSessionPitchRequest,\n    RestoreSessionPlanRevisionRequest,\n    SaveSessionStoryBriefRequest,\n    SaveSessionStoryOutlineRequest,\n    SaveSessionStorySetupRequest,\n    SelectSessionBeatSheetRequest,\n    SelectSessionCharacterSheetRequest,\n    SelectSessionGenreRequest,\n    SelectSessionPitchRequest,\n    SelectSessionToneRequest,\n    SessionAssetView,\n    SessionBeatSheetGenerationResponse,\n    SessionBeatSh