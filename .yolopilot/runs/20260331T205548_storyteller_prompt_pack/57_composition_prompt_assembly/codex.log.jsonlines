nd/app/services/session_hydration.py:880:    refinement_metadata = row.character_data.get(\"refinement\")\nbackend/app/services/session_hydration.py:861:    if not isinstance(getattr(row, \"character_data\", None), Mapping):\nbackend/app/services/session_hydration.py:864:    candidate = row.character_data.get(\"candidate\")\nbackend/app/services/session_hydration.py:869:    if not isinstance(getattr(row, \"character_data\", None), Mapping):\nbackend/app/services/session_hydration.py:872:    batch_metadata = row.character_data.get(\"batch_metadata\")\nbackend/app/services/session_hydration.py:877:    if not isinstance(getattr(row, \"character_data\", None), Mapping):\nbackend/app/services/session_hydration.py:880:    refinement_metadata = row.character_data.get(\"refinement\")\nbackend/app/models/__init__.py:28:    GeneratedBeatSheetBeat,\nbackend/app/models/__init__.py:60:    ExistingCharacterSheetContext,\nbackend/app/models/__init__.py:176:    ExistingSelectedPitchContext,\nbackend/app/models/__init__.py:354:    \"ExistingSelectedPitchContext\",\nbackend/app/models/__init__.py:421:    \"ExistingCharacterSheetContext\",\nbackend/app/models/__init__.py:434:    \"GeneratedBeatSheetBeat\",\nbackend/app/models/pitch_generation.py:25:class ExistingSelectedPitchContext(BaseModel):\nbackend/app/models/pitch_generation.py:82:    selected_pitch: ExistingSelectedPitchContext | None = None\nbackend/app/db/models.py:506:    character_data: Mapped[dict[str, Any] | list[Any] | None] = mapped_column(JSON)\nbackend/app/models/character_generation.py:12:from app.models.pitch_generation import ExistingSelectedPitchContext\nbackend/app/models/character_generation.py:72:class ExistingCharacterSheetContext(BaseModel):\nbackend/app/models/character_generation.py:153:    selected_pitch: ExistingSelectedPitchContext\nbackend/app/models/character_generation.py:154:    existing_character_sheet: ExistingCharacterSheetContext | None = None\nbackend/app/models/beat_sheet_generation.py:12:from 