{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Started", "message": "in progress: /bin/zsh -lc \"./scripts/dev-compose.sh run --rm browser node --input-type=module - <<'JS'\nimport fs from 'node:fs/promises'\nimport path from 'node:path'\nimport puppeteer from 'puppeteer'\n\nconst sessionId = '16b30070-2006-457f-bcae-f9ca147cff40'\nconst workspaceUrl = \"'`http://frontend:8566/sessions/${sessionId}`\nconst artifactDir = '\"'/workspace/.artifacts/webapp-qa'\n\nasync function ensureDir(filePath) {\n  await fs.mkdir(path.dirname(filePath), { recursive: true })\n}\n\nasync function readText(page, selector) {\n  return page.\"'$eval(selector, (element) => element.textContent?.trim() ?? '\"'')\n}\n\nconst browser = await puppeteer.launch({\n  args: ['--no-sandbox', '--disable-setuid-sandbox'],\n  headless: true,\n})\n\ntry {\n  const page = await browser.newPage()\n  page.setDefaultTimeout(20000)\n  await page.setViewport({ width: 1440, height: 960 })\n  await page.goto(workspaceUrl, { waitUntil: 'networkidle2' })\n  await page.waitForSelector(\\\"[data-testid='workspace-route']\\\")\n  await page.waitForSelector('.plan-revision-panel')\n\n  await page.waitForFunction(() => {\n    const badges = Array.from(document.querySelectorAll('.plan-revision-panel__badges .badge'))\n    return badges.some((badge) => badge.textContent?.includes('Revision 2'))\n  })\n\n  await page.waitForFunction(() => {\n    const firstArtifact = document.querySelector('.plan-revision-panel__artifact-list .plan-revision-panel__artifact span')\n    return firstArtifact?.textContent?.includes('Otter Bell Moonpath') ?? false\n  })\n\n  const beforePath = path.join(artifactDir, 'revision-history-before.png')\n  await ensureDir(beforePath)\n  await page.screenshot({ path: beforePath, fullPage: false })\n\n  const beforeArtifact = await readText(page, '.plan-revision-panel__artifact-list .plan-revision-panel__artifact span')\n  if (\"'!beforeArtifact.includes('\"'Otter Bell Moonpath')) {\n    throw new Error(\"'`Unexpected pre-restore artifact label: ${beforeArtifact}`)\n  }\n\n  await page.click('\"'.plan-revision-panel__history-item button')\n\n  await page.waitForFunction(() => {\n    const badges = Array.from(document.querySelectorAll('.plan-revision-panel__badges .badge'))\n    return badges.some((badge) => badge.textContent?.includes('Revision 3'))\n  })\n\n  await page.waitForFunction(() => {\n    const firstArtifact = document.querySelector('.plan-revision-panel__artifact-list .plan-revision-panel__artifact span')\n    return firstArtifact?.textContent?.includes('Lantern Harbor Promise') ?? false\n  })\n\n  await page.waitForFunction(() => document.body?.innerText.includes('Restored saved plan'))\n\n  const afterPath = path.join(artifactDir, 'revision-history-after.png')\n  await ensureDir(afterPath)\n  await page.screenshot({ path: afterPath, fullPage: false })\n\n  const afterArtifact = await readText(page, '.plan-revision-panel__artifact-list .plan-revision-panel__artifact span')\n  if (\"'!afterArtifact.includes('\"'Lantern Harbor Promise')) {\n    throw new Error(\"'`Unexpected post-restore artifact label: ${afterArtifact}`)\n  }\n\n  console.log(JSON.stringify({ sessionId, beforeArtifact, afterArtifact, beforePath, afterPath }, null, 2))\n} finally {\n  await browser.close()\n}\nJS'", "raw_event": {"item": {"aggregated_output": "", "command": "/bin/zsh -lc \"./scripts/dev-compose.sh run --rm browser node --input-type=module - <<'JS'\nimport fs from 'node:fs/promises'\nimport path from 'node:path'\nimport puppeteer from 'puppeteer'\n\nconst sessionId = '16b30070-2006-457f-bcae-f9ca147cff40'\nconst workspaceUrl = \"'`http://frontend:8566/sessions/${sessionId}`\nconst artifactDir = '\"'/workspace/.artifacts/webapp-qa'\n\nasync function ensureDir(filePath) {\n  await fs.mkdir(path.dirname(filePath), { recursive: true })\n}\n\nasync function readText(page, selector) {\n  return page.\"'$eval(selector, (element) => element.textContent?.tri