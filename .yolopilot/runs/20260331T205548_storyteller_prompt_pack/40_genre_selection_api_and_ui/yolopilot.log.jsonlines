                   </Button>\n                    </div>\n                  }\n                  leading={(genre.sort_order + 1).toString().padStart(2, '0')}\n                  meta={\n                    <>\n                      {selected ? (\n                        <Badge tone=\"success\">Current</Badge>\n                      ) : (\n                        <Badge tone=\"neutral\">Available</Badge>\n                      )}\n                      {tensionCeiling != null ? (\n                        <Badge tone=\"brand\">{tensionCeiling}</Badge>\n                      ) : null}\n                    </>\n                  }\n                  selected={selected}\n                  title={genre.label}\n                >\n                  <dl className=\"genre-selection-card__facts\">\n                    <div>\n                      <dt>Arc</dt>\n                      <dd>\n                        {coreArc ?? 'Bedtime-safe arc guidance included.'}\n                      </dd>\n                    </div>\n                    <div>\n                      <dt>Safety note</dt>\n                      <dd>\n                        {genre.bedtime_safety_notes ??\n                          'Keep stakes gentle and land the ending in visible rest.'}\n                      </dd>\n                    </div>\n                  </dl>\n                </SelectionCard>\n              )\n            })}\n          </CardGrid>\n        ) : null}\n      </section>\n    </section>\n  )\n}\n", "command": "/bin/zsh -lc \"sed -n '240,420p' frontend/src/features/session/GenreSelectionStage.tsx\"", "exit_code": 0, "id": "item_221", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 414, "prompt_index": 41, "prompt_name": "40 \u2014 Genre Selection API and UI", "prompt_total": 100}, "timestap": "2026-04-01T18:53:07-07:00"}
