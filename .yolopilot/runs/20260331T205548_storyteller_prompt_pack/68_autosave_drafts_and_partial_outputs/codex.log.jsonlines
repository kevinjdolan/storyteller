{"type":"item.completed","item":{"id":"item_126","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,240p' backend/app/__main__.py\"","aggregated_output":"from __future__ import annotations\n\nimport uvicorn\n\nfrom app.settings import SettingsValidationError, get_settings\n\n\ndef main() -> None:\n    try:\n        settings = get_settings()\n    except SettingsValidationError as exc:\n        raise SystemExit(exc.format_for_cli()) from None\n\n    uvicorn.run(\n        \"app.main:app\",\n        host=settings.host,\n        port=settings.port,\n        reload=settings.reload,\n    )\n\n\nif __name__ == \"__main__\":\n    main()\n","exit_code":0,"status":"completed"}}
