tion=\\\"Choose the emotional texture and bedtime-safety posture for the session.\\\",\\n        invalidates_on_edit=(\\n            WorkflowStage.BRIEF,\\n            WorkflowStage.PITCHES,\\n            WorkflowStage.CHARACTERS,\\n            WorkflowStage.BEATS,\\n            WorkflowStage.COMPOSITION,\\n            WorkflowStage.AUDIO,\\n            WorkflowStage.FINALIZE,\\n        ),\\n    ),\\n    WorkflowStageDefinition(\\n        id=WorkflowStage.BRIEF,\\n        label=\\\"Story brief\\\",\\n        description=(\\n            \\\"Capture the user's free-form idea and any normalized planning summary derived from it.\\\"\\n        ),\\n        invalidates_on_edit=(\\n            WorkflowStage.PITCHES,\\n            WorkflowStage.CHARACTERS,\\n            WorkflowStage.BEATS,\\n            WorkflowStage.COMPOSITION,\\n            WorkflowStage.AUDIO,\\n            WorkflowStage.FINALIZE,\\n        ),\\n    ),\\n    WorkflowStageDefinition(\\n        id=WorkflowStage.PITCHES,\\n        label=\\\"Pitches\\\",\\n        description=\\\"Generate, compare, refine, and accept candidate story directions.\\\",\\n        invalidates_on_edit=(\\n            WorkflowStage.CHARACTERS,\\n            WorkflowStage.BEATS,\\n            WorkflowStage.COMPOSITION,\\n            WorkflowStage.AUDIO,\\n            WorkflowStage.FINALIZE,\\n        ),\\n    ),\\n    WorkflowStageDefinition(\\n        id=WorkflowStage.CHARACTERS,\\n        label=\\\"Characters\\\",\\n        description=(\\n            \\\"Define the accepted character sheet that later planning and writing will reference.\\\"\\n        ),\\n        invalidates_on_edit=(\\n            WorkflowStage.BEATS,\\n            WorkflowStage.COMPOSITION,\\n            WorkflowStage.AUDIO,\\n            WorkflowStage.FINALIZE,\\n        ),\\n    ),\\n    WorkflowStageDefinition(\\n        id=WorkflowStage.BEATS,\\n        label=\\\"Beat sheet\\\",\\n        description=\\\"Store the accepted Save-the-Cat beat sheet for the 