n\",\"exit_code\":0,\"status\":\"completed\"}}\nprompts/13-storage-abstraction-and-buckets.yolopilot.md:345:    prompts/89-full-journey-e2e-test.md\nprompts/13-storage-abstraction-and-buckets.yolopilot.md:374:    prompts/69-composition-loop-e2e-test.md\nprompts/13-storage-abstraction-and-buckets.yolopilot.md:398:    prompts/59-planning-funnel-e2e-test.md\nprompts/18-postgres-job-runner-skeleton.yolopilot.md:214:    ./prompts/89-full-journey-e2e-test.md\nprompts/18-postgres-job-runner-skeleton.yolopilot.md:247:    ./prompts/69-composition-loop-e2e-test.md\nprompts/18-postgres-job-runner-skeleton.yolopilot.md:274:    ./prompts/59-planning-funnel-e2e-test.md\nprompts/18-postgres-job-runner-skeleton.yolopilot.md:527:    ./prompts/00-project-charter.codex.jsonlines:9:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_3\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"rg --files -g 'README.md' -g 'docs/**' -g 'prompts/**' -g 'AGENTS.md'\\\"\",\"aggregated_output\":\"prompts/00-project-charter.codex.jsonlines\\nprompts/36-conversation-memory-summaries.md\\nprompts/99-release-checklist-and-future-roadmap.md\\nprompts/44-pitch-generation-pipeline.md\\nprompts/42-story-setup-brief-form.md\\nprompts/07-developer-bootstrap-scripts.md\\nprompts/20-frontend-app-shell-and-routing.md\\nprompts/52-bedtime-safety-and-content-guidelines.md\\nprompts/02-vite-react-scaffold.md\\nprompts/78-download-endpoints-and-object-access.md\\nprompts/01-monorepo-skeleton.md\\nprompts/13-storage-abstraction-and-buckets.md\\nprompts/48-save-the-cat-beat-sheet-generation.md\\nprompts/95-ci-pipeline.md\\nprompts/46-character-sheet-generation.md\\nprompts/83-artifact-packaging-and-links.md\\nprompts/11-postgres-schema-and-migrations.md\\nprompts/06-gitignore-and-secrets-hygiene.md\\nprompts/65-interrupt-and-redirect-composition.md\\nprompts/30-chat-to-ui-action-schema.md\\nprompts/37-agent-tool-registry.md\\nprompts/54-chapter-scene-card-editor.md\\nprompts/62-composition-streaming-even