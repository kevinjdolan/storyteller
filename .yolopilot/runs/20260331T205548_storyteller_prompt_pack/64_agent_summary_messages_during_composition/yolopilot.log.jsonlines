{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Started", "message": "in progress: /bin/zsh -lc \"python - <<'PY'\nimport json, time, urllib.request\n\nBASE='http://127.0.0.1:8565'\nheaders={'Content-Type':'application/json'}\n\ndef post(path, payload):\n    data=json.dumps(payload).encode('utf-8')\n    req=urllib.request.Request(BASE+path, data=data, headers=headers, method='POST')\n    with urllib.request.urlopen(req, timeout=30) as resp:\n        body=resp.read().decode('utf-8')\n        return resp.status, json.loads(body)\n\ndef get(path):\n    with urllib.request.urlopen(BASE+path, timeout=30) as resp:\n        body=resp.read().decode('utf-8')\n        return resp.status, json.loads(body)\n\nstatus, created = post('/api/v1/sessions', {'working_title':'Prompt 64 Visual QA'})\nprint('create', status)\nsession_id = created['id']\nsteps = [\n    ('genre', f'/api/v1/sessions/{session_id}/selections/genre', {'genre_slug':'quest-fantasy','origin':'workspace'}),\n    ('tone', f'/api/v1/sessions/{session_id}/selections/tone', {'tone_profile_slug':'hushed-wonder','origin':'workspace'}),\n    ('brief', f'/api/v1/sessions/{session_id}/story-brief', {'raw_brief':'A harbor fox follows a drifting bell across moonlit water and brings the night back to calm.','origin':'workspace'}),\n]\nfor label, path, payload in steps:\n    status, data = post(path, payload)\n    print(label, status)\n\nstatus, pitch_payload = post(f'/api/v1/sessions/{session_id}/pitches/generate', {'candidate_count': 3, 'origin':'workspace'})\nprint('pitches', status)\nfirst_pitch_id = pitch_payload['snapshot']['pitch_batches'][0]['pitches'][0]['id']\nstatus, _ = post(f'/api/v1/sessions/{session_id}/selections/pitch', {'pitch_id': first_pitch_id, 'origin':'workspace'})\nprint('select pitch', status)\nstatus, character_payload = post(f'/api/v1/sessions/{session_id}/characters/generate', {'candidate_count': 2, 'origin':'workspace'})\nprint('characters', status)\nfirst_character_id = character_payload['snapshot']['character_sheet_batches'][0]['character_sheets'][0]['id']\nstatus, _ = post(f'/api/v1/sessions/{session_id}/selections/character-sheet', {'character_sheet_id': first_character_id, 'origin':'workspace'})\nprint('select character', status)\nstatus, beat_payload = post(f'/api/v1/sessions/{session_id}/beats/generate', {'origin':'workspace'})\nprint('beats', status)\nfirst_beat_id = beat_payload['snapshot']['beat_sheet_revisions'][0]['id']\nstatus, _ = post(f'/api/v1/sessions/{session_id}/selections/beat-sheet', {'beat_sheet_id': first_beat_id, 'origin':'workspace'})\nprint('select beat', status)\nstatus, setup_payload = post(f'/api/v1/sessions/{session_id}/story-setup', {\n    'target_word_count': 1800,\n    'target_runtime_minutes': 12,\n    'chapter_count': 3,\n    'approximate_scene_count': 8,\n    'guidance_notes': 'Let each chapter land calmer than it began.',\n    'origin':'workspace',\n})\nprint('story setup', status)\nstatus, start_payload = post(f'/api/v1/sessions/{session_id}/composition/start', {'mode':'fresh','origin':'workspace'})\nprint('start composition', status)\nfor attempt in range(30):\n    status, hydrate = get(f'/api/v1/sessions/{session_id}/hydrate')\n    history = hydrate['recent_history']['events']\n    summaries = [\n        event for event in history\n        if event['event_type'] == 'chat.message.recorded'\n        and event.get('payload', {}).get('source') == 'composition_summary'\n    ]\n    if summaries:\n        print('session_id', session_id)\n        print('summary_count', len(summaries))\n        print('latest_summary', summaries[-1]['payload']['content_preview'])\n        break\n    time.sleep(2)\nelse:\n    print('session_id', session_id)\n    print('summary_count', 0)\nPY\"", "raw_event": {"item": {"aggregated_output": "", "command": "/bin/zsh -lc \"python - <<'PY'\nimport json, time, urllib.request\n\nBASE='http://127.0.0.1:8565'\nheaders={'Content-Type':'application/json'}\n\ndef post(path, payload):\n    d