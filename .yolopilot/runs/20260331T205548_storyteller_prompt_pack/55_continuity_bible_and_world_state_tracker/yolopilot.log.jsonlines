age_details = {\n        WorkflowStage.GENRE: ('completed', 'Selected genre: Quest Fantasy.'),\n        WorkflowStage.TONE: ('completed', 'Selected tone profile: Hushed Wonder.'),\n        WorkflowStage.BRIEF: ('completed', 'Accepted normalized brief.'),\n        WorkflowStage.PITCHES: ('completed', 'Accepted the harbor lantern pitch.'),\n        WorkflowStage.CHARACTERS: ('completed', 'Locked the character sheet.'),\n        WorkflowStage.BEATS: ('in_progress', 'Midpoint needs one more bedtime-soft pass.'),\n    }\n    for stage_state in story_session.workflow_stage_states:\n        if stage_state.stage in stage_details:\n            status, detail = stage_details[stage_state.stage]\n            stage_state.status = WorkflowStageState(status)\n            stage_state.detail = detail\n            if status == 'completed':\n                stage_state.completed_at = now\n            elif status == 'in_progress':\n                stage_state.started_at = now\n\n    brief = StoryBrief(\n        session_id=snapshot.id,\n        revision_number=1,\n        story_idea='A child follows floating lanterns across a harbor and helps a shy otter guardian bring them home.',\n        desired_themes='Belonging, gentle courage, and a calm return home.',\n        key_images='Lanterns on dark water, otter paws, and moonlit docks.',\n        audience_notes='For an early-elementary read-aloud that stays cozy instead of suspenseful.',\n        must_have_elements='End with every lantern home and the harbor quiet again.',\n        raw_brief='A child follows floating lanterns across a harbor and helps a shy otter guardian bring them home.',\n        normalized_summary='A harbor bedtime quest with a calm lantern-by-lantern reunion.',\n        normalized_preferences={\n            'setting': 'Juniper Harbor',\n            'constraint_notes': ['End with the harbor settled and everyone tucked in.'],\n            'bedtime_safety_concerns': ['Keep every surprise quickly reassuring.'],\n            'candidate_motifs': ['floating lanterns', 'moonlit docks'],\n        },\n        planning_notes='Keep the midpoint more awestruck than tense.',\n        is_active=True,\n        accepted_at=now,\n    )\n    session.add(brief)\n    session.flush()\n\n    pitch = Pitch(\n        session_id=snapshot.id,\n        story_brief_id=brief.id,\n        generation_key='pitch-batch-1',\n        pitch_index=0,\n        title='Lanterns Over Juniper Lake',\n        logline='A child follows floating lanterns across a harbor and helps a shy otter guardian bring them home.',\n        summary='The harbor will not settle until the final lantern finds its right doorstep.',\n        bedtime_notes='Let wonder lead, and keep every turn buffered by company and light.',\n        is_selected=True,\n        accepted_at=now,\n    )\n    session.add(pitch)\n    session.flush()\n\n    character_sheet = CharacterSheet(\n        session_id=snapshot.id,\n        pitch_id=pitch.id,\n        revision_number=12,\n        title='Juniper Keeper Cast',\n        protagonist_name='Mira',\n        summary='A child and a shy otter guardian carry the story with a compact, bedtime-safe support cast.',\n        character_data={\n            'candidate': {\n                'protagonist': {\n                    'name': 'Mira',\n                    'role': 'Curious harbor child',\n                    'goal': 'Help every drifting lantern get home before the harbor sleeps.',\n                    'flaw': 'She worries that one wrong step will disappoint everyone.',\n                    'comfort_trait': 'She counts breaths while tracing lantern light on the dock.',\n                    'relationships': ['Trusted by the otter guardian'],\n                    'visual_anchors': ['knit night coat', 'small harbor satchel'],\n                },\n                'supporting_cast': [\n                    {\n                        'name': 'Pip',\n                        'role': 'Otter guardian',\n                        'goal': 'Guide each lantern to the right doorstep.',\n                        'flaw': 'He hesitates when he thinks he has let someone down.',\n                        'comfort_trait': 'He hums before speaking when the night feels uncertain.',\n                        'relationships': ['Mira learns courage by helping Pip'],\n                        'visual_anchors': ['lantern pole', 'river-stone pendant'],\n                    }\n                ],\n                'visual_motifs': ['floating lanterns', 'moonlit docks', 'otter paws'],\n            }\n        },\n        is_selected=True,\n        accepted_at=now,\n    )\n    session.add(character_sheet)\n    session.flush()\n\n    beat_sheet = BeatSheet(\n        session_id=snapshot.id,\n        character_sheet_id=character_sheet.id,\n        revision_number=3,\n        summary='A harbor Save-the-Cat arc that lands in calm belonging.',\n        bedtime_notes='Keep each turn soft enough for bedtime, especially around the midpoint and all-is-lost beats.',\n        beats={\n            'bedtime_goal': 'Land in a visibly sleepy ending.',\n            'beats': [\n                {'key': 'opening_image', 'label': 'Opening Image', 'order': 1, 'summary': 'The harbor glows softly as Mira checks the last lanterns.'},\n                {'key': 'midpoint', 'label': 'Midpoint', 'order': 9, 'summary': 'The hidden lantern map opens and shows the last route home.'},\n                {'key': 'all_is_lost', 'label': 'All Is Lost', 'order': 11, 'summary': 'One lantern drifts off course and Mira thinks she has failed.'},\n            ],\n        },\n        is_selected=True,\n        accepted_at=now,\n    )\n    session.add(beat_sheet)\n    session.flush()\n\n    story_setup = StorySetup(\n        session_id=snapshot.id,\n        beat_sheet_id=beat_sheet.id,\n        revision_number=1,\n        target_word_count=1800,\n        target_runtime_minutes=12,\n        chapter_count=3,\n        approximate_scene_count=9,\n        chapter_style='three gentle chapters',\n        guidance_notes='Let each chapter end on a calmer image than it began.',\n        is_selected=False,\n    )\n    session.add(story_setup)\n    session.flush()\n\n    continuity_bible = ContinuityBible(\n        session_id=snapshot.id,\n        revision_number=3,\n        source_stage=WorkflowStage.BEATS,\n        source_summary='Accepted beat sheet: Harbor lantern return.',\n        summary_text='Mira anchors the current story in Juniper Harbor. Protect the promise of helping every lantern home before sleep.',\n        summary_data={\n            'schema_version': 1,\n            'facts': [\n                {'key': 'character:mira:1', 'category': 'character', 'title': 'Mira', 'detail': 'Curious harbor child who needs to trust that steady help is enough.', 'source_stage': 'characters', 'source_label': 'Juniper Keeper Cast'},\n                {'key': 'location:juniper-harbor:1', 'category': 'location', 'title': 'Juniper Harbor', 'detail': 'Use the harbor docks and lantern routes as the default world anchor.', 'source_stage': 'brief', 'source_label': 'Story brief'},\n                {'key': 'promise:lanterns-home:1', 'category': 'promise', 'title': 'Safe return promise', 'detail': 'Every drifting lantern reaches home before the harbor fully sleeps.', 'source_stage': 'beats', 'source_label': 'Revision 3'},\n                {'key': 'voice:guardrail:1', 'category': 'voice_constraint', 'title': 'Bedtime guardrail', 'detail': 'Keep every surprise luminous, buffered by company, and quick to settle.', 'source_stage': 'tone', 'source_label': 'Hushed Wonder'},\n                {'key': 'thread:midpoint:1', 'category': 'unresolved_thread', 'title': 'Midpoint reveal', 'detail': 'The hidden lantern map still needs a gentle explanation before the finale.', 'source_stage': 'beats', 'source_label': 'Revision 3'},\n                {'key': 'locked:chapter-1:1', 'category': 'locked_detail', 'title': 'Chapter 1: Lantern Wake', 'detail': 'Mira has already promi