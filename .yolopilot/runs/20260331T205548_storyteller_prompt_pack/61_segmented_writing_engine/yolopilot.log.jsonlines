lize a composition job without completed text\"\n  1275\t            )\n  1276\t        return \"\\n\\n\".join(\n  1277\t            segment.strip() for segment in completed_segments if segment.strip()\n  1278\t        ).strip()\n  1279\t\n  1280\t    def _replace_prior_segment_revision(self, segment: CompositionSegment) -> None:\n  1281\t        stmt = select(CompositionSegment).where(\n  1282\t            CompositionSegment.session_id == segment.session_id,\n  1283\t            CompositionSegment.segment_index == segment.segment_index,\n  1284\t            CompositionSegment.id != segment.id,\n  1285\t            CompositionSegment.superseded_by_segment_id.is_(None),\n  1286\t        )\n  1287\t        for row in self._session.execute(stmt).scalars().all():\n  1288\t            row.superseded_by_segment_id = segment.id\n  1289\t\n  1290\t    def _save_segment_asset(\n  1291\t        self,\n  1292\t        *,\n  1293\t        job: CompositionJob,\n  1294\t        segment: CompositionSegment,\n  1295\t        storage_location,\n  1296\t        draft: GeneratedCompositionSegmentDraft,\n  1297\t    ) -> None:\n  1298\t        object_metadata = self._storage().fetch_object_metadata(storage_location)\n  1299\t        self._supersede_segment_assets(job.session_id, segment.segment_index)\n  1300\t        self._assets.save_asset_record(\n  1301\t            session_id=job.session_id,\n  1302\t            asset_kind=AssetKind.COMPOSITION_SEGMENT,\n  1303\t            storage_bucket=storage_location.bucket,\n  1304\t            object_path=storage_location.key,\n  1305\t            mime_type=\"text/markdown\",\n  1306\t            status=AssetStatus.READY,\n  1307\t            composition_job_id=job.id,\n  1308\t            composition_segment_id=segment.id,\n  1309\t            segment_index=segment.segment_index,\n  1310\t            byte_size=object_metadata.size_bytes,\n  1311\t            metadata_json={\n  1312\t                \"orchestration_version\": \"composition_job.v1\",\n  1313\t                \"generation_source\": draft.source,\n  1314\t                \"carryover_summary\": segment.accepted_summary,\n  1315\t                \"evaluation\": [\n  1316\t                    {\n  1317\t                        \"name\": criterion.name,\n  1318\t                        \"passed\": criterion.passed,\n  1319\t                        \"measured_value\": criterion.measured_value,\n  1320\t                        \"detail\": criterion.detail,\n  1321\t                    }\n  1322\t                    for criterion in draft.evaluation.criteria\n  1323\t                ],\n  1324\t            },\n  1325\t        )\n  1326\t\n  1327\t    def _record_segment_model_usage(\n  1328\t        self,\n  1329\t        *,\n  1330\t        session_id: str,\n  1331\t        draft: GeneratedCompositionSegmentDraft,\n  1332\t        elapsed_ms: int,\n  1333\t    ) -> None:\n  1334\t        if draft.model_id is None:\n  1335\t            return\n  1336\t\n  1337\t        SessionModelUsageService(self._session).record_model_call(\n  1338\t            context=ModelUsageContext(\n  1339\t                session_id=session_id,\n  1340\t                usage_bucket=ModelUsageBucket.COMPOSITION,\n  1341\t                workflow_stage=WorkflowStage.COMPOSITION,\n  1342\t                purpose=\"segmented_composition_segment\",\n  1343\t                model_id=draft.model_id,\n  1344\t                prompt_version=draft.prompt_version,\n  1345\t            ),\n  1346\t            elapsed_ms=elapsed_ms,\n  1347\t            outcome=_resolve_model_usage_outcome(\n  1348\t                source=draft.source,\n  1349\t                raw_response=draft.raw_response,\n  1350\t            ),\n  1351\t            raw_response=draft.raw_response,\n  1352\t            error_message=_extract_model_usage_error_message(draft.raw_response),\n  1353\t        )\n  1354\t\n  1355\t    def _supersede_segment_assets(self, session_id: str, segment_index: int) -> None:\n  1356\t        stmt = select(SessionAsset).where(\n  1357\t            SessionAsset.session_id == session_id,\n  1358\t            SessionAsset.asset_kind == AssetKind.COMPOSITION_SEGMENT,\n  1359\t            SessionAsset.segment_index == segment_index,\n  1360\t            SessionAsset.status == AssetStatus.READY,\n  1361\t        )\n  1362\t        for asset in self._session.execute(stmt).scalars().all():\n  1363\t            asset.status = AssetStatus.SUPERSEDED\n  1364\t            asset.superseded_at = utc_now()\n  1365\t\n  1366\t    def _next_segment_revision(self, session_id: str, segment_index: int) -> int:\n  1367\t        stmt = (\n  1368\t            select(CompositionSegment)\n  1369\t            .where(\n  1370\t                CompositionSegment.session_id == session_id,\n  1371\t                CompositionSegment.segment_index == segment_index,\n  1372\t            )\n  1373\t            .order_by(CompositionSegment.revision_number.desc())\n  1374\t            .limit(1)\n  1375\t        )\n  1376\t        row = self._session.execute(stmt).scalar_one_or_none()\n  1377\t        return (row.revision_number if row is not None else 0) + 1\n  1378\t\n  1379\t    def _cancel_job_rows(self, job: CompositionJob, *, reason: str) -> None:\n  1380\t        normalized_reason = reason.strip()\n  1381\t        if not normalized_reason:\n  1382\t            raise ValueError(\"cancel reason must not be empty\")\n  1383\t\n  1384\t        job.status = JobStatus.CANCELLED\n  1385\t        job.stop_reason = normalized_reason\n  1386\t        job.completed_at = job.completed_at or utc_now()\n  1387\t        for segment in job.segments:\n  1388\t            if segment.status in {JobStatus.QUEUED, JobStatus.IN_PROGRESS, JobStatus.PAUSED}:\n  1389\t                segment.status = JobStatus.CANCELLED\n  1390\t\n  1391\t    def _supersede_story_assets(self, session_id: str) -> None:\n  1392\t        stmt = select(SessionAsset).where(\n  1393\t            SessionAsset.session_id == session_id,\n  1394\t            SessionAsset.asset_kind == AssetKind.STORY_TEXT,\n  1395\t            SessionAsset.status == AssetStatus.READY,\n  1396\t        )\n  1397\t        for asset in self._session.execute(stmt).scalars().all():\n  1398\t            asset.status = AssetStatus.SUPERSEDED\n  1399\t            asset.superseded_at = utc_now()\n  1400\t\n  1401\t    def _enqueue_runtime_job(self, session_id: str, composition_job_id: str) -> None:\n  1402\t        if self._has_pending_runtime_job(composition_job_id):\n  1403\t            return\n  1404\t        self._jobs.enqueue_job(\n  1405\t            job_type=COMPOSITION_RUNTIME_JOB_TYPE,\n  1406\t            payload={\"composition_job_id\": composition_job_id},\n  1407\t            session_id=session_id,\n  1408\t        )\n  1409\t\n  1410\t    def _has_pending_runtime_job(self, composition_job_id: str) -> bool:\n  1411\t        stmt = select(BackgroundJob).where(\n  1412\t            BackgroundJob.job_type == COMPOSITION_RUNTIME_JOB_TYPE,\n  1413\t            BackgroundJob.status == JobStatus.QUEUED,\n  1414\t        )\n  1415\t        for row in self._session.execute(stmt).scalars().all():\n  1416\t            payload = row.payload if isinstance(row.payload, Mapping) else {}\n  1417\t            if payload.get(\"composition_job_id\") == composition_job_id:\n  1418\t                return True\n  1419\t        return False\n  1420\t\n  1421\t    def _storage(self) -> ObjectStorageService:\n  1422\t        if self._object_storage is None:\n  1423\t            self._object_storage = build_object_storage_service(get_settings())\n  1424\t        return self._object_storage\n  1425\t\n", "command": "/bin/zsh -lc \"nl -ba backend/app/services/composition_jobs.py | sed -n '1240,1425p'\"", "exit_code": 0, "id": "item_108", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 218, "prompt_index": 62, "prompt_name": "61 \u2014 Segmented 