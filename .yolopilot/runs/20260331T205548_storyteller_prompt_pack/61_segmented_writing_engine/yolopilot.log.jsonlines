n  1475\t    completed_segments = (latest_completed_segment_index - start_index) + 1\n  1476\t    return round((completed_segments / max(total_segments, 1)) * 100, 2)\n  1477\t\n  1478\t\n  1479\tdef _split_remaining_text(prefix: str, remaining_text: str) -> list[str]:\n  1480\t    if not remaining_text:\n  1481\t        return []\n  1482\t\n  1483\t    paragraphs = [paragraph for paragraph in remaining_text.split(\"\\n\\n\") if paragraph.strip()]\n  1484\t    chunks: list[str] = []\n  1485\t    for paragraph in paragraphs:\n  1486\t        if chunks:\n  1487\t            chunks.append(f\"\\n\\n{paragraph}\")\n  1488\t        else:\n  1489\t            chunks.append(paragraph if not prefix else paragraph)\n  1490\t    return chunks\n  1491\t\n  1492\t\n  1493\tdef _extract_last_sentence(text: str) -> str | None:\n  1494\t    sentences = [\n  1495\t        sentence.strip() for sentence in text.replace(\"\\n\", \" \").split(\".\") if sentence.strip()\n  1496\t    ]\n  1497\t    if not sentences:\n  1498\t        return None\n  1499\t    return sentences[-1]\n  1500\t\n  1501\t\n  1502\tdef _count_words(text: str | None) -> int:\n  1503\t    if text is None:\n  1504\t        return 0\n  1505\t    return len([part for part in text.split() if part.strip()])\n  1506\t\n  1507\t\n  1508\tdef _read_metadata(job: CompositionJob) -> dict[str, Any]:\n  1509\t    if isinstance(job.metadata_json, Mapping):\n  1510\t        return dict(job.metadata_json)\n  1511\t    return {}\n  1512\t\n  1513\t\n  1514\tdef _read_total_segments(job: CompositionJob) -> int:\n  1515\t    metadata = _read_metadata(job)\n  1516\t    total_segments = metadata.get(\"total_segments\")\n  1517\t    if isinstance(total_segments, int) and total_segments >= 1:\n  1518\t        return total_segments\n  1519\t    raise CompositionJobStateError(\n  1520\t        f\"composition job {job.id!r} is missing total_segments metadata\",\n  1521\t    )\n  1522\t\n  1523\t\n  1524\tdef _read_start_segment_index(job: CompositionJob) -> int:\n  1525\t    metadata = _read_metadata(job)\n  1526\t    start_segment_index = metadata.get(\"start_segment_index\")\n  1527\t    if isinstance(start_segment_index, int) and start_segment_index >= 1:\n  1528\t        return start_segment_index\n  1529\t    raise CompositionJobStateError(\n  1530\t        f\"composition job {job.id!r} is missing start_segment_index metadata\",\n  1531\t    )\n  1532\t\n  1533\t\n  1534\tdef _read_mapping(value: object, key: str | None = None) -> Mapping[str, Any]:\n  1535\t    candidate = value\n  1536\t    if key is not None and isinstance(value, Mapping):\n  1537\t        candidate = value.get(key)\n  1538\t    if isinstance(candidate, Mapping):\n  1539\t        return candidate\n  1540\t    return {}\n  1541\t\n  1542\t\n  1543\tdef _read_list(value: object, key: str) -> list[Any]:\n  1544\t    if not isinstance(value, Mapping):\n  1545\t        return []\n  1546\t    candidate = value.get(key)\n  1547\t    if isinstance(candidate, list):\n  1548\t        return candidate\n  1549\t    return []\n  1550\t\n  1551\t\n  1552\tdef _read_text(value: object, key: str) -> str | None:\n  1553\t    if not isinstance(value, Mapping):\n  1554\t        return None\n  1555\t    candidate = value.get(key)\n  1556\t    if candidate is None:\n  1557\t        return None\n  1558\t    normalized = str(candidate).strip()\n  1559\t    return normalized or None\n", "command": "/bin/zsh -lc \"nl -ba backend/app/services/composition_jobs.py | sed -n '1425,1565p'\"", "exit_code": 0, "id": "item_109", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 220, "prompt_index": 62, "prompt_name": "61 \u2014 Segmented Writing Engine", "prompt_total": 100}, "timestap": "2026-04-02T07:05:59-07:00"}
