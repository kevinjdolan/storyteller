de/storyteller/frontend/src/features/session/live/sessionRealtimeClient.ts:81:  if (ack.replay_strategy === 'hydrate') {\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.ts:122:function resolveWebSocketBase() {\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.ts:136:export function resolveSessionRealtimeWebSocketUrl() {\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.ts:143:  const url = new URL(configuredUrl, resolveWebSocketBase())\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.ts:157:  const resolveWebSocketUrl =\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.ts:158:    clientOptions.resolveWebSocketUrl ?? resolveSessionRealtimeWebSocketUrl\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.ts:164:    ((url: string) => createBrowserWebSocket(url))\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.ts:174:      let activeSocket: WebSocketLike | null = null\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.ts:253:        const webSocketUrl = resolveWebSocketUrl()\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.ts:269:            connectionDetail: 'WebSocket is unavailable in this environment.',\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.test.ts:4:class FakeWebSocket {\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.test.ts:55:      resolveWebSocketUrl: () => null,\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.test.ts:74:    const sockets: FakeWebSocket[] = []\n/Users/kevin/code/storyteller/frontend/src/features/session/live/sessionRealtimeClient.test.ts:87:      resolveWebSocketUrl: () => 'ws://