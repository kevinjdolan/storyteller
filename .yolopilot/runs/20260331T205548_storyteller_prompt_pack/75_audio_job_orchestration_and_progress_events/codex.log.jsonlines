{"type":"item.started","item":{"id":"item_246","type":"command_execution","command":"/bin/zsh -lc \"node <<'NODE'\nconst puppeteer = (await import('/Users/kevin/code/storyteller/tools/webapp-qa/node_modules/puppeteer/lib/esm/puppeteer/puppeteer.js')).default\nconst fs = await import('node:fs/promises')\n\nconst outputPath = '/Users/kevin/code/storyteller/.artifacts/webapp-qa/prompt-75-audio-progress-ui.png'\nawait fs.mkdir('/Users/kevin/code/storyteller/.artifacts/webapp-qa', { recursive: true })\n\nconst snapshot = {\n  id: 'moonlit-harbor',\n  display_title: 'Lanterns Over Juniper Lake',\n  current_stage: 'audio',\n  resume_stage: 'audio',\n  furthest_completed_stage: 'composition',\n  overall_status: 'in_progress',\n  created_at: '2026-04-01T03:00:00Z',\n  updated_at: '2026-04-02T05:18:00Z',\n  completed_at: null,\n  selected_genre: { id: 'genre-1', slug: 'quest-fantasy', label: 'Quest Fantasy' },\n  selected_tone_profile: { id: 'tone-1', slug: 'hushed-wonder', label: 'Hushed Wonder' },\n  progress: {\n    total_stages: 10,\n    completed_stages: 8,\n    in_progress_stages: 1,\n    needs_regeneration_stages: 0,\n  },\n  stage_states: [\n    {\n      stage: 'audio',\n      label: 'Audio',\n      description: 'Configure narration settings and generate resumable audio artifacts.',\n      status: 'in_progress',\n      detail: 'Narration is rendering in durable worker steps.',\n    },\n    {\n      stage: 'finalize',\n      label: 'Finalize',\n      description: 'Read, listen, review final assets, and download exports.',\n      status: 'draft',\n      detail: null,\n    },\n  ],\n  selected_story_setup: {\n    id: 'setup-1',\n    revision_number: 1,\n    target_word_count: 1800,\n    target_runtime_minutes: 13,\n    chapter_count: 3,\n    approximate_scene_count: 7,\n    chapter_style: 'short',\n    guidance_notes: 'Let each chapter settle before the next one brightens.',\n  },\n  latest_story_asset: {\n    id: 'story-asset-1',\n    asset_kind: 'story_text',\n    status: 'ready',\n    ready_at: '2026-04-02T05:10:00Z',\n  },\n  latest_audio_asset: null,\n  audio_settings: {\n    voice_key: 'moonbeam',\n    narration_style: 'calm',\n    playback_speed: 0.95,\n    include_background_music: true,\n    music_profile: 'night_ambience',\n    narration_volume: 92,\n    music_volume: 18,\n    guidance_notes: 'Keep the harbor bed soft under dialogue turns.',\n    music_profile_options: [\n      {\n        key: 'night_ambience',\n        label: 'Night ambience',\n        description: 'Low environmental bed for harbor, forest, or sky scenes.',\n        bedtime_use_case: 'Fits scene-setting passages that want a steady sense of place.',\n        asset_file_name: 'night_ambience.wav',\n        loop_duration_seconds: 24,\n        recommended_music_volume: 18,\n        recommended_music_volume_min: 8,\n        recommended_music_volume_max: 22,\n        mix_note: 'Keeps the bed darkest and quietest so consonants remain easy to hear.',\n      },\n    ],\n    mix_preview: {\n      strategy: 'curated_bed_ducked',\n      summary: 'Night ambience loops under the narration at -30.9 dB before ducking. Voice gain -1.1 dB, 8:1 ducking, and an 8s fade out.',\n      track_key: 'night_ambience',\n      track_label: 'Night ambience',\n      track_description: 'Low environmental bed for harbor, forest, or sky scenes.',\n      narration_gain_db: -1.1,\n      music_gain_db: -30.9,\n      ducking_ratio: 8,\n      ducking_threshold: 0.05,\n      fade_out_seconds: 8,\n      loop_duration_seconds: 24,\n    },\n    runtime_estimate: {\n      estimated_word_count: 1800,\n      estimated_chapter_count: 3,\n      chapter_pause_count: 2,\n      chapter_pause_seconds: 3,\n      total_chapter_pause_seconds: 6,\n      assumed_words_per_minute: 140,\n      minimum_words_per_minute: 120,\n      maximum_words_per_minute: 160,\n      target_duration_seconds: 825,\n      minimum_duration_seconds: 705,\n      maximum_duration_seconds: 960,\n      basis_source: 'story_setup_target',\n      pacing_band: 'balanced',\n    },\n  },\n  active_composition_job: null,\n  latest_composition_job: null,\n  latest_audio_job: {\n    id: 'audio-job-7',\n    status: 'in_progress',\n    voice_key: 'moonbeam',\n    playback_speed: 0.95,\n    include_background_music: true,\n    music_profile: 'night_ambience',\n    progress_percent: 68,\n    current_step: 'Mixing narration with the selected background bed.',\n    current_step_index: 5,\n    total_steps: 6,\n    completed_segments: 3,\n    estimated_duration_seconds: 780,\n    total_segments: 3,\n    current_segment_index: 3,\n    latest_asset_id: 'audio-segment-3',\n    latest_asset_kind: 'narration_segment',\n    attempt_count: 1,\n    stop_reason: null,\n    error_message: null,\n    started_at: '2026-04-02T05:16:00Z',\n    completed_at: null,\n    created_at: '2026-04-02T05:15:30Z',\n    updated_at: '2026-04-02T05:18:00Z',\n  },\n  active_audio_job: {\n    id: 'audio-job-7',\n    status: 'in_progress',\n    voice_key: 'moonbeam',\n    playback_speed: 0.95,\n    include_background_music: true,\n    music_profile: 'night_ambience',\n    progress_percent: 68,\n    current_step: 'Mixing narration with the selected background bed.',\n    current_step_index: 5,\n    total_steps: 6,\n    completed_segments: 3,\n    estimated_duration_seconds: 780,\n    total_segments: 3,\n    current_segment_index: 3,\n    latest_asset_id: 'audio-segment-3',\n    latest_asset_kind: 'narration_segment',\n    attempt_count: 1,\n    stop_reason: null,\n    error_message: null,\n    started_at: '2026-04-02T05:16:00Z',\n    completed_at: null,\n    created_at: '2026-04-02T05:15:30Z',\n    updated_at: '2026-04-02T05:18:00Z',\n  },\n}\n\nconst hydration = {\n  snapshot,\n  recent_history: {\n    session_id: 'moonlit-harbor',\n    latest_sequence_number: 2,\n    events: [\n      {\n        id: 'event-1',\n        session_id: 'moonlit-harbor',\n        sequence_number: 1,\n        actor: { actor_type: 'user', actor_id: 'local-user' },\n        event_type: 'session.created',\n        stage: null,\n        summary: 'Created session: Lanterns Over Juniper Lake.',\n        payload: { schema_version: 1, working_title: 'Lanterns Over Juniper Lake' },\n        created_at: '2026-04-01T03:00:00Z',\n      },\n      {\n        id: 'event-2',\n        session_id: 'moonlit-harbor',\n        sequence_number: 2,\n        actor: { actor_type: 'assistant', actor_id: 'audio-worker' },\n        event_type: 'job.progress.recorded',\n        stage: 'audio',\n        summary: 'Mixing narration with the selected background bed.',\n        payload: {\n          schema_version: 1,\n          job_id: 'audio-job-7',\n          job_kind: 'audio',\n          status: 'in_progress',\n          progress_percent: 68,\n          current_step: 'Mixing narration with the selected background bed.',\n          current_step_index: 5,\n          total_steps: 6,\n          completed_segments: 3,\n          current_segment_index: 3,\n          total_segments: 3,\n          latest_asset_id: 'audio-segment-3',\n          latest_asset_kind: 'narration_segment',\n          estimated_duration_seconds: 780,\n          message: 'Mixing narration with the selected background bed.',\n        },\n        created_at: '2026-04-02T05:18:00Z',\n      },\n    ],\n  },\n  hydration: {\n    strategy: 'materialized_only',\n    materialized_through_sequence_number: 2,\n    replay_from_sequence_number: null,\n    replayed_event_count: 0,\n    latest_sequence_number: 2,\n    history_event_count: 2,\n    history_window_truncated: false,\n  },\n}\n\nconst browser = await puppeteer.launch({ headless: true })\nconst page = await browser.newPage({ viewport: { width: 1440, height: 1600 } })\npage.on('console', (message) => console.log(\"'`[browser:${message.type()}] ${message.text()}`))\nawait page.setRequestInterception(true)\npage.on('\"'request', async (request) => {\n  const url = new URL(request.url())\n  if (url.pathname === '/api/v1/sessions/moonlit-harbor/hydrate') {\n    await request.respond({\n      status: 200,\n      contentType: 'application/json',\n      body: JSON.stringify(hydration),\n    })\n    return\n  }\n  if (url.pathname === '/api/v1/catalog/genres') {\n    await request.respond({\n      status: 200,\n      contentType: 'application/json',\n      body: JSON.stringify([{ id: 'genre-1', slug: 'quest-fantasy', label: 'Quest Fantasy', description: 'Softly adventurous bedtime quests.' }]),\n    })\n    return\n  }\n  if (url.pathname === '/api/v1/catalog/genres/quest-fantasy/tones') {\n    await request.respond({\n      status: 200,\n      contentType: 'application/json',\n      body: JSON.stringify([{ id: 'tone-1', slug: 'hushed-wonder', label: 'Hushed Wonder', description: 'Soft awe with quiet momentum.' }]),\n    })\n    return\n  }\n  if (url.pathname === '/api/v1/sessions/moonlit-harbor/ui-actions' && request.method() === 'POST') {\n    await request.respond({\n      status: 201,\n      contentType: 'application/json',\n      body: JSON.stringify({\n        id: 'ui-action-1',\n        session_id: 'moonlit-harbor',\n        sequence_number: 3,\n        actor: { actor_type: 'user', actor_id: 'local-user' },\n        event_type: 'ui.action.recorded',\n        stage: 'audio',\n        summary: 'Navigated to audio stage.',\n        payload: null,\n        created_at: '2026-04-02T05:18:05Z',\n      }),\n    })\n    return\n  }\n  await request.continue()\n})\n\nawait page.goto('http://127.0.0.1:8566/sessions/moonlit-harbor?stage=audio', { waitUntil: 'networkidle0' })\nawait page.waitForSelector('[aria-label=\\\"Narration render progress\\\"]', { timeout: 15000 })\nawait page.waitForFunction(() => document.body.innerText.includes('68% rendered'))\nawait page.waitForFunction(() => document.body.innerText.includes('Mixing narration with the selected background bed.'))\nconst visibleText = await page.evaluate(() => document.body.innerText)\nconsole.log(visibleText.includes('68% rendered') ? 'ASSERT progress badge ok' : 'ASSERT progress badge missing')\nconsole.log(visibleText.includes('Step 5 of 6. 3 of 3 narration segments are durable already. Estimated listening length 13 min.') ? 'ASSERT progress hint ok' : 'ASSERT progress hint missing')\nawait page.screenshot({ path: outputPath, fullPage: true })\nconsole.log(\"'`SCREENSHOT ${outputPath}`)\nawait browser.close()\nNODE'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
