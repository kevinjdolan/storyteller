{"type":"item.completed","item":{"id":"item_240","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,200p' /Users/kevin/code/storyteller/frontend/src/app/routePaths.ts\"","aggregated_output":"import { generatePath } from 'react-router-dom'\n\nexport const routePaths = {\n  home: '/',\n  sessionWorkspace: '/sessions/:sessionId',\n  notFound: '*',\n} as const\n\nexport function buildSessionWorkspacePath(\n  sessionId: string,\n  options: {\n    stage?: string | null\n  } = {},\n) {\n  const path = generatePath(routePaths.sessionWorkspace, { sessionId })\n\n  if (options.stage == null || options.stage === '') {\n    return path\n  }\n\n  const searchParams = new URLSearchParams({\n    stage: options.stage,\n  })\n\n  return `${path}?${searchParams.toString()}`\n}\n","exit_code":0,"status":"completed"}}
