200,\n      contentType: 'application/json',\n      body: JSON.stringify({ message: 'Hello from FastAPI\"'!'\"' }),\n    })\n    return\n  }\n\n  if (url.pathname === '/api/v1/sessions/moonlit-harbor/hydrate') {\n    await request.respond({\n      status: 200,\n      contentType: 'application/json',\n      body: JSON.stringify(hydration),\n    })\n    return\n  }\n\n  if (url.pathname === '/api/v1/catalog/genres') {\n    await request.respond({\n      status: 200,\n      contentType: 'application/json',\n      body: JSON.stringify([{ id: 'genre-1', slug: 'quest-fantasy', label: 'Quest Fantasy', description: 'Softly adventurous bedtime quests.' }]),\n    })\n    return\n  }\n\n  if (url.pathname === '/api/v1/catalog/genres/quest-fantasy/tones') {\n    await request.respond({\n      status: 200,\n      contentType: 'application/json',\n      body: JSON.stringify([{ id: 'tone-1', slug: 'hushed-wonder', label: 'Hushed Wonder', description: 'Soft awe with quiet momentum.' }]),\n    })\n    return\n  }\n\n  if (url.pathname === '/api/v1/sessions/moonlit-harbor/ui-actions' && request.method() === 'POST') {\n    await request.respond({\n      status: 201,\n      contentType: 'application/json',\n      body: JSON.stringify({\n        id: 'ui-action-1',\n        session_id: 'moonlit-harbor',\n        sequence_number: 3,\n        actor: { actor_type: 'user', actor_id: 'local-user' },\n        event_type: 'ui.action.recorded',\n        stage: 'audio',\n        summary: 'Navigated to audio stage.',\n        payload: null,\n        created_at: '2026-04-02T05:18:05Z',\n      }),\n    })\n    return\n  }\n\n  await request.continue()\n})\n\nawait page.goto('http://127.0.0.1:8566/sessions/moonlit-harbor?stage=audio', { waitUntil: 'networkidle0' })\nawait page.waitForSelector('[aria-label=\\\"Narration render progress\\\"]', { timeout: 15000 })\nawait page.waitForFunction(() => document.body.innerText.includes('68% rendered'))\nawait page.waitForFunction(() => document.body.innerText.includes('Mixing narration with the selected background bed.'))\n\nconst visibleText = await page.evaluate(() => document.body.innerText)\nconsole.log(visibleText.includes('68% rendered') ? 'ASSERT progress badge ok' : 'ASSERT progress badge missing')\nconsole.log(\n  visibleText.includes('Step 5 of 6. 3 of 3 narration segments are durable already. Estimated listening length 13 min.')\n    ? 'ASSERT progress hint ok'\n    : 'ASSERT progress hint missing',\n)\n\nawait page.screenshot({ path: outputPath, fullPage: true })\nconsole.log(\"'`SCREENSHOT ${outputPath}`)\nawait browser.close()\nEOF\nnode /tmp/prompt75_audio_qa.mjs'","aggregated_output":"","exit_code":null,"status":"in_progress"}}
