{"type":"item.completed","item":{"id":"item_109","type":"command_execution","command":"/bin/zsh -lc \"sed -n '152,225p' /Users/kevin/code/storyteller/frontend/src/shared/ui/primitives.tsx\"","aggregated_output":"type ProgressBarTone = 'brand' | 'moss' | 'accent'\n\ntype ProgressBarProps = {\n  'aria-label'?: string\n  className?: string\n  hint?: ReactNode\n  label?: ReactNode\n  max?: number\n  tone?: ProgressBarTone\n  value: number\n  valueText?: ReactNode\n}\n\nfunction clamp(value: number, minimum: number, maximum: number) {\n  return Math.min(Math.max(value, minimum), maximum)\n}\n\nexport function ProgressBar({\n  'aria-label': ariaLabel,\n  className,\n  hint,\n  label,\n  max = 100,\n  tone = 'brand',\n  value,\n  valueText,\n}: ProgressBarProps) {\n  const safeMax = max <= 0 ? 100 : max\n  const safeValue = clamp(value, 0, safeMax)\n  const percentage = Math.round((safeValue / safeMax) * 100)\n  const resolvedValueText = valueText ?? `${percentage}%`\n\n  return (\n    <div className={cx('progress', `progress--${tone}`, className)}>\n      {label != null || valueText != null ? (\n        <div className=\"progress__meta\">\n          {label != null ? (\n            <span className=\"progress__label\">{label}</span>\n          ) : (\n            <span />\n          )}\n          <span className=\"progress__value\">{resolvedValueText}</span>\n        </div>\n      ) : null}\n      <div\n        aria-label={\n          ariaLabel ?? (typeof label === 'string' ? label : 'Progress')\n        }\n        aria-valuemax={safeMax}\n        aria-valuemin={0}\n        aria-valuenow={Math.round(safeValue)}\n        aria-valuetext={\n          typeof resolvedValueText === 'string' ? resolvedValueText : undefined\n        }\n        className=\"progress__track\"\n        role=\"progressbar\"\n      >\n        <span\n          aria-hidden=\"true\"\n          className=\"progress__fill\"\n          style={{ width: `${percentage}%` }}\n        />\n      </div>\n      {hint != null ? <p className=\"progress__hint\">{hint}</p> : null}\n    </div>\n  )\n}\n\ntype UnorderedStackedListProps = Omit<\n  ComponentPropsWithoutRef<'ul'>,\n  'className'\n> & {\n  as?: 'ul'\n  className?: string\n","exit_code":0,"status":"completed"}}
