\"status\"),\n1197:class SessionAsset(UUIDPrimaryKeyMixin, TimestampMixin, Base):\n1213:    audio_job_id: Mapped[str | None] = mapped_column(\n1215:        ForeignKey(\"audio_jobs.id\", ondelete=\"SET NULL\"),\n1228:    metadata_json: Mapped[dict[str, Any] | list[Any] | None] = mapped_column(JSON)\n1238:    audio_job: Mapped[\"AudioJob | None\"] = relationship(back_populates=\"assets\")\n1248:            \"ix_session_assets_audio_job_id_asset_kind_segment_index\",\n1249:            \"audio_job_id\",\n","exit_code":0,"status":"completed"}}
