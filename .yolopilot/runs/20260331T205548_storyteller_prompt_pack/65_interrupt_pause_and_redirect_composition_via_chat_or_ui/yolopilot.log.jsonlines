nre(\n            slug=f\\\"visual-qa-quest-{suffix}\\\",\n            label=\\\"Quest Fantasy\\\",\n            description=\\\"A gentle harbor adventure for browser QA.\\\",\n        )\n        tone = ToneProfile(\n            genre=genre,\n            slug=f\\\"visual-qa-tone-{suffix}\\\",\n            label=\\\"Hushed Wonder\\\",\n            description=\\\"Soft and luminous.\\\",\n        )\n        session.add_all([genre, tone])\n        session.flush()\n\n        snapshot = service.create_session(working_title=title)\n        story_session = session.get(StorySession, snapshot.id)\n        assert story_session is not None\n        story_session.selected_genre = genre\n        story_session.selected_tone_profile = tone\n        session.flush()\n\n        for stage in (\n            WorkflowStage.GENRE,\n            WorkflowStage.TONE,\n            WorkflowStage.BRIEF,\n            WorkflowStage.PITCHES,\n            WorkflowStage.CHARACTERS,\n            WorkflowStage.BEATS,\n            WorkflowStage.STORY_SETUP,\n        ):\n            service.update_stage_state(\n                snapshot.id,\n                stage=stage,\n                status=WorkflowStageState.COMPLETED,\n            )\n\n        brief = StoryBrief(\n            session_id=snapshot.id,\n            revision_number=1,\n            raw_brief=\\\"A harbor fox follows a silver clue and returns home calm.\\\",\n            normalized_summary=\\\"A bedtime harbor mystery with gentle emotional repair.\\\",\n            planning_notes=\\\"Keep the midpoint safe and sleepy.\\\",\n            is_active=True,\n            accepted_at=now,\n        )\n        session.add(brief)\n        session.flush()\n\n        pitch = Pitch(\n            session_id=snapshot.id,\n            story_brief_id=brief.id,\n            generation_key=f\\\"visual-qa-{suffix}\\\",\n            pitch_index=1,\n            title=\\\"The Silver Bell Buoy\\\",\n            logline=\\\"A harbor fox follows a bell across moonlit water.\\\",\n            is_selected=True,\n            accepted_at=now,\n        )\n        session.add(pitch)\n        session.flush()\n\n        character_sheet = CharacterSheet(\n            session_id=snapshot.id,\n            pitch_id=pitch.id,\n            revision_number=1,\n            title=\\\"Mira and the Bell\\\",\n            protagonist_name=\\\"Mira\\\",\n            is_selected=True,\n            accepted_at=now,\n        )\n        session.add(character_sheet)\n        session.flush()\n\n        beat_sheet = BeatSheet(\n            session_id=snapshot.id,\n            character_sheet_id=character_sheet.id,\n            revision_number=1,\n            summary=\\\"A soft Save-the-Cat arc.\\\",\n            beats=[\n                {\n                    \\\"key\\\": \\\"opening_image\\\",\n                    \\\"label\\\": \\\"Opening Image\\\",\n                    \\\"order\\\": 1,\n                    \\\"summary\\\": \\\"Mira watches the harbor settle under soft moonlight.\\\",\n                    \\\"emotional_intent\\\": \\\"Begin in stillness and wonder.\\\",\n                },\n                {\n                    \\\"key\\\": \\\"catalyst\\\",\n                    \\\"label\\\": \\\"Catalyst\\\",\n                    \\\"order\\\": 2,\n                    \\\"summary\\\": \\\"A bell buoy drifts away from the dock and asks for help.\\\",\n                    \\\"emotional_intent\\\": \\\"Introduce a gentle problem.\\\",\n                },\n                {\n                    \\\"key\\\": \\\"midpoint\\\",\n                    \\\"label\\\": \\\"Midpoint\\\",\n                    \\\"order\\\": 3,\n                    \\\"summary\\\": \\\"Mira finds the hidden cove where the bell belongs.\\\",\n                    \\\"emotional_intent\\\": \\\"Lift wonder while keeping the surprise soft.\\\",\n                },\n                {\n                    \\\"key\\\": \\\"finale\\\",\n                    \\\"label\\\": \\\"Finale\\\",\n                    \\\"order\\\": 4,\n                    \\\"summary\\\": \\\"The bell returns home and the harbor settles together.\\\",\n                    \\\"emotional_intent\\\": \\\"Deliver repair and visible calm.\\\",\n                },\n            ],\n            is_selected=True,\n            accepted_at=now,\n        )\n        session.add(beat_sheet)\n        session.flush()\n\n        story_setup = StorySetup(\n            session_id=snapshot.id,\n            beat_sheet_id=beat_sheet.id,\n            revision_number=1,\n            target_word_count=1600,\n            target_runtime_minutes=11,\n            chapter_count=3,\n            approximate_scene_count=9,\n            chapter_style=\\\"three gentle chapters\\\",\n            guidance_notes=\\\"End each chapter with a calmer image than it began.\\\",\n            is_selected=True,\n            accepted_at=now,\n        )\n        session.add(story_setup)\n        session.flush()\n\n        story_outline = StoryOutline(\n            session_id=snapshot.id,\n            beat_sheet_id=beat_sheet.id,\n            story_setup_id=story_setup.id,\n            revision_number=1,\n            outline_kind=\\\"chapter\\\",\n            summary=\\\"Three draftable chapters mapped from the beat sheet.\\\",\n            cards=[\n                {\n                    \\\"card_key\\\": \\\"chapter-1\\\",\n                    \\\"card_type\\\": \\\"chapter\\\",\n                    \\\"position\\\": 1,\n                    \\\"title\\\": \\\"Chapter 1: Opening Image to Catalyst\\\",\n                    \\\"summary\\\": \\\"Set the moonlit harbor mood and launch Mira after the drifting bell.\\\",\n                    \\\"beat_keys\\\": [\\\"opening_image\\\", \\\"catalyst\\\"],\n                    \\\"beat_labels\\\": [\\\"Opening Image\\\", \\\"Catalyst\\\"],\n                    \\\"emotional_shift\\\": \\\"Move from stillness toward gentle motion.\\\",\n                    \\\"target_word_count\\\": 533,\n                    \\\"target_runtime_minutes\\\": 4,\n                    \\\"target_scene_count\\\": 3,\n                    \\\"bedtime_guardrail\\\": \\\"Keep the problem small, visible, and quickly reassuring.\\\",\n                },\n                {\n                    \\\"card_key\\\": \\\"chapter-2\\\",\n                    \\\"card_type\\\": \\\"chapter\\\",\n                    \\\"position\\\": 2,\n                    \\\"title\\\": \\\"Chapter 2: Midpoint\\\",\n                    \\\"summary\\\": \\\"Let Mira discover the hidden cove and feel the bell's meaning open up.\\\",\n                    \\\"beat_keys\\\": [\\\"midpoint\\\"],\n                    \\\"beat_labels\\\": [\\\"Midpoint\\\"],\n                    \\\"emotional_shift\\\": \\\"Lift wonder without breaking the bedtime tone.\\\",\n                    \\\"target_word_count\\\": 533,\n                    \\\"target_runtime_minutes\\\": 4,\n                    \\\"target_scene_count\\\": 3,\n                    \\\"bedtime_guardrail\\\": \\\"Keep the reveal luminous and quickly reassuring.\\\",\n                },\n                {\n                    \\\"card_key\\\": \\\"chapter-3\\\",\n                    \\\"card_type\\\": \\\"chapter\\\",\n                    \\\"position\\\": 3,\n                    \\\"title\\\": \\\"Chapter 3: Finale\\\",\n                    \\\"summary\\\": \\\"Guide the harbor back into rest.\\\",\n                    \\\"beat_keys\\\": [\\\"finale\\\"],\n                    \\\"beat_labels\\\": [\\\"Finale\\\"],\n                    \\\"emotional_shift\\\": \\\"Turn gentle doubt into visible relief and belonging.\\\",\n                    \\\"target_word_count\\\": 534,\n                    \\\"target_runtime_minutes\\\": 3,\n                    \\\"target_scene_count\\\": 3,\n                    \\\"bedtime_guardrail\\\": \\\"Land in repair and sleepy calm.\\\",\n                },\n            ],\n            metadata_json={\n                \\\"genre_label\\\": genre.label,\n                \\\"tone_label\\\": tone.label,\n                \\\"target_word_count\\\": 1600,\n            },\n            is_selected=True,\n            accepted_at=now,\n        )\n        session.add(story_outline)\n        session.flush()\n\n        service.update_stage_state(\n            snapshot.id,\n            stage=WorkflowStage.COMPOSITION,\n            status=WorkflowStageState.IN_PROGRESS,\n        )\n        composition_job = CompositionJob(\n            session_id=snapshot.id,\n            beat_sheet_id=beat_sheet.id,\n            story_setup_id=story_setup.id,\n            job_kind=CompositionJobKind.DRAFT,\n            status=JobStatus.IN_PROGRESS,\n            progress_percent=41.5,\n            current_segment_index=2,\n            started_at=now,\n            metadata_json={\n                \\\"accepted_story_so_far\\\": (\n                    \\\"Mira padded past the moonlit docks while the harbor hummed in its sleep.\\\\n\\\\n\\\"\n                    \\\"The bell's glow drifted deeper into the cove, asking her to come closer.\\\"\n                ),\n                \\\"latest_partial_output\\\": (\n                    \\\"The bell's glow drifted deeper into the cove, asking her to come closer.\\\"\n                ),\n                \\\"latest_segment_summary\\\": (\n                    \\\"Mira follows the bell deeper into the quiet harbor while the scene stays calm.\\\"\n                ),\n            },\n        )\n        session.add(composition_job)\n        session.flush()\n        session.commit()\n        return snapshot.id, composition_job.id\n\n\npause_session_id, pause_job_id = create_story_session(\\\"Visual QA Pause Queued\\\")\nwith SessionLocal() as session:\n    CompositionJobService(session).pause_job(pause_session_id, pause_job_id)\n    hydration = SessionHydrationService(session).hydrate_session(\n        pause_session_id,\n        history_limit=10,\n    )\n    session.commit()\n    print(\n        f\\\"pause={pause_session_id}::{pause_job_id}::{hydration.snapshot.active_composition_job.interruption_request.message}\\\"\n    )\n\nredirect_session_id, redirect_job_id = create_story_session(\\\"Visual QA Redirect Queued\\\")\nwith SessionLocal() as session:\n    CompositionJobService(session).request_redirect(\n        redirect_session_id,\n        redirect_job_id,\n        instructions=\\\"Introduce the otter earlier and soften the midpoint into reassurance.\\\",\n        rewrite_from_segment_index=2,\n        origin=\\\"workspace\\\",\n    )\n    hydration = SessionHydrationService(session).hydrate_session(\n        redirect_session_id,\n        history_limit=10,\n    )\n    session.commit()\n    print(\n        f\\\"redirect={redirect_session_id}::{redirect_job_id}::{hydration.snapshot.active_composition_job.interruption_request.message}\\\"\n    )\nPY\"", "exit_code": 1, "id": "item_301", "status": "failed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 588, "prompt_index": 66, "prompt_name": "65 \u2014 Interrupt, Pause, and Redirect Composition via Chat or UI", "prompt_total": 100}, "timestap": "2026-04-02T11:05:48-07:00"}
