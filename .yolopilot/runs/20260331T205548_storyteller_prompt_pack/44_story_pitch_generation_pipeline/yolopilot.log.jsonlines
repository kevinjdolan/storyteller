frontend/src/api/sessions.ts:322:  snapshot: SessionSnapshot\nfrontend/src/api/sessions.ts:323:  event: SessionHistoryEvent\nfrontend/src/api/sessions.ts:326:export type CreateSessionResponse = Pick<SessionSnapshot, 'id'>\nfrontend/src/api/sessions.ts:328:export function fetchRecentSessions(limit = 20) {\nfrontend/src/api/sessions.ts:329:  return getJson<RecentSessionSummary[]>(`/api/v1/sessions?limit=${limit}`)\nfrontend/src/api/sessions.ts:332:export function fetchSessionSnapshot(sessionId: string) {\nfrontend/src/api/sessions.ts:333:  return getJson<SessionSnapshot>(`/api/v1/sessions/${sessionId}`)\nfrontend/src/api/sessions.ts:336:export function fetchSessionHydration(sessionId: string) {\nfrontend/src/api/sessions.ts:337:  return getJson<SessionHydration>(`/api/v1/sessions/${sessionId}/hydrate`)\nfrontend/src/api/sessions.ts:340:export function fetchSessionHistory(sessionId: string) {\nfrontend/src/api/sessions.ts:341:  return getJson<SessionHistory>(`/api/v1/sessions/${sessionId}/history`)\nfrontend/src/api/sessions.ts:344:export function recordSessionUiAction(\nfrontend/src/api/sessions.ts:345:  sessionId: string,\nfrontend/src/api/sessions.ts:346:  body: RecordSessionUIActionRequest,\nfrontend/src/api/sessions.ts:348:  return postJson<SessionHistoryEvent>(\nfrontend/src/api/sessions.ts:349:    `/api/v1/sessions/${sessionId}/ui-actions`,\nfrontend/src/api/sessions.ts:354:export function applySessionContextUpdate(\nfrontend/src/api/sessions.ts:355:  sessionId: string,\nfrontend/src/api/sessions.ts:356:  body: SessionContextUpdateRequest,\nfrontend/src/api/sessions.ts:358:  return postJson<SessionContextUpdateResponse>(\nfrontend/src/api/sessions.ts:359:    `/api/v1/sessions/${sessionId}/context-updates`,\nfrontend/src/api/sessions.ts:364:export function saveSessionStoryBrief(\nfrontend/src/api/sessions.ts:365:  sessionId: string,\nfrontend/src/api/sessions.ts:366:  body: SaveSessionStoryBriefRequest,\nfrontend/src/api/sessions.ts:368:  return postJson<SessionStoryBriefResponse>(\nfrontend/src/api/sessions.ts:369:    `/api/v1/sessions/${sessionId}/story-brief`,\nfrontend/src/api/sessions.ts:374:export function parseSessionChatIntent(\nfrontend/src/api/sessions.ts:375:  sessionId: string,\nfrontend/src/api/sessions.ts:378:    explicitCommand?: SessionExplicitChatCommand | null\nfrontend/src/api/sessions.ts:382:    `/api/v1/sessions/${sessionId}/chat/intents`,\nfrontend/src/api/sessions.ts:390:export function createSession(workingTitle?: string) {\nfrontend/src/api/sessions.ts:391:  return postJson<CreateSessionResponse>('/api/v1/sessions', {\ndocs/frontend-design-foundation.md:13:- Color: bedtime-friendly ink, surface, brand, moss, gold, and rose tones are\ndocs/frontend-design-foundation.md:60:  <Badge tone=\"brand\">Draft</Badge>\ndocs/domain-model.md:1:# Domain Model and Session State Machine\ndocs/domain-model.md:3:This document defines the durable business objects and workflow rules for a single story-creation session. The goal is to give the backend, frontend, migrations, and later AI orchestration code one shared contract for how a session progresses, pauses, rewinds, and resumes.\ndocs/domain-model.md:7:- The `story_session` is the durable unit of work.\ndocs/domain-model.md:9:- Every workflow stage is tracked explicitly, even when later stages are generated from earlier ones.\ndocs/domain-model.md:14:## Session Snapshot Contract\ndocs/domain-model.md:16:The session snapshot returned to the UI should eventually include these fields, even if some land in later prompts:\ndocs/domain-model.md:20:| `id` | Stable UUID for the story session. |\ndocs/domain-model.md:23:| `resume_stage` | Earliest stage that still needs work when a session is reopened. |\ndocs/domain-model.md:25:| `overall_status` | Session-level rollup such as `draft`, `in_progress`, `completed`, or `needs_regeneration`. |\ndocs/domain-model.md:26:| `selected_genre_id` | Accepted genre catalog row for the session. |\ndocs/domain-model.md:27:| `selected_tone_profile_id` | Accepted tone profile row for the session. |\ndocs/domain-model.md:28:| `selected_pitch_id` | Accepted pitch record. |\ndocs/domain-model.md:38:`resume_stage` is the key anti-guessing field. The backend computes it from durable stage states so the frontend does not need to infer where to reopen a session by looking at which panels happen to have data.\ndocs/domain-model.md:41:such as pitches, character sheets, beat sheets, and setup revisions point back to the owning\ndocs/domain-model.md:42:session, and the accepted row is tracked on the child record itself. The API snapshot can still\ndocs/domain-model.md:49:| `story_session` | Root aggregate for one bedtime-story project. | IDs, title, stage pointers, overall status, timestamps. | Owns the current accepted choices and job pointers. |\ndocs/domain-model.md:50:| `workflow_stage_state` | Per-stage state for the session. | `session_id`, `stage`, `status`, `updated_at`, `last_event_id`. | Stored explicitly so resume does not depend on sparse child tables. |\ndocs/domain-model.md:51:| `genre` | Curated genre catalog entry. | slug, label, description, bedtime-safety notes, arc notes. | Backend-owned reference data. |\ndocs/domain-model.md:52:| `tone_profile` | Curated tone option linked to a genre. | `genre_id`, slug, label, descriptors, bedtime notes, default planning hints. | Tone choices are filtered by genre. |\ndocs/domain-model.md:54:| `pitch` | One candidate story premise. | batch or generation group, summary, hook, bedtime notes, selection flag. | `selected_pitch_id` on the session represents the accepted pitch; selection does not require a separate table. |\ndocs/domain-model.md:55:| `character_sheet` | Accepted cast and character traits for the chosen direction. | protagonist/supporting cast data, revision, generation metadata. | Multiple revisions may exist; the session points at the accepted one. |\ndocs/domain-model.md:61:| `session_asset` | Durable artifact metadata for session files and exports. | asset kind, object path, MIME type, byte size, checksum, segment index, readiness status. | Covers draft snapshots, composition segments, audio segments, `.docx`, and final audio without scanning object storage. |\ndocs/domain-model.md:62:| `event_log_entry` | Append-only session history. | actor, event type, stage context, payload with `schema_version`, created_at. | Supports replay, resume hydration, debugging, and audit. |\ndocs/domain-model.md:64:## Canonical Workflow Stages\ndocs/domain-model.md:70:| 1 | `genre` | Genre | The user accepts a genre for the session. |\ndocs/domain-model.md:71:| 2 | `tone` | Tone | The user accepts a tone profile for the selected genre. |\ndocs/domain-model.md:72:| 3 | `brief` | Story brief | The session has an accepted free-form brief and any required normalized summary. |\ndocs/domain-model.md:73:| 4 | `pitches` | Pitches | One pitch is accepted or the user intentionally keeps a current pitch set for further refinement. |\ndocs/domain-model.md:74:| 5 | `characters` | Characters | One character sheet is accepted. |\ndocs/domain-model.md:75:| 6 | `beats` | Beat sheet | One beat sheet is accepted. |\ndocs/domain-model.md:84:- `frontend/src/features/session/workflowStages.ts`\ndocs/domain-model.md:95:| `in_progress` | Durable work is actively being produced or updated. | Pitch generation is running, composition is streaming segments, or audio rendering is underway. |\ndocs/domain-model.md:96:| `completed` | The stage has an accepted output that is still valid relative to all upstream dependencies. | A beat sheet was accepted and no upstream planning change has made it stale. |\ndocs/domain-model.md:97:| `needs_regeneration` | The stage was completed before, but an upstream change made its accepted output stale. The old output may remain visible for comparison, but it is not the current source of truth. | The user edits characters after a beat sheet exists, so beats, composition, audio, and finalize become stale. |\ndocs/domain-model.md:99:### Session-Level Rollup\ndocs/domain-model.md:101:The session-level `overall_status` should be derived, not manually entered:\ndocs/domain-model.md:104:- `in_progress`: at least one stage is `in_progress`, or some stages are completed but the session has not reached a valid finalization state.\ndocs/domain-model.md:106:- `needs_regeneration`: one or more stages are `needs_regeneration`, even if the session also has readable prior outputs.\ndocs/domain-model.md:112:`genre -> tone -> brief -> pitches -> characters -> beats -> story_setup -> composition -> audio -> finalize`\ndocs/domain-model.md:131:| `genre` | `tone`, `brief`, `pitches`, `characters`, `beats`, `composition`, `audio`, `finalize` |\ndocs/domain-model.md:132:| `tone` | `brief`, `pitches`, `characters`, `beats`, `composition`, `audio`, `finalize` |\ndocs/domain-model.md:133:| `brief` | `pitches`, `characters`, `beats`, `composition`, `audio`, `finalize` |\ndocs/domain-model.md:134:| `pitches` | `characters`, `beats`, `composition`, `audio`, `finalize` |\ndocs/domain-model.md:145:- They still influence later composition, but a new pitch or character sheet does not automatically erase the user's preferred target length.\ndocs/domain-model.md:158:## Re-entry From Past Sessions\ndocs/domain-model.md:162:1. Planning session reopened midstream:\ndocs/domain-model.md:163:   - Example: `genre`, `tone`, and `brief` are `completed`; `pitches` is `in_progress`.\ndocs/domain-model.md:164:   - Result: open the session on `resume_stage = pitches`.\ndocs/domain-model.md:166:   - Example: `composition`, `audio`, and `finalize` were `completed`, then the user edits the beat sheet.\ndocs/domain-model.md:177:- Frontend mirror for rendering and client-side navigation: `frontend/src/features/session/workflowStages.ts`\ndocs/domain-model.md:185:- The backend service layer, not the frontend, decides whether a requested stage transition is valid for the current session snapshot.\ndocs/product-brief.md:5:Storyteller is a session-based bedtime story creation studio. It helps a user move from a loose story idea to a finished written story and finished narration audio, with the ability to leave and come back later without losing progress.\ndocs/product-brief.md:7:The first meaningful screen is the sessions home. It must foreground past sessions, including both in-progress and completed stories, so resume and revisit are the default behaviors rather than an afterthought.\ndocs/product-brief.md:12:- Guided, not opaque: users move through explicit workflow stages instead of one giant prompt box.\ndocs/product-brief.md:21:1. Genre selection from a curated genre list.\ndocs/product-brief.md:22:2. Tone selection from options preconfigured for the chosen genre.\ndocs/product-brief.md:24:4. Story pitches generated by Gemini, with selection, refinement, or regeneration.\ndocs/product-brief.md:25:5. Character sheet generation, again with selection and refinement.\ndocs/product-brief.md:26:6. Save-the-Cat beat sheet generation and editing.\ndocs/product-brief.md:34:### Sessions and Resume\ndocs/product-brief.md:36:- Sessions are durable backend entities.\ndocs/product-brief.md:37:- A user can reopen a session from any stage.\ndocs/product-brief.md:38:- In-progress and completed sessions both appear on the home screen.\ndocs/product-brief.md:48:- User chat can propose structured actions such as selecting a tone or refining beats.\ndocs/product-brief.md:49:- The model may propose actions, but a deterministic backend policy layer decides whether each action is valid for the session's current stage.\ndocs/product-brief.md:84:- resume work from prior sessions without losing context\ndocs/realtime-events.md:4:prompt 17. It is intentionally boring: session-scoped channels, a small number\ndocs/realtime-events.md:14:- Every live event belongs to exactly one story session.\ndocs/realtime-events.md:15:- The browser subscribes to one session channel at a time: `session:{session_id}`.\ndocs/realtime-events.md:27:One workspace tab opens one live connection and sends a session subscription\ndocs/realtime-events.md:34:  \"session_id\": \"session-123\",\ndocs/realtime-events.md:47:  \"session_id\": \"session-123\",\ndocs/realtime-events.md:48:  \"channel\": \"session:session-123\",\ndocs/realtime-events.md:65:- Only connections subscribed to `session:{session_id}` receive that session's\ndocs/realtime-events.md:67:- Multiple tabs can subscribe to the same session and all receive the same\ndocs/realtime-events.md:69:- A tab viewing a different session should open a separate subscription instead\ndocs/realtime-events.md:70:  of multiplexing unrelated sessions through one feed.\ndocs/realtime-events.md:73:  whether the tab should rehydrate from the session snapshot endpoint.\ndocs/realtime-events.md:77:Every session event shares the same outer shape:\ndocs/realtime-events.md:84:  \"session_id\": \"session-123\",\ndocs/realtime-events.md:85:  \"channel\": \"session:session-123\",\ndocs/realtime-events.md:105:- `channel`: always `session:{session_id}`.\ndocs/realtime-events.md:127:| `error.notification` | yes | User-visible session or job error that should survive replay. |\ndocs/realtime-events.md:276:errors that are not session-specific should stay out of this feed and live in\ndocs/realtime-events.md:281:The event log remains the source of truth for replayable session history. The\ndocs/realtime-events.md:293:  latest session snapshot and then continue applying future live events.\ndocs/realtime-events.md:294:- The session snapshot endpoint from prompt 38 is the fallback when replay alone\ndocs/realtime-events.md:304:- The server must still verify that the requested session exists before\ndocs/realtime-events.md:307:  local identity assumption with session ownership checks before joining\ndocs/realtime-events.md:308:  `session:{session_id}`.\ndocs/realtime-events.md:313:selecting a tone or changing runtime targets. Those pending states should clear\ndocs/frontend-state-architecture.md:4:session-local runtime state.\ndocs/frontend-state-architecture.md:9:   - `frontend/src/features/session/sessionQueries.ts`\ndocs/frontend-state-architecture.md:10:   - Home page lists use `useRecentSessionsQuery()`.\ndocs/frontend-state-architecture.md:11:   - Workspace snapshots use `useSessionSnapshotQuery(sessionId)`.\ndocs/frontend-state-architecture.md:12:2. Session-local runtime state lives in a tiny external store.\ndocs/frontend-state-architecture.md:13:   - `frontend/src/features/session/sessionRuntimeStore.ts`\ndocs/frontend-state-architecture.md:17:   - `frontend/src/features/session/SessionWorkspaceProvider.tsx`\ndocs/frontend-state-architecture.md:18:   - Child components can read the current session query and runtime state with\ndocs/frontend-state-architecture.md:26:  durable session data.\ndocs/frontend-state-architecture.md:28:  mutating or duplicating the session snapshot shape.\ndocs/frontend-state-architecture.md:35:const recentSessionsQuery = useRecentSessionsQuery()\ndocs/frontend-state-architecture.md:36:const sessions = recentSessionsQuery.data ?? []\ndocs/frontend-state-architecture.md:42:<SessionWorkspaceProvider sessionId={sessionId}>\ndocs/frontend-state-architecture.md:43:  <SessionWorkspaceContent />\ndocs/frontend-state-architecture.md:44:</SessionWorkspaceProvider>\ndocs/frontend-state-architecture.md:48:const snapshotQuery = useCurrentSessionSnapshotQuery()\ndocs/frontend-state-architecture.md:49:const pendingActions = useSessionPendingActions()\ndocs/frontend-state-architecture.md:50:const eventStream = useSessionEventStream()\ndocs/frontend-state-architecture.md:56:const runtime = useSessionRuntimeActions()\ndocs/frontend-state-architecture.md:60:  label: 'Accepted revised beat sheet',\nbackend/tests/test_chat_action_contracts.py:12:    SelectGenreAction,\nbackend/tests/test_chat_action_contracts.py:27:                    \"action_type\": \"select_genre\",\nbackend/tests/test_chat_action_contracts.py:28:                    \"target_stage\": \"genre\",\nbackend/tests/test_chat_action_contracts.py:30:                    \"rationale\": \"The user explicitly named a catalog genre.\",\nbackend/tests/test_chat_action_contracts.py:33:                        \"genre_slug\": \"quest-fantasy\",\nbackend/tests/test_chat_action_contracts.py:67:    assert isinstance(batch.actions[0], SelectGenreAction)\nbackend/tests/test_chat_action_contracts.py:76:        match=\"select_genre must require confirmation under the default policy\",\nbackend/tests/test_chat_action_contracts.py:84:                        \"action_type\": \"select_genre\",\nbackend/tests/test_chat_action_contracts.py:85:                        \"target_stage\": \"genre\",\nbackend/tests/test_chat_action_contracts.py:89:                            \"genre_label\": \"Quest Fantasy\",\nbackend/tests/test_chat_action_contracts.py:145:        get_chat_to_ui_action_default_policy(ChatToUIActionType.SELECT_PITCH)\ndocs/adr/0001-core-runtime-architecture.md:8:Storyteller is a session-based bedtime story studio, not a single-shot prompt demo. A user needs to move through a staged workflow, leave, come back later, and still see the current plan, generated text, generated audio, and recent activity.\ndocs/adr/0001-core-runtime-architecture.md:13:- session state needs to survive refreshes, restarts, and long-running work\ndocs/adr/0001-core-runtime-architecture.md:29:- The backend policy layer decides whether a model-suggested action is valid for the current workflow stage before state changes are accepted.\ndocs/adr/0001-core-runtime-architecture.md:33:PostgreSQL owns the structured state required to resume a story session.\ndocs/adr/0001-core-runtime-architecture.md:37:- session\ndocs/adr/0001-core-runtime-architecture.md:38:- workflow stage\ndocs/adr/0001-core-runtime-architecture.md:40:- selected genre and tone\ndocs/adr/0001-core-runtime-architecture.md:41:- brief, pitch batch, selected pitch\ndocs/adr/0001-core-runtime-architecture.md:42:- character sheet candidates and selection\ndocs/adr/0001-core-runtime-architecture.md:43:- beat sheet\ndocs/adr/0001-core-runtime-architecture.md:49:Session resume should come from durable state, not browser cache. The event history is part of the product, not just an internal log, because it supports replay, auditability, and UI-to-chat echoes.\ndocs/adr/0001-core-runtime-architecture.md:66:- WebSockets handle session progress, job status, and incremental event delivery.\ndocs/adr/0001-core-runtime-architecture.md:67:- On reconnect, the client should rehydrate from durable session state and recent event history before continuing with live updates.\ndocs/adr/0001-core-runtime-architecture.md:69:The websocket channel is a delivery mechanism, not the source of truth. If a socket drops, the session must still be recoverable from PostgreSQL and storage.\ndocs/adr/0001-core-runtime-architecture.md:85:- They guide pitch generation, beat planning, and composition prompts.\ndocs/adr/0001-core-runtime-architecture.md:87:- They should not be enforced as exact cutoffs that distort story quality or bedtime tone.\ndocs/adr/0001-core-runtime-architecture.md:110:- Treat the durable event history as product data that can be queried during session resume.\ndocs/README.md:9:- `domain-model.md`: durable session entities, workflow-stage contract, and stage-state rules\ndocs/README.md:15:- `realtime-events.md`: session-channel contract, live event families, replay rules, and local auth assumptions\ndocs/README.md:16:- `realtime-events.schema.json`: machine-readable schema bundle for subscription frames and session events\ndocs/README.md:17:- `genre-tone-catalog.md`: curated catalog provenance, editing rules, and seed command\nfrontend/src/vite-env.d.ts:4:  readonly VITE_SESSION_EVENTS_WS_URL?: string\ndocs/system-diagram.md:3:This diagram shows the intended runtime shape for Storyteller after the core session, worker, and realtime prompts are built. It documents where session resume, durable event history, realtime delivery, and long-running jobs belong.\ndocs/system-diagram.md:7:    Browser[\"Browser UI<br/>React + Vite<br/>sessions home, chat pane, workflow pane\"]\ndocs/system-diagram.md:8:    API[\"FastAPI API<br/>routes, policy checks, session reads/writes\"]\ndocs/system-diagram.md:9:    WS[\"WebSocket session stream<br/>replay recent events + deliver live progress\"]\ndocs/system-diagram.md:11:    Postgres[(\"PostgreSQL<br/>sessions, workflow state,<br/>durable event history,<br/>job records, asset metadata\")]\ndocs/system-diagram.md:16:    API -->|\"resume session snapshot\"| Browser\ndocs/system-diagram.md:35:- Resume starts from PostgreSQL session state plus durable event history.\ndocs/system-diagram.md:42:Word count, runtime, and chapter count are soft planning hints. They shape prompts and estimates, but the system should favor story quality, bedtime tone, and coherent pacing over exact numeric compliance.\nfrontend/README.md:10:- `src/app/router.tsx`: browser-router configuration for the home page, session workspace, and not-found fallback\nfrontend/README.md:12:- `src/app/routePaths.ts`: central path helpers, including the session-workspace URL builder\nfrontend/README.md:19:- `src/features/session/sessionQueries.ts`: React Query hooks and cache keys for session server state\nfrontend/README.md:20:- `src/features/session/sessionRuntimeStore.ts`: local session runtime store for live events and optimistic actions\nfrontend/README.md:28:- `src/features/`: reusable product-domain logic that can be shared across pages, including session query hooks and runtime state\nfrontend/README.md:32:- `src/state/`: state models and future global/session store modules\nfrontend/README.md:44:Later prompts should extend this TypeScript app into the sessions-first workspace rather than replacing it.\nbackend/tests/test_action_policy_api.py:7:from app.db import Base, Genre, ToneProfile\nbackend/tests/test_action_policy_api.py:8:from app.db.session import get_engine, get_session_factory\nbackend/tests/test_action_policy_api.py:10:from app.services import SessionService\nbackend/tests/test_action_policy_api.py:25:    get_session_factory.cache_clear()\nbackend/tests/test_action_policy_api.py:35:    get_session_factory.cache_clear()\nbackend/tests/test_action_policy_api.py:41:    db_session = get_session_factory()()\nbackend/tests/test_action_policy_api.py:43:        genre = Genre(\nbackend/tests/test_action_policy_api.py:48:        tone = ToneProfile(\nbackend/tests/test_action_policy_api.py:49:            genre=genre,\nbackend/tests/test_action_policy_api.py:54:        db_session.add_all([genre, tone])\nbackend/tests/test_action_policy_api.py:55:        db_session.flush()\nbackend/tests/test_action_policy_api.py:56:        session_id = SessionService(db_session).create_session(working_title=\"Lantern Cove\").id\nbackend/tests/test_action_policy_api.py:57:        db_session.commit()\nbackend/tests/test_action_policy_api.py:59:        db_session.close()\nbackend/tests/test_action_policy_api.py:62:        f\"/api/v1/sessions/{session_id}/actions/evaluate\",\nbackend/tests/test_action_policy_api.py:68:                        \"action_type\": \"select_tone\",\nbackend/tests/test_action_policy_api.py:69:                        \"target_stage\": \"tone\",\nbackend/tests/test_action_policy_api.py:71:                        \"rationale\": \"The user asked for a hushed tone.\",\nbackend/tests/test_action_policy_api.py:74:                            \"tone_profile_slug\": \"hushed-wonder\",\nbackend/tests/test_action_policy_api.py:84:    assert payload[\"session_id\"] == session_id\nbackend/tests/test_action_policy_api.py:86:    assert payload[\"evaluated_actions\"][0][\"prerequisite_action_types\"] == [\"select_genre\"]\nbackend/tests/test_action_policy_api.py:92:def test_evaluate_actions_endpoint_returns_404_for_missing_session(\nbackend/tests/test_action_policy_api.py:96:        \"/api/v1/sessions/missing-session/actions/evaluate\",\nbackend/tests/test_action_policy_api.py:101:    assert response.json() == {\"detail\": \"session 'missing-session' was not found\"}\ndocs/realtime-events.schema.json:5:    \"session_event\": {\ndocs/realtime-events.schema.json:59:              \"$ref\": \"#/$defs/SessionEventActor\"\ndocs/realtime-events.schema.json:117:            \"session_id\": {\ndocs/realtime-events.schema.json:119:              \"title\": \"Session Id\",\ndocs/realtime-events.schema.json:141:            \"session_id\",\ndocs/realtime-events.schema.json:274:              \"$ref\": \"#/$defs/SessionEventActor\"\ndocs/realtime-events.schema.json:334:            \"session_id\": {\ndocs/realtime-events.schema.json:336:              \"title\": \"Session Id\",\ndocs/realtime-events.schema.json:353:            \"session_id\",\ndocs/realtime-events.schema.json:438:              \"$ref\": \"#/$defs/SessionEventActor\"\ndocs/realtime-events.schema.json:496:            \"session_id\": {\ndocs/realtime-events.schema.json:498:              \"title\": \"Session Id\",\ndocs/realtime-events.schema.json:520:            \"session_id\",\ndocs/realtime-events.schema.json:768:              \"$ref\": \"#/$defs/SessionEventActor\"\ndocs/realtime-events.schema.json:826:            \"session_id\": {\ndocs/realtime-events.schema.json:828:              \"title\": \"Session Id\",\ndocs/realtime-events.schema.json:850:            \"session_id\",\ndocs/realtime-events.schema.json:992:              \"$ref\": \"#/$defs/SessionEventActor\"\ndocs/realtime-events.schema.json:1050:            \"session_id\": {\ndocs/realtime-events.schema.json:1052:              \"title\": \"Session Id\",\ndocs/realtime-events.schema.json:1074:            \"session_id\",\ndocs/realtime-events.schema.json:1106:        \"SessionEventActor\": {\ndocs/realtime-events.schema.json:1128:          \"title\": \"SessionEventActor\",\ndocs/realtime-events.schema.json:1219:              \"$ref\": \"#/$defs/SessionEventActor\"\ndocs/