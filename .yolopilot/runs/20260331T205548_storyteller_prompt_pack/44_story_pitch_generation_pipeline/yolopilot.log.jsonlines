.image.title=fake-gcs-server,com.docker.compose.container-number=1,org.opencontainers.image.created=2026-02-14T14:26:39.911Z,com.docker.compose.config-hash=3af81cd2ef47ec0d6751038b81bed6b2ec36aa5cad54f5df40c11665f753b1ff,com.docker.compose.depends_on=,com.docker.compose.version=5.1.0,desktop.docker.io/ports.scheme=v2,desktop.docker.io/ports/4443/tcp=:8568,com.docker.compose.oneoff=False,com.docker.compose.project=storyteller,com.docker.compose.project.config_files=/Users/kevin/code/storyteller/infra/compose/docker-compose.yml,com.docker.compose.project.working_dir=/Users/kevin/code/storyteller/infra/compose,org.opencontainers.image.description=Google Cloud Storage emulator \\u0026 testing library.\",\"LocalVolumes\":\"1\",\"Mounts\":\"storyteller_gc\u2026\",\"Name\":\"storyteller-gcs-1\",\"Names\":\"storyteller-gcs-1\",\"Networks\":\"storyteller_default\",\"Ports\":\"0.0.0.0:8568-\\u003e4443/tcp, [::]:8568-\\u003e4443/tcp\",\"Project\":\"storyteller\",\"Publishers\":[{\"URL\":\"0.0.0.0\",\"TargetPort\":4443,\"PublishedPort\":8568,\"Protocol\":\"tcp\"},{\"URL\":\"::\",\"TargetPort\":4443,\"PublishedPort\":8568,\"Protocol\":\"tcp\"}],\"RunningFor\":\"23 hours ago\",\"Service\":\"gcs\",\"Size\":\"0B\",\"State\":\"running\",\"Status\":\"Up 23 hours (healthy)\"}\n{\"Command\":\"\\\"docker-entrypoint.s\u2026\\\"\",\"CreatedAt\":\"2026-03-31 22:34:25 -0700 PDT\",\"ExitCode\":0,\"Health\":\"healthy\",\"ID\":\"8a86150eb93e\",\"Image\":\"postgres:16-alpine\",\"Labels\":\"com.docker.compose.container-number=1,com.docker.compose.image=sha256:20edbde7749f822887a1a022ad526fde0a47d6b2be9a8364433605cf65099416,com.docker.compose.oneoff=False,com.docker.compose.project.working_dir=/Users/kevin/code/storyteller/infra/compose,com.docker.compose.version=5.1.0,desktop.docker.io/ports/5432/tcp=:8567,com.docker.compose.config-hash=db79a9cebe759dd28e8d8d05dc7d161e005784bacf23a0175e9153579436bab5,com.docker.compose.depends_on=,com.docker.compose.project=storyteller,com.docker.compose.project