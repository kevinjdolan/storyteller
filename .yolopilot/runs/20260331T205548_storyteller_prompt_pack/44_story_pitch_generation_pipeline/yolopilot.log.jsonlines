atch(db_session) -> None:\nbackend/tests/test_action_policy_service.py:96:    catalog = _seed_catalog(db_session)\nbackend/tests/test_action_policy_service.py:97:    session_id = SessionService(db_session).create_session(working_title=\"Policy\").id\nbackend/tests/test_action_policy_service.py:99:    request = SessionActionPolicyEvaluationRequest.model_validate(\nbackend/tests/test_action_policy_service.py:106:                        \"action_type\": \"select_genre\",\nbackend/tests/test_action_policy_service.py:107:                        \"target_stage\": \"genre\",\nbackend/tests/test_action_policy_service.py:112:                            \"genre_slug\": catalog[\"quest_fantasy\"].slug,\nbackend/tests/test_action_policy_service.py:119:                        \"action_type\": \"select_tone\",\nbackend/tests/test_action_policy_service.py:120:                        \"target_stage\": \"tone\",\nbackend/tests/test_action_policy_service.py:122:                        \"rationale\": \"The user asked for a hushed tone.\",\nbackend/tests/test_action_policy_service.py:125:                            \"tone_profile_slug\": catalog[\"hushed_wonder\"].slug,\nbackend/tests/test_action_policy_service.py:133:    result = SessionActionPolicyService(db_session).evaluate_request(\nbackend/tests/test_action_policy_service.py:134:        session_id,\nbackend/tests/test_action_policy_service.py:138:    assert result.evaluated_actions[0].decision == SessionActionDecision.ACCEPTED\nbackend/tests/test_action_policy_service.py:139:    assert result.evaluated_actions[1].decision == SessionActionDecision.REQUIRES_CONFIRMATION\nbackend/tests/test_action_policy_service.py:144:    db_session,\nbackend/tests/test_action_policy_service.py:146:    catalog = _seed_catalog(db_session)\nbackend/tests/test_action_policy_service.py:147:    seeded = _create_story_setup_session(\nbackend/tests/test_action_policy_service.py:148:        db_session,\nbackend/tests/test_action_policy_service.py:152:    request = SessionActionPolicyEvaluationRequest.model_validate(\nbackend/tests/test_action_policy_service.py:172:    preview = SessionActionPolicyService(db_session).evaluate_request(\nbackend/tests/test_action_policy_service.py:173:        seeded[\"session_id\"],\nbackend/tests/test_action_policy_service.py:176:    confirmed = SessionActionPolicyEvaluationRequest.model_validate(\nbackend/tests/test_action_policy_service.py:186:    applied = SessionActionPolicyService(db_session).evaluate_request(\nbackend/tests/test_action_policy_service.py:187:        seeded[\"session_id\"],\nbackend/tests/test_action_policy_service.py:194:    assert preview_item.decision == SessionActionDecision.REQUIRES_CONFIRMATION\nbackend/tests/test_action_policy_service.py:197:        == SessionActionReasonCode.CONFIRMATION_REQUIRED_DUE_TO_SIDE_EFFECTS\nbackend/tests/test_action_policy_service.py:200:        effect.kind == SessionActionSideEffectKind.INVALIDATE_STAGES\nbackend/tests/test_action_policy_service.py:205:        effect.kind == SessionActionSideEffectKind.STOP_ACTIVE_JOB\nbackend/tests/test_action_policy_service.py:210:    assert applied_item.decision == SessionActionDecision.ACCEPTED_WITH_SIDE_EFFECTS\nbackend/tests/test_action_policy_service.py:213:def test_policy_rejects_audio_generation_when_story_text_is_not_ready(db_session) -> None:\nbackend/tests/test_action_policy_service.py:214:    catalog = _seed_catalog(db_session)\nbackend/tests/test_action_policy_service.py:215:    seeded = _create_story_setup_session(\nbackend/tests/test_action_policy_service.py:216:        db_session,\nbackend/tests/test_action_policy_service.py:220:    request = SessionActionPolicyEvaluationRequest.model_validate(\nbackend/tests/test_action_policy_service.py:241:    result = SessionActionPolicyService(db_session).evaluate_request(\nbackend/tests/test_action_policy_service.py:242:        seeded[\"session_id\"],\nbackend/tests/test_action_policy_service.py:246:    assert result.evaluated_actions[0].de