over {\n  transform: translateY(-1px);\n}\n\n.selection-card--selected {\n  border-color: rgba(169, 116, 60, 0.24);\n  background:\n    linear-gradient(\n      180deg,\n      rgba(255, 250, 242, 0.98),\n      rgba(255, 255, 255, 0.78)\n    ),\n    var(--color-surface-strong);\n  box-shadow:\n    inset 0 0 0 1px rgba(169, 116, 60, 0.14),\n    var(--shadow-surface-md);\n}\n\n.selection-card__header {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr) auto;\n  align-items: start;\n  gap: var(--space-3);\n}\n\n.selection-card__leading {\n  width: 2.5rem;\n  height: 2.5rem;\n  display: inline-grid;\n  place-items: center;\n  border-radius: var(--radius-pill);\n  background: rgba(39, 69, 99, 0.12);\n  color: var(--color-brand);\n  font-family: var(--font-family-mono);\n  font-weight: 700;\n}\n\n.selection-card__copy,\n.split-card__body,\n.split-card__aside,\n.summary-panel__body {\n  display: grid;\n  gap: var(--space-3);\n}\n\n.selection-card__eyebrow,\n.split-card__eyebrow {\n  margin: 0 0 var(--space-1);\n  font-size: 0.78rem;\n  font-weight: 700;\n  letter-spacing: 0.12em;\n  text-transform: uppercase;\n  color: var(--color-gold);\n}\n\n.selection-card__title,\n.summary-panel__title,\n.split-card__title {\n  margin: 0;\n  font-family: var(--font-family-display);\n  color: var(--color-ink-strong);\n}\n\n.selection-card__description,\n.summary-panel__description,\n.split-card__description,\n.empty-state-block__description,\n.inline-help__body {\n  margin: 0;\n  color: var(--color-ink-soft);\n}\n\n.selection-card__meta,\n.split-card__meta {\n  display: flex;\n  align-items: start;\n  justify-content: end;\n  flex-wrap: wrap;\n  gap: var(--space-2);\n}\n\n.selection-card__body,\n", "command": "/bin/zsh -lc \"sed -n '420,880p' frontend/src/styles/index.css\"", "exit_code": 0, "id": "item_53", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 105, "prompt_index": 42, "prompt_name": "41 \u201