5, 255, 255, 0.62);\n  --color-border-soft: rgba(35, 49, 64, 0.12);\n  --color-border-strong: rgba(35, 49, 64, 0.18);\n\n  --shadow-surface-lg: 0 28px 80px rgba(24, 32, 40, 0.14);\n  --shadow-surface-md: 0 18px 42px rgba(24, 32, 40, 0.08);\n  --shadow-button: 0 18px 32px rgba(39, 69, 99, 0.2);\n\n  --focus-outline-color: #3f6da8;\n  --focus-ring-color: rgba(63, 109, 168, 0.22);\n}\n\n* {\n  box-sizing: border-box;\n}\n\nhtml {\n  min-height: 100%;\n}\n\nbody {\n  margin: 0;\n  min-height: 100vh;\n  color: var(--color-ink-strong);\n  background:\n    radial-gradient(\n      circle at top left,\n      var(--color-page-glow-left),\n      transparent 34%\n    ),\n    radial-gradient(\n      circle at top right,\n      var(--color-page-glow-right),\n      transparent 30%\n    ),\n    linear-gradient(\n      180deg,\n      var(--color-page-top) 0%,\n      #faf5ee 42%,\n      var(--color-page-bottom) 100%\n    );\n}\n\nbody,\n#root {\n  min-height: 100vh;\n}\n\nimg {\n  display: block;\n  max-width: 100%;\n}\n\nbutton,\ninput,\ntextarea,\nselect {\n  font: inherit;\n}\n\nbutton:not(:disabled) {\n  cursor: pointer;\n}\n\na {\n  color: inherit;\n}\n\n::selection {\n  color: #fffaf3;\n  background: rgba(39, 69, 99, 0.46);\n}\n\n:where(a, button, input, textarea, select, [tabindex]):focus-visible {\n  outline: 2px solid var(--focus-outline-color);\n  outline-offset: 3px;\n  box-shadow: 0 0 0 0.375rem var(--focus-ring-color);\n}\n\n.visually-hidden {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n.skip-link {\n  position: absolute;\n  top: var(--space-4);\n  left: var(--space-4);\n  z-index: 5;\n  padding: 0.7rem 0.95rem;\n  border-radius: var(--radius-pill);\n  background: var(--color-brand);\n  color: #fbf7f1;\n  text-decoration: none;\n  transform: translateY(-150%);\n  transition: transform 160ms ease;\n}\n\n.skip-link:focus-visible {\n  transform: translateY(0);\n}\n\n.eyebrow,\n.app-kicker {\n  margin: 0;\n  font-size: var(--font-size-label);\n  font-weight: 700;\n  letter-spacing: 0.18em;\n  text-transform: uppercase;\n  color: var(--color-gold);\n}\n\n.body-copy,\n.panel__description,\n.panel-heading p,\n.session-group__header p,\n.session-card__timestamp,\n.session-summary-card span,\n.workspace-topbar__status-card dt,\n.workspace-chat-pane__status,\n.workspace-chat-entry p,\n.workspace-chat-entry time,\n.workspace-chat-composer p,\n.workspace-stage-card__header p,\n.workspace-stage-card__meta p,\n.workspace-stage-nav__copy p,\n.workspace-stage-detail__note,\n.workspace-stage-detail-card p,\n.workspace-stage-detail__list p,\n.feedback-banner__description,\n.workspace-summary-card p,\n.connection-indicator__detail,\n.toast-card__body {\n  margin: 0;\n  color: var(--color-ink-soft);\n}\n\n.panel {\n  position: relative;\n  padding: var(--space-7);\n  border: 1px solid var(--color-border-soft);\n  border-radius: var(--radius-xl);\n  background: var(--color-surface);\n  box-shadow: var(--shadow-surface-lg);\n  backdrop-filter: blur(18px);\n}\n\n.panel--hero {\n  background:\n    linear-gradient(\n      140deg,\n      rgba(255, 250, 244, 0.98),\n      rgba(244, 238, 230, 0.94)\n    ),\n    var(--color-surface-strong);\n}\n\n.panel--subtle {\n  background: rgba(255, 252, 248, 0.76);\n  box-shadow: var(--shadow-surface-md);\n}\n\n.panel__header {\n  display: flex;\n  align-items: start;\n  justify-content: space-between;\n  gap: var(--space-4);\n  margin-bottom: var(--space-6);\n}\n\n.panel__copy {\n  display: grid;\n  gap: var(--space-2);\n  min-width: 0;\n}\n\n.panel__title,\n.app-brand,\nh1,\nh2,\nh3,\nh4 {\n  margin: 0;\n  font-family: var(--font-family-display);\n  letter-spacing: -0.02em;\n  line-height: var(--line-height-tight);\n}\n\n.panel__title {\n  font-size: clamp(1.55rem, 2.6vw, 2.1rem);\n  color: var(--color-ink-strong);\n}\n\n.panel__description {\n  display: grid;\n  gap: var(--space-3);\n}\