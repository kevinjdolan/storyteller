notes\": _normalize_optional_text(current_brief.planning_notes)\n   797\t        if current_brief is not None\n   798\t        else None,\n   799\t        \"raw_brief\": _normalize_optional_text(current_brief.raw_brief)\n   800\t        if current_brief is not None\n   801\t        else None,\n   802\t    }\n   803\t    incoming_values = {\n   804\t        \"story_idea\": incoming_story_idea,\n   805\t        \"desired_themes\": _normalize_optional_text(desired_themes),\n   806\t        \"key_images\": _normalize_optional_text(key_images),\n   807\t        \"audience_notes\": _normalize_optional_text(audience_notes),\n   808\t        \"must_have_elements\": _normalize_optional_text(must_have_elements),\n   809\t        \"normalized_summary\": _normalize_optional_text(normalized_summary),\n   810\t        \"planning_notes\": _normalize_optional_text(planning_notes),\n   811\t    }\n   812\t\n   813\t    resolved_values = {\n   814\t        field_name: _resolve_story_brief_value(\n   815\t            current_values[field_name],\n   816\t            incoming_values[field_name],\n   817\t            edit_mode=edit_mode,\n   818\t        )\n   819\t        for field_name in _STORY_BRIEF_TEXT_FIELDS\n   820\t    }\n   821\t    composed_raw_brief = _compose_story_brief_text(\n   822\t        story_idea=resolved_values[\"story_idea\"],\n   823\t        desired_themes=resolved_values[\"desired_themes\"],\n   824\t        key_images=resolved_values[\"key_images\"],\n   825\t        audience_notes=resolved_values[\"audience_notes\"],\n   826\t        must_have_elements=resolved_values[\"must_have_elements\"],\n   827\t    )\n   828\t\n   829\t    if composed_raw_brief is None:\n   830\t        composed_raw_brief = _resolve_story_brief_value(\n   831\t            current_values[\"raw_brief\"],\n   832\t            _normalize_optional_text(raw_brief),\n   833\t            edit_mode=edit_mode,\n   834\t        )\n   835\t\n   836\t    if composed_raw_brief is None:\n   837\t        raise SessionStoryBriefSaveError(\n   838\t            \"story brief content requires a story idea or free-form brief before it can be saved\"\n   839\t        )\n   840\t\n   841\t    resolved_values[\"raw_brief\"] = composed_raw_brief\n   842\t    return resolved_values\n   843\t\n   844\t\n   845\tdef _resolve_story_brief_value(\n   846\t    current_value: str | None,\n   847\t    incoming_value: str | None,\n   848\t    *,\n   849\t    edit_mode: StoryBriefEditMode,\n   850\t) -> str | None:\n   851\t    if edit_mode == StoryBriefEditMode.REPLACE:\n   852\t        return incoming_value\n   853\t\n   854\t    if edit_mode == StoryBriefEditMode.APPEND:\n   855\t        if incoming_value is None:\n   856\t            return current_value\n   857\t        if current_value is None:\n   858\t            return incoming_value\n   859\t        if incoming_value in current_value:\n   860\t            return current_value\n   861\t        return f\"{current_value.rstrip()}\\n\\n{incoming_value.lstrip()}\"\n   862\t\n   863\t    return incoming_value if incoming_value is not None else current_value\n   864\t\n   865\t\n   866\tdef _compose_story_brief_text(\n   867\t    *,\n   868\t    story_idea: str | None,\n   869\t    desired_themes: str | None,\n   870\t    key_images: str | None,\n   871\t    audience_notes: str | None,\n   872\t    must_have_elements: str | None,\n   873\t) -> str | None:\n   874\t    sections: list[str] = []\n   875\t\n   876\t    if story_idea is not None:\n   877\t        sections.append(story_idea)\n   878\t\n   879\t    for label, value in (\n   880\t        (\"Desired themes\", desired_themes),\n   881\t        (\"Key images\", key_images),\n   882\t        (\"Target audience notes\", audience_notes),\n   883\t        (\"Must-have elements\", must_have_elements),\n   884\t    ):\n   885\t        if value is not None:\n   886\t            sections.append(f\"{label}: {value}\")\n   887\t\n   888\t    if not sections:\n   889\t        return None\n   890\t\n   891\t    return \"\\n\\n\".join(sections)\n   892\t\n   893\t\n   894\tdef _build_story_brief_stage_detail(value: str) -> str:\n   895\t    return f\"Saved story brief: {_truncate_story_brief_text(value, limit=160)}\"\n   896\t\n   897\t\n   898\tdef _build_story_brief_invalidation_detail() -> str:\n   899\t    return \"Story brief changed. Refresh pitches and any downstream planning.\"\n   900\t\n   901\t\n   902\tdef _build_story_brief_changed_fields(\n   903\t    previous_brief: StoryBrief | None,\n   904\t    new_brief: StoryBrief,\n   905\t) -> list[str]:\n   906\t    if previous_brief is None:\n   907\t        return [\n   908\t            field_name\n   909\t            for field_name in (\n   910\t                \"story_idea\",\n   911\t                \"desired_themes\",\n   912\t                \"key_images\",\n   913\t                \"audience_notes\",\n   914\t                \"must_have_elements\",\n   915\t                \"raw_brief\",\n   916\t                \"normalized_summary\",\n   917\t                \"planning_notes\",\n   918\t            )\n   919\t            if getattr(new_brief, field_name) is not None\n   920\t        ]\n   921\t\n   922\t    changed_fields: list[str] = []\n   923\t    for field_name in (\n   924\t        \"story_idea\",\n   925\t        \"desired_themes\",\n   926\t        \"key_images\",\n   927\t        \"audience_notes\",\n   928\t        \"must_have_elements\",\n   929\t        \"raw_brief\",\n   930\t        \"normalized_summary\",\n   931\t        \"planning_notes\",\n   932\t    ):\n   933\t        if getattr(previous_brief, field_name) != getattr(new_brief, field_name):\n   934\t            changed_fields.append(field_name)\n   935\t\n   936\t    return changed_fields or [\"raw_brief\"]\n   937\t\n   938\t\n   939\tdef _build_story_brief_event_values(\n   940\t    story_brief: StoryBrief,\n   941\t    *,\n   942\t    edit_mode: StoryBriefEditMode,\n   943\t) -> dict[str, str | int | None]:\n   944\t    return {\n   945\t        \"story_idea\": story_brief.story_idea,\n   946\t        \"desired_themes\": story_brief.desired_themes,\n   947\t        \"key_images\": story_brief.key_images,\n   948\t        \"audience_notes\": story_brief.audience_notes,\n   949\t        \"must_have_elements\": story_brief.must_have_elements,\n   950\t        \"raw_brief\": story_brief.raw_brief,\n   951\t        \"normalized_summary\": story_brief.normalized_summary,\n   952\t        \"planning_notes\": story_brief.planning_notes,\n   953\t        \"edit_mode\": edit_mode.value,\n   954\t        \"revision_number\": story_brief.revision_number,\n   955\t    }\n   956\t\n   957\t\n   958\tdef _build_story_brief_summary_text(*, has_existing_brief: bool, origin: str) -> str:\n   959\t    action = \"Updated\" if has_existing_brief else \"Saved\"\n   960\t    return f\"{action} story brief from {origin}.\"\n   961\t\n   962\t\n   963\tdef _truncate_story_brief_text(value: str, *, limit: int) -> str:\n   964\t    if len(value) <= limit:\n   965\t        return value\n   966\t\n   967\t    return f\"{value[: limit - 3].rstrip()}...\"\n", "command": "/bin/zsh -lc \"nl -ba backend/app/services/sessions.py | sed -n '760,980p'\"", "exit_code": 0, "id": "item_320", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 603, "prompt_index": 43, "prompt_name": "42 \u2014 Story Setup Brief Form", "prompt_total": 100}, "timestap": "2026-04-01T20:07:49-07:00"}
