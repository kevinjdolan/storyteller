er__footer {\n  display: flex;\n  align-items: start;\n  justify-content: space-between;\n  gap: var(--space-3);\n}\n\n.workspace-chat-composer__header strong {\n  display: block;\n  margin-bottom: var(--space-2);\n}\n\n.workspace-chat-composer__footer {\n  align-items: center;\n}\n\n.workspace-overview-grid {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: var(--space-3);\n}\n\n.workspace-summary-card {\n  padding: 1rem;\n  border-radius: var(--radius-lg);\n}\n\n.workspace-summary-card strong {\n  display: block;\n  margin-bottom: var(--space-3);\n  font-size: 1.1rem;\n}\n\n.workspace-stage-shell {\n  display: grid;\n  grid-template-columns: minmax(19rem, 0.95fr) minmax(0, 1.35fr);\n  gap: var(--space-4);\n}\n\n.workspace-stage-navigator,\n.workspace-stage-detail,\n.workspace-stage-detail-card {\n  border: 1px solid rgba(39, 69, 99, 0.08);\n  background: var(--color-surface-muted);\n}\n\n.workspace-stage-navigator {\n  display: grid;\n  gap: var(--space-4);\n  padding: var(--space-4);\n  border-radius: var(--radius-xl);\n}\n\n.workspace-stage-nav__list,\n.workspace-stage-detail__list ul {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n}\n\n.workspace-stage-nav__list {\n  display: grid;\n  gap: var(--space-3);\n}\n\n.workspace-stage-nav__link {\n  display: grid;\n  gap: var(--space-3);\n  padding: var(--space-4);\n  border: 1px solid rgba(39, 69, 99, 0.08);\n  border-radius: var(--radius-xl);\n  background: rgba(255, 255, 255, 0.72);\n  text-decoration: none;\n  transition:\n    transform 160ms ease,\n    box-shadow 160ms ease,\n    border-color 160ms ease,\n    background-color 160ms ease;\n}\n\n.workspace-stage-nav__link:hover {\n  transform: translateY(-1px);\n}\n\n.workspace-stage-nav__link--selected {\n  border-color: rgba(169, 116, 60, 0.22);\n  background:\n    linear-gradient(\n      180deg,\n      rgba(255, 250, 242, 0.98),\n      rgba(255, 255, 255, 0.78)\n    ),\n    var(--color-surface-strong);\n  box-shadow: var(--shad