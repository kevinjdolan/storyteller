{\n    54\t  const normalized = normalizeText(value)\n    55\t  return normalized.length > 0 ? normalized : null\n    56\t}\n    57\t\n    58\tfunction buildFormState(snapshot: SessionSnapshot): StoryBriefFormState {\n    59\t  return {\n    60\t    storyIdea: snapshot.story_brief?.story_idea ?? '',\n    61\t    desiredThemes: snapshot.story_brief?.desired_themes ?? '',\n    62\t    keyImages: snapshot.story_brief?.key_images ?? '',\n    63\t    audienceNotes: snapshot.story_brief?.audience_notes ?? '',\n    64\t    mustHaveElements: snapshot.story_brief?.must_have_elements ?? '',\n    65\t  }\n    66\t}\n    67\t\n    68\tfunction buildCanonicalBriefPreview(values: StoryBriefFormState) {\n    69\t  const sections: string[] = []\n    70\t\n    71\t  if (normalizeText(values.storyIdea).length > 0) {\n    72\t    sections.push(normalizeText(values.storyIdea))\n    73\t  }\n    74\t\n    75\t  for (const [label, value] of [\n    76\t    ['Desired themes', values.desiredThemes],\n    77\t    ['Key images', values.keyImages],\n    78\t    ['Target audience notes', values.audienceNotes],\n    79\t    ['Must-have elements', values.mustHaveElements],\n    80\t  ] as const) {\n    81\t    const normalized = normalizeText(value)\n    82\t\n    83\t    if (normalized.length > 0) {\n    84\t      sections.push(`${label}: ${normalized}`)\n    85\t    }\n    86\t  }\n    87\t\n    88\t  return sections.join('\\n\\n')\n    89\t}\n    90\t\n    91\tfunction buildSpecificityCount(values: StoryBriefFormState) {\n    92\t  return [\n    93\t    values.desiredThemes,\n    94\t    values.keyImages,\n    95\t    values.audienceNotes,\n    96\t    values.mustHaveElements,\n    97\t  ].filter((value) => normalizeText(value).length > 0).length\n    98\t}\n    99\t\n   100\tfunction buildBriefTitle(values: StoryBriefFormState, snapshot: SessionSnapshot) {\n   101\t  const preview =\n   102\t    normalizeText(values.storyIdea) ||\n   103\t    snapshot.story_brief?.normalized_summary ||\n   104\t    snapshot.story_brief?.story_idea ||\n   105\t    ''\n   106\t\n   107\t  if (preview.length === 0) {\n   108\t    return 'Brief not saved yet'\n   109\t  }\n   110\t\n   111\t  if (preview.length <= 92) {\n   112\t    return preview\n   113\t  }\n   114\t\n   115\t  return `${preview.slice(0, 89).trimEnd()}...`\n   116\t}\n   117\t\n   118\tfunction buildRevisionHelp(\n   119\t  selectedStage: SessionWorkspaceStageView,\n   120\t  snapshot: SessionSnapshot,\n   121\t) {\n   122\t  if (selectedStage.availability === 'locked') {\n   123\t    return {\n   124\t      body: 'Finish genre and tone first. The brief stays previewable, but saving is disabled until the bedtime lane is fully chosen.',\n   125\t      title: 'Brief saving unlocks after tone',\n   126\t      tone: 'warning' as const,\n   127\t    }\n   128\t  }\n   129\t\n   130\t  if (\n   131\t    selectedStage.availability === 'revisitable' &&\n   132\t    snapshot.story_brief != null\n   133\t  ) {\n   134\t    return {\n   135\t      body: 'Editing a saved brief creates a new revision, keeps the latest version active, and refreshes pitches plus any later planning that depends on it.',\n   136\t      title: 'Revisions refresh downstream planning',\n   137\t      tone: 'warning' as const,\n   138\t    }\n   139\t  }\n   140\t\n   141\t  return {\n   142\t    body: 'Start with one or two natural sentences. Use the optional fields only when they add helpful specificity for later pitch generation.',\n   143\t    title: 'Keep the brief open-ended, not rigid',\n   144\t    tone: 'info' as const,\n   145\t  }\n   146\t}\n   147\t\n   148\tfunction formatUpdatedAt(value: string | null | undefined) {\n   149\t  if (value == null) {\n   150\t    return 'Not saved yet'\n   151\t  }\n   152\t\n   153\t  return `Saved ${savedAtFormatter.format(new Date(value))}`\n   154\t}\n   155\t\n   156\tfunction normalizeFormState(values: StoryBriefFormState) {\n   157\t  return {\n   158\t    storyIdea: normalizeText(values.storyIdea),\n   159\t    desiredThemes: normalizeText(values.desiredThemes),\n   160\t    keyImages: normalizeText(values.keyImages),\n   161\t    audienceNotes: normalizeText(values.audienceNotes),\n   162\t    mustHaveElements: normalizeText(values.mustHaveElements),\n   163\t  }\n   164\t}\n   165\t\n   166\tfunction formStatesMatch(\n   167\t  left: StoryBriefFormState,\n   168\t  right: StoryBriefFormState,\n   169\t) {\n   170\t  const normalizedLeft = normalizeFormState(left)\n   171\t  const normalizedRight = normalizeFormState(right)\n   172\t\n   173\t  return (\n   174\t    normalizedLeft.storyIdea === normalizedRight.storyIdea &&\n   175\t    normalizedLeft.desiredThemes === normalizedRight.desiredThemes &&\n   176\t    normalizedLeft.keyImages === normalizedRight.keyImages &&\n   177\t    normalizedLeft.audienceNotes === normalizedRight.audienceNotes &&\n   178\t    normalizedLeft.mustHaveElements === normalizedRight.mustHaveElements\n   179\t  )\n   180\t}\n   181\t\n   182\texport function StoryBriefStage({\n   183\t  onPreviewStage,\n   184\t  onSaveStoryBrief,\n   185\t  selectedStage,\n   186\t  snapshot,\n   187\t}: StoryBriefStageProps) {\n   188\t  const [formState, setFormState] = useState<StoryBriefFormState>(() =>\n   189\t    buildFormState(snapshot),\n   190\t  )\n   191\t  const [formError, setFormError] = useState<string | null>(null)\n   192\t  const [isSaving, setIsSaving] = useState(false)\n   193\t\n   194\t  useEffect(() => {\n   195\t    setFormState(buildFormState(snapshot))\n   196\t    setFormError(null)\n   197\t  }, [snapshot])\n   198\t\n   199\t  const savedState = buildFormState(snapshot)\n   200\t  const isLocked = selectedStage.availability === 'locked'\n   201\t  const specificityCount = buildSpecificityCount(formState)\n   202\t  const briefTitle = buildBriefTitle(formState, snapshot)\n   203\t  const canonicalPreview = buildCanonicalBriefPreview(formState)\n   204\t  const revisionHelp = buildRevisionHelp(selectedStage, snapshot)\n   205\t  const storyIdeaError =\n   206\t    !isLocked && normalizeText(formState.storyIdea).length === 0\n   207\t      ? 'Start with the bedtime story idea in your own words.'\n   208\t      : null\n   209\t  const isDirty = !formStatesMatch(formState, savedState)\n   210\t\n   211\t  async function handleSave() {\n   212\t    if (isLocked || storyIdeaError != null || isSaving || !isDirty) {\n   213\t      return\n   214\t    }\n   215\t\n   216\t    setIsSaving(true)\n   217\t    setFormError(null)\n   218\t\n   219\t    try {\n   220\t      await onSaveStoryBrief({\n   221\t        storyIdea: toNullableText(formState.storyIdea),\n   222\t        desiredThemes: toNullableText(formState.desiredThemes),\n   223\t        keyImages: toNullableText(formState.keyImages),\n   224\t        audienceNotes: toNullableText(formState.audienceNotes),\n   225\t        mustHaveElements: toNullableText(formState.mustHaveElements),\n   226\t        origin: 'workspace',\n   227\t      })\n   228\t    } catch (error) {\n   229\t      setFormError(\n   230\t        error instanceof Error\n   231\t          ? error.message\n   232\t          : 'The story brief could not be saved right now.',\n   233\t      )\n   234\t    } finally {\n   235\t      setIsSaving(false)\n   236\t    }\n   237\t  }\n   238\t\n   239\t  return (\n   240\t    <section aria-label=\"Story brief stage\" className=\"workspace-stage-panel\">\n   241\t      <CardGrid className=\"workspace-stage-detail__cards\" columns={3}>\n   242\t        <SummaryPanel\n   243\t          description={\n   244\t            snapshot.story_brief?.normalized_summary ??\n   245\t            'This is the durable bedtime prompt that later pitch generation will inherit.'\n   246\t          }\n   247\t          label=\"Current brief\"\n   248\t          title={briefTitle}\n   249\t          tone={snapshot.story_brief != null ? 'accent' : 'default'}\n   250\t        >\n   251\t          <div className=\"workspace-stage-detail__badges\">\n   252\t            {snapshot.story_brief != null ? (\n   253\t              <Badge tone=\"brand\">\n   254\t                Revision {snapshot.story_brief.revision_number}\n   255\t              </Badge>\n   256\t            ) : (\n   257\t              <Badge tone=\"warning\">Unsaved</Badge>\n   258\t            )}\n   259\t          </div>\n   260\t        </SummaryPanel>\n", "command": "/bin/zsh -lc \"nl -ba frontend/src/features/session/StoryBriefStage.tsx | sed -n '1,260p'\"", "exit_code": 0, "id": "item_314", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 591, "prompt_index": 43, "prompt_name": "42 \u2014 Story Setup Brief Form", "prompt_total": 100}, "timestap": "2026-04-01T20:07:49-07:00"}
