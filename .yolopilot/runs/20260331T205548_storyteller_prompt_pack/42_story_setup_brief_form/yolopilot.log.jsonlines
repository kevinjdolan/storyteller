kspace-stage-panel {\n  display: grid;\n  gap: var(--space-4);\n}\n\n.workspace-stage-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: var(--space-3);\n}\n\n.workspace-stage-card {\n  display: grid;\n  gap: var(--space-4);\n  padding: var(--space-4);\n  border-radius: var(--radius-xl);\n}\n\n.workspace-stage-card--current {\n  background:\n    linear-gradient(\n      180deg,\n      rgba(255, 250, 242, 0.98),\n      rgba(255, 255, 255, 0.76)\n    ),\n    var(--color-surface-strong);\n  box-shadow:\n    inset 0 0 0 1px rgba(169, 116, 60, 0.16),\n    var(--shadow-surface-md);\n}\n\n.workspace-stage-card__header {\n  display: flex;\n  align-items: start;\n  gap: var(--space-3);\n}\n\n.workspace-stage-card__header span {\n  width: 2rem;\n  height: 2rem;\n  display: inline-grid;\n  place-items: center;\n  flex-shrink: 0;\n  border-radius: var(--radius-pill);\n  color: var(--color-brand);\n  background: rgba(39, 69, 99, 0.12);\n  font-weight: 700;\n}\n\n.workspace-stage-card__header strong {\n  display: block;\n  margin-bottom: 0.25rem;\n}\n\n.workspace-stage-card__meta {\n  display: grid;\n  gap: var(--space-3);\n}\n\n.app-loading {\n  margin: 0;\n  padding: 20vh 24px;\n  text-align: center;\n  color: var(--color-ink-soft);\n}\n\n@media (max-width: 900px) {\n  .app-header,\n  .workspace-topbar {\n    display: flex;\n    flex-direction: column;\n    align-items: start;\n  }\n\n  .app-nav,\n  .app-caption {\n    justify-self: start;\n  }\n\n  .app-caption {\n    max-width: none;\n    text-align: left;\n  }\n\n  .app-utility-bar,\n  .session-summary-grid,\n  .session-card__meta,\n  .workspace-shell,\n  .workspace-stage-shell,\n  .workspace-stage-detail__cards,\n  .workspace-overview-grid,\n  .workspace-topbar__status,\n  .workspace-stage-grid,\n  .card-grid--2,\n  .card-grid--3,\n  .form-columns,\n  .sticky-summary-layout,\n  .split-card {\n    grid-template-columns: 1fr;\n  }\n\n  .workspace-topbar__actions {\n    width: 100%;\n    justify-items: stretch;\n  }\n\n  .split-card__aside {\n    padding-left: 0;\n    padding-top: var(--space-3);\n    border-left: 0;\n    border-top: 1px solid rgba(39, 69, 99, 0.08);\n  }\n\n  .workspace-pane--chat {\n    position: static;\n    max-height: none;\n  }\n\n  .workspace-chat-transcript {\n    max-height: 26rem;\n  }\n}\n\n@media (max-width: 640px) {\n  .app-shell {\n    padding-inline: 1rem;\n  }\n\n  .toast-region {\n    top: auto;\n    right: 1rem;\n    bottom: 1rem;\n    left: 1rem;\n", "command": "/bin/zsh -lc \"sed -n '1980,2195p' frontend/src/styles/index.css\"", "exit_code": 0, "id": "item_166", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 316, "prompt_index": 43, "prompt_name": "42 \u2014 Story Setup Brief Form", "prompt_total": 100}, "timestap": "2026-04-01T19:45:47-07:00"}
