 {\n   777\t    const result = await saveSessionStoryBrief(sessionId, {\n   778\t      story_idea: options.storyIdea ?? null,\n   779\t      desired_themes: options.desiredThemes ?? null,\n   780\t      key_images: options.keyImages ?? null,\n   781\t      audience_notes: options.audienceNotes ?? null,\n   782\t      must_have_elements: options.mustHaveElements ?? null,\n   783\t      raw_brief: options.rawBrief ?? null,\n   784\t      normalized_summary: options.normalizedSummary ?? null,\n   785\t      planning_notes: options.planningNotes ?? null,\n   786\t      edit_mode: options.editMode ?? 'replace',\n   787\t      origin: options.origin,\n   788\t    })\n   789\t\n   790\t    runtimeStore.hydrateSessionSnapshot(result.snapshot)\n   791\t    appendHistoryEventToChat(result.event)\n   792\t\n   793\t    if (options.previewCurrentStage !== false) {\n   794\t      setPreviewStage(result.snapshot.current_stage)\n   795\t    }\n   796\t\n   797\t    return result\n   798\t  }\n   799\t\n   800\t  async function applySupportedChatAction(action: ChatToUiAction) {\n   801\t    if (action.action_type === 'navigate_to_stage') {\n   802\t      setPreviewStage(action.target_stage)\n   803\t      await persistUiAction({\n   804\t        action: action.action_type,\n   805\t        stage: action.target_stage,\n   806\t        controlId: 'chat-intent',\n   807\t        origin: 'chat',\n   808\t        valueSummary: getWorkflowStageLabel(action.target_stage),\n   809\t      })\n   810\t      return\n   811\t    }\n   812\t\n   813\t    if (action.action_type === 'select_genre') {\n   814\t      await applyGenreSelection({\n   815\t        genreId: action.extracted_values.genre_id ?? null,\n   816\t        genreLabel: action.extracted_values.genre_label ?? null,\n   817\t        genreSlug: action.extracted_values.genre_slug ?? null,\n   818\t        origin: 'chat',\n   819\t      })\n   820\t      return\n   821\t    }\n   822\t\n   823\t    if (action.action_type === 'select_tone') {\n   824\t      await applyToneSelection({\n   825\t        toneProfileId: action.extracted_values.tone_profile_id ?? null,\n   826\t        toneProfileLabel: action.extracted_values.tone_profile_label ?? null,\n   827\t        toneProfileSlug: action.extracted_values.tone_profile_slug ?? null,\n   828\t        origin: 'chat',\n   829\t      })\n   830\t      return\n   831\t    }\n   832\t\n   833\t    if (action.action_type === 'update_story_brief') {\n   834\t      await applyStoryBriefSave({\n   835\t        storyIdea:\n   836\t          action.extracted_values.story_idea ??\n   837\t          action.extracted_values.raw_brief ??\n   838\t          null,\n   839\t        desiredThemes: action.extracted_values.desired_themes ?? null,\n   840\t        keyImages: action.extracted_values.key_images ?? null,\n   841\t        audienceNotes: action.extracted_values.audience_notes ?? null,\n   842\t        mustHaveElements: action.extracted_values.must_have_elements ?? null,\n   843\t        rawBrief: action.extracted_values.raw_brief ?? null,\n   844\t        normalizedSummary: action.extracted_values.normalized_summary ?? null,\n   845\t        planningNotes: action.extracted_values.planning_notes ?? null,\n   846\t        editMode: action.extracted_values.edit_mode,\n   847\t        origin: 'chat',\n   848\t      })\n   849\t      return\n   850\t    }\n   851\t\n   852\t    if (action.action_type === 'open_finalize_view') {\n   853\t      setPreviewStage('finalize')\n   854\t      await persistUiAction({\n   855\t        action: action.action_type,\n   856\t        stage: 'finalize',\n   857\t        controlId: 'chat-intent',\n   858\t        origin: 'chat',\n   859\t        valueSummary: 'Finalize',\n   860\t      })\n   861\t    }\n   862\t  }\n   863\t\n   864\t  async function submitChatTurn(options: {\n   865\t    explicitCommand?: SessionExplicitChatCommand | null\n   866\t    message: string\n   867\t  }) {\n   868\t    const submittedAt = new Date().toISOString()\n   869\t\n   870\t    runtimeStore.appendChatMessage(\n   871\t      createSessionChatMessage({\n   872\t        role: 'user',\n   873\t        body: options.message,\n   874\t        createdAt: submittedAt,\n   875\t      }),\n   876\t    )\n   877\t\n   878\t    const parsedIntent = await parseSessionChatIntent(\n   879\t      sessionId,\n   880\t      options.message,\n   881\t      {\n   882\t        explicitCommand: options.explicitCommand ?? null,\n   883\t      },\n   884\t    )\n   885\t    const assistantCreatedAt = new Date().toISOString()\n   886\t\n   887\t    runtimeStore.appendChatMessage(\n   888\t      createSessionChatMessage({\n   889\t        role: 'assistant',\n   890\t        body: parsedIntent.assistant_response,\n   891\t        createdAt: assistantCreatedAt,\n   892\t      }),\n   893\t    )\n   894\t\n   895\t    buildIntentActionEchoMessages({\n   896\t      result: parsedIntent,\n   897\t      createdAt: assistantCreatedAt,\n   898\t      idPrefix: `intent-${submittedAt}`,\n   899\t    }).forEach((actionEcho) => {\n   900\t      runtimeStore.appendChatMessage(actionEcho)\n   901\t    })\n   902\t\n   903\t    const evaluatedActions =\n   904\t      parsedIntent.policy_evaluation?.evaluated_actions ?? []\n   905\t\n   906\t    for (const evaluatedAction of evaluatedActions) {\n   907\t      if (\n   908\t        evaluatedAction.decision !== 'accepted' &&\n   909\t        evaluatedAction.decision !== 'accepted_with_side_effects'\n   910\t      ) {\n   911\t        continue\n   912\t      }\n   913\t\n   914\t      const action =\n   915\t        parsedIntent.proposed_actions.actions[evaluatedAction.action_index]\n   916\t\n   917\t      if (\n   918\t        action == null ||\n   919\t        (action.action_type !== 'navigate_to_stage' &&\n   920\t          action.action_type !== 'select_genre' &&\n   921\t          action.action_type !== 'select_tone' &&\n   922\t          action.action_type !== 'update_story_brief' &&\n   923\t          action.action_type !== 'open_finalize_view')\n   924\t      ) {\n   925\t        continue\n   926\t      }\n   927\t\n   928\t      await applySupportedChatAction(action).catch(() => {})\n   929\t    }\n   930\t  }\n", "command": "/bin/zsh -lc \"nl -ba frontend/src/pages/session/SessionWorkspacePage.tsx | sed -n '730,930p'\"", "exit_code": 0, "id": "item_315", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 593, "prompt_index": 43, "prompt_name": "42 \u2014 Story Setup Brief Form", "prompt_total": 100}, "timestap": "2026-04-01T20:07:49-07:00"}
