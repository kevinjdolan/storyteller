{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Started", "message": "in progress: /bin/zsh -lc \"docker compose -f infra/compose/docker-compose.yml exec -T backend python - <<'PY'\nfrom datetime import datetime, timezone\n\nfrom app.db import StorySetup, WorkflowStage, WorkflowStageState, get_session_factory\nfrom app.services.sessions import SessionService\n\nsession_factory = get_session_factory()\nwith session_factory() as db_session:\n    service = SessionService(db_session)\n    snapshot = service.create_session(working_title='Audio Estimate QA')\n\n    for stage in (\n        WorkflowStage.GENRE,\n        WorkflowStage.TONE,\n        WorkflowStage.BRIEF,\n        WorkflowStage.PITCHES,\n        WorkflowStage.CHARACTERS,\n        WorkflowStage.BEATS,\n    ):\n        service.update_stage_state(\n            snapshot.id,\n            stage=stage,\n            status=WorkflowStageState.COMPLETED,\n            detail=f'Accepted {stage.value}.',\n        )\n\n    story_setup = StorySetup(\n        session_id=snapshot.id,\n        revision_number=1,\n        target_word_count=1800,\n        target_runtime_minutes=12,\n        chapter_count=3,\n        guidance_notes='Three short chapters with calm chapter landings.',\n        is_selected=True,\n        accepted_at=datetime.now(timezone.utc),\n    )\n    db_session.add(story_setup)\n    db_session.commit()\n\n    service.update_stage_state(\n        snapshot.id,\n        stage=WorkflowStage.STORY_SETUP,\n        status=WorkflowStageState.COMPLETED,\n        detail='Accepted story setup preferences.',\n    )\n    service.update_stage_state(\n        snapshot.id,\n        stage=WorkflowStage.COMPOSITION,\n        status=WorkflowStageState.COMPLETED,\n        detail='Draft story completed.',\n    )\n    service.update_stage_state(\n        snapshot.id,\n        stage=WorkflowStage.AUDIO,\n        status=WorkflowStageState.IN_PROGRESS,\n        detail='Tune narration settings.',\n    )\n\n    print(sna