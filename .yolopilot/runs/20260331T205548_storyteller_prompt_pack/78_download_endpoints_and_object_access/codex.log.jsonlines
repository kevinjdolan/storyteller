TORYTELLER_HOST\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"0.0.0.0\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").strip(),\\\\\\\\\\\\\\\\n        port=_read_int(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"STORYTELLER_PORT\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", 8565),\\\\\\\\\\\\\\\\n        reload=_read_bool(\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"STORYTELLER_RELOAD\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n            environment.lower() == \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"development\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n        ),\\\\\\\\\\\\\\\\n        api_v1_prefix=_normalize_api_prefix(\\\\\\\\\\\\\\\\n            os.getenv(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"STORYTELLER_API_V1_PREFIX\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"/api/v1\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"),\\\\\\\\\\\\\\\\n        ),\\\\\\\\\\\\\\\\n        cors_allowed_origins=_read_csv(\\\\\\\\\\\\\\\\n            \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"STORYTELLER_CORS_ALLOWED_ORIGINS\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\\n            DEFAULT_CORS_ALLOWED_ORIGINS,\\\\\\\\\\\\\\\\n        ),\\\\\\\\\\\\\\\\n        database_url=os.getenv(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"STORYTELLER_DATABASE_URL\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").strip(),\\\\\\\\\\\\\\\\n        log_level=os.getenv(\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"STORYTELLER_LOG_LEVEL\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"INFO\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\").strip().upper(),\\\\\\\\\\\\\\\\n    )\\\\\\\\\\\\\\\\n\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\"command\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\"/bin/zsh -lc \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"sed -n '1,260p' backend/app/settings/config.py\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\"\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\"exit_code\\\\\\\\\\\\\\\": 0, \\\\\\\\\\\\\\\"id\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\"item_27\\\\\\\\\\\\\\\", \\\\\\\\\\\\\\\"status\\\\\\\\\\\\\\\": \\\\\\\\\\\\\\\"completed\