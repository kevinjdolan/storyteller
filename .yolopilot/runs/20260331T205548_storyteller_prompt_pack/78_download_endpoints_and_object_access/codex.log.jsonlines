c/features/session/CompositionStage.tsx:800:                    disabled: downstreamSegmentCount === 0,\nfrontend/src/features/session/CompositionStage.tsx:802:                      downstreamSegmentCount > 0\nfrontend/src/features/session/CompositionStage.tsx:803:                        ? 'Auto-regenerate downstream'\nfrontend/src/features/session/CompositionStage.tsx:804:                        : 'No downstream text to refresh',\nfrontend/src/features/session/CompositionStage.tsx:808:                    disabled: downstreamSegmentCount === 0,\nfrontend/src/features/session/CompositionStage.tsx:813:                value={rewriteDownstreamMode}\nfrontend/src/features/session/CompositionStage.tsx:835:                : downstreamSegmentCount > 0\nfrontend/src/features/session/CompositionStage.tsx:836:                  ? rewriteDownstreamMode === 'auto_regenerate'\nfrontend/src/features/session/CompositionStage.tsx:855:                    downstreamRegenerationMode:\nfrontend/src/features/session/CompositionStage.tsx:856:                      downstreamSegmentCount > 0 ? rewriteDownstreamMode : null,\nfrontend/src/features/session/CompositionStage.tsx:871:                            downstream_regeneration_mode:\nfrontend/src/features/session/CompositionStage.tsx:872:                              rewritePayload.downstreamRegenerationMode,\nfrontend/src/features/session/live/sessionRealtimeClient.ts:37:export type SessionRealtimeConnectionController = {\nfrontend/src/features/session/live/sessionRealtimeClient.ts:42:export type SessionRealtimeClient = {\nfrontend/src/features/session/live/sessionRealtimeClient.ts:136:export function resolveSessionRealtimeWebSocketUrl() {\nfrontend/src/features/session/live/sessionRealtimeClient.ts:154:export function createSessionRealtimeClient(\nfrontend/src/features/session/live/SessionFeedStatusIndicator.tsx:90:export function SessionFeedStatusIndicator({\nfrontend/src/features/session/live/sessionRealtime.ts:9:export const SESSION_REALTIME_SCHEMA_VERSION = 1\nfrontend/src/features/session/live/sessionRealtime.ts:10:export const SESSION_CHANNEL_PREFIX = 'session:'\nfrontend/src/features/session/live/sessionRealtime.ts:12:export type SessionEventActorType = 'user' | 'assistant' | 'system' | 'service'\nfrontend/src/features/session/live/sessionRealtime.ts:14:export type SessionEventActor = {\nfrontend/src/features/session/live/sessionRealtime.ts:19:export type SessionRealtimeDeliveryMode = 'live' | 'replay'\nfrontend/src/features/session/live/sessionRealtime.ts:21:export type SessionRealtimeReplayStrategy = 'none' | 'delta' | 'hydrate'\nfrontend/src/features/session/live/sessionRealtime.ts:23:export type ChatContentFormat = 'plain_text' | 'markdown'\nfrontend/src/features/session/live/sessionRealtime.ts:25:export type UIActionEchoResult = 'accepted' | 'rejected'\nfrontend/src/features/session/live/sessionRealtime.ts:27:export type CompositionChunkKind = 'segment_start' | 'delta' | 'segment_summary'\nfrontend/src/features/session/live/sessionRealtime.ts:29:export type SessionJobKind = 'composition' | 'audio'\nfrontend/src/features/session/live/sessionRealtime.ts:31:export type SessionJobStatus =\nfrontend/src/features/session/live/sessionRealtime.ts:39:export type ErrorSeverity = 'warning' | 'error'\nfrontend/src/features/session/live/sessionRealtime.ts:41:export type SessionSubscriptionRequest = {\nfrontend/src/features/session/live/sessionRealtime.ts:50:export type SessionSubscriptionAck = {\nfrontend/src/features/session/live/sessionRealtime.ts:65:export type ChatMessageEventPayload = {\nfrontend/src/features/session/live/sessionRealtime.ts:74:export type WorkflowStageChangedEventPayload = {\nfrontend/src/features/session/live/sessionRealtime.ts:86:export type UIActionEchoEventPayload = {\nfrontend/src/features/session/live/sessionRealtime.ts:98:export type CompositionChunkEventPayload = {\nfrontend/src/features/session/live/sessionRealtime.ts:112:export type JobProgressEventPayload = {\nfronte