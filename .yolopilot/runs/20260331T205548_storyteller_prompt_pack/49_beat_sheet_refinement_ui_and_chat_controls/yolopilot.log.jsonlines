{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Finished", "message": "completed, exit 0: /bin/zsh -lc \"nl -ba backend/tests/test_session_beat_sheet_service.py | sed -n '1,320p'\"", "raw_event": {"item": {"aggregated_output": "     1\tfrom __future__ import annotations\n     2\t\n     3\tfrom datetime import datetime, timezone\n     4\t\n     5\timport pytest\n     6\tfrom app.db import Base, BeatSheet, make_engine\n     7\tfrom app.models import (\n     8\t    BeatSheetEvaluation,\n     9\t    BeatSheetEvaluationCriterion,\n    10\t    BeatSheetGenerationResult,\n    11\t    ExistingSelectedPitchContext,\n    12\t    GeneratedBeatSheetBeat,\n    13\t    GeneratedBeatSheetCandidate,\n    14\t    NormalizedBriefPreferences,\n    15\t    WorkflowStage,\n    16\t    WorkflowStageState,\n    17\t)\n    18\tfrom app.services.catalog import CATALOG_FILE_PATH, load_catalog_document, seed_catalog\n    19\tfrom app.services.sessions import SessionService\n    20\tfrom sqlalchemy.orm import sessionmaker\n    21\t\n    22\t\n    23\tdef _enable_sqlite_foreign_keys(engine) -> None:\n    24\t    with engine.begin() as connection:\n    25\t        connection.exec_driver_sql(\"PRAGMA foreign_keys=ON\")\n    26\t\n    27\t\n    28\t@pytest.fixture\n    29\tdef db_session():\n    30\t    engine = make_engine(\"sqlite+pysqlite:///:memory:\")\n    31\t    _enable_sqlite_foreign_keys(engine)\n    32\t    Base.metadata.create_all(engine)\n    33\t    session = sessionmaker(bind=engine, autoflush=False, expire_on_commit=False)()\n    34\t\n    35\t    try:\n    36\t        yield session\n    37\t    finally:\n    38\t        session.close()\n    39\t        engine.dispose()\n    40\t\n    41\t\n    42\tclass StubBeatSheetGenerationService:\n    43\t    def __init__(self) -> None:\n    44\t        self.calls: list[dict[str, object | None]] = []\n    45\t\n    46\t    def generate_beat_sheet(self, **kwargs) -> BeatSheetGenerationResult:\n    47\t        self.calls.append(kwargs)\n    48\t        beats = [\n    49\t            GeneratedBeatSheetBeat(\n    50\t                key=key,\n    51\t                label=label,\n    52\t                summary=f\"{label} keeps the harbor plan high level and concrete.\",\n    53\t                emotional_intent=f\"{label} should feel calm and emotionally legible.\",\n    54\t                bedtime_softening_note=(\n    55\t                    f\"{label} stays bedtime-safe by keeping tension readable and quickly soothed.\"\n    56\t                ),\n    57\t            )\n    58\t            for key, label in (\n    59\t                (\"opening_image\", \"Opening Image\"),\n    60\t                (\"theme_stated\", \"Theme Stated\"),\n    61\t                (\"set_up\", \"Set-Up\"),\n    62\t                (\"catalyst\", \"Catalyst\"),\n    63\t                (\"debate\", \"Debate\"),\n    64\t                (\"break_into_two\", \"Break into Two\"),\n    65\t                (\"b_story\", \"B Story\"),\n    66\t                (\"fun_and_games\", \"Fun and Games\"),\n    67\t                (\"midpoint\", \"Midpoint\"),\n    68\t                (\"bad_guys_close_in\", \"Bad Guys Close In\"),\n    69\t                (\"all_is_lost\", \"All Is Lost\"),\n    70\t                (\"dark_night_of_the_soul\", \"Dark Night of the Soul\"),\n    71\t                (\"break_into_three\", \"Break into Three\"),\n    72\t                (\"finale\", \"Finale\"),\n    73\t                (\"final_image\", \"Final Image\"),\n    74\t            )\n    75\t        ]\n    76\t        return BeatSheetGenerationResult(\n    77\t            source=\"stub\",\n    78\t            model_id=\"stub-beat-generator\",\n    79\t            prompt_version=\"beat_sheet_generation.test\",\n    80\t            beat_sheet=GeneratedBeatSheetCandidate(\n    81\t                summary=\"A harbor Save-the-Cat arc that lands in calm belonging.\",\n    82\t                bedtime_notes=\"Keep every pressure beat quickly buffered by warmth and visibility.\",\n    83\t                beats=beats,\n    84\t            ),\n    85\t            evaluation=BeatSheetEvaluation(\n    86\t                passed=True,\n    87\t                criteria=[\n    88\t                    BeatSheetEvaluationCriterion(\n    89\t                        name=\"all_required_beats_present\",\n    90\t                        passed=True,\n    91\t                        measured_value=15,\n    92\t                    )\n    93\t                ],\n    94\t            ),\n    95\t            raw_response={\"stub\": True},\n    96\t        )\n    97\t\n    98\t\n    99\tdef _seed_catalog_rows(db_session) -> None:\n   100\t    seed_catalog(db_session, load_catalog_document(CATALOG_FILE_PATH))\n   101\t\n   102\t\n   103\tdef _create_character_ready_session(db_session):\n   104\t    service = SessionService(db_session)\n   105\t    snapshot = service.create_session(working_title=\"Beat Sheet Stage\")\n   106\t    service.select_genre(snapshot.id, genre_slug=\"quest-fantasy\")\n   107\t    service.select_tone(snapshot.id, tone_profile_slug=\"hushed-wonder\")\n   108\t    service.save_story_brief(\n   109\t        snapshot.id,\n   110\t        story_idea=\"A child and an otter guardian follow floating lanterns across a harbor before bed.\",\n   111\t        normalized_preferences=NormalizedBriefPreferences(\n   112\t            protagonist_type=\"A child and an otter guardian\",\n   113\t            setting=\"a moonlit harbor\",\n   114\t            emotional_goal=\"a calm return home\",\n   115\t            constraint_notes=[\"End with the harbor settled and safe.\"],\n   116\t            bedtime_safety_concerns=[\"Keep every surprise quickly reassuring.\"],\n   117\t            candidate_motifs=[\"floating lanterns\", \"moonlit docks\"],\n   118\t        ),\n   119\t    )\n   120\t    generated_pitches = service.generate_pitches(snapshot.id, candidate_count=3)\n   121\t    service.select_pitch(\n   122\t        snapshot.id,\n   123\t        pitch_id=generated_pitches.snapshot.pitch_batches[0].pitches[0].id,\n   124\t    )\n   125\t    generated_characters = service.generate_character_sheets(snapshot.id, candidate_count=3)\n   126\t    service.select_character_sheet(\n   127\t        snapshot.id,\n   128\t        character_sheet_id=generated_characters.snapshot.character_sheet_batches[0].character_sheets[0].id,\n   129\t    )\n   130\t    return service, snapshot.id\n   131\t\n   132\t\n   133\tdef test_generate_beat_sheet_persists_revisioned_candidate_and_keeps_stage_active(\n   134\t    db_session,\n   135\t) -> None:\n   136\t    _seed_catalog_rows(db_session)\n   137\t    service, session_id = _create_character_ready_session(db_session)\n   138\t    beat_generator = StubBeatSheetGenerationService()\n   139\t\n   140\t    result = service.generate_beat_sheet(\n   141\t        session_id,\n   142\t        guidance=\"Keep the midpoint more awestruck than tense.\",\n   143\t        focus_beats=[\"midpoint\"],\n   144\t        bedtime_goal=\"feel sleepy and safe by the ending\",\n   145\t        beat_sheet_generation_service=beat_generator,\n   146\t    )\n   147\t\n   148\t    assert result.event.event_type == \"ai.output.recorded\"\n   149\t    assert result.snapshot.current_stage == WorkflowStage.BEATS\n   150\t    assert result.snapshot.resume_stage == WorkflowStage.BEATS\n   151\t    assert result.snapshot.selected_beat_sheet is None\n   152\t    assert result.snapshot.beat_sheet_revisions[0].summary == (\n   153\t        \"A harbor Save-the-Cat arc that lands in calm belonging.\"\n   154\t    )\n   155\t    assert len(result.snapshot.beat_sheet_revisions[0].beats) == 15\n   156\t    assert result.snapshot.stage_states[5].status == WorkflowStageState.IN_PROGRESS\n   157\t    assert \"Accept a revision to continue.\" in (result.snapshot.stage_states[5].detail or \"\")\n   158\t    assert beat_generator.calls[0][\"guidance\"] == \"Keep the midpoint more awestruck than tense.\"\n   159\t\n   160\t\n   161\tdef test_select_beat_sheet_marks_choice_and_advances_to_story_setup(db_session) -> None:\n   162\t    _seed_catalog_rows(db_session)\n   163\t    service, session_id = _create_character_ready_session(db_session)\n   164\t    generated = service.generate_beat_sheet(\n   165\t        session_id,\n   166\t        beat_sheet_generation_service=StubBeatSheetGenerationService(),\n   167\t    )\n   168\t    first_revision = generated.snapshot.beat_sheet_revisions[0]\n   169\t\n   170\t    result = service.select_beat_sheet(\n   171\t        session_id,\n   172\t        beat_sheet_id=first_revision.id,\n   173\t    )\n   174\t\n   175\t    assert result.event.event_type == \"selection.recorded\"\n   176\t    assert result.event.payload is not None\n   177\t    assert result.event.payload.selection_kind == \"beat_sheet\"\n   178\t    assert result.snapshot.current_stage == WorkflowStage.STORY_SETUP\n   179\t    assert result.snapshot.resume_stage == WorkflowStage.STORY_SETUP\n   180\t    assert result.snapshot.selected_beat_sheet is not None\n   181\t    assert result.snapshot.selected_beat_sheet.id == first_revision.id\n   182\t    assert result.snapshot.selected_beat_sheet.is_selected is True\n   183\t    assert result.snapshot.stage_states[5].status == WorkflowStageState.COMPLETED\n   184\t\n   185\t\n   186\tdef test_refine_beat_sheet_creates_selected_revision_and_invalidates_composition(\n   187\t    db_session,\n   188\t) -> None:\n   189\t    _seed_catalog_rows(db_session)\n   190\t    service, session_id = _create_character_ready_session(db_session)\n   191\t    generated = service.generate_beat_sheet(\n   192\t        session_id,\n   193\t        beat_sheet_generation_service=StubBeatSheetGenerationService(),\n   194\t    )\n   195\t    selected = service.select_beat_sheet(\n   196\t        session_id,\n   197\t        beat_sheet_id=generated.snapshot.beat_sheet_revisions[0].id,\n   198\t    )\n   199\t    service.update_stage_state(\n   200\t        session_id,\n   201\t        stage=WorkflowStage.STORY_SETUP,\n   202\t        status=WorkflowStageState.COMPLETED,\n   203\t        detail=\"Accepted setup.\",\n   204\t    )\n   205\t    service.update_stage_state(\n   206\t        session_id,\n   207\t        stage=WorkflowStage.COMPOSITION,\n   208\t        status=WorkflowStageState.COMPLETED,\n   209\t        detail=\"Drafted story text.\",\n   210\t    )\n   211\t\n   212\t    result = service.refine_beat_sheet(\n   213\t        session_id,\n   214\t        revision_number=selected.snapshot.selected_beat_sheet.revision_number,\n   215\t        instructions=\"Soften the midpoint and all-is-lost beats.\",\n   216\t        beat_names=[\"midpoint\", \"all_is_lost\"],\n   217\t        bedtime_goal=\"settle into a visibly sleepy ending\",\n   218\t        beat_sheet_generation_service=StubBeatSheetGenerationService(),\n   219\t    )\n   220\t\n   221\t    refreshed_beat_sheets = db_session.query(BeatSheet).filter(BeatSheet.session_id == session_id).all()\n   222\t    assert len(refreshed_beat_sheets) == 2\n   223\t    assert result.snapshot.selected_beat_sheet is not None\n   224\t    assert result.snapshot.selected_beat_sheet.revision_number == 2\n   225\t    assert result.snapshot.stage_states[5].status == WorkflowStageState.COMPLETED\n   226\t    assert result.snapshot.stage_states[7].status == WorkflowStageState.NEEDS_REGENERATION\n   227\t    assert result.snapshot.stage_states[8].status == WorkflowStageState.DRAFT\n", "command": "/bin/zsh -lc \"nl -ba backend/tests/test_session_beat_sheet_service.py | sed -n '1,320p'\"", "exit_code": 0, "id": "item_45", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 91, "prompt_index": 50, "prompt_name": "49 \u2014 Beat Sheet Refinement UI and Chat Controls", "prompt_total": 100}, "timestap": "2026-04-02T00:24:24-07:00"}
