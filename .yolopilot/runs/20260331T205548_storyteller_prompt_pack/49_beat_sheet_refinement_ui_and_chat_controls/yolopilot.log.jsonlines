snapshot.detail = normalized_detail\n  2232\t        invalidated_stages = self._invalidate_dependent_stages(\n  2233\t            stage_map,\n  2234\t            stage=payload.stage,\n  2235\t            detail=normalized_detail,\n  2236\t        )\n  2237\t        self._apply_rollups(story_session, stage_map)\n  2238\t\n  2239\t        if previous_status != stage_snapshot.status or invalidated_stages:\n  2240\t            stage_event = self._event_log.record_stage_state_changed(\n  2241\t                story_session.id,\n  2242\t                stage=payload.stage,\n  2243\t                previous_status=previous_status,\n  2244\t                status=stage_snapshot.status,\n  2245\t                detail=stage_snapshot.detail,\n  2246\t                invalidated_stages=invalidated_stages,\n  2247\t                current_stage=story_session.current_stage,\n  2248\t                resume_stage=story_session.resume_stage,\n  2249\t                furthest_completed_stage=story_session.furthest_completed_stage,\n  2250\t                overall_status=story_session.overall_status,\n  2251\t                actor=actor,\n  2252\t            )\n  2253\t            for invalidated_stage in invalidated_stages:\n  2254\t                stage_map[invalidated_stage].last_event = stage_event\n  2255\t\n  2256\t        edit_event = self._event_log.record_user_edit(\n  2257\t            story_session.id,\n  2258\t            target_kind=target_kind,\n  2259\t            stage=payload.stage,\n  2260\t            changed_fields=[\"detail\"],\n  2261\t            source=payload.origin,\n  2262\t            field_values={\n  2263\t                \"detail\": normalized_detail,\n  2264\t                \"control_id\": payload.control_id,\n  2265\t            },\n  2266\t            summary_text=_build_stage_note_summary(payload.stage, normalized_detail),\n  2267\t            actor=actor,\n  2268\t        )\n  2269\t        stage_snapshot.last_event = edit_event\n  2270\t        self._session.commit()\n  2271\t        return SessionContextUpdateResponse(\n  2272\t            snapshot=self.load_session_snapshot(story_session.id),\n  2273\t            event=self._event_log.build_event_view(edit_event),\n  2274\t        )\n  2275\t\n  2276\t    def update_stage_state(\n  2277\t        self,\n  2278\t        session_id: str,\n  2279\t        *,\n  2280\t        stage: WorkflowStage,\n  2281\t        status: WorkflowStageState,\n  2282\t        detail: str | None = None,\n  2283\t        actor: SessionEventActor | None = None,\n  2284\t    ) -> SessionSnapshot:\n  2285\t        story_session = self._sessions.get_for_update(session_id)\n  2286\t        if story_session is None:\n  2287\t            raise SessionNotFoundError(f\"session {session_id!r} was not found\")\n  2288\t\n  2289\t        stage_map = self._stage_states.ensure_for_session(story_session)\n  2290\t        self._validate_stage_transition(stage_map, stage=stage, status=status)\n  2291\t\n  2292\t        snapshot = stage_map[stage]\n  2293\t        previous_status = snapshot.status\n  2294\t        now = utc_now()\n  2295\t        snapshot.detail = _normalize_optional_text(detail)\n  2296\t        invalidated_stages: list[WorkflowStage] = []\n  2297\t\n  2298\t        if status == WorkflowStageState.DRAFT:\n  2299\t            snapshot.status = WorkflowStageState.DRAFT\n  2300\t            snapshot.started_at = None\n  2301\t            snapshot.completed_at = None\n  2302\t        elif status == WorkflowStageState.IN_PROGRESS:\n  2303\t            snapshot.status = WorkflowStageState.IN_PROGRESS\n  2304\t            snapshot.started_at = snapshot.started_at or now\n  2305\t            snapshot.completed_at = None\n  2306\t        elif status == WorkflowStageState.COMPLETED:\n  2307\t            snapshot.status = WorkflowStageState.COMPLETED\n  2308\t            snapshot.started_at = snapshot.started_at or now\n  2309\t            snapshot.completed_at = now\n  2310\t            invalidated_stages = self._invalidate_dependent_stages(\n  2311\t                stage_map,\n  2312\t                stage=stage,\n  2313\t                detail=snapshot.detail,\n  2314\t            )\n  2315\t        else:\n  2316\t            snapshot.status = WorkflowStageState.NEEDS_REGENERATION\n  2317\t            invalidated_stages = self._invalidate_dependent_stages(\n  2318\t                stage_map,\n  2319\t                stage=stage,\n  2320\t                detail=snapshot.detail,\n  2321\t            )\n  2322\t\n  2323\t        self._apply_rollups(story_session, stage_map)\n  2324\t        stage_event = self._event_log.record_stage_state_changed(\n  2325\t            story_session.id,\n  2326\t            stage=stage,\n  2327\t            previous_status=previous_status,\n  2328\t            status=snapshot.status,\n  2329\t            detail=snapshot.detail,\n  2330\t            invalidated_stages=invalidated_stages,\n  2331\t            current_stage=story_session.current_stage,\n  2332\t            resume_stage=story_session.resume_stage,\n  2333\t            furthest_completed_stage=story_session.furthest_completed_stage,\n  2334\t            overall_status=story_session.overall_status,\n  2335\t            actor=actor,\n  2336\t        )\n  2337\t        snapshot.last_event = stage_event\n  2338\t        for invalidated_stage in invalidated_stages:\n  2339\t            stage_map[invalidated_stage].last_event = stage_event\n  2340\t        self._session.commit()\n  2341\t        return self.load_session_snapshot(story_session.id)\n  2342\t\n  2343\t    def _validate_stage_transition(\n  2344\t        self,\n  2345\t        stage_map: Mapping[WorkflowStage, object],\n  2346\t        *,\n  2347\t        stage: WorkflowStage,\n  2348\t        status: WorkflowStageState,\n  2349\t    ) -> None:\n  2350\t        if status in {WorkflowStageState.IN_PROGRESS, WorkflowStageState.COMPLETED}:\n  2351\t            incomplete_prerequisites = [\n  2352\t                prior_stage.value\n  2353\t                for prior_stage in _stages_before(stage)\n  2354\t                if getattr(stage_map[prior_stage], \"status\") != WorkflowStageState.COMPLETED\n  2355\t            ]\n  2356\t            if incomplete_prerequisites:\n  2357\t                joined = \", \".join(incomplete_prerequisites)\n  2358\t                raise InvalidStageTransitionError(\n  2359\t                    f\"cannot set {stage.value!r} to {status.value!r} before prerequisites are \"\n  2360\t                    f\"completed: {joined}\"\n  2361\t                )\n  2362\t\n  2363\t        if status == WorkflowStageState.NEEDS_REGENERATION and stage == WorkflowStage.GENRE:\n  2364\t            raise InvalidStageTransitionError(\"genre cannot be marked needs_regeneration directly\")\n  2365\t\n  2366\t    def _load_active_genre(\n  2367\t        self,\n  2368\t        *,\n  2369\t        genre_id: str | None = None,\n  2370\t        genre_slug: str | None = None,\n  2371\t        genre_label: str | None = None,\n  2372\t    ):\n  2373\t        return find_active_genre(\n  2374\t            self._session,\n  2375\t            genre_id=genre_id,\n  2376\t            genre_slug=genre_slug,\n  2377\t            genre_label=genre_label,\n  2378\t        )\n  2379\t\n  2380\t    def _load_active_tone_for_genre(\n  2381\t        self,\n  2382\t        *,\n  2383\t        genre_id: str,\n  2384\t        tone_profile_id: str | None = None,\n  2385\t        tone_profile_slug: str | None = None,\n  2386\t        tone_profile_label: str | None = None,\n  2387\t    ):\n  2388\t        return find_active_tone_for_genre(\n  2389\t            self._session,\n  2390\t            genre_id=genre_id,\n  2391\t            tone_profile_id=tone_profile_id,\n  2392\t            tone_profile_slug=tone_profile_slug,\n  2393\t            tone_profile_label=tone_profile_label,\n  2394\t        )\n  2395\t\n  2396\t    def _invalidate_dependent_stages(\n  2397\t        self,\n  2398\t        stage_map: Mapping[WorkflowStage, object],\n  2399\t        *,\n  2400\t        stage: WorkflowStage,\n  2401\t        detail: str | None,\n  2402\t    ) -> list[WorkflowStage]:\n  2403\t        if stage == WorkflowStage.FINALIZE:\n  2404\t            return []\n  2405\t\n  2406\t        reason = detail or f\"Needs regeneration after {stage.value} changed.\"\n  2407\t        invalidated_stages: list[WorkflowStage] = []\n  2408\t\n  2409\t        for invalidated_stage in get_invalidated_stages_after_edit(stage):\n  2410\t            snapshot = stage_map[invalidated_stage]\n  2411\t            if getattr(snapshot, \"status\") == WorkflowStageState.DRAFT:\n  2412\t                continue\n  2413\t\n  2414\t            snapshot.status = WorkflowStageState.NEEDS_REGENERATION\n  2415\t            snapshot.detail = reason\n  2416\t            invalidated_stages.append(invalidated_stage)\n  2417\t\n  2418\t        return invalidated_stages\n  2419\t\n  2420\t    def _apply_rollups(\n  2421\t        self,\n  2422\t        story_session,\n  2423\t        stage_map: Mapping[WorkflowStage, object],\n  2424\t    ) -> None:\n  2425\t        statuses = {stage: getattr(stage_map[stage], \"status\") for stage in stage_map}\n  2426\t        resume_stage = resolve_resume_stage(statuses)\n  2427\t        furthest_completed_stage = resolve_furthest_completed_stage(statuses)\n  2428\t        overall_status = resolve_overall_status(statuses)\n  2429\t\n  2430\t        story_session.current_stage = resume_stage\n  2431\t        story_session.resume_stage = resume_stage\n  2432\t        story_session.furthest_completed_stage = furthest_completed_stage\n  2433\t        story_session.overall_status = overall_status\n  2434\t        story_session.completed_at = (\n  2435\t            utc_now() if overall_status == WorkflowStageState.COMPLETED else None\n  2436\t        )\n  2437\t\n  2438\t\n  2439\tdef _normalize_optional_text(value: str | None) -> str | None:\n  2440\t    if value is None:\n  2441\t        return None\n  2442\t\n  2443\t    normalized = value.strip()\n  2444\t    return normalized or None\n  2445\t\n  2446\t\n  2447\tdef _stages_before(stage: WorkflowStage) -> tuple[WorkflowStage, ...]:\n  2448\t    stages = WORKFLOW_STAGE_SEQUENCE\n  2449\t    return stages[: stages.index(stage)]\n  2450\t\n  2451\t\n  2452\tdef _build_stage_note_summary(stage: WorkflowStage, detail: str | None) -> str:\n  2453\t    label = get_workflow_stage_definition(stage).label\n  2454\t    if detail:\n  2455\t        return f\"Updated {label.lower()} notes from the workspace.\"\n  2456\t    return f\"Cleared {label.lower()} notes from the workspace.\"\n  2457\t\n  2458\t\n  2459\tdef _build_genre_selection_detail(label: str) -> str:\n  2460\t    return f\"Selected genre: {label}. Tone choices filter from this lane next.\"\n  2461\t\n  2462\t\n  2463\tdef _build_genre_invalidation_detail(label: str) -> str:\n  2464\t    return f\"Genre changed to {label}. Revisit tone and any downstream planning.\"\n  2465\t\n  2466\t\n  2467\tdef _build_tone_selection_detail(label: str) -> str:\n  2468\t    return f\"Selected tone: {label}. The story brief will inherit this bedtime texture.\"\n  2469\t\n  2470\t\n  2471\tdef _build_tone_invalidation_detail(label: str) -> str:\n  2472\t    return f\"Tone changed to {label}. Revisit the brief and any downstream planning.\"\n  2473\t\n  2474\t\n  2475\tdef _build_selected_pitch_context(pitch: Pitch) -> ExistingSelectedPitchContext:\n  2476\t    return ExistingSelectedPitchContext(\n  2477\t        title=pitch.title,\n  2478\t        hook=pitch.logline,\n  2479\t        central_conflict=pitch.summary,\n  2480\t        why_it_fits=pitch.bedtime_notes,\n  2481\t    )\n  2482\t\n  2483\t\n  2484\tdef _build_pitch_generation_key() -> str:\n  2485\t    return f\"pitch-batch-{uuid4().hex[:12]}\"\n  2486\t\n  2487\t\n  2488\tdef _build_character_generation_key() -> str:\n  2489\t    return f\"character-batch-{uuid4().hex[:12]}\"\n  2490\t\n  2491\t\n  2492\tdef _build_pitch_generation_stage_detail(candidate_count: int) -> str:\n  2493\t    return f\"Generated {candidate_count} pitch options. Select one to continue.\"\n  2494\t\n  2495\t\n  2496\tdef _build_character_sheet_generation_stage_detail(candidate_count: int) -> str:\n  2497\t    return f\"Generated {candidate_count} character options. Select one to continue.\"\n  2498\t\n  2499\t\n  2500\tdef _build_pitch_generation_summary_text(pitches: list[object]) -> str:\n  2501\t    titles = [getattr(pitch, \"title\", None) for pitch in pitches]\n  2502\t    summarized_titles = [title for title in titles if isinstance(title, str) and title]\n  2503\t    if not summarized_titles:\n  2504\t        return \"Generated a fresh pitch batch.\"\n  2505\t\n  2506\t    return \"Generated pitches: \" + \", \".join(summarized_titles[:3]) + \".\"\n  2507\t\n  2508\t\n  2509\tdef _build_character_sheet_generation_summary_text(character_sheets: list[object]) -> str:\n  2510\t    titles = [getattr(character_sheet, \"title\", None) for character_sheet in character_sheets]\n  2511\t    summarized_titles = [title for title in titles if isinstance(title, str) and title]\n  2512\t    if not summarized_titles:\n  2513\t        return \"Generated a fresh character-sheet batch.\"\n  2514\t\n  2515\t    return \"Generated character sheets: \" + \", \".join(summarized_titles[:3]) + \".\"\n  2516\t\n  2517\t\n  2518\tdef _build_pitch_refinement_rationale(pitch: Pitch, instructions: str) -> str:\n  2519\t    return f'Refined from \"{pitch.title}\" with: {instructions}'\n  2520\t\n  2521\t\n  2522\tdef _build_character_sheet_refinement_rationale(\n  2523\t    character_sheet: CharacterSheet,\n  2524\t    instructions: str,\n  2525\t    *,\n  2526\t    focus_character_names: list[str],\n  2527\t    change_summary: str | None,\n  2528\t    change_impact: CharacterChangeImpact,\n  2529\t) -> str:\n  2530\t    focus_tail = \"\"\n  2531\t    if focus_character_names:\n  2532\t        focus_tail = f\" Focus characters: {', '.join(focus_character_names)}.\"\n  2533\t    change_tail = \"\"\n  2534\t    if change_summary:\n  2535\t        change_tail = f\" Requested change: {change_summary}.\"\n  2536\t    impact_tail = f\" Change impact: {change_impact.value}.\"\n  2537\t\n  2538\t    label = _read_character_sheet_label(character_sheet)\n  2539\t    return (\n  2540\t        f'Refined from \"{label}\" with: {instructions}.'\n  2541\t        f\"{change_tail}{focus_tail}{impact_tail}\"\n  2542\t    )\n  2543\t\n  2544\t\n  2545\tdef _build_pitch_refinement_summary_text(refined_pitch: Pitch, *, source_pitch: Pitch) -> str:\n  2546\t    return f\"Generated refined pitch {refined_pitch.title} from {source_pitch.title}.\"\n  2547\t\n  2548\t\n  2549\tdef _build_character_sheet_refinement_summary_text(\n  2550\t    refined_character_sheet: CharacterSheet,\n  2551\t    *,\n  2552\t    source_character_sheet: CharacterSheet,\n  2553\t) -> str:\n  2554\t    return (\n  2555\t        \"Generated refined character sheet \"\n  2556\t        f\"{_read_character_sheet_label(refined_character_sheet)} from \"\n  2557\t        f\"{_read_character_sheet_label(source_character_sheet)}.\"\n  2558\t    )\n  2559\t\n  2560\t\n  2561\tdef _build_pitch_selection_detail(pitch: Pitch) -> str:\n  2562\t    return f\"Selected pitch: {pitch.title}. {pitch.logline}\"\n  2563\t\n  2564\t\n  2565\tdef _build_character_sheet_selection_detail(character_sheet: CharacterSheet) -> str:\n  2566\t    label = _read_character_sheet_label(character_sheet)\n  2567\t    change_summary = _read_character_sheet_change_summary(character_sheet)\n  2568\t    change_impact = _read_character_sheet_change_impact(character_sheet)\n  2569\t    refinement_tail = \"\"\n  2570\t    if change_summary is not None:\n  2571\t        impact_label = (\n  2572\t            f\"{change_impact.value.capitalize()} refinement\"\n  2573\t            if change_impact is not None\n  2574\t            else \"Refinement\"\n  2575\t        )\n  2576\t        refinement_tail = f\" {impact_label}: {change_summary}.\"\n  2577\t    if character_sheet.protagonist_name:\n  2578\t        return (\n  2579\t            f\"Selected character sheet: {label}. Lead character: \"\n  2580\t            f\"{character_sheet.protagonist_name}.{refinement_tail}\"\n  2581\t        )\n  2582\t\n  2583\t    return f\"Selected character sheet: {label}.{refinement_tail}\"\n  2584\t\n  2585\t\n  2586\tdef _build_pitch_invalidation_detail(pitch: Pitch) -> str:\n  2587\t    return (\n  2588\t        f\"Pitch selection changed to {pitch.title}. Refresh character work and any downstream \"\n  2589\t        \"planning.\"\n  2590\t    )\n  2591\t\n  2592\t\n  2593\tdef _build_character_sheet_invalidation_detail(\n  2594\t    character_sheet: CharacterSheet,\n  2595\t    *,\n  2596\t    change_impact: CharacterChangeImpact = CharacterChangeImpact.MAJOR,\n  2597\t) -> str:\n  2598\t    label = _read_character_sheet_label(character_sheet)\n  2599\t    return (\n  2600\t        f\"{change_impact.value.capitalize()} character change accepted in {label}. Refresh beats and any downstream \"\n  2601\t        \"planning.\"\n  2602\t    )\n  2603\t\n  2604\t\n  2605\tdef _find_matching_pitches(\n  2606\t    pitches: list[Pitch],\n  2607\t    *,\n  2608\t    pitch_id: str | None,\n  2609\t    generation_key: str | None,\n  2610\t    pitch_index: int | None,\n  2611\t    title: str | None,\n  2612\t) -> list[Pitch]:\n  2613\t    title_match = title.lower() if title is not None else None\n  2614\t    matches: list[Pitch] = []\n  2615\t\n  2616\t    for pitch in pitches:\n  2617\t        if pitch_id is not None and pitch.id != pitch_id:\n  2618\t            continue\n  2619\t        if generation_key is not None and pitch.generation_key != generation_key:\n  2620\t            continue\n  2621\t        if pitch_index is not None and pitch.pitch_index != pitch_index:\n  2622\t            continue\n  2623\t        if title_match is not None and pitch.title.lower() != title_match:\n  2624\t            continue\n  2625\t        matches.append(pitch)\n  2626\t\n  2627\t    return matches\n  2628\t\n  2629\t\n  2630\tdef _find_matching_character_sheets(\n  2631\t    character_sheets: list[CharacterSheet],\n  2632\t    *,\n  2633\t    character_sheet_id: str | None,\n  2634\t    revision_number: int | None,\n  2635\t    title: str | None,\n  2636\t) -> list[CharacterSheet]:\n  2637\t    title_match = title.lower() if title is not None else None\n  2638\t    matches: list[CharacterSheet] = []\n  2639\t\n  2640\t    for character_sheet in character_sheets:\n  2641\t        if character_sheet_id is not None and character_sheet.id != character_sheet_id:\n  2642\t            continue\n  2643\t        if revision_number is not None and character_sheet.revision_number != revision_number:\n  2644\t            continue\n  2645\t        if title_match is not None and (character_sheet.title or \"\").lower() != title_match:\n  2646\t            continue\n  2647\t        matches.append(character_sheet)\n  2648\t\n  2649\t    return matches\n  2650\t\n  2651\t\n  2652\tdef _resolve_source_character_sheet(\n  2653\t    character_sheets: list[CharacterSheet],\n  2654\t    *,\n  2655\t    selected_character_sheet: CharacterSheet | None,\n  2656\t    character_sheet_id: str | None,\n  2657\t    revision_number: int | None,\n  2658\t    title: str | None,\n  2659\t) -> CharacterSheet | None:\n  2660\t    if character_sheet_id is None and revision_number is None and title is None:\n  2661\t        return selected_character_sheet\n  2662\t\n  2663\t    matches = _find_matching_character_sheets(\n  2664\t        character_sheets,\n  2665\t        character_sheet_id=character_sheet_id,\n  2666\t        revision_number=revision_number,\n  2667\t        title=title,\n  2668\t    )\n  2669\t    if len(matches) != 1:\n  2670\t        return None\n  2671\t\n  2672\t    return matches[0]\n  2673\t\n  2674\t\n  2675\tdef _build_pitch_persistence_metadata(\n  2676\t    result,\n  2677\t    *,\n  2678\t    generation_kind: str,\n  2679\t    guidance: str | None = None,\n  2680\t    source_pitch: Pitch | None = None,\n  2681\t    selection_rationale: str | None = None,\n  2682\t) -> dict[str, Any]:\n  2683\t    payload = build_pitch_model_output(result)\n  2684\t    payload[\"batch_metadata\"] = {\n  2685\t        \"generation_kind\": generation_kind,\n  2686\t        \"guidance\": guidance,\n  2687\t    }\n  2688\t    if source_pitch is not None:\n  2689\t        payload[\"refinement\"] = {\n  2690\t            \"source_pitch_id\": source_pitch.id,\n  2691\t            \"source_pitch_title\": source_pitch.title,\n  2692\t            \"source_generation_key\": source_pitch.generation_key,\n  2693\t            \"refinement_instructions\": guidance,\n  2694\t            \"selection_rationale\": selection_rationale,\n  2695\t        }\n  2696\t    return payload\n  2697\t\n  2698\t\n  2699\tdef _build_character_persistence_metadata(\n  2700\t    result,\n  2701\t    *,\n  2702\t    generation_key: str,\n  2703\t    generation_kind: str,\n  2704\t    guidance: str | None = None,\n  2705\t    selected_pitch: Pitch,\n  2706\t    source_character_sheet: CharacterSheet | None = None,\n  2707\t    selection_rationale: str | None = None,\n  2708\t    change_summary: str | None = None,\n  2709\t    focus_character_names: list[str] | None = None,\n  2710\t    change_impact: CharacterChangeImpact | None = None,\n  2711\t) -> dict[str, Any]:\n  2712\t    payload = build_character_model_output(result)\n  2713\t    payload[\"batch_metadata\"] = {\n  2714\t        \"generation_key\": generation_key,\n  2715\t        \"generation_kind\": generation_kind,\n  2716\t        \"guidance\": guidance,\n  2717\t    }\n  2718\t    payload[\"pitch_context\"] = {\n  2719\t        \"source_pitch_id\": selected_pitch.id,\n  2720\t        \"source_pitch_title\": selected_pitch.title,\n  2721\t    }\n  2722\t    if source_character_sheet is not None:\n  2723\t        payload[\"refinement\"] = {\n  2724\t            \"source_pitch_id\": selected_pitch.id,\n  2725\t            \"source_pitch_title\": selected_pitch.title,\n  2726\t            \"source_character_sheet_id\": source_character_sheet.id,\n  2727\t            \"source_character_sheet_title\": _read_character_sheet_label(source_character_sheet),\n  2728\t            \"refinement_instructions\": guidance,\n  2729\t            \"selection_rationale\": selection_rationale,\n  2730\t            \"change_summary\": change_summary,\n  2731\t            \"focus_character_names\": list(focus_character_names or []),\n  2732\t            \"change_impact\": change_impact.value if change_impact is not None else None,\n  2733\t        }\n  2734\t    return payload\n  2735\t\n  2736\t\n  2737\tdef _read_character_sheet_selection_rationale(character_sheet: CharacterSheet) -> str | None:\n  2738\t    if not isinstance(character_sheet.character_data, Mapping):\n  2739\t        return None\n  2740\t\n  2741\t    refinement = character_sheet.character_data.get(\"refinement\")\n  2742\t    if not isinstance(refinement, Mapping):\n  2743\t        return None\n  2744\t\n  2745\t    rationale = refinement.get(\"selection_rationale\")\n  2746\t    return rationale if isinstance(rationale, str) and rationale else None\n  2747\t\n  2748\t\n  2749\tdef _read_character_sheet_change_summary(character_sheet: CharacterSheet) -> str | None:\n  2750\t    if not isinstance(character_sheet.character_data, Mapping):\n  2751\t        return None\n  2752\t\n  2753\t    refinement = character_sheet.character_data.get(\"refinement\")\n  2754\t    if not isinstance(refinement, Mapping):\n  2755\t        return None\n  2756\t\n  2757\t    summary = refinement.get(\"change_summary\")\n  2758\t    return summary if isinstance(summary, str) and summary else None\n  2759\t\n  2760\t\n  2761\tdef _read_character_sheet_change_impact(\n  2762\t    character_sheet: CharacterSheet,\n  2763\t) -> CharacterChangeImpact | None:\n  2764\t    if not isinstance(character_sheet.character_data, Mapping):\n  2765\t        return None\n  2766\t\n  2767\t    refinement = character_sheet.character_data.get(\"refinement\")\n  2768\t    if not isinstance(refinement, Mapping):\n  2769\t        return None\n  2770\t\n  2771\t    change_impact = refinement.get(\"change_impact\")\n  2772\t    if change_impact == CharacterChangeImpact.MINOR.value:\n  2773\t        return CharacterChangeImpact.MINOR\n  2774\t    if change_impact == CharacterChangeImpact.MAJOR.value:\n  2775\t        return CharacterChangeImpact.MAJOR\n  2776\t    return None\n  2777\t\n  2778\t\n  2779\tdef _build_existing_character_sheet_context(\n  2780\t    character_sheet: CharacterSheet,\n  2781\t) -> ExistingCharacterSheetContext:\n  2782\t    protagonist_payload = None\n  2783\t    supporting_cast_payload = []\n  2784\t    if isinstance(character_sheet.character_data, Mapping):\n  2785\t        candidate_payload = character_sheet.character_data.get(\"candidate\")\n  2786\t        if isinstance(candidate_payload, Mapping):\n  2787\t            protagonist_payload = candidate_payload.get(\"protagonist\")\n  2788\t            supporting_cast_payload = candidate_payload.get(\"supporting_cast\", [])\n  2789\t\n  2790\t    return ExistingCharacterSheetContext(\n  2791\t        title=character_sheet.title,\n  2792\t        summary=character_sheet.summary,\n  2793\t        protagonist_name=character_sheet.protagonist_name,\n  2794\t        bedtime_safety_notes=character_sheet.bedtime_notes,\n  2795\t        protagonist=protagonist_payload,\n  2796\t        supporting_cast=(\n  2797\t            supporting_cast_payload\n  2798\t            if isinstance(supporting_cast_payload, list)\n  2799\t            else []\n  2800\t        ),\n  2801\t    )\n  2802\t\n  2803\t\n  2804\tdef _next_character_sheet_revision_number(character_sheets: list[CharacterSheet]) -> int:\n  2805\t    if not character_sheets:\n  2806\t        return 1\n  2807\t\n  2808\t    return max(character_sheet.revision_number for character_sheet in character_sheets) + 1\n  2809\t\n  2810\t\n  2811\tdef _read_character_sheet_label(character_sheet: CharacterSheet) -> str:\n  2812\t    return (\n  2813\t        character_sheet.title\n  2814\t        or character_sheet.protagonist_name\n  2815\t        or f\"Character sheet revision {character_sheet.revision_number}\"\n  2816\t    )\n  2817\t\n  2818\t\n  2819\tdef _build_beat_sheet_persistence_payload(\n  2820\t    result,\n  2821\t    *,\n  2822\t    generation_kind: str,\n  2823\t    guidance: str | None = None,\n  2824\t    focus_beats: list[str] | None = None,\n  2825\t    bedtime_goal: str | None = None,\n  2826\t    selected_pitch: Pitch,\n  2827\t    source_beat_sheet: BeatSheet | None = None,\n  2828\t    selection_rationale: str | None = None,\n  2829\t) -> dict[str, Any]:\n  2830\t    payload = build_beat_sheet_model_output(result)\n  2831\t    payload[\"generation_kind\"] = generation_kind\n  2832\t    payload[\"guidance\"] = guidance\n  2833\t    payload[\"focus_beats\"] = list(focus_beats or [])\n  2834\t    payload[\"bedtime_goal\"] = bedtime_goal\n  2835\t    payload[\"beats\"] = [\n  2836\t        {\n  2837\t            \"key\": beat.key,\n  2838\t            \"label\": beat.label,\n  2839\t            \"order\": index,\n  2840\t            \"summary\": beat.summary,\n  2841\t            \"emotional_intent\": beat.emotional_intent,\n  2842\t            \"bedtime_softening_note\": beat.bedtime_softening_note,\n  2843\t        }\n  2844\t        for index, beat in enumerate(result.beat_sheet.beats, start=1)\n  2845\t    ]\n  2846\t    payload[\"pitch_context\"] = {\n  2847\t        \"source_pitch_id\": selected_pitch.id,\n  2848\t        \"source_pitch_title\": selected_pitch.title,\n  2849\t    }\n  2850\t    if source_beat_sheet is not None:\n  2851\t        payload[\"refinement\"] = {\n  2852\t            \"source_beat_sheet_id\": source_beat_sheet.id,\n  2853\t            \"source_beat_sheet_revision_number\": source_beat_sheet.revision_number,\n  2854\t            \"refinement_instructions\": guidance,\n  2855\t            \"selection_rationale\": selection_rationale,\n  2856\t        }\n  2857\t    return payload\n  2858\t\n  2859\t\n  2860\tdef _build_existing_beat_sheet_context(beat_sheet: BeatSheet) -> ExistingBeatSheetContext:\n  2861\t    return ExistingBeatSheetContext(\n  2862\t        revision_number=beat_sheet.revision_number,\n  2863\t        summary=beat_sheet.summary,\n  2864\t        bedtime_notes=beat_sheet.bedtime_notes,\n  2865\t        beats=_read_generated_beat_sheet_beats(beat_sheet),\n  2866\t    )\n  2867\t\n  2868\t\n  2869\tdef _read_generated_beat_sheet_beats(beat_sheet: BeatSheet) -> list:\n  2870\t    if not isinstance(beat_sheet.beats, Mapping):\n  2871\t        return []\n  2872\t\n  2873\t    raw_beats = beat_sheet.beats.get(\"beats\")\n  2874\t    if not isinstance(raw_beats, list):\n  2875\t        return []\n  2876\t\n  2877\t    generated_beats = []\n  2878\t    for raw_beat in raw_beats:\n  2879\t        if not isinstance(raw_beat, Mapping):\n  2880\t            continue\n  2881\t        generated_beats.append(\n  2882\t            {\n  2883\t                \"key\": raw_beat.get(\"key\"),\n  2884\t                \"label\": raw_beat.get(\"label\"),\n  2885\t                \"summary\": raw_beat.get(\"summary\"),\n  2886\t                \"emotional_intent\": raw_beat.get(\"emotional_intent\"),\n  2887\t                \"bedtime_softening_note\": raw_beat.get(\"bedtime_softening_note\"),\n  2888\t            }\n  2889\t        )\n  2890\t\n  2891\t    return generated_beats\n  2892\t\n  2893\t\n  2894\tdef _next_beat_sheet_revision_number(beat_sheets: list[BeatSheet]) -> int:\n  2895\t    if not beat_sheets:\n  2896\t        return 1\n  2897\t\n  2898\t    return max(beat_sheet.revision_number for beat_sheet in beat_sheets) + 1\n  2899\t\n  2900\t\n  2901\tdef _build_beat_sheet_generation_stage_detail(\n  2902\t    beat_sheet,\n  2903\t) -> str:\n  2904\t    beat_count = len(getattr(beat_sheet, \"beats\", []))\n  2905\t    return (\n  2906\t        f\"Generated beat-sheet revision with {beat_count} Save-the-Cat beats. \"\n  2907\t        \"Accept a revision to continue.\"\n  2908\t    )\n  2909\t\n  2910\t\n  2911\tdef _build_beat_sheet_generation_summary_text(beat_sheet) -> str:\n  2912\t    summary = getattr(beat_sheet, \"summary\", None)\n  2913\t    if isinstance(summary, str) and summary:\n  2914\t        return f\"Generated beat sheet: {summary}\"\n  2915\t    return \"Generated a fresh Save-the-Cat beat sheet.\"\n  2916\t\n  2917\t\n  2918\tdef _build_beat_sheet_refinement_rationale(\n  2919\t    beat_sheet: BeatSheet,\n  2920\t    instructions: str,\n  2921\t    *,\n  2922\t    beat_names: list[str],\n  2923\t    bedtime_goal: str | None,\n  2924\t) -> str:\n  2925\t    focus_tail = f\" Focus beats: {', '.join(beat_names)}.\" if beat_names else \"\"\n  2926\t    bedtime_tail = f\" Bedtime goal: {bedtime_goal}.\" if bedtime_goal else \"\"\n  2927\t    return (\n  2928\t        f'Refined from \"{_read_beat_sheet_label(beat_sheet)}\" with: {instructions}.'\n  2929\t        f\"{focus_tail}{bedtime_tail}\"\n  2930\t    )\n  2931\t\n  2932\t\n  2933\tdef _build_beat_sheet_refinement_summary_text(\n  2934\t    refined_beat_sheet: BeatSheet,\n  2935\t    *,\n  2936\t    source_beat_sheet: BeatSheet,\n  2937\t) -> str:\n  2938\t    return (\n  2939\t        \"Generated refined beat sheet \"\n  2940\t        f\"{_read_beat_sheet_label(refined_beat_sheet)} from \"\n  2941\t        f\"{_read_beat_sheet_label(source_beat_sheet)}.\"\n  2942\t    )\n  2943\t\n  2944\t\n  2945\tdef _build_beat_sheet_selection_detail(beat_sheet: BeatSheet) -> str:\n  2946\t    summary = beat_sheet.summary or \"Beat sheet accepted for downstream planning.\"\n  2947\t    return f\"Accepted beat sheet revision {beat_sheet.revision_number}. {summary}\"\n  2948\t\n  2949\t\n  2950\tdef _build_beat_sheet_invalidation_detail(beat_sheet: BeatSheet) -> str:\n  2951\t    return (\n  2952\t        f\"Beat sheet revision {beat_sheet.revision_number} was accepted. Refresh composition \"\n  2953\t        \"and any downstream planning.\"\n  2954\t    )\n  2955\t\n  2956\t\n  2957\tdef _find_matching_beat_sheets(\n  2958\t    beat_sheets: list[BeatSheet],\n  2959\t    *,\n  2960\t    beat_sheet_id: str | None,\n  2961\t    revision_number: int | None,\n  2962\t) -> list[BeatSheet]:\n  2963\t    matches: list[BeatSheet] = []\n  2964\t\n  2965\t    for beat_sheet in beat_sheets:\n  2966\t        if beat_sheet_id is not None and beat_sheet.id != beat_sheet_id:\n  2967\t            continue\n  2968\t        if revision_number is not None and beat_sheet.revision_number != revision_number:\n  2969\t            continue\n  2970\t        matches.append(beat_sheet)\n  2971\t\n  2972\t    return matches\n  2973\t\n  2974\t\n  2975\tdef _resolve_source_beat_sheet(\n  2976\t    beat_sheets: list[BeatSheet],\n  2977\t    *,\n  2978\t    selected_beat_sheet: BeatSheet | None,\n  2979\t    beat_sheet_id: str | None,\n  2980\t    revision_number: int | None,\n  2981\t) -> BeatSheet | None:\n  2982\t    if beat_sheet_id is None and revision_number is None:\n  2983\t        return selected_beat_sheet\n  2984\t\n  2985\t    matches = _find_matching_beat_sheets(\n  2986\t        beat_sheets,\n  2987\t        beat_sheet_id=beat_sheet_id,\n  2988\t        revision_number=revision_number,\n  2989\t    )\n  2990\t    if len(matches) != 1:\n  2991\t        return None\n  2992\t\n  2993\t    return matches[0]\n  2994\t\n  2995\t\n  2996\tdef _read_beat_sheet_label(beat_sheet: BeatSheet) -> str:\n  2997\t    return f\"Beat sheet revision {beat_sheet.revision_number}\"\n  2998\t\n  2999\t\n  3000\tdef _read_beat_sheet_selection_rationale(beat_sheet: BeatSheet) -> str | None:\n  3001\t    if not isinstance(beat_sheet.beat