ous_status=previous_status,\n  2155\t                status=stage_snapshot.status,\n  2156\t                detail=stage_snapshot.detail,\n  2157\t                invalidated_stages=invalidated_stages,\n  2158\t                current_stage=story_session.current_stage,\n  2159\t                resume_stage=story_session.resume_stage,\n  2160\t                furthest_completed_stage=story_session.furthest_completed_stage,\n  2161\t                overall_status=story_session.overall_status,\n  2162\t                actor=actor,\n  2163\t            )\n  2164\t            for invalidated_stage in invalidated_stages:\n  2165\t                stage_map[invalidated_stage].last_event = stage_event\n  2166\t\n  2167\t        selection_event = self._event_log.record_selection(\n  2168\t            story_session.id,\n  2169\t            selection_kind=SelectionKind.BEAT_SHEET,\n  2170\t            stage=WorkflowStage.BEATS,\n  2171\t            label=_read_beat_sheet_label(selected_beat_sheet),\n  2172\t            selection_id=selected_beat_sheet.id,\n  2173\t            rationale=_read_beat_sheet_selection_rationale(selected_beat_sheet),\n  2174\t            previous_selection_id=(\n  2175\t                previous_selected_beat_sheet.id\n  2176\t                if previous_selected_beat_sheet is not None\n  2177\t                else None\n  2178\t            ),\n  2179\t            source=origin,\n  2180\t            accepted=True,\n  2181\t            actor=actor,\n  2182\t        )\n  2183\t        stage_snapshot.last_event = selection_event\n  2184\t        self._session.commit()\n  2185\t        return SessionSelectionResponse(\n  2186\t            snapshot=self.load_session_snapshot(story_session.id),\n  2187\t            event=self._event_log.build_event_view(selection_event),\n  2188\t        )\n  2189\t\n  2190\t    def apply_context_update(\n  2191\t        self,\n  2192\t        session_id: str,\n  2193\t        *,\n  2194\t        payload: SessionContextUpdat