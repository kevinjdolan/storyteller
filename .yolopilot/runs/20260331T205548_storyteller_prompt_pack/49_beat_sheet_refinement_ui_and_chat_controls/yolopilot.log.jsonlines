erialized_sequence_number(\n   226\t    aggregate: SessionAggregate,\n   227\t    *,\n   228\t    conversation_memory: ConversationMemorySnapshotView | None,\n   229\t) -> int | None:\n   230\t    sequence_numbers = [\n   231\t        stage_state.last_event.sequence_number\n   232\t        for stage_state in aggregate.session.workflow_stage_states\n   233\t        if getattr(stage_state, \"last_event\", None) is not None\n   234\t    ]\n   235\t\n   236\t    return max(sequence_numbers) if sequence_numbers else None\n   237\t\n   238\t\n   239\tdef select_replay_events(\n   240\t    events,\n   241\t    *,\n   242\t    materialized_sequence_number: int | None,\n   243\t):\n   244\t    if materialized_sequence_number is None:\n   245\t        return [\n   246\t            event\n   247\t            for event in events\n   248\t            if event.event_type\n   249\t            in {\n   250\t                SessionEventType.WORKFLOW_STAGE_CHANGED.value,\n   251\t                SessionEventType.COMPOSITION_PROGRESS_RECORDED.value,\n   252\t                SessionEventType.AUDIO_PROGRESS_RECORDED.value,\n   253\t            }\n   254\t        ]\n   255\t\n   256\t    return [\n   257\t        event\n   258\t        for event in events\n   259\t        if event.sequence_number > materialized_sequence_number\n   260\t        and event.event_type\n   261\t        in {\n   262\t            SessionEventType.WORKFLOW_STAGE_CHANGED.value,\n   263\t            SessionEventType.COMPOSITION_PROGRESS_RECORDED.value,\n   264\t            SessionEventType.AUDIO_PROGRESS_RECORDED.value,\n   265\t        }\n   266\t    ]\n   267\t\n   268\t\n   269\tdef replay_session_snapshot(\n   270\t    snapshot: SessionSnapshot,\n   271\t    events,\n   272\t):\n   273\t    if not events:\n   274\t        return snapshot, 0\n   275\t\n   276\t    hydrated = snapshot.model_copy(deep=True)\n   277\t    replayed_event_count = 0\n   278\t\n   279\t    for event in events:\n   280\t        applied = False\n   281\t        if event.event_type == SessionEventType.WORKFLOW_STAGE_CHANGED.value and isinstance(\n   282\t            event.payload, WorkflowStageChangedEventPayload\n   283\t        ):\n   284\t            apply_workflow_stage_changed_event(hydrated, event)\n   285\t            applied = True\n   286\t        elif (\n   287\t            event.event_type == SessionEventType.COMPOSITION_PROGRESS_RECORDED.value\n   288\t            and isinstance(event.payload, CompositionProgressEventPayload)\n   289\t        ):\n   290\t            apply_job_progress_event(\n   291\t                hydrated,\n   292\t                stage=WorkflowStage.COMPOSITION,\n   293\t                job_kind=\"composition\",\n   294\t                payload=event.payload,\n   295\t                event_created_at=event.created_at,\n   296\t                event_summary=event.summary,\n   297\t            )\n   298\t            applied = True\n   299\t        elif event.event_type == SessionEventType.AUDIO_PROGRESS_RECORDED.value and isinstance(\n   300\t            event.payload, AudioProgressEventPayload\n   301\t        ):\n   302\t            apply_job_progress_event(\n   303\t                hydrated,\n   304\t                stage=WorkflowStage.AUDIO,\n   305\t                job_kind=\"audio\",\n   306\t                payload=event.payload,\n   307\t                event_created_at=event.created_at,\n   308\t                event_summary=event.summary,\n   309\t            )\n   310\t            applied = True\n   311\t\n   312\t        if applied:\n   313\t            replayed_event_count += 1\n   314\t\n   315\t    hydrated.progress = build_progress(hydrated.stage_states)\n   316\t    recompute_rollups(hydrated)\n   317\t    return hydrated, replayed_event_count\n   318\t\n   319\t\n   320\tdef apply_workflow_stage_changed_event(snapshot: SessionSnapshot, event) -> None:\n   321\t    payload = event.payload\n   322\t    if not isinstance(payload, WorkflowStageChangedEventPayload) or event.stage is None:\n   323\t        return\n   324\t\n   325\t    for index, stage_state in enumerate(snapshot.stage_states):\n   326\t        if stage_state.stage == event.stage and is_event_newer(\n   327\t            stage_state.last_event_at,\n   328\t            event.created_at,\n   329\t        ):\n   330\t            started_at = stage_state.started_at\n   331\t            if payload.status in {\n   332\t                WorkflowStageState.IN_PROGRESS,\n   333\t                WorkflowStageState.COMPLETED,\n   334\t            }:\n   335\t                started_at = started_at or event.created_at\n   336\t            completed_at = stage_state.completed_at\n   337\t            if payload.status == WorkflowStageState.COMPLETED:\n   338\t                completed_at = completed_at or event.created_at\n   339\t            elif payload.status != WorkflowStageState.COMPLETED:\n   340\t                completed_at = None\n   341\t\n   342\t            snapshot.stage_states[index] = stage_state.model_copy(\n   343\t                update={\n   344\t                    \"status\": payload.status,\n   345\t                    \"detail\": payload.detail if payload.detail is not None else stage_state.detail,\n   346\t                    \"started_at\": started_at,\n   347\t                    \"completed_at\": completed_at,\n   348\t                    \"last_event_summary\": event.summary,\n   349\t                    \"last_event_type\": event.event_type,\n   350\t                    \"last_event_at\": event.created_at,\n   351\t                }\n   352\t            )\n   353\t            continue\n   354\t\n   355\t        if stage_state.stage in payload.invalidated_stages and is_event_newer(\n   356\t            stage_state.last_event_at, event.created_at\n   357\t        ):\n   358\t            snapshot.stage_states[index] = stage_state.model_copy(\n   359\t                update={\n   360\t                    \"status\": WorkflowStageState.NEEDS_REGENERATION,\n   361\t                    \"last_event_summary\": event.summary,\n   362\t                    \"last_event_type\": event.event_type,\n   363\t                    \"last_event_at\": event.created_at,\n   364\t                }\n   365\t            )\n   366\t\n   367\t    snapshot.current_stage = payload.current_stage\n   368\t    snapshot.resume_stage = payload.resume_stage\n   369\t    snapshot.furthest_completed_stage = payload.furthest_completed_stage\n   370\t    snapshot.overall_status = payload.overall_status\n   371\t    if is_event_newer(snapshot.updated_at, event.created_at):\n   372\t        snapshot.updated_at = event.created_at\n   373\t\n   374\t\n   375\tdef apply_job_progress_event(\n   376\t    snapshot: SessionSnapshot,\n   377\t    *,\n   378\t    stage: WorkflowStage,\n   379\t    job_kind: str,\n   380\t    payload: CompositionProgressEventPayload | AudioProgressEventPayload,\n   381\t    event_created_at: datetime,\n   382\t    event_summary: str,\n   383\t) -> None:\n   384\t    if job_kind == \"composition\":\n   385\t        latest_job = merge_composition_job_view(\n   386\t            snapshot.latest_composition_job,\n   387\t            payload,\n   388\t            event_created_at=event_created_at,\n   389\t        )\n   390\t        snapshot.latest_composition_job = latest_job\n   391\t        if latest_job is not None and latest_job.status in _ACTIVE_JOB_STATUS_VALUES:\n   392\t            snapshot.active_composition_job = latest_job\n   393\t        elif (\n   394\t            snapshot.active_composition_job is not None\n   395\t            and snapshot.active_composition_job.id == payload.job_id\n   396\t        ):\n   397\t            snapshot.active_composition_job = None\n   398\t        job_detail = build_composition_job_detail(\n   399\t            latest_job,\n   400\t            fallback_summary=event_summary,\n   401\t        )\n   402\t    else:\n   403\t        latest_job = merge_audio_job_view(\n   404\t            snapshot.latest_audio_job,\n   405\t            payload,\n   406\t            event_created_at=event_created_at,\n   407\t        )\n   408\t        snapshot.latest_audio_job = latest_job\n   409\t        if latest_job is not None and latest_job.status in _ACTIVE_JOB_STATUS_VALUES:\n   410\t            snapshot.active_audio_job = latest_job\n   411\t        elif (\n   412\t            snapshot.active_audio_job is not None and snapshot.active_audio_job.id == payload.job_id\n   413\t        ):\n   414\t            snapshot.active_audio_job = None\n   415\t        job_detail = build_audio_job_detail(\n   416\t            latest_job,\n   417\t            fallback_summary=event_summary,\n   418\t        )\n   419\t\n   420\t    update_stage_state_from_job(\n", "command": "/bin/zsh -lc \"nl -ba backend/app/services/session_hydration.py | sed -n '200,420p'\"", "exit_code": 0, "id": "item_24", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 48, "prompt_index": 50, "prompt_name": "49 \u2014 Beat Sheet Refinement UI and Chat Controls", "prompt_total": 100}, "timestap": "2026-04-02T00:22:17-07:00"}
