en.getByTestId('live-feed-status')).toHaveTextContent('Idle')\n    expect(screen.getByRole('link', { name: 'Return home' })).toHaveAttribute(\n      'href',\n      '/',\n    )\n    expect(screen.getByRole('log')).toBeInTheDocument()\n    expect(\n      screen.getByRole('button', { name: 'Send message' }),\n    ).toBeInTheDocument()\n    expect(\n      screen.getByText(\n        'The current focus is softening the midpoint before composition starts.',\n      ),\n    ).toBeInTheDocument()\n    expect(\n      screen.getByRole('heading', {\n        level: 3,\n        name: 'Generate a beat sheet revision',\n      }),\n    ).toBeInTheDocument()\n    expect(\n      screen.getByRole('heading', { level: 3, name: 'Beat outline preview' }),\n", "command": "/bin/zsh -lc \"sed -n '2820,2898p' frontend/src/pages/session/SessionWorkspacePage.test.tsx\"", "exit_code": 0, "id": "item_126", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 252, "prompt_index": 50, "prompt_name": "49 \u2014 Beat Sheet Refinement UI and Chat Controls", "prompt_total": 100}, "timestap": "2026-04-02T00:48:09-07:00"}
