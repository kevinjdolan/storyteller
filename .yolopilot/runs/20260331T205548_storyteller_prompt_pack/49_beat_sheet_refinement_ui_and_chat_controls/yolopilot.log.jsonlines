ateRequest,\n    46\t    SessionContextUpdateResponse,\n    47\t    SessionEventView,\n    48\t    SessionHistoryView,\n    49\t    SessionHydrationView,\n    50\t    SessionPitchGenerationResponse,\n    51\t    SessionSelectionResponse,\n    52\t    SessionSnapshot,\n    53\t    SessionStoryBriefResponse,\n    54\t)\n    55\tfrom app.services import (\n    56\t    BeatSheetGenerationService,\n    57\t    BriefNormalizationService,\n    58\t    CharacterGenerationService,\n    59\t    PitchGenerationService,\n    60\t    SessionActionPolicyService,\n    61\t    SessionIntentParserService,\n    62\t)\n    63\tfrom app.services.session_hydration import SessionHydrationNotFoundError, SessionHydrationService\n    64\tfrom app.services.sessions import (\n    65\t    InvalidStageTransitionError,\n    66\t    SessionCharacterSheetGenerationError,\n    67\t    SessionCharacterSheetSelectionError,\n    68\t    SessionBeatSheetGenerationError,\n    69\t    SessionBeatSheetSelectionError,\n    70\t    SessionGenreSelectionError,\n    71\t    SessionNotFoundError,\n    72\t    SessionPitchGenerationError,\n    73\t    SessionPitchSelectionError,\n    74\t    SessionService,\n    75\t    SessionStoryBriefSaveError,\n    76\t    SessionToneSelectionError,\n    77\t    UnsupportedSessionContextUpdateError,\n    78\t)\n    79\t\n    80\trouter = APIRouter(prefix=\"/sessions\", tags=[\"sessions\"])\n    81\t\n    82\t\n    83\t@router.get(\n    84\t    \"\",\n    85\t    response_model=list[RecentSessionSummary],\n    86\t    summary=\"List recent story sessions\",\n    87\t)\n    88\tdef list_recent_sessions(\n    89\t    db_session: Annotated[Session, Depends(get_db_session)],\n    90\t    limit: Annotated[int, Query(ge=1, le=100)] = 20,\n    91\t) -> list[RecentSessionSummary]:\n    92\t    return SessionService(db_session).list_recent_sessions(limit=limit)\n    93\t\n    94\t\n    95\t@router.get(\n    96\t    \"/{session_id}\",\n    97\t    response_model=SessionSnapshot,\n    