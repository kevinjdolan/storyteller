\n    48\t}\n    49\t\n    50\tconst revisionTimestampFormatter = new Intl.DateTimeFormat(undefined, {\n    51\t  month: 'short',\n    52\t  day: 'numeric',\n    53\t  hour: 'numeric',\n    54\t  minute: '2-digit',\n    55\t})\n    56\t\n    57\tfunction formatRevisionTimestamp(value: string) {\n    58\t  return `Saved ${revisionTimestampFormatter.format(new Date(value))}`\n    59\t}\n    60\t\n    61\tfunction humanizeBeatName(value: string) {\n    62\t  return value\n    63\t    .replace(/[_-]+/g, ' ')\n    64\t    .replace(/\\b\\w/g, (letter) => letter.toUpperCase())\n    65\t}\n    66\t\n    67\tfunction parseBeatNames(value: string) {\n    68\t  return value\n    69\t    .split(/[\\n,]/g)\n    70\t    .map((entry) => entry.trim())\n    71\t    .filter(Boolean)\n    72\t}\n    73\t\n    74\tfunction readBeatSelectionCopy(beatSheet: {\n    75\t  summary?: string | null\n    76\t  selection_rationale?: string | null\n    77\t}) {\n    78\t  return (\n    79\t    beatSheet.selection_rationale ??\n    80\t    beatSheet.summary ??\n    81\t    'The accepted Save-the-Cat revision will appear here once one is chosen.'\n    82\t  )\n    83\t}\n    84\t\n    85\tfunction buildBeatRevisionSummary(beatSheet: BeatSheetView) {\n    86\t  if (\n    87\t    beatSheet.generation_kind === 'refinement' &&\n    88\t    beatSheet.source_beat_sheet_revision_number != null &&\n    89\t    beatSheet.refinement_instructions != null\n    90\t  ) {\n    91\t    return `Refined from revision ${beatSheet.source_beat_sheet_revision_number}. ${beatSheet.refinement_instructions}`\n    92\t  }\n    93\t\n    94\t  if (\n    95\t    beatSheet.generation_kind === 'refinement' &&\n    96\t    beatSheet.source_beat_sheet_revision_number != null\n    97\t  ) {\n    98\t    return `Refined from revision ${beatSheet.source_beat_sheet_revision_number}.`\n    99\t  }\n   100\t\n   101\t  if (beatSheet.updated_at != null) {\n   102\t    return formatRevisionTimestamp(beatSheet.updated_at)\n   103\t  }\n   104\t\n   105\t  return 'Fresh Save-the-Cat outline ready for review.'\n   106\t}\n   107\t\n   108\tfunction buildFocusBeatSummary(beatSheet: BeatSheetView) {\n   109\t  if (beatSheet.focus_beats.length === 0) {\n   110\t    return 'No focus beats were called out for this revision.'\n   111\t  }\n   112\t\n   113\t  return beatSheet.focus_beats.map(humanizeBeatName).join(', ')\n   114\t}\n   115\t\n   116\tfunction buildRevisionHelp(\n   117\t  selectedStage: SessionWorkspaceStageView,\n   118\t  snapshot: SessionSnapshot,\n   119\t  beatSheetRevisions: BeatSheetView[],\n   120\t) {\n   121\t  if (selectedStage.availability === 'locked') {\n   122\t    return {\n   123\t      body: 'Accept a character sheet first. The beat stage stays visible, but generation is disabled until the cast is durable.',\n   124\t      title: 'Character selection comes first',\n   125\t      tone: 'warning' as const,\n   126\t    }\n   127\t  }\n   128\t\n   129\t  if (\n   130\t    selectedStage.availability === 'revisitable' &&\n   131\t    snapshot.selected_beat_sheet\n   132\t  ) {\n   133\t    return {\n   134\t      body: 'Generating or refining beats reopens downstream planning. The accepted revision stays visible while you compare new structures.',\n   135\t      title: 'New beat revisions refresh later work',\n   136\t      tone: 'warning' as const,\n   137\t    }\n   138\t  }\n   139\t\n   140\t  if (beatSheetRevisions.length > 0) {\n   141\t    return {\n   142\t      body: 'Keep the structure high level. Each beat should anchor the emotional turn, show bedtime softening, and preserve the full Save-the-Cat order.',\n   143\t      title: 'Compare the arc before accepting it',\n   144\t      tone: 'success' as const,\n   145\t    }\n   146\t  }\n   147\t\n   148\t  return {\n   149\t    body: 'Generate the first beat-sheet revision from the selected pitch and character sheet, then review the full fifteen-beat progression before moving on.',\n   150\t    title: 'Start with a full Save-the-Cat outline',\n   151\t    tone: 'info' as const,\n   152\t  }\n   153\t}\n   154\t\n   155\texport function BeatSheetStage({\n   156\t  onGenerateBeatSheet,\n   157\t  onPreviewStage,\n   158\t  onRefineBeatSheet,\n   159\t  onSelectBeatSheet,\n   160\t  selectedStage,\n   161\t  snapshot,\n   162\t}: BeatSheetStageProps) {\n   163\t  const beatSheetRevisions = useMemo(\n   164\t    () => snapshot.beat_sheet_revisions ?? [],\n   165\t    [snapshot.beat_sheet_revisions],\n   166\t  )\n   167\t  const latestBeatSheet = beatSheetRevisions[0] ?? null\n   168\t  const selectedBeatSheetId = snapshot.selected_beat_sheet?.id ?? null\n   169\t  const revisionHelp = buildRevisionHelp(\n   170\t    selectedStage,\n   171\t    snapshot,\n   172\t    beatSheetRevisions,\n   173\t  )\n   174\t  const [guidance, setGuidance] = useState('')\n   175\t  const [generationFocusBeats, setGenerationFocusBeats] = useState('')\n   176\t  const [generationBedtimeGoal, setGenerationBedtimeGoal] = useState('')\n   177\t  const [generationError, setGenerationError] = useState<string | null>(null)\n   178\t  const [refinementInstructions, setRefinementInstructions] = useState('')\n   179\t  const [refinementFocusBeats, setRefinementFocusBeats] = useState('')\n   180\t  const [refinementBedtimeGoal, setRefinementBedtimeGoal] = useState('')\n   181\t  const [refinementError, setRefinementError] = useState<string | null>(null)\n   182\t  const [selectionError, setSelectionError] = useState<string | null>(null)\n   183\t  const [isGenerating, setIsGenerating] = useState(false)\n   184\t  const [isRefining, setIsRefining] = useState(false)\n   185\t  const [pendingBeatSheetId, setPendingBeatSheetId] = useState<string | null>(\n   186\t    null,\n   187\t  )\n   188\t  const [refinementBaseBeatSheetId, setRefinementBaseBeatSheetId] = useState<\n   189\t    string | null\n   190\t  >(selectedBeatSheetId ?? latestBeatSheet?.id ?? null)\n   191\t  const [inspectedBeatSheetId, setInspectedBeatSheetId] = useState<\n   192\t    string | null\n   193\t  >(selectedBeatSheetId ?? latestBeatSheet?.id ?? null)\n   194\t\n   195\t  const refinementBaseBeatSheet =\n   196\t    beatSheetRevisions.find(\n   197\t      (beatSheet) => beatSheet.id === refinementBaseBeatSheetId,\n   198\t    ) ?? null\n   199\t  const inspectedBeatSheet =\n   200\t    beatSheetRevisions.find(\n   201\t      (beatSheet) => beatSheet.id === inspectedBeatSheetId,\n   202\t    ) ??\n   203\t    snapshot.selected_beat_sheet ??\n   204\t    latestBeatSheet\n   205\t\n   206\t  useEffect(() => {\n   207\t    if (\n   208\t      refinementBaseBeatSheetId != null &&\n   209\t      beatSheetRevisions.some(\n   210\t        (beatSheet) => beatSheet.id === refinementBaseBeatSheetId,\n   211\t      )\n   212\t    ) {\n   213\t      return\n   214\t    }\n   215\t\n   216\t    setRefinementBaseBeatSheetId(\n   217\t      selectedBeatSheetId ?? latestBeatSheet?.id ?? null,\n   218\t    )\n   219\t  }, [\n   220\t    beatSheetRevisions,\n   221\t    latestBeatSheet?.id,\n   222\t    refinementBaseBeatSheetId,\n   223\t    selectedBeatSheetId,\n   224\t  ])\n   225\t\n   226\t  useEffect(() => {\n   227\t    if (\n   228\t      inspectedBeatSheetId != null &&\n   229\t      beatSheetRevisions.some(\n   230\t        (beatSheet) => beatSheet.id === inspectedBeatSheetId,\n   231\t      )\n   232\t    ) {\n   233\t      return\n   234\t    }\n   235\t\n   236\t    setInspectedBeatSheetId(selectedBeatSheetId ?? latestBeatSheet?.id ?? null)\n   237\t  }, [\n   238\t    beatSheetRevisions,\n   239\t    inspectedBeatSheetId,\n   240\t    latestBeatSheet?.id,\n   241\t    selectedBeatSheetId,\n   242\t  ])\n   243\t\n   244\t  async function handleGenerateBeatSheet() {\n   245\t    if (selectedStage.availability === 'locked' || isGenerating) {\n   246\t      return\n   247\t    }\n   248\t\n   249\t    setGenerationError(null)\n   250\t    setIsGenerating(true)\n   251\t\n   252\t    try {\n   253\t      await onGenerateBeatSheet({\n   254\t        guidance: guidance.trim() || null,\n   255\t        focusBeats: parseBeatNames(generationFocusBeats),\n   256\t        bedtimeGoal: generationBedtimeGoal.trim() || null,\n   257\t        origin: 'workspace',\n   258\t      })\n   259\t      setGuidance('')\n   260\t      setGenerationFocusBeats('')\n   261\t      setGenerationBedtimeGoal('')\n   262\t    } catch (error) {\n   263\t      setGenerationError(\n   264\t        error instanceof Error\n   265\t          ? error.message\n   266\t          : 'The beat-sheet revision could not be generated right now.',\n   267\t      )\n   268\t    } finally {\n   269\t      setIsGenerating(false)\n   270\t    }\n   271\t  }\n   272\t\n   273\t  async function handleBeatSheetSelection(beatSheet: BeatSheetView) {\n   274\t    setPendingBeatSheetId(beatSheet.id)\n   275\t    setSelectionError(null)\n   276\t\n   277\t    try {\n   278\t      await onSelectBeatSheet({\n   279\t        beatSheetId: beatSheet.id,\n   280\t        revisionNumber: beatSheet.revision_number,\n   281\t        origin: 'workspace',\n   282\t      })\n   283\t    } catch (error) {\n   284\t      setSelectionError(\n   285\t        error instanceof Error\n   286\t          ? error.message\n   287\t          : 'The selected beat sheet could not be saved right now.',\n   288\t      )\n   289\t    } finally {\n   290\t      setPendingBeatSheetId(null)\n   291\t    }\n   292\t  }\n   293\t\n   294\t  async function handleBeatSheetRefinement() {\n   295\t    if (\n   296\t      selectedStage.availability === 'locked' ||\n   297\t      isRefining ||\n   298\t      refinementBaseBeatSheet == null ||\n   299\t      refinementInstructions.trim().length === 0\n   300\t    ) {\n   301\t      return\n   302\t    }\n   303\t\n   304\t    setRefinementError(null)\n   305\t    setIsRefining(true)\n   306\t\n   307\t    try {\n   308\t      await onRefineBeatSheet({\n   309\t        beatSheetId: refinementBaseBeatSheet.id,\n   310\t        revisionNumber: refinementBaseBeatSheet.revision_number,\n   311\t        instructions: refinementInstructions.trim(),\n   312\t        beatNames: parseBeatNames(refinementFocusBeats),\n   313\t        bedtimeGoal: refinementBedtimeGoal.trim() || null,\n   314\t        origin: 'workspace',\n   315\t      })\n   316\t      setRefinementInstructions('')\n   317\t      setRefinementFocusBeats('')\n   318\t      setRefinementBedtimeGoal('')\n   319\t    } catch (error) {\n   320\t      setRefinementError(\n   321\t        error instanceof Error\n   322\t          ? error.message\n   323\t          : 'The beat-sheet refinement could not be saved right now.',\n   324\t      )\n   325\t    } finally {\n   326\t      setIsRefining(false)\n   327\t    }\n   328\t  }\n   329\t\n   330\t  return (\n   331\t    <section aria-label=\"Beat sheet stage\" className=\"workspace-stage-panel\">\n   332\t      <CardGrid className=\"workspace-stage-detail__cards\" columns={3}>\n   333\t        <SummaryPanel\n   334\t          description={\n   335\t            snapshot.selected_beat_sheet != null\n   336\t              ? readBeatSelectionCopy(snapshot.selected_beat_sheet)\n   337\t              : 'No beat revision is accepted yet. Generate or refine one, then choose the version that gives composition the clearest bedtime-safe arc.'\n   338\t          }\n   339\t          label=\"Current selection\"\n   340\t          title={\n   341\t            snapshot.selected_beat_sheet != null\n   342\t              ? `Revision ${snapshot.selected_beat_sheet.revision_number}`\n   343\t              : 'Beat sheet pending'\n   344\t          }\n   345\t          tone={snapshot.selected_beat_sheet != null ? 'accent' : 'default'}\n   346\t        />\n   347\t\n   348\t        <SummaryPanel\n   349\t          description={\n   350\t            latestBeatSheet != null\n   351\t              ? buildBeatRevisionSummary(latestBeatSheet)\n   352\t              : 'The newest durable beat revision will appear here once generation runs.'\n   353\t          }\n   354\t          label=\"Latest revision\"\n   355\t          title={\n   356\t            latestBeatSheet != null\n   357\t              ? latestBeatSheet.generation_kind === 'refinement'\n   358\t                ? `Revision ${latestBeatSheet.revision_number} refined`\n   359\t                : `Revision ${latestBeatSheet.revision_number} ready`\n   360\t              : 'No beat revision yet'\n   361\t          }\n   362\t        >\n   363\t          {latestBeatSheet != null ? (\n   364\t            <div className=\"workspace-stage-detail__badges\">\n   365\t              <Badge tone=\"brand\">{latestBeatSheet.beats.length} beats</Badge>\n   366\t              {latestBeatSheet.generation_kind === 'refinement' ? (\n   367\t                <Badge tone=\"accent\">Refinement</Badge>\n   368\t              ) : null}\n   369\t              {latestBeatSheet.focus_beats.length > 0 ? (\n   370\t                <Badge tone=\"neutral\">\n   371\t                  {latestBeatSheet.focus_beats.length} focus beat\n   372\t                  {latestBeatSheet.focus_beats.length === 1 ? '' : 's'}\n   373\t                </Badge>\n   374\t              ) : null}\n   375\t            </div>\n   376\t          ) : null}\n   377\t        </SummaryPanel>\n   378\t\n   379\t        <SummaryPanel\n   380\t          description={\n   381\t            snapshot.selected_beat_sheet != null\n   382\t              ? 'Story setup can now inherit a durable structure for pacing, runtime, and chapter planning.'\n   383\t              : 'Accepting a beat revision completes this stage and unlocks story setup.'\n   384\t          }\n   385\t          label=\"Next step\"\n   386\t          title={\n   387\t            snapshot.selected_beat_sheet != null\n   388\t              ? 'Story setup is ready next'\n   389\t              : 'Choose one revision to continue'\n   390\t          }\n   391\t        >\n   392\t          <div className=\"cta-row\">\n   393\t            <Button\n   394\t              onClick={() => {\n   395\t                onPreviewStage(\n   396\t                  snapshot.selected_beat_sheet != null\n   397\t                    ? 'story_setup'\n   398\t                    : 'characters',\n   399\t                )\n   400\t              }}\n   401\t              tone=\"ghost\"\n   402\t            >\n   403\t              {snapshot.selected_beat_sheet != null\n   404\t                ? 'Preview story setup'\n   405\t                : 'Revisit characters'}\n   406\t            </Button>\n   407\t          </div>\n   408\t        </SummaryPanel>\n   409\t      </CardGrid>\n   410\t\n   411\t      <InlineHelp title={revisionHelp.title} tone={revisionHelp.tone}>\n   412\t        {revisionHelp.body}\n   413\t      </InlineHelp>\n   414\t\n   415\t      {generationError != null ? (\n   416\t        <InlineHelp title=\"Beat generation failed\" tone=\"warning\">\n   417\t          {generationError}\n   418\t        </InlineHelp>\n   419\t      ) : null}\n   420\t\n   421\t      {selectionError != null ? (\n   422\t        <InlineHelp title=\"Beat selection failed\" tone=\"warning\">\n   423\t          {selectionError}\n   424\t        </InlineHelp>\n   425\t      ) : null}\n   426\t\n   427\t      {refinementError != null ? (\n   428\t        <InlineHelp title=\"Beat refinement failed\" tone=\"warning\">\n   429\t          {refinementError}\n   430\t        </InlineHelp>\n   431\t      ) : null}\n   432\t\n   433\t      <section className=\"workspace-stage-panel\">\n   434\t        <div className=\"panel-heading\">\n   435\t          <div>\n   436\t            <h3>Generate a beat sheet revision</h3>\n   437\t            <p>\n   438\t              Create or refresh the Save-the-Cat outline from the accepted pitch\n   439\t              and character sheet, keeping the structure high level and\n   440\t              bedtime-safe.\n   441\t            </p>\n   442\t          </div>\n   443\t          <Badge tone={latestBeatSheet != null ? 'success' : 'warning'}>\n   444\t            {latestBeatSheet != null ? 'Revision ready' : 'Generation required'}\n   445\t          </Badge>\n   446\t        </div>\n   447\t\n   448\t        <CardGrid className=\"beat-stage__controls\" columns={2}>\n   449\t          <TextArea\n   450\t            description=\"Optional guidance can steer the next revision. For example: soften the midpoint, make the catalyst more luminous, or keep the finale quieter.\"\n   451\t            disabled={selectedStage.availability === 'locked' || isGenerating}\n   452\t            label=\"Optional beat guidance\"\n   453\t            onChange={(event) => {\n   454\t              setGuidance(event.currentTarget.value)\n   455\t            }}\n   456\t            rows={4}\n   457\t            value={guidance}\n   458\t          />\n   459\t\n   460\t          <TextArea\n   461\t            description=\"Optional. Focus specific beats by key or label. Separate entries with commas or line breaks.\"\n   462\t            disabled={selectedStage.availability === 'locked' || isGenerating}\n   463\t            label=\"Focus beats\"\n   464\t            onChange={(event) => {\n   465\t              setGenerationFocusBeats(event.currentTarget.value)\n   466\t            }}\n   467\t            rows={4}\n   468\t            value={generationFocusBeats}\n   469\t          />\n   470\t\n   471\t          <TextArea\n   472\t            description=\"Optional. Capture the bedtime landing you want the outline to protect all the way through the final image.\"\n   473\t            disabled={selectedStage.availability === 'locked' || isGenerating}\n   474\t            label=\"Bedtime goal\"\n   475\t            onChange={(event) => {\n   476\t              setGenerationBedtimeGoal(event.currentTarget.value)\n   477\t            }}\n   478\t            rows={3}\n   479\t            value={generationBedtimeGoal}\n   480\t          />\n   481\t        </CardGrid>\n   482\t\n   483\t        <div className=\"cta-row\">\n   484\t          <Button\n   485\t            disabled={selectedStage.availability === 'locked' || isGenerating}\n   486\t            onClick={() => {\n   487\t              void handleGenerateBeatSheet()\n   488\t            }}\n   489\t            tone=\"primary\"\n   490\t          >\n   491\t            {isGenerating\n   492\t              ? 'Generating beat sheet...'\n   493\t              : latestBeatSheet != null\n   494\t                ? 'Regenerate beat sheet'\n   495\t                : 'Generate beat sheet'}\n   496\t          </Button>\n   497\t          <Button\n   498\t            onClick={() => {\n   499\t              onPreviewStage('characters')\n   500\t            }}\n   501\t            tone=\"ghost\"\n   502\t          >\n   503\t            Revisit characters\n   504\t          </Button>\n   505\t        </div>\n   506\t      </section>\n   507\t\n   508\t      <section className=\"workspace-stage-panel\">\n   509\t        <div className=\"panel-heading\">\n   510\t          <div>\n   511\t            <h3>Refine a saved beat revision</h3>\n   512\t            <p>\n   513\t              Pick one saved revision, describe the structural change, and save\n   514\t              the result as a new durable option without losing earlier beats.\n   515\t            </p>\n   516\t          </div>\n   517\t          <Badge tone={refinementBaseBeatSheet != null ? 'brand' : 'warning'}>\n   518\t            {refinementBaseBeatSheet != null\n   519\t              ? 'Ready to refine'\n   520\t              : 'Generate a base revision'}\n", "command": "/bin/zsh -lc \"nl -ba frontend/src/features/session/BeatSheetStage.tsx | sed -n '1,520p'\"", "exit_code": 0, "id": "item_10", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 23, "prompt_index": 50, "prompt_name": "49 \u2014 Beat Sheet Refinement UI and Chat Controls", "prompt_tot