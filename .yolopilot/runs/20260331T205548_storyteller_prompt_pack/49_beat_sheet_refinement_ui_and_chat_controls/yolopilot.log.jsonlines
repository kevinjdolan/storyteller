rkflowStageId | null\n   283\t  related_stages: WorkflowStageId[]\n   284\t  related_action_types: string[]\n   285\t}\n   286\t\n   287\texport type SessionActionPolicySideEffect = {\n   288\t  kind: string\n   289\t  message: string\n   290\t  stages: WorkflowStageId[]\n   291\t  selection_field?: string | null\n   292\t  job_kind?: string | null\n   293\t  asset_kind?: string | null\n   294\t}\n   295\t\n   296\texport type SessionActionPolicyEvaluationItem = {\n   297\t  action_index: number\n   298\t  action_type: string\n   299\t  target_stage: WorkflowStageId\n   300\t  decision: SessionActionDecision\n   301\t  summary: string\n   302\t  reasons: SessionActionPolicyReason[]\n   303\t  side_effects: SessionActionPolicySideEffect[]\n   304\t  prerequisite_action_types: string[]\n   305\t}\n   306\t\n   307\texport type SessionActionPolicyEvaluation = {\n   308\t  schema_version: number\n   309\t  session_id: string\n   310\t  evaluated_actions: SessionActionPolicyEvaluationItem[]\n   311\t}\n   312\t\n   313\texport type ParsedChatIntentResponse = {\n   314\t  schema_version: number\n   315\t  status: 'parsed' | 'needs_clarification' | 'failed'\n   316\t  needs_clarification: boolean\n   317\t  assistant_response: string\n   318\t  clarification_reason?: string | null\n   319\t  proposed_actions: ChatToUiActionBatch\n   320\t  policy_evaluation?: SessionActionPolicyEvaluation | null\n   321\t}\n   322\t\n   323\texport type SessionExplicitChatCommandId =\n   324\t  | 'next_stage'\n   325\t  | 'summarize_plan'\n   326\t  | 'regenerate_pitches'\n   327\t  | 'pause_writing'\n   328\t  | 'resume_writing'\n   329\t\n   330\texport type SessionExplicitChatCommandSource = 'slash_command' | 'quick_action'\n   331\t\n   332\texport type SessionExplicitChatCommand = {\n   333\t  command_id: SessionExplicitChatCommandId\n   334\t  source: SessionExplicitChatCommandSource\n   335\t  proposed_actions: ChatToUiActionBatch\n   336\t}\n   337\t\n   338\texport type ParseSessi