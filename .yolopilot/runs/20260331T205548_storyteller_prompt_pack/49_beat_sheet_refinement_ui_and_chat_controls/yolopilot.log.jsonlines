\n    44\t\n    45\tclass UserEditTargetKind(str, Enum):\n    46\t    STORY_BRIEF = \"story_brief\"\n    47\t    PITCH = \"pitch\"\n    48\t    CHARACTER_SHEET = \"character_sheet\"\n    49\t    BEAT_SHEET = \"beat_sheet\"\n    50\t    STORY_SETUP = \"story_setup\"\n    51\t    COMPOSITION_SEGMENT = \"composition_segment\"\n    52\t    AUDIO_SETTINGS = \"audio_settings\"\n    53\t\n    54\t\n    55\tclass ChatMessageRole(str, Enum):\n    56\t    USER = \"user\"\n    57\t    ASSISTANT = \"assistant\"\n    58\t    SYSTEM = \"system\"\n    59\t    TOOL = \"tool\"\n    60\t\n    61\t\n    62\tclass EventActorType(str, Enum):\n    63\t    USER = \"user\"\n    64\t    ASSISTANT = \"assistant\"\n    65\t    SYSTEM = \"system\"\n    66\t    SERVICE = \"service\"\n    67\t\n    68\t\n    69\tclass SessionEventActor(BaseModel):\n    70\t    model_config = ConfigDict(extra=\"forbid\", frozen=True)\n    71\t\n    72\t    actor_type: EventActorType\n    73\t    actor_id: str | None = None\n    74\t\n    75\t\n    76\tclass EventPayload(BaseModel):\n    77\t    model_config = ConfigDict(extra=\"forbid\")\n    78\t\n    79\t    schema_version: int = Field(default=1, ge=1)\n    80\t\n    81\t\n    82\tclass SessionCreatedEventPayload(EventPayload):\n    83\t    working_title: str | None = None\n    84\t\n    85\t\n    86\tclass WorkflowStageChangedEventPayload(EventPayload):\n    87\t    previous_status: WorkflowStageState\n    88\t    status: WorkflowStageState\n    89\t    detail: str | None = None\n    90\t    invalidated_stages: list[WorkflowStage] = Field(default_factory=list)\n    91\t    current_stage: WorkflowStage\n    92\t    resume_stage: WorkflowStage\n    93\t    furthest_completed_stage: WorkflowStage | None = None\n    94\t    overall_status: WorkflowStageState\n    95\t\n    96\t\n    97\tclass SelectionRecordedEventPayload(EventPayload):\n    98\t    selection_kind: SelectionKind\n    99\t    selection_id: str | None = None\n   100\t    slug: str | None = None\n   101\t    label: str | None = None\n   102\t    rationale: str | None = None\n   103\t    previous_selection_id: str | None = None\n   104\t    source: str = \"unknown\"\n   105\t    accepted: bool = True\n   106\t\n   107\t\n   108\tclass AIOutputRecordedEventPayload(EventPayload):\n   109\t    output_kind: AIOutputKind\n   110\t    resource_id: str | None = None\n   111\t    generation_key: str | None = None\n   112\t    candidate_count: int | None = None\n   113\t    model_id: str | None = None\n   114\t    summary: str | None = None\n   115\t\n   116\t\n   117\tclass UserEditRecordedEventPayload(EventPayload):\n   118\t    target_kind: UserEditTargetKind\n   119\t    target_id: str | None = None\n   120\t    revision_number: int | None = None\n   121\t    changed_fields: list[str] = Field(default_factory=list)\n   122\t    source: str = \"unknown\"\n   123\t    field_values: dict[str, Any] | None = None\n   124\t    summary_text: str | None = None\n   125\t\n   126\t\n   127\tclass ChatMessageRecordedEventPayload(EventPayload):\n   128\t    message_role: ChatMessageRole\n   129\t    message_id: str | None = None\n   130\t    content_preview: str\n   131\t    content_length: int\n   132\t    source: str = \"chat\"\n   133\t\n   134\t\n   135\tclass ChatIntentParsedEventPayload(EventPayload):\n   136\t    prompt_version: str\n   137\t    model_id: str\n   138\t    current_stage: WorkflowStage\n   139\t    stage_label: str\n   140\t    stage_description: str\n   141\t    stage_status: WorkflowStageState\n   142\t    stage_detail: str | None = None\n   143\t    session_summary: str\n   144\t    user_message: str\n   145\t    rendered_prompt: str\n   146\t    result: ParsedChatIntentResponse\n   147\t    raw_response: dict[str, Any] | list[Any] | str | None = None\n   148\t\n   149\t\n   150\tclass UIActionRecordedEventPayload(EventPayload):\n   151\t    action: str\n   152\t    control_id: str | None = None\n   153\t    value_summary: str | None = None\n   154\t    origin: str = \"workspace\"\n   155\t\n   156\t\n   157\tclass CompositionProgressEventPayload(EventPayload):\n   158\t    job_id: str\n   159\t    status: str\n   160\t    progress_percent: float | None = None\n   161\t    current_segment_index: int | None = None\n   162\t    total_segments: int | None = None\n   163\t    segment_id: str | None = None\n   164\t\n   165\t\n   166\tclass AudioProgressEventPayload(EventPayload):\n   167\t    job_id: str\n   168\t    status: str\n   169\t    progress_percent: float | None = None\n   170\t    current_segment_index: int | None = None\n   171\t    total_segments: int | None = None\n   172\t    segment_id: str | None = None\n   173\t    estimated_duration_seconds: int | None = None\n   174\t    voice_key: str | None = None\n   175\t\n   176\t\n   177\tSessionEventPayload: TypeAlias = (\n   178\t    SessionCreatedEventPayload\n   179\t    | WorkflowStageChangedEventPayload\n   180\t    | SelectionRecordedEventPayload\n   181\t    | AIOutputRecordedEventPayload\n   182\t    | UserEditRecordedEventPayload\n   183\t    | ChatMessageRecordedEventPayload\n   184\t    | ChatIntentParsedEventPayload\n   185\t    | UIActionRecordedEventPayload\n   186\t    | CompositionProgressEventPayload\n   187\t    | AudioProgressEventPayload\n   188\t)\n   189\t\n   190\t_EVENT_PAYLOAD_MODELS: dict[str, type[EventPayload]] = {\n   191\t    SessionEventType.SESSION_CREATED.value: SessionCreatedEventPayload,\n   192\t    SessionEventType.WORKFLOW_STAGE_CHANGED.value: WorkflowStageChangedEventPayload,\n   193\t    SessionEventType.SELECTION_RECORDED.value: SelectionRecordedEventPayload,\n   194\t    SessionEventType.AI_OUTPUT_RECORDED.value: AIOutputRecordedEventPayload,\n   195\t    SessionEventType.USER_EDIT_RECORDED.value: UserEditRecordedEventPayload,\n   196\t    SessionEventType.CHAT_MESSAGE_RECORDED.value: ChatMessageRecordedEventPayload,\n   197\t    SessionEventType.CHAT_INTENT_PARSED.value: ChatIntentParsedEventPayload,\n   198\t    SessionEventType.UI_ACTION_RECORDED.value: UIActionRecordedEventPayload,\n   199\t    SessionEventType.COMPOSITION_PROGRESS_RECORDED.value: CompositionProgressEventPayload,\n   200\t    SessionEventType.AUDIO_PROGRESS_RECORDED.value: AudioProgressEventPayload,\n   201\t}\n   202\t\n   203\t\n   204\tclass SessionEventView(BaseModel):\n   205\t    id: str\n   206\t    session_id: str\n   207\t    sequence_number: int\n   208\t    actor: SessionEventActor\n   209\t    event_type: str\n   210\t    stage: WorkflowStage | None = None\n   211\t    summary: str\n   212\t    payload: SessionEventPayload | dict[str, Any] | list[Any] | None = None\n   213\t    created_at: datetime\n   214\t\n   215\t\n   216\tclass SessionHistoryView(BaseModel):\n   217\t    session_id: str\n   218\t    latest_sequence_number: int | None = None\n   219\t    events: list[SessionEventView] = Field(default_factory=list)\n   220\t\n   221\t\n   222\tdef serialize_event_payload(\n   223\t    payload: EventPayload | Mapping[str, Any] | None,\n   224\t) -> dict[str, Any]:\n   225\t    if payload is None:\n   226\t        return {\"schema_version\": 1}\n   227\t\n   228\t    if isinstance(payload, EventPayload):\n   229\t        return payload.model_dump(mode=\"json\")\n   230\t\n   231\t    normalized_payload = dict(payload)\n   232\t    normalized_payload.setdefault(\"schema_version\", 1)\n   233\t    return normalized_payload\n   234\t\n   235\t\n   236\tdef parse_event_payload(\n   237\t    event_type: str,\n   238\t    payload: Mapping[str, Any] | list[Any] | None,\n   239\t) -> SessionEventPayload | dict[str, Any] | list[Any] | None:\n   240\t    if payload is None:\n   241\t        return None\n   242\t\n   243\t    if isinstance(payload, list):\n   244\t        return payload\n   245\t\n   246\t    normalized_payload = dict(payload)\n   247\t    normalized_payload.setdefault(\"schema_version\", 1)\n   248\t    payload_model = _EVENT_PAYLOAD_MODELS.get(event_type)\n   249\t\n   250\t    if payload_model is None:\n   251\t        return normalized_payload\n   252\t\n   253\t    return payload_model.model_validate(normalized_payload)\n", "command": "/bin/zsh -lc \"nl -ba backend/app/models/events.py | sed -n '1,260p'\"", "exit_code": 0, "id": "item_18", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 39, "prompt_index": 50, "prompt_name": "49 \u2014 Beat Sheet Refinement UI and Chat Controls", "prompt_total": 100}, "timestap": "2026-04-02T00:22:02-07:00"}
