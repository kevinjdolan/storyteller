er\n   387\t  latest_sequence_number?: number | null\n   388\t  history_event_count: number\n   389\t  history_window_truncated: boolean\n   390\t}\n   391\t\n   392\texport type SessionHydration = {\n   393\t  snapshot: SessionSnapshot\n   394\t  recent_history: SessionHistory\n   395\t  hydration: SessionHydrationMetadata\n   396\t}\n   397\t\n   398\texport type SessionContextUpdateResponse = {\n   399\t  snapshot: SessionSnapshot\n   400\t  event: SessionHistoryEvent\n   401\t}\n   402\t\n   403\texport type SaveSessionStoryBriefRequest = {\n   404\t  story_idea?: string | null\n   405\t  desired_themes?: string | null\n   406\t  key_images?: string | null\n   407\t  audience_notes?: string | null\n   408\t  must_have_elements?: string | null\n   409\t  raw_brief?: string | null\n   410\t  normalized_summary?: string | null\n   411\t  normalized_preferences?: NormalizedBriefPreferencesView | null\n   412\t  planning_notes?: string | null\n   413\t  edit_mode?: 'replace' | 'append' | 'merge'\n   414\t  origin?: string\n   415\t}\n   416\t\n   417\texport type SessionStoryBriefResponse = {\n   418\t  snapshot: SessionSnapshot\n   419\t  event: SessionHistoryEvent\n   420\t}\n", "command": "/bin/zsh -lc \"nl -ba frontend/src/api/sessions.ts | sed -n '1,420p'\"", "exit_code": 0, "id": "item_25", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 50, "prompt_index": 50, "prompt_name": "49 \u2014 Beat Sheet Refinement UI and Chat Controls", "prompt_total": 100}, "timestap": "2026-04-02T00:22:17-07:00"}
