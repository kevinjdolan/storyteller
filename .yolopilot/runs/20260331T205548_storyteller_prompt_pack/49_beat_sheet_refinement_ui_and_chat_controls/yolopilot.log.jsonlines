from_existing,\n    47\t)\n    48\tfrom app.services.catalog import find_active_genre, find_active_tone_for_genre\n    49\tfrom app.services.beat_sheet_generation import (\n    50\t    BeatSheetGenerationService,\n    51\t    build_beat_sheet_model_output,\n    52\t)\n    53\tfrom app.services.character_generation import (\n    54\t    CharacterGenerationService,\n    55\t    build_character_model_output,\n    56\t)\n    57\tfrom app.services.character_sheet_changes import infer_character_change_impact\n    58\tfrom app.services.event_log import SessionEventLogService\n    59\tfrom app.services.pitch_generation import PitchGenerationService, build_pitch_model_output\n    60\tfrom app.services.session_hydration import (\n    61\t    SessionHydrationNotFoundError,\n    62\t    SessionHydrationService,\n    63\t    build_recent_session_summary,\n    64\t    resolve_furthest_completed_stage,\n    65\t    resolve_overall_status,\n    66\t)\n    67\t\n    68\t\n    69\tclass SessionServiceError(Exception):\n    70\t    \"\"\"Base error for session service failures.\"\"\"\n    71\t\n    72\t\n    73\tclass SessionNotFoundError(SessionServiceError):\n    74\t    \"\"\"Raised when a requested session does not exist.\"\"\"\n    75\t\n    76\t\n    77\tclass InvalidStageTransitionError(SessionServiceError):\n    78\t    \"\"\"Raised when a stage update violates workflow rules.\"\"\"\n    79\t\n    80\t\n    81\tclass UnsupportedSessionContextUpdateError(SessionServiceError):\n    82\t    \"\"\"Raised when a UI-originated context update is not supported.\"\"\"\n    83\t\n    84\t\n    85\tclass SessionGenreSelectionError(SessionServiceError):\n    86\t    \"\"\"Raised when a genre selection request cannot be fulfilled.\"\"\"\n    87\t\n    88\t\n    89\tclass SessionToneSelectionError(SessionServiceError):\n    90\t    \"\"\"Raised when a tone selection request cannot be fulfilled.\"\"\"\n    91\t\n    92\t\n    93\tclass SessionStoryBriefSaveError(SessionServiceError):\n    94\t    \"\"\"Raised when a story brief save request cannot be fulfilled.\"\"\"\n    95\t\n    96\t\n    97\tclass SessionPitchGenerationError(SessionServiceError):\n    98\t    \"\"\"Raised when a pitch generation request cannot be fulfilled.\"\"\"\n    99\t\n   100\t\n   101\tclass SessionPitchSelectionError(SessionServiceError):\n   102\t    \"\"\"Raised when a pitch selection request cannot be fulfilled.\"\"\"\n   103\t\n   104\t\n   105\tclass SessionCharacterSheetGenerationError(SessionServiceError):\n   106\t    \"\"\"Raised when a character-sheet generation request cannot be fulfilled.\"\"\"\n   107\t\n   108\t\n   109\tclass SessionCharacterSheetSelectionError(SessionServiceError):\n   110\t    \"\"\"Raised when a character-sheet selection request cannot be fulfilled.\"\"\"\n   111\t\n   112\t\n   113\tclass SessionBeatSheetGenerationError(SessionServiceError):\n   114\t    \"\"\"Raised when a beat-sheet generation request cannot be fulfilled.\"\"\"\n   115\t\n   116\t\n   117\tclass SessionBeatSheetSelectionError(SessionServiceError):\n   118\t    \"\"\"Raised when a beat-sheet selection request cannot be fulfilled.\"\"\"\n   119\t\n   120\t\n   121\tSTAGE_EDIT_TARGET_KIND_MAP: dict[WorkflowStage, UserEditTargetKind] = {\n   122\t    WorkflowStage.BRIEF: UserEditTargetKind.STORY_BRIEF,\n   123\t    WorkflowStage.PITCHES: UserEditTargetKind.PITCH,\n   124\t    WorkflowStage.CHARACTERS: UserEditTargetKind.CHARACTER_SHEET,\n   125\t    WorkflowStage.BEATS: UserEditTargetKind.BEAT_SHEET,\n   126\t    WorkflowStage.STORY_SETUP: UserEditTargetKind.STORY_SETUP,\n   127\t    WorkflowStage.COMPOSITION: UserEditTargetKind.COMPOSITION_SEGMENT,\n   128\t    WorkflowStage.AUDIO: UserEditTargetKind.AUDIO_SETTINGS,\n   129\t}\n   130\t\n   131\t\n   132\tclass SessionService:\n   133\t    def __init__(\n   134\t        self,\n   135\t        session: Session,\n   136\t        *,\n   137\t        brief_normalization_service: BriefNormalizationService | None = None,\n   138\t    ):\n   139\t        self._session = session\n   140\t        self._sessions = StorySessionRepository(session)\n   141\t        self._stage_states = WorkflowStageStateRepository(session)\n   142\t        self._event_log = SessionEventLogService(session)\n   143\t        self._brief_normalizer = brief_normalization_service or BriefNormalizationService()\n   144\t\n   145\t    def create_session(\n   146\t        self,\n   147\t        *,\n   148\t        working_title: str | None = None,\n   149\t        actor: SessionEventActor | None = None,\n   150\t    ) -> SessionSnapshot:\n   151\t        story_session = self._sessions.create(working_title=_normalize_optional_text(working_title))\n   152\t        stage_map = self._stage_states.ensure_for_session(story_session)\n   153\t        self._apply_rollups(story_session, stage_map)\n   154\t        self._event_log.record_session_created(\n   155\t            story_session.id,\n   156\t            working_title=story_session.working_title,\n   157\t            actor=actor,\n   158\t        )\n   159\t        self._session.commit()\n   160\t        return self.load_session_snapshot(story_session.id)\n   161\t\n   162\t    def load_session_snapshot(self, session_id: str) -> SessionSnapshot:\n   163\t        try:\n   164\t            return SessionHydrationService(self._session).load_session_snapshot(session_id)\n   165\t        except SessionHydrationNotFoundError as exc:\n   166\t            raise SessionNotFoundError(f\"session {session_id!r} was not found\") from exc\n   167\t\n   168\t    def list_recent_sessions(self, *, limit: int = 20) -> list[RecentSessionSummary]:\n   169\t        if limit <= 0:\n   170\t            raise ValueError(\"limit must be greater than zero\")\n", "command": "/bin/zsh -lc \"nl -ba backend/app/services/sessions.py | sed -n '1,170p'\"", "exit_code": 0, "id": "item_46", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number":