\t        \"description\": \"Select a catalog genre by id, slug, or label.\",\n    55\t        \"common_fields\": [\"genre_id\", \"genre_slug\", \"genre_label\"],\n    56\t    },\n    57\t    {\n    58\t        \"action_type\": \"select_tone\",\n    59\t        \"stage\": \"tone\",\n    60\t        \"description\": \"Select a tone profile by id, slug, or label.\",\n    61\t        \"common_fields\": [\n    62\t            \"tone_profile_id\",\n    63\t            \"tone_profile_slug\",\n    64\t            \"tone_profile_label\",\n    65\t        ],\n    66\t    },\n    67\t    {\n    68\t        \"action_type\": \"update_story_brief\",\n    69\t        \"stage\": \"brief\",\n    70\t        \"description\": \"Change the story brief text or planning notes.\",\n    71\t        \"common_fields\": [\n    72\t            \"raw_brief\",\n    73\t            \"normalized_summary\",\n    74\t            \"planning_notes\",\n    75\t            \"edit_mode\",\n    76\t        ],\n    77\t    },\n    78\t    {\n    79\t        \"action_type\": \"regenerate_pitches\",\n    80\t        \"stage\": \"pitches\",\n    81\t        \"description\": \"Ask for a new batch of pitches.\",\n    82\t        \"common_fields\": [\"candidate_count\", \"guidance\", \"preserve_selected_pitch\"],\n    83\t    },\n    84\t    {\n    85\t        \"action_type\": \"refine_pitch\",\n    86\t        \"stage\": \"pitches\",\n    87\t        \"description\": \"Create a refined pitch from an existing candidate and select it.\",\n    88\t        \"common_fields\": [\n    89\t            \"pitch_id\",\n    90\t            \"generation_key\",\n    91\t            \"pitch_index\",\n    92\t            \"title\",\n    93\t            \"instructions\",\n    94\t        ],\n    95\t    },\n    96\t    {\n    97\t        \"action_type\": \"select_pitch\",\n    98\t        \"stage\": \"pitches\",\n    99\t        \"description\": \"Select a pitch by id, generation key, index, or title.\",\n   100\t        \"common_fields\": [\"pitch_id\", \"generation_key\", \"pitch_index\", \"title\"],\n   101\t    },\n   102\t    {\n   103\t        \"action_type\": \"select_character_sheet\",\n   104\t        \"stage\": \"characters\",\n   105\t        \"description\": \"Choose a character sheet revision.\",\n   106\t        \"common_fields\": [\"character_sheet_id\", \"revision_number\", \"title\"],\n   107\t    },\n   108\t    {\n   109\t        \"action_type\": \"refine_character_sheet\",\n   110\t        \"stage\": \"characters\",\n   111\t        \"description\": \"Request character-sheet edits with concrete instructions.\",\n   112\t        \"common_fields\": [\n   113\t            \"character_sheet_id\",\n   114\t            \"revision_number\",\n   115\t            \"title\",\n   116\t            \"instructions\",\n   117\t            \"focus_character_names\",\n   118\t            \"change_summary\",\n   119\t            \"change_impact\",\n   120\t        ],\n   121\t    },\n   122\t    {\n   123\t        \"action_type\": \"regenerate_character_sheet\",\n   124\t        \"stage\": \"characters\",\n   125\t        \"description\": \"Regenerate the character sheet with optional guidance.\",\n   126\t        \"common_fields\": [\"guidance\"],\n   127\t    },\n   128\t    {\n   129\t        \"action_type\": \"accept_beat_sheet\",\n   130\t        \"stage\": \"beats\",\n   131\t        \"description\": \"Accept a beat sheet revision.\",\n   132\t        \"common_fields\": [\"beat_sheet_id\", \"revision_number\"],\n   133\t    },\n   134\t    {\n   135\t        \"action_type\": \"refine_beat_sheet\",\n   136\t        \"stage\": \"beats\",\n   137\t        \"description\": \"Request beat-sheet edits with explicit instructions.\",\n   138\t        \"common_fields\": [\"instructions\", \"beat_names\", \"bedtime_goal\"],\n   139\t    },\n   140\t    {\n   141\t        \"action_type\": \"regenerate_beat_sheet\",\n   142\t        \"stage\": \"beats\",\n   143\t        \"description\": \"Regenerate the beat sheet with guidance.\",\n   144\t        \"common_fields\": [\"guidance\", \"focus_beats\"],\n   145\t    },\n   146\t    {\n   147\t        \"action_type\": \"update_story_setup\",\n   148\t        \"stage\": \"story_setup\",\n   149\t        \"description\": (\n   150\t            \"Update soft planning targets like length, runtime, chapters, or setup guidance.\"\n   151\t        ),\n   152\t        \"common_fields\": [\n   153\t            \"target_word_count\",\n   154\t            \"target_runtime_minutes\",\n   155\t            \"chapter_count\",\n   156\t            \"chapter_style\",\n   157\t            \"guidance_notes\",\n   158\t        ],\n   159\t    },\n   160\t    {\n   161\t        \"action_type\": \"start_composition\",\n   162\t        \"stage\": \"composition\",\n   163\t        \"description\": \"Start writing, continue, or rewrite composition.\",\n   164\t        \"common_fields\": [\"mode\", \"instructions\", \"restart_from_segment_index\"],\n   165\t    },\n   166\t    {\n   167\t        \"action_type\": \"pause_job\",\n   168\t        \"stage\": \"composition|audio\",\n   169\t        \"description\": \"Pause a composition or audio job.\",\n   170\t        \"common_fields\": [\"job_kind\", \"job_id\", \"reason\"],\n   171\t    },\n   172\t    {\n   173\t        \"action_type\": \"resume_job\",\n   174\t        \"stage\": \"composition|audio\",\n   175\t        \"description\": \"Resume a composition or audio job.\",\n   176\t        \"common_fields\": [\"job_kind\", \"job_id\", \"reason\"],\n   177\t    },\n   178\t    {\n   179\t        \"action_type\": \"redirect_composition\",\n   180\t        \"stage\": \"composition\",\n   181\t        \"description\": \"Redirect writing with concrete rewrite instructions.\",\n   182\t        \"common_fields\": [\n   183\t            \"instructions\",\n   184\t            \"rewrite_from_segment_index\",\n   185\t            \"preserve_completed_segments\",\n   186\t        ],\n   187\