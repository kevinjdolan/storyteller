ionEventLogService\n    48\t\n    49\t_ACTIVE_JOB_STATUS_VALUES = {\n    50\t    JobStatus.QUEUED.value,\n    51\t    JobStatus.IN_PROGRESS.value,\n    52\t    JobStatus.PAUSED.value,\n    53\t}\n    54\t\n    55\t\n    56\tclass SessionHydrationServiceError(Exception):\n    57\t    \"\"\"Base error for session hydration failures.\"\"\"\n    58\t\n    59\t\n    60\tclass SessionHydrationNotFoundError(SessionHydrationServiceError):\n    61\t    \"\"\"Raised when a requested session cannot be hydrated.\"\"\"\n    62\t\n    63\t\n    64\tclass SessionHydrationService:\n    65\t    def __init__(self, session: Session):\n    66\t        self._session = session\n    67\t        self._sessions = StorySessionRepository(session)\n    68\t        self._memory = SessionMemoryService(session)\n    69\t        self._events = SessionEventLogService(session)\n    70\t\n    71\t    def load_session_snapshot(self, session_id: str) -> SessionSnapshot:\n    72\t        aggregate = self._sessions.get_aggregate(session_id)\n    73\t        if aggregate is None:\n    74\t            raise SessionHydrationNotFoundError(f\"session {session_id!r} was not found\")\n    75\t\n    76\t        return build_session_snapshot(\n    77\t            aggregate,\n    78\t            conversation_memory=self._memory.load_latest_snapshot(session_id),\n    79\t        )\n    80\t\n    81\t    def hydrate_session(\n    82\t        self,\n    83\t        session_id: str,\n    84\t        *,\n    85\t        history_limit: int = 40,\n    86\t    ) -> SessionHydrationView:\n    87\t        if history_limit <= 0:\n    88\t            raise ValueError(\"history_limit must be greater than zero\")\n    89\t\n    90\t        aggregate = self._sessions.get_aggregate(session_id)\n    91\t        if aggregate is None:\n    92\t            raise SessionHydrationNotFoundError(f\"session {session_id!r} was not found\")\n    93\t\n    94\t        conversation_memory = self._memory.load_latest_snapshot(session_id)\n    95\t        base_snapshot = build_session_snapshot(\n    96\t            aggregate,\n    97\t            conversation_memory=conversation_memory,\n    98\t        )\n    99\t        recent_history = self._events.list_session_history(session_id, limit=history_limit)\n   100\t        materialized_sequence = resolve_materialized_sequence_number(\n   101\t            aggregate,\n   102\t            conversation_memory=conversation_memory,\n   103\t        )\n   104\t        replay_events = select_replay_events(\n   105\t            recent_history.events,\n   106\t            materialized_sequence_number=materialized_sequence,\n   107\t        )\n   108\t        hydrated_snapshot, replayed_event_count = replay_session_snapshot(\n   109\t            base_snapshot,\n   110\t            replay_events,\n   111\t        )\n   112\t        hydrated_snapshot.agent_context_summary = build_session_agent_context_summary(\n   113\t            hydrated_snapshot,\n   114\t            use_conversation_memory=False,\n   115\t        )\n   116\t\n   117\t        first_history_sequence = (\n   118\t            recent_history.events[0].sequence_number if recent_history.events else None\n   119\t        )\n   120\t        latest_sequence_number = recent_history.latest_sequence_number\n", "command": "/bin/zsh -lc \"nl -ba backend/app/services/session_hydration.py | sed -n '1,120p'\"", "exit_code": 0, "id": "item_68", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 132, "prompt_index": 50, "prompt_name": "49 \u2014 Beat Sheet Refinement UI and Chat Controls", "prompt_total": 100}, "timestap": "2026-04-02T00:31:10-07:00"}
