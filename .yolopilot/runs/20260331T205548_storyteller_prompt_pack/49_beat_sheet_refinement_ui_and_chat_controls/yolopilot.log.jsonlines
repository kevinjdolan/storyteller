sSelected ? 'step' : undefined}\n  1539\t                        className=\"workflow-card-link\"\n  1540\t                        onClick={(event) => {\n  1541\t                          if (!isPlainLeftClick(event) || stage.isSelected) {\n  1542\t                            return\n  1543\t                          }\n  1544\t\n  1545\t                          void persistUiAction({\n  1546\t                            action: 'navigate_to_stage',\n  1547\t                            stage: stage.stage,\n  1548\t                            controlId: 'stage-navigator',\n  1549\t                            origin: 'workspace',\n  1550\t                            valueSummary: stage.label,\n  1551\t                          }).catch(() => {})\n  1552\t                        }}\n  1553\t                        to={buildSessionWorkspacePath(snapshot.id, {\n  1554\t                          stage: stage.stage,\n  1555\t                        })}\n  1556\t                      >\n  1557\t                        <SelectionCard\n  1558\t                          description={stage.description}\n  1559\t                          eyebrow={`Stage ${(stage.index + 1)\n  1560\t                            .toString()\n  1561\t                            .padStart(2, '0')}`}\n  1562\t                          footer={\n  1563\t                            stage.isCurrent\n  1564\t                              ? 'This is the durable current stage saved by the backend.'\n  1565\t                              : stage.availability === 'locked'\n  1566\t                                ? 'Locked stages stay previewable without implying they are editable yet.'\n  1567\t                                : 'Available stages can mount richer editors later without changing the shell.'\n  1568\t                          }\n  1569\t                          leading={(stage.index + 1)\n  1570\t                            .toString()\n  1571\t                            .padStart(2, '0')}\n  1572\t                          meta={\n  1573\t                            <>\n  1574\t                              <Badge tone={stageStatus.tone}>\n  1575\t                                {stageStatus.label}\n  1576\t                              </Badge>\n  1577\t                              <Badge tone={availabilityCopy.tone}>\n  1578\t                                {availabilityCopy.label}\n  1579\t                              </Badge>\n  1580\t                            </>\n  1581\t                          }\n  1582\t                          selected={stage.isSelected}\n  1583\t                          title={stage.label}\n  1584\t                        />\n  1585\t                      </Link>\n  1586\t                    </li>\n  1587\t                  )\n  1588\t                })}\n  1589\t              </ol>\n  1590\t            </nav>\n  1591\t\n  1592\t            <article className=\"workspace-stage-detail\">\n  1593\t              <div className=\"workspace-stage-detail__hero\">\n  1594\t                <div>\n  1595\t                  <p className=\"eyebrow\">Stage scaffold</p>\n  1596\t                  <h2>{selectedStage.scaffoldTitle}</h2>\n  1597\t                  <p className=\"body-copy\">{selectedStage.scaffoldSummary}</p>\n  1598\t                </div>\n  1599\t\n  1600\t                <div className=\"workspace-stage-detail__badges\">\n  1601\t                  <Badge tone={selectedStageStatus.tone}>\n  1602\t                    {selectedStageStatus.label}\n  1603\t                  </Badge>\n  1604\t                  <Badge tone={selectedStageAvailability.tone}>\n  1605\t                    {selectedStageAvailability.label}\n  1606\t                  </Badge>\n  1607\t                </div>\n  1608\t              </div>\n  1609\t\n  1610\t              <p className=\"workspace-stage-detail__note\">{stageRoutingCopy}</p>\n  1611\t\n  1612\t              {selectedStage.stage === 'genre' ? (\n  1613\t                <GenreSelectionStage\n  1614\t                  onPreviewStage={setPreviewStage}\n  1615\t                  onSelectGenre={applyGenreSelection}\n  1616\t                  selectedStage={selectedStage}\n  1617\t                  snapshot={snapshot}\n  1618\t                />\n  1619\t              ) : selectedStage.stage === 'tone' ? (\n  1620\t                <ToneSelectionStage\n  1621\t                  onPreviewStage={setPreviewStage}\n  1622\t                  onSelectTone={applyToneSelection}\n  1623\t                  selectedStage={selectedStage}\n  1624\t                  snapshot={snapshot}\n  1625\t                />\n  1626\t              ) : selectedStage.stage === 'brief' ? (\n  1627\t                <StoryBriefStage\n  1628\t                  onPreviewStage={setPreviewStage}\n  1629\t                  onSaveStoryBrief={applyStoryBriefSave}\n  1630\t                  selectedStage={selectedStage}\n  1631\t                  snapshot={snapshot}\n  1632\t                />\n  1633\t              ) : selectedStage.stage === 'pitches' ? (\n  1634\t                <PitchSelectionStage\n  1635\t                  onGeneratePitches={applyPitchGeneration}\n  1636\t                  onPreviewStage={setPreviewStage}\n  1637\t                  onRefinePitch={applyPitchRefinement}\n  1638\t                  onSelectPitch={applyPitchSelection}\n  1639\t                  selectedStage={selectedStage}\n  1640\t                  snapshot={snapshot}\n  1641\t                />\n  1642\t              ) : selectedStage.stage === 'characters' ? (\n  1643\t                <CharacterSelectionStage\n  1644\t                  onGenerateCharacterSheets={applyCharacterSheetGeneration}\n  1645\t                  onPreviewStage={setPreviewStage}\n  1646\t                  onRefineCharacterSheet={applyCharacterSheetRefinement}\n  1647\t                  onSelectCharacterSheet={applyCharacterSheetSelection}\n  1648\t                  selectedStage={selectedStage}\n  1649\t                  snapshot={snapshot}\n  1650\t                />\n  1651\t              ) : selectedStage.stage === 'beats' ? (\n  1652\t                <BeatSheetStage\n  1653\t                  onGenerateBeatSheet={applyBeatSheetGeneration}\n  1654\t                  onPreviewStage={setPreviewStage}\n  1655\t                  onRefineBeatSheet={applyBeatSheetRefinement}\n  1656\t                  onSelectBeatSheet={applyBeatSheetSelection}\n  1657\t                  selectedStage={selectedStage}\n  1658\t                  snapshot={snapshot}\n  1659\t                />\n  1660\t              ) : (\n  1661\t                <>\n  1662\t                  <CardGrid\n  1663\t                    className=\"workspace-stage-detail__cards\"\n  1664\t                    columns={3}\n  1665\t                  >\n  1666\t                    <SummaryPanel\n  1667\t                      description=\"Accepted detail, last-event summaries, and later live job progress can all drop into the same compact summary shell.\"\n  1668\t                      label=\"Current session signal\"\n  1669\t                      title={buildStageDetailSummary(selectedStage)}\n  1670\t                    />\n  1671\t\n  1672\t                    <SummaryPanel\n  1673\t                      description=\"Navigator links preview a stage through routing instead of mutating the backend-owned session snapshot in the browser.\"\n  1674\t                      label=\"Route mapping\"\n  1675\t                      title={\n  1676\t                        <span className=\"workspace-stage-detail__route\">\n  1677\t                          ?stage={selectedStage.stage}\n  1678\t                        </span>\n  1679\t                      }\n  1680\t                    />\n  1681\t\n  1682\t                    <SummaryPanel\n  1683\t                      description={\n  1684\t                        selectedStageInvalidations.length > 0\n  1685\t                          ? selectedStageInvalidations.join(', ')\n  1686\t                          : 'Finalize sits at the end of the workflow and can remain review-only.'\n  1687\t                      }\n  1688\t                      label=\"Downstream impact\"\n  1689\t                      title={\n  1690\t                        selectedStageInvalidations.length > 0\n  1691\t                          ? `Editing this step can refresh ${selectedStageInvalidations.length} later stage${selectedStageInvalidations.length === 1 ? '' : 's'}.`\n  1692\t                          : 'This terminal review step does not invalidate anything later.'\n  1693\t                      }\n  1694\t                    />\n  1695\t                  </CardGrid>\n  1696\t\n  1697\t                  <section className=\"workspace-stage-panel\">\n  1698\t                    <div className=\"panel-heading\">\n  1699\t                      <div>\n  1700\t                        <h3>Stage note</h3>\n  1701\t                        <p>{buildStageNoteEditorDescription(selectedStage)}</p>\n  1702\t                      </div>\n  1703\t                      <Badge tone={selectedStageStatus.tone}>\n  1704\t                        {selectedStageStatus.label}\n  1705\t                      </Badge>\n  1706\t                    </div>\n  1707\t\n  1708\t                    <TextArea\n  1709\t                      description=\"Saved notes become durable session context, show up in replayable history, and feed the backend agent summary.\"\n  1710\t                      disabled={stageNoteEditingDisabled}\n  1711\t                      error={stageNoteError}\n  1712\t                      label={`${selectedStage.label} note`}\n  1713\t                      onChange={(event) => {\n  1714\t                        setStageNoteDraft(event.currentTarget.value)\n  1715\t                      }}\n  1716\t                      rows={5}\n  1717\t                      value={stageNoteDraft}\n  1718\t                    />\n  1719\t\n  1720\t                    <div className=\"cta-row\">\n  1721\t                      <Button\n  1722\t                        disabled={\n  1723\t                          stageNoteEditingDisabled ||\n  1724\t                          !stageNoteDirty ||\n  1725\t                          isSavingStageNote\n  1726\t                        }\n  1727\t                        onClick={() => {\n  1728\t                          void saveStageNote()\n  1729\t                        }}\n  1730\t                        tone=\"primary\"\n  1731\t                      >\n  1732\t                        {isSavingStageNote ? 'Saving note...' : 'Save note'}\n  1733\t                      </Button>\n  1734\t                      <Button\n  1735\t                        disabled={\n  1736\t                          stageNoteEditingDisabled ||\n  1737\t                          !stageNoteDirty ||\n  1738\t                          isSavingStageNote\n  1739\t                        }\n  1740\t                        onClick={() => {\n  1741\t                          setStageNoteDraft(savedStageDetail)\n  1742\t                          setStageNoteError(null)\n  1743\t                        }}\n  1744\t                        tone=\"ghost\"\n  1745\t                      >\n  1746\t                        Reset\n  1747\t                      </Button>\n  1748\t                    </div>\n  1749\t                  </section>\n  1750\t\n  1751\t                  <SessionStageEditorPreview\n  1752\t                    invalidationLabels={selectedStageInvalidations}\n  1753\t                    selectedStage={selectedStage}\n  1754\t                    snapshot={snapshot}\n  1755\t                  />\n  1756\t\n  1757\t                  <section className=\"workspace-stage-detail__list\">\n  1758\t                    <div className=\"panel-heading\">\n  1759\t                      <div>\n  1760\t                        <h3>Planned controls</h3>\n  1761\t                        <p>\n  1762\t                          These placeholder bullets mark the extension points\n  1763\t                          for the real business logic that will arrive in later\n  1764\t                          prompts.\n  1765\t                        </p>\n  1766\t                      </div>\n  1767\t                    </div>\n  1768\t\n  1769\t                    <ul>\n  1770\t                      {selectedStage.scaffoldBullets.map((bullet) => (\n  1771\t                        <li key={bullet}>{bullet}</li>\n  1772\t                      ))}\n  1773\t                    </ul>\n  1774\t                  </section>\n  1775\t                </>\n  1776\t              )}\n  1777\t            </article>\n  1778\t          </section>\n  1779\t\n  1780\t          <section\n  1781\t            aria-label=\"Workspace overview\"\n  1782\t            className=\"workspace-overview-grid\"\n  1783\t          >\n  1784\t            <SummaryPanel label=\"Progress\">\n  1785\t              <ProgressBar\n  1786\t                aria-label={`${snapshot.display_title} workflow progress`}\n  1787\t                hint={`Resume at ${getWorkflowStageLabel(snapshot.resume_stage)} with ${progress.percent}% of the workflow currently complete.`}\n  1788\t                label=\"Workflow progress\"\n  1789\t                value={progress.percent}\n  1790\t                valueText={progress.label}\n  1791\t              />\n  1792\t            </SummaryPanel>\n  1793\t\n  1794\t            <SummaryPanel\n  1795\t              description={buildPlanFocusCopy(snapshot)}\n  1796\t              label=\"Story lane\"\n  1797\t              title={`${snapshot.selected_genre?.label ?? 'Genre pending'} / ${snapshot.selected_tone_profile?.label ?? 'Tone pending'}`}\n  1798\t            />\n  1799\t\n  1800\t            <SummaryPanel\n  1801\t              description={buildProductionCopy(snapshot)}\n  1802\t              label=\"Production\"\n  1803\t              title={activeStage.label}\n  1804\t            />\n  1805\t          </section>\n  1806\t        </section>\n  1807\t      </div>\n  1808\t    </section>\n  1809\t  )\n  1810\t}\n  1811\t\n  1812\texport function SessionWorkspacePage() {\n  1813\t  const { sessionId = 'unknown-session' } = useParams()\n  1814\t\n  1815\t  return (\n  1816\t    <SessionWorkspaceProvider key={sessionId} sessionId={sessionId}>\n  1817\t      <SessionWorkspaceErrorBoundary sessionId={sessionId}>\n  1818\t        <SessionWorkspaceContent sessionId={sessionId} />\n  1819\t      </SessionWorkspaceErrorBoundary>\n  1820\t    </SessionWorkspaceProvider>\n  1821\t  )\n  1822\t}\n", "command": "/bin/zsh -lc \"nl -ba frontend/src/pages/session/SessionWorkspacePage.tsx | sed -n '1500,1850p'\"", "exit_code": 0, "id": "item_6", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 14, "prompt_index": 50, "prompt_name": "49 \u2014 Beat Sheet Refinement UI and Chat Controls", "prompt_total": 100}, "timestap": "2026-04-02T00:21:30-07:00"}
