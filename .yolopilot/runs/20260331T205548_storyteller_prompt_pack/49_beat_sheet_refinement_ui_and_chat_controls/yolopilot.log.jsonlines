itch two to become a calmer sibling story.',\n    44\t          requires_confirmation: true,\n    45\t          extracted_values: {\n    46\t            pitch_index: 2,\n    47\t            instructions: 'Make pitch two about siblings who help each other.',\n    48\t          },\n    49\t        },\n    50\t        {\n    51\t          schema_version: 1,\n    52\t          action_type: 'update_audio_settings',\n    53\t          target_stage: 'audio',\n    54\t          confidence: 0.69,\n    55\t          rationale: 'The user requested slower narration and no music.',\n    56\t          requires_confirmation: false,\n    57\t          extracted_values: {\n    58\t            playback_speed: 0.9,\n    59\t            include_background_music: false,\n    60\t          },\n    61\t        },\n    62\t      ],\n    63\t    })\n    64\t\n    65\t    expect(batch).not.toBeNull()\n    66\t    expect(batch?.actions).toHaveLength(4)\n    67\t    expect(batch?.actions[0]).toMatchObject({\n    68\t      action_type: 'select_genre',\n    69\t      target_stage: 'genre',\n    70\t      extracted_values: {\n    71\t        genre_slug: 'quest-fantasy',\n    72\t      },\n    73\t    })\n    74\t    expect(batch?.actions[2]).toMatchObject({\n    75\t      action_type: 'refine_pitch',\n    76\t      extracted_values: {\n    77\t        pitch_index: 2,\n    78\t        instructions: 'Make pitch two about siblings who help each other.',\n    79\t      },\n    80\t    })\n    81\t    expect(batch?.actions[3]).toMatchObject({\n    82\t      action_type: 'update_audio_settings',\n    83\t      extracted_values: {\n    84\t        playback_speed: 0.9,\n    85\t        include_background_music: false,\n    86\t      },\n    87\t    })\n    88\t  })\n    89\t\n    90\t  it('rejects confirm-first actions that try to skip confirmation', () => {\n    91\t    expect(\n    92\t      parseChatToUiActionBatch({\n    93\t        schema_version: 1,\n    94\t        actions: [\n    95\t          {\n    96\t            schema_version: 1,\n    97\t            action_type: 'select_pitch',\n    98\t            target_stage: 'pitches',\n    99\t            confidence: 0.91,\n   100\t            requires_confirmation: false,\n   101\t            extracted_values: {\n   102\t              pitch_index: 2,\n   103\t            },\n   104\t          },\n   105\t        ],\n   106\t      }),\n   107\t    ).toBeNull()\n   108\t  })\n   109\t\n   110\t  it('rejects story setup updates with no extracted planning values', () => {\n   111\t    expect(\n   112\t      parseChatToUiActionBatch({\n   113\t        schema_version: 1,\n   114\t        actions: [\n   115\t          {\n   116\t            schema_version: 1,\n   117\t            action_type: 'update_story_setup',\n   118\t            target_stage: 'story_setup',\n   119\t            confidence: 0.52,\n   120\t            requires_confirmation: false,\n", "command": "/bin/zsh -lc \"nl -ba frontend/src/features/session/chat/chatToUiActions.test.ts | sed -n '1,120p'\"", "exit_code": 0, "id": "item_60", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 119, "prompt_index": 50, "prompt_name": "49 \u2014 Beat Sheet Refinement UI and Chat Controls", "prompt_total": 100}, "timestap": "2026-04-02T00:27:43-07:00"}
