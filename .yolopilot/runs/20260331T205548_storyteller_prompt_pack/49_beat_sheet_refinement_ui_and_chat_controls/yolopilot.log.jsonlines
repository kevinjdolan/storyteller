{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Finished", "message": "completed, exit 0: /bin/zsh -lc \"nl -ba backend/app/models/chat_actions.py | sed -n '1,420p'\"", "raw_event": {"item": {"aggregated_output": "     1\tfrom __future__ import annotations\n     2\t\n     3\tfrom enum import Enum\n     4\tfrom typing import Annotated, Any, Literal, TypeAlias\n     5\t\n     6\tfrom pydantic import BaseModel, ConfigDict, Field, TypeAdapter, model_validator\n     7\t\n     8\tfrom app.models.workflow import WORKFLOW_STAGE_SEQUENCE, WorkflowStage\n     9\t\n    10\tCHAT_TO_UI_ACTION_SCHEMA_VERSION = 1\n    11\t\n    12\t\n    13\tclass ChatToUIActionType(str, Enum):\n    14\t    NAVIGATE_TO_STAGE = \"navigate_to_stage\"\n    15\t    SELECT_GENRE = \"select_genre\"\n    16\t    SELECT_TONE = \"select_tone\"\n    17\t    UPDATE_STORY_BRIEF = \"update_story_brief\"\n    18\t    REGENERATE_PITCHES = \"regenerate_pitches\"\n    19\t    REFINE_PITCH = \"refine_pitch\"\n    20\t    SELECT_PITCH = \"select_pitch\"\n    21\t    SELECT_CHARACTER_SHEET = \"select_character_sheet\"\n    22\t    REFINE_CHARACTER_SHEET = \"refine_character_sheet\"\n    23\t    REGENERATE_CHARACTER_SHEET = \"regenerate_character_sheet\"\n    24\t    ACCEPT_BEAT_SHEET = \"accept_beat_sheet\"\n    25\t    REFINE_BEAT_SHEET = \"refine_beat_sheet\"\n    26\t    REGENERATE_BEAT_SHEET = \"regenerate_beat_sheet\"\n    27\t    UPDATE_STORY_SETUP = \"update_story_setup\"\n    28\t    START_COMPOSITION = \"start_composition\"\n    29\t    PAUSE_JOB = \"pause_job\"\n    30\t    RESUME_JOB = \"resume_job\"\n    31\t    REDIRECT_COMPOSITION = \"redirect_composition\"\n    32\t    UPDATE_AUDIO_SETTINGS = \"update_audio_settings\"\n    33\t    START_AUDIO_GENERATION = \"start_audio_generation\"\n    34\t    OPEN_FINALIZE_VIEW = \"open_finalize_view\"\n    35\t    DOWNLOAD_ASSET = \"download_asset\"\n    36\t\n    37\t\n    38\tclass ChatToUIActionDefaultPolicy(str, Enum):\n    39\t    AUTO_APPLY_CANDIDATE = \"auto_apply_candidate\"\n    40\t    CONFIRM_FIRST = \"confirm_first\"\n    41\t\n    42\t\n    43\tclass ChatToUIJobKind(str, Enum):\n    44\t    COMPOSITION = \"composition\"\n    45\t    AUDIO = \"audio\"\n    46\t\n    47\t\n    48\tclass CharacterChangeImpact(str, Enum):\n    49\t    MINOR = \"minor\"\n    50\t    MAJOR = \"major\"\n    51\t\n    52\t\n    53\tclass StoryBriefEditMode(str, Enum):\n    54\t    REPLACE = \"replace\"\n    55\t    APPEND = \"append\"\n    56\t    MERGE = \"merge\"\n    57\t\n    58\t\n    59\tclass CompositionStartMode(str, Enum):\n    60\t    FRESH = \"fresh\"\n    61\t    CONTINUE = \"continue\"\n    62\t    REWRITE = \"rewrite\"\n    63\t\n    64\t\n    65\tclass FinalizeView(str, Enum):\n    66\t    READER = \"reader\"\n    67\t    PLAYER = \"player\"\n    68\t\n    69\t\n    70\tclass DownloadAssetKind(str, Enum):\n    71\t    STORY_DOCX = \"story_docx\"\n    72\t    FINAL_AUDIO = \"final_audio\"\n    73\t\n    74\t\n    75\tDEFAULT_CHAT_TO_UI_ACTION_POLICIES: dict[ChatToUIActionType, ChatToUIActionDefaultPolicy] = {\n    76\t    ChatToUIActionType.NAVIGATE_TO_STAGE: ChatToUIActionDefaultPolicy.AUTO_APPLY_CANDIDATE,\n    77\t    ChatToUIActionType.SELECT_GENRE: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    78\t    ChatToUIActionType.SELECT_TONE: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    79\t    ChatToUIActionType.UPDATE_STORY_BRIEF: ChatToUIActionDefaultPolicy.AUTO_APPLY_CANDIDATE,\n    80\t    ChatToUIActionType.REGENERATE_PITCHES: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    81\t    ChatToUIActionType.REFINE_PITCH: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    82\t    ChatToUIActionType.SELECT_PITCH: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    83\t    ChatToUIActionType.SELECT_CHARACTER_SHEET: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    84\t    ChatToUIActionType.REFINE_CHARACTER_SHEET: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    85\t    ChatToUIActionType.REGENERATE_CHARACTER_SHEET: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    86\t    ChatToUIActionType.ACCEPT_BEAT_SHEET: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    87\t    ChatToUIActionType.REFINE_BEAT_SHEET: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    88\t    ChatToUIActionType.REGENERATE_BEAT_SHEET: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    89\t    ChatToUIActionType.UPDATE_STORY_SETUP: ChatToUIActionDefaultPolicy.AUTO_APPLY_CANDIDATE,\n    90\t    ChatToUIActionType.START_COMPOSITION: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    91\t    ChatToUIActionType.PAUSE_JOB: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    92\t    ChatToUIActionType.RESUME_JOB: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    93\t    ChatToUIActionType.REDIRECT_COMPOSITION: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    94\t    ChatToUIActionType.UPDATE_AUDIO_SETTINGS: ChatToUIActionDefaultPolicy.AUTO_APPLY_CANDIDATE,\n    95\t    ChatToUIActionType.START_AUDIO_GENERATION: ChatToUIActionDefaultPolicy.CONFIRM_FIRST,\n    96\t    ChatToUIActionType.OPEN_FINALIZE_VIEW: ChatToUIActionDefaultPolicy.AUTO_APPLY_CANDIDATE,\n    97\t    ChatToUIActionType.DOWNLOAD_ASSET: ChatToUIActionDefaultPolicy.AUTO_APPLY_CANDIDATE,\n    98\t}\n    99\t\n   100\t\n   101\tdef get_chat_to_ui_action_default_policy(\n   102\t    action_type: ChatToUIActionType,\n   103\t) -> ChatToUIActionDefaultPolicy:\n   104\t    return DEFAULT_CHAT_TO_UI_ACTION_POLICIES[action_type]\n   105\t\n   106\t\n   107\tclass ChatToUIModel(BaseModel):\n   108\t    model_config = ConfigDict(extra=\"forbid\")\n   109\t\n   110\t    schema_version: int = Field(default=CHAT_TO_UI_ACTION_SCHEMA_VERSION, ge=1)\n   111\t\n   112\t\n   113\tclass ChatToUIExtractedValues(BaseModel):\n   114\t    model_config = ConfigDict(extra=\"forbid\")\n   115\t\n   116\t\n   117\tdef _require_any_identifier(\n   118\t    *values: str | int | None,\n   119\t    error_message: str,\n   120\t) -> None:\n   121\t    if all(value is None for value in values):\n   122\t        raise ValueError(error_message)\n   123\t\n   124\t\n   125\tdef _require_any_field(\n   126\t    values: dict[str, object | None],\n   127\t    error_message: str,\n   128\t) -> None:\n   129\t    if all(value is None for value in values.values()):\n   130\t        raise ValueError(error_message)\n   131\t\n   132\t\n   133\tclass SelectGenreValues(ChatToUIExtractedValues):\n   134\t    genre_id: str | None = Field(default=None, min_length=1)\n   135\t    genre_slug: str | None = Field(default=None, min_length=1)\n   136\t    genre_label: str | None = Field(default=None, min_length=1)\n   137\t\n   138\t    @model_validator(mode=\"after\")\n   139\t    def validate_identifier(self) -> SelectGenreValues:\n   140\t        _require_any_identifier(\n   141\t            self.genre_id,\n   142\t            self.genre_slug,\n   143\t            self.genre_label,\n   144\t            error_message=\"select_genre requires a genre_id, genre_slug, or genre_label\",\n   145\t        )\n   146\t        return self\n   147\t\n   148\t\n   149\tclass SelectToneValues(ChatToUIExtractedValues):\n   150\t    tone_profile_id: str | None = Field(default=None, min_length=1)\n   151\t    tone_profile_slug: str | None = Field(default=None, min_length=1)\n   152\t    tone_profile_label: str | None = Field(default=None, min_length=1)\n   153\t\n   154\t    @model_validator(mode=\"after\")\n   155\t    def validate_identifier(self) -> SelectToneValues:\n   156\t        _require_any_identifier(\n   157\t            self.tone_profile_id,\n   158\t            self.tone_profile_slug,\n   159\t            self.tone_profile_label,\n   160\t            error_message=(\n   161\t                \"select_tone requires a tone_profile_id, tone_profile_slug, or tone_profile_label\"\n   162\t            ),\n   163\t        )\n   164\t        return self\n   165\t\n   166\t\n   167\tclass UpdateStoryBriefValues(ChatToUIExtractedValues):\n   168\t    story_idea: str | None = Field(default=None, min_length=1)\n   169\t    desired_themes: str | None = Field(default=None, min_length=1)\n   170\t    key_images: str | None = Field(default=None, min_length=1)\n   171\t    audience_notes: str | None = Field(default=None, min_length=1)\n   172\t    must_have_elements: str | None = Field(default=None, min_length=1)\n   173\t    raw_brief: str | None = Field(default=None, min_length=1)\n   174\t    normalized_summary: str | None = Field(default=None, min_length=1)\n   175\t    planning_notes: str | None = Field(default=None, min_length=1)\n   176\t    edit_mode: StoryBriefEditMode = StoryBriefEditMode.MERGE\n   177\t\n   178\t    @model_validator(mode=\"after\")\n   179\t    def validate_story_brief(self) -> UpdateStoryBriefValues:\n   180\t        _require_any_field(\n   181\t            {\n   182\t                \"story_idea\": self.story_idea,\n   183\t                \"desired_themes\": self.desired_themes,\n   184\t                \"key_images\": self.key_images,\n   185\t                \"audience_notes\": self.audience_notes,\n   186\t                \"must_have_elements\": self.must_have_elements,\n   187\t                \"raw_brief\": self.raw_brief,\n   188\t                \"normalized_summary\": self.normalized_summary,\n   189\t                \"planning_notes\": self.planning_notes,\n   190\t            },\n   191\t            error_message=(\n   192\t                \"update_story_brief requires a story brief field, \"\n   193\t                \"normalized_summary, or planning_notes\"\n   194\t            ),\n   195\t        )\n   196\t        return self\n   197\t\n   198\t\n   199\tclass RegeneratePitchesValues(ChatToUIExtractedValues):\n   200\t    candidate_count: int | None = Field(default=None, ge=2, le=6)\n   201\t    guidance: str | None = Field(default=None, min_length=1)\n   202\t    preserve_selected_pitch: bool = False\n   203\t\n   204\t\n   205\tclass SelectPitchValues(ChatToUIExtractedValues):\n   206\t    pitch_id: str | None = Field(default=None, min_length=1)\n   207\t    generation_key: str | None = Field(default=None, min_length=1)\n   208\t    pitch_index: int | None = Field(default=None, ge=1)\n   209\t    title: str | None = Field(default=None, min_length=1)\n   210\t\n   211\t    @model_validator(mode=\"after\")\n   212\t    def validate_identifier(self) -> SelectPitchValues:\n   213\t        _require_any_identifier(\n   214\t            self.pitch_id,\n   215\t            self.generation_key,\n   216\t            self.pitch_index,\n   217\t            self.title,\n   218\t            error_message=(\n   219\t                \"select_pitch requires a pitch_id, generation_key, pitch_index, or title\"\n   220\t            ),\n   221\t        )\n   222\t        return self\n   223\t\n   224\t\n   225\tclass RefinePitchValues(ChatToUIExtractedValues):\n   226\t    pitch_id: str | None = Field(default=None, min_length=1)\n   227\t    generation_key: str | None = Field(default=None, min_length=1)\n   228\t    pitch_index: int | None = Field(default=None, ge=1)\n   229\t    title: str | None = Field(default=None, min_length=1)\n   230\t    instructions: str = Field(min_length=1)\n   231\t\n   232\t    @model_validator(mode=\"after\")\n   233\t    def validate_identifier(self) -> RefinePitchValues:\n   234\t        _require_any_identifier(\n   235\t            self.pitch_id,\n   236\t            self.generation_key,\n   237\t            self.pitch_index,\n   238\t            self.title,\n   239\t            error_message=(\n   240\t                \"refine_pitch requires a pitch_id, generation_key, pitch_index, or title\"\n   241\t            ),\n   242\t        )\n   243\t        return self\n   244\t\n   245\t\n   246\tclass SelectCharacterSheetValues(ChatToUIExtractedValues):\n   247\t    character_sheet_id: str | None = Field(default=None, min_length=1)\n   248\t    revision_number: int | None = Field(default=None, ge=1)\n   249\t    title: str | None = Field(default=None, min_length=1)\n   250\t\n