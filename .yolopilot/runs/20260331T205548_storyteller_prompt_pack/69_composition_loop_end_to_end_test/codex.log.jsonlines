egment_index == 2\n>           assert (\n                resumed_session_hydration.snapshot.active_composition_job.accepted_story_so_far\n                == expected_segment_one\n            )\nE           AssertionError: assert None == 'Draft segment 1 lets Mira follow the silver bell along a lantern path where every ripple stays readable, warm, and ge...ip can hand the story forward with the promise intact, the water settled, and the night ready for the next quiet turn.'\nE            +  where None = CompositionJobView(id='b73ef89e-d24b-48d3-9b96-eff2e772ede0', job_kind='draft', status='queued', progress_percent=33.3...ted_at=datetime.datetime(2026, 4, 2, 20, 22, 29, 672781), updated_at=datetime.datetime(2026, 4, 2, 20, 22, 29, 904712)).accepted_story_so_far\nE            +    where CompositionJobView(id='b73ef89e-d24b-48d3-9b96-eff2e772ede0', job_kind='draft', status='queued', progress_percent=33.3...ted_at=datetime.datetime(2026, 4, 2, 20, 22, 29, 672781), updated_at=datetime.datetime(2026, 4, 2, 20, 22, 29, 904712)) = SessionSnapshot(id='54bbbda5-0e34-478e-baca-c3b9a6a801e5', display_title='Moonlit Harbor', working_title='Moonlit Harb... Rev 1: Mira and the Bell (Mira)\\nCurrent composition detail: Writing 33% complete.\\nComposition job: queued at 33.3%').active_composition_job\nE            +      where SessionSnapshot(id='54bbbda5-0e34-478e-baca-c3b9a6a801e5', display_title='Moonlit Harbor', working_title='Moonlit Harb... Rev 1: Mira and the Bell (Mira)\\nCurrent composition detail: Writing 33% complete.\\nComposition job: queued at 33.3%') = SessionHydrationView(snapshot=SessionSnapshot(id='54bbbda5-0e34-478e-baca-c3b9a6a801e5', display_title='Moonlit Harbor..._number=23, replayed_event_count=7, latest_sequence_number=32, history_event_count=32, history_window_truncated=False)).snapshot\n\ntests/test_story_tools.py:1466: AssertionError\n=========================== short test summary info ============================\nFAILED tests/test_story_tools.py::test_c