rd__facts\">\nfrontend/src/features/session/CharacterSelectionStage.tsx:362:      className=\"workspace-stage-panel\"\nfrontend/src/features/session/CharacterSelectionStage.tsx:476:      <section className=\"workspace-stage-panel\">\nfrontend/src/features/session/CharacterSelectionStage.tsx:542:      <section className=\"workspace-stage-panel\">\nfrontend/src/features/session/CharacterSelectionStage.tsx:667:        <section className=\"workspace-stage-panel\">\nfrontend/src/features/session/CharacterSelectionStage.tsx:758:        <section className=\"workspace-stage-panel\">\nfrontend/src/features/session/ToneSelectionStage.tsx:206:      className=\"workspace-stage-panel\"\nfrontend/src/features/session/ToneSelectionStage.tsx:282:      <section className=\"workspace-stage-panel\">\nfrontend/src/features/session/ToneSelectionStage.tsx:381:                    <div className=\"tone-selection-card__footer\">\nfrontend/src/features/session/ToneSelectionStage.tsx:417:                    <div className=\"tone-selection-card__descriptors\">\nfrontend/src/features/session/ToneSelectionStage.tsx:426:                  <dl className=\"genre-selection-card__facts tone-selection-card__facts\">\nfrontend/src/features/session/ToneSelectionStage.tsx:449:                    <div className=\"tone-selection-card__motifs\">\nfrontend/src/features/session/PitchSelectionStage.tsx:298:      className=\"workspace-stage-panel\"\nfrontend/src/features/session/PitchSelectionStage.tsx:389:      <section className=\"workspace-stage-panel\">\nfrontend/src/features/session/PitchSelectionStage.tsx:455:      <section className=\"workspace-stage-panel\">\nfrontend/src/features/session/PitchSelectionStage.tsx:538:        <section className=\"workspace-stage-panel\">\nfrontend/src/features/session/PitchSelectionStage.tsx:609:        <section className=\"workspace-stage-panel\">\n","exit_code":0,"status":"completed"}}
