ini.api_key\")\nbackend/app/settings/config.py:448:    gemini: GeminiSettings\nbackend/app/settings/config.py:495:    def gemini_api_key(self) -> str:\nbackend/app/settings/config.py:496:        return self.gemini.api_key.get_secret_value()\n","exit_code":0,"status":"completed"}}
