/app/models/story_tools.py:19:    GENERATE_BEAT_SHEET = \"generate_beat_sheet\"\nbackend/app/services/story_tools.py:254:                name=StoryWorkflowToolName.GENERATE_BEAT_SHEET,\nbackend/app/services/story_tools.py:271:                    ChatToUIActionType.REGENERATE_BEAT_SHEET,\nbackend/app/services/story_tools.py:496:            ChatToUIActionType.REGENERATE_BEAT_SHEET,\nbackend/app/services/story_tools.py:500:                tool_name=StoryWorkflowToolName.GENERATE_BEAT_SHEET,\nbackend/app/services/story_tools.py:789:            tool_name=StoryWorkflowToolName.GENERATE_BEAT_SHEET,\nbackend/tests/test_story_tools.py:305:        StoryWorkflowToolName.GENERATE_BEAT_SHEET,\n","exit_code":0,"status":"completed"}}
