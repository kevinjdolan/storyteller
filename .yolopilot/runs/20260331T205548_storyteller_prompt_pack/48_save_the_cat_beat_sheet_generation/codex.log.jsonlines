/src/styles/index.css:997:.tone-selection-card__footer {\nfrontend/src/styles/index.css:1004:.genre-selection-card__footer p,\nfrontend/src/styles/index.css:1005:.tone-selection-card__footer p {\nfrontend/src/styles/index.css:1010:.tone-selection-card__descriptors {\nfrontend/src/styles/index.css:1016:.tone-selection-card__motifs {\nfrontend/src/styles/index.css:1024:.tone-selection-card__motifs span {\nfrontend/src/styles/index.css:1032:.tone-selection-card__motifs p {\nfrontend/src/styles/index.css:1362:.workspace-stage-card__header strong,\nfrontend/src/styles/index.css:1410:.workspace-stage-card {\nfrontend/src/styles/index.css:1633:.workspace-stage-card__header span,\nfrontend/src/styles/index.css:2151:.workspace-stage-panel {\nfrontend/src/styles/index.css:2259:.workspace-stage-card {\nfrontend/src/styles/index.css:2266:.workspace-stage-card--current {\nfrontend/src/styles/index.css:2279:.workspace-stage-card__header {\nfrontend/src/styles/index.css:2285:.workspace-stage-card__header span {\nfrontend/src/styles/index.css:2297:.workspace-stage-card__header strong {\nfrontend/src/styles/index.css:2302:.workspace-stage-card__meta {\nfrontend/src/styles/index.css:2397:  .genre-selection-card__footer,\nfrontend/src/styles/index.css:2398:  .tone-selection-card__footer,\nfrontend/src/styles/index.css:2403:  .selection-card__header,\nfrontend/src/styles/index.css:2416:  .selection-card__header {\nfrontend/src/styles/index.css:2420:  .selection-card__meta {\nfrontend/src/shared/ui/workflow.tsx:345:        'selection-card',\nfrontend/src/shared/ui/workflow.tsx:346:        selected && 'selection-card--selected',\nfrontend/src/shared/ui/workflow.tsx:351:      <header className=\"selection-card__header\">\nfrontend/src/shared/ui/workflow.tsx:353:          <div className=\"selection-card__leading\">{leading}</div>\nfrontend/src/shared/ui/workflow.tsx:355:        <div className=\"selection-card__copy\">\nfrontend/src/shared/ui/workflow.tsx:357:            <p className=\"sele