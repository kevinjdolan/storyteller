ompose/docker-compose.yml`: local frontend, backend, and browser QA services\\\\\\\\ndiff --git a/infra/compose/docker-compose.yml b/infra/compose/docker-compose.yml\\\\\\\\nindex 8bbe2f9..692adcf 100644\\\\\\\\n--- a/infra/compose/docker-compose.yml\\\\\\\\n+++ b/infra/compose/docker-compose.yml\\\\\\\\n@@ -8,9 +8,10 @@ services:\\\\\\\\n     environment:\\\\\\\\n       PYTHONDONTWRITEBYTECODE: \\\\\\\\\\\\\\\"1\\\\\\\\\\\\\\\"\\\\\\\\n       PYTHONUNBUFFERED: \\\\\\\\\\\\\\\"1\\\\\\\\\\\\\\\"\\\\\\\\n+      STORYTELLER_ENVIRONMENT: development\\\\\\\\n     ports:\\\\\\\\n       - \\\\\\\\\\\\\\\"8565:8565\\\\\\\\\\\\\\\"\\\\\\\\n-    command: uvicorn app.main:app --reload --host 0.0.0.0 --port 8565\\\\\\\\n+    command: python -m app\\\\\\\\n     healthcheck:\\\\\\\\n       test:\\\\\\\\n         - CMD\\\\\\\\n@@ -18,7 +19,7 @@ services:\\\\\\\\n         - -c\\\\\\\\n         - |\\\\\\\\n           import sys, urllib.request\\\\\\\\n-          urllib.request.urlopen(\\\\\\\\\\\\\\\"http://127.0.0.1:8565/api/hello\\\\\\\\\\\\\\\")\\\\\\\\n+          urllib.request.urlopen(\\\\\\\\\\\\\\\"http://127.0.0.1:8565/health\\\\\\\\\\\\\\\")\\\\\\\\n           sys.exit(0)\\\\\\\\n       interval: 5s\\\\\\\\n       timeout: 5s\\\\\\\\n\\\\\\\", \\\\\\\"command\\\\\\\": \\\\\\\"/bin/zsh -lc 'git diff -- backend README.md docs/architecture-overview.md infra/compose/docker-compose.yml frontend/src/features/system/useBackendStatus.ts'\\\\\\\", \\\\\\\"exit_code\\\\\\\": 0, \\\\\\\"id\\\\\\\": \\\\\\\"item_34\\\\\\\", \\\\\\\"status\\\\\\\": \\\\\\\"completed\\\\\\\", \\\\\\\"type\\\\\\\": \\\\\\\"command_execution\\\\\\\"}, \\\\\\\"type\\\\\\\": \\\\\\\"item.completed\\\\\\\"}, \\\\\\\"task_display_context\\\\\\\": {\\\\\\\"event_number\\\\\\\": 68, \\\\\\\"prompt_index\\\\\\\": 4, \\\\\\\"prompt_name\\\\\\\": \\\\\\\"03 \\\\\\\\u2014 Scaffold the FastAPI Backend\\\\\\\", \\\\\\\"prompt_total\\\\\\\": 100}, \\\\\\\"timestap\\\\\\\": \\\\\\\"2026-03-31T21:26:49-07:00\\\\\\\"}\\\\