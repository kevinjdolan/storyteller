     ? pitchGenerationResponse(requestBody)\n1472:            : pitchGenerationResponse\n1480:        pathname === '/api/v1/sessions/moonlit-harbor/selections/pitch' &&\n1487:        pitchSelectionRequests.push(requestBody)\n1489:          typeof pitchSelectionResponse === 'function'\n1490:            ? pitchSelectionResponse(requestBody)\n1491:            : pitchSelectionResponse\n1524:    pitchGenerationRequests,\n1525:    pitchSelectionRequests,\n1599:      screen.getByRole('button', { name: 'Regenerate pitches' }),\n1606:        'Slash commands: /next-stage, /regenerate-pitches, /plan',\n1697:    expect(screen.getByText('Quest Fantasy / Tone pending')).toBeInTheDocument()\n1721:      selected_pitch: null,\n1916:        name: 'Review and select story pitches',\n2016:  it('generates a durable pitch batch from the pitches stage', async () => {\n2017:    const pitchStageSnapshot = buildStoryBriefSaveResponse({\n2022:    const pitchStageHistory = {\n2028:    const { pitchGenerationRequests } = mockWorkspaceApi({\n2029:      history: pitchStageHistory,\n2031:        snapshot: pitchStageSnapshot,\n2032:        recent_history: pitchStageHistory,\n2047:        name: 'Review and select story pitches',\n2051:      screen.getByRole('heading', { level: 3, name: 'Generate a pitch batch' }),\n2057:    fireEvent.change(screen.getByLabelText('Optional pitch guidance'), {\n2063:    fireEvent.click(screen.getByRole('button', { name: 'Generate pitches' }))\n2065:    expect(pitchGenerationRequests).toEqual([\n2070:        preserve_selected_pitch: false,\n2081:      await screen.findByText(/generated 5 pitch options/i),\n2085:  it('selects a generated pitch card and advances to characters', async () => {\n2095:    const { pitchSelectionRequests } = mockWorkspaceApi({\n2111:    const pitchCard = await screen.findByRole('heading', {\n2116:      within(pitchCard.closest('article') as HTMLElement).getByRole('button', {\n2117:        name: 'Choose pitch',\n2121:    expect(pitchSelectionRe