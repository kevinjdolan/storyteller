{"type":"item.started","item":{"id":"item_390","type":"command_execution","command":"/bin/zsh -lc \"docker compose -f infra/compose/docker-compose.yml run --rm browser node - <<'JS'\nconst puppeteer = require('puppeteer');\n(async () => {\n  const browser = await puppeteer.launch({headless: true, executablePath: process.env.PUPPETEER_EXECUTABLE_PATH, args: ['--no-sandbox', '--disable-setuid-sandbox']});\n  const page = await browser.newPage();\n  await page.setViewport({width: 1440, height: 1400});\n  await page.goto('http://frontend:8566/sessions/3193b0ba-3739-4a74-a1e7-91b1cd456493?stage=composition', {waitUntil: 'networkidle2', timeout: 20000});\n  await new Promise((resolve) => setTimeout(resolve, 3000));\n  const text = await page.evaluate(() => document.body?.innerText || '');\n  for (const phrase of ['2 downstream segments need continuity refresh.', 'Stale downstream', 'Accept rewrite', 'Pending review']) {\n    console.log(phrase, text.includes(phrase));\n  }\n  await browser.close();\n})();\nJS\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
