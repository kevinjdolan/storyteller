{"type":"item.started","item":{"id":"item_415","type":"command_execution","command":"/bin/zsh -lc \"docker compose -f infra/compose/docker-compose.yml exec -T backend python - <<'PY'\nfrom app.db import (\n    CompositionDownstreamMode,\n    CompositionJob,\n    CompositionJobKind,\n    CompositionSegment,\n    JobStatus,\n    SessionAsset,\n    StorySession,\n)\nfrom app.db.session import get_session_factory\nfrom app.models import WorkflowStage, WorkflowStageState\nfrom app.services import CompositionJobService, SessionService\nfrom app.settings import get_settings\nfrom app.storage import build_object_storage_service\nfrom tests.test_story_tools import RecordingCompositionWriter\n\nSESSION_ID = '3193b0ba-3739-4a74-a1e7-91b1cd456493'\nDRAFT_JOB_ID = '345b4be3-03f8-4798-af9f-c5b8f585e7fe'\n\nsession_factory = get_session_factory()\nsettings = get_settings()\nobject_storage = build_object_storage_service(settings)\n\nwith session_factory() as session:\n    story_session = session.get(StorySession, SESSION_ID)\n    story_session.working_title = 'Prompt 66 Rewrite QA'\n    rewrite_job_ids = [job.id for job in session.query(CompositionJob).filter(CompositionJob.session_id == SESSION_ID, CompositionJob.job_kind == CompositionJobKind.REWRITE).all()]\n    if rewrite_job_ids:\n        rewrite_segment_ids = [segment.id for segment in session.query(CompositionSegment).filter(CompositionSegment.composition_job_id.in_(rewrite_job_ids)).all()]\n        if rewrite_segment_ids:\n            session.query(SessionAsset).filter(SessionAsset.composition_segment_id.in_(rewrite_segment_ids)).delete(synchronize_session=False)\n        session.query(SessionAsset).filter(SessionAsset.composition_job_id.in_(rewrite_job_ids)).delete(synchronize_session=False)\n        session.query(CompositionSegment).filter(CompositionSegment.composition_job_id.in_(rewrite_job_ids)).delete(synchronize_session=False)\n        session.query(CompositionJob).filter(CompositionJob.id.in_(rewrite_job_ids)).delete(synchronize_session=False)\n    draft_job = session.get(CompositionJob, DRAFT_JOB_ID)\n    draft_job.status = JobStatus.COMPLETED\n    draft_job.progress_percent = 100\n    draft_job.current_segment_index = 3\n    draft_job.error_message = None\n    draft_job.stop_reason = None\n    for segment in session.query(CompositionSegment).filter(CompositionSegment.composition_job_id == DRAFT_JOB_ID):\n        segment.status = JobStatus.COMPLETED\n        segment.acceptance_state = 'accepted'\n        segment.is_stale = False\n        segment.stale_reason = None\n        segment.stale_at = None\n        segment.stale_by_job_id = None\n        segment.superseded_by_segment_id = None\n    SessionService(session).update_stage_state(SESSION_ID, stage=WorkflowStage.COMPOSITION, status=WorkflowStageState.COMPLETED)\n    session.commit()\nwith session_factory() as session:\n    service = CompositionJobService(session, object_storage=object_storage, writer=RecordingCompositionWriter(label='QA Rewrite'))\n    start_result = service.start_job(SESSION_ID, job_kind=CompositionJobKind.REWRITE, start_segment_index=1, end_segment_index=1, downstream_regeneration_mode=CompositionDownstreamMode.REQUIRE_CONFIRMATION, instructions='Soften the harbor opening and bring Pip into view immediately.', cancel_reason=None)\n    service.run_job(start_result.job.id)\n    snapshot = SessionService(session).load_session_snapshot(SESSION_ID)\n    print({'job_id': start_result.job.id, 'pending_review': snapshot.latest_composition_job.pending_review if snapshot.latest_composition_job else None})\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
