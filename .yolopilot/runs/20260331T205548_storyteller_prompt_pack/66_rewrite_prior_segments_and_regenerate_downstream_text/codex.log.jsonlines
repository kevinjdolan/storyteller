nt-family-display);\n  font-size: clamp(2.3rem, 4.2vw, 3.3rem);\n  line-height: 0.9;\n}\n\n.composition-stage__progress-callout span {\n  color: rgba(249, 243, 235, 0.74);\n}\n\n.composition-stage__progress {\n  gap: var(--space-3);\n}\n\n.composition-stage__progress .progress__meta {\n  align-items: end;\n}\n\n.composition-stage__progress .progress__label {\n  font-size: 1.02rem;\n  font-weight: 700;\n}\n\n.composition-stage__progress .progress__value {\n  font-size: 1.3rem;\n  font-weight: 700;\n  color: var(--color-brand);\n}\n\n.composition-stage__progress .progress__track {\n  height: 1rem;\n  border-radius: 999px;\n}\n\n.composition-stage__studio-grid {\n  display: grid;\n  gap: var(--space-5);\n  grid-template-columns: minmax(0, 1.55fr) minmax(19rem, 0.95fr);\n  align-items: start;\n}\n\n.composition-stage__surface,\n.composition-stage__control-panel,\n.composition-stage__archive {\n  gap: var(--space-4);\n}\n\n.composition-stage__surface-header,\n.composition-stage__control-panel .panel-heading {\n  display: flex;\n  justify-content: space-between;\n  gap: var(--space-4);\n  align-items: start;\n}\n\n.composition-stage__surface-header h3,\n.composition-stage__control-panel h3,\n.composition-stage__archive h3 {\n  margin: 0;\n  font-family: var(--font-family-display);\n  font-size: clamp(1.55rem, 2.2vw, 2rem);\n}\n\n.composition-stage__segment-meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: var(--space-2);\n}\n\n.composition-stage__segment-pill,\n.composition-stage__beat-pill {\n  display: inline-flex;\n  align-items: center;\n  min-height: 2rem;\n  padding: 0.3rem 0.7rem;\n  border-radius: var(--radius-pill);\n  font-size: 0.86rem;\n  font-weight: 700;\n}\n\n.composition-stage__segment-pill {\n  background: rgba(39, 69, 99, 0.1);\n  color: var(--color-brand);\n}\n\n.composition-stage__beat-pill {\n  background: rgba(169, 116, 60, 0.12);\n  color: var(--color-gold);\n}\n\n.composition-stage__manuscript-shell {\n  position: relative;\n  overflow: hidden;\