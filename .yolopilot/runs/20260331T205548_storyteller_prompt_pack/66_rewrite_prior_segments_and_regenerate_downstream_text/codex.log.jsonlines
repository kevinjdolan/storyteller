{"type":"item.started","item":{"id":"item_286","type":"command_execution","command":"/bin/zsh -lc \"docker compose -f infra/compose/docker-compose.yml exec -T backend python - <<'PY'\nfrom datetime import datetime, timezone\n\nfrom app.db import (\n    CompositionDownstreamMode,\n    CompositionJob,\n    CompositionJobKind,\n    JobStatus,\n    StorySession,\n)\nfrom app.db.session import get_session_factory\nfrom app.models import WorkflowStage, WorkflowStageState\nfrom app.services import CompositionJobService, SessionService\nfrom app.settings import get_settings\nfrom app.storage import build_object_storage_service\nfrom tests.test_story_tools import RecordingCompositionWriter\n\nSESSION_ID = '3193b0ba-3739-4a74-a1e7-91b1cd456493'\nJOB_ID = '345b4be3-03f8-4798-af9f-c5b8f585e7fe'\nNOW = datetime.now(timezone.utc)\n\nsession_factory = get_session_factory()\nsettings = get_settings()\nobject_storage = build_object_storage_service(settings)\n\nwith session_factory() as session:\n    story_session = session.get(StorySession, SESSION_ID)\n    if story_session is None:\n        raise RuntimeError(f'missing session {SESSION_ID}')\n    story_session.working_title = 'Prompt 66 Rewrite QA'\n    draft_job = session.get(CompositionJob, JOB_ID)\n    if draft_job is None:\n        raise RuntimeError(f'missing draft job {JOB_ID}')\n    draft_job.status = JobStatus.COMPLETED\n    draft_job.progress_percent = 100\n    draft_job.current_segment_index = 3\n    draft_job.completed_at = NOW\n    SessionService(session).update_stage_state(\n        SESSION_ID,\n        stage=WorkflowStage.COMPOSITION,\n        status=WorkflowStageState.COMPLETED,\n    )\n    session.commit()\n\nwith session_factory() as session:\n    service = CompositionJobService(\n        session,\n        object_storage=object_storage,\n        writer=RecordingCompositionWriter(label='QA Rewrite'),\n    )\n    start_result = service.start_job(\n        SESSION_ID,\n        job_kind=CompositionJobKind.REWRITE,\n        start_segment_index=1,\n        end_segment_index=2,\n        downstream_regeneration_mode=CompositionDownstreamMode.REQUIRE_CONFIRMATION,\n        instructions='Soften the opening and midpoint while keeping Pip visible from the first page.',\n    )\n    run_result = service.run_job(start_result.job.id)\n    snapshot = SessionService(session).load_session_snapshot(SESSION_ID)\n    print({\n        'session_id': SESSION_ID,\n        'job_id': start_result.job.id,\n        'run_status': run_result.status.value,\n        'latest_job_status': snapshot.latest_composition_job.status if snapshot.latest_composition_job else None,\n        'pending_review': snapshot.latest_composition_job.pending_review if snapshot.latest_composition_job else None,\n        'pending_segments': [\n            segment.segment_index\n            for segment in snapshot.composition_segments or []\n            if segment.pending_version_id is not None\n        ],\n        'stale_segments': [\n            segment.segment_index\n            for segment in snapshot.composition_segments or []\n            if segment.is_stale\n        ],\n    })\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
