{"type":"item.started","item":{"id":"item_269","type":"command_execution","command":"/bin/zsh -lc \"python - <<'PY'\nimport json, urllib.request\nsession_ids = [\n    '5381b9c3-322e-4c2a-9e3b-40475240d816',\n    '3193b0ba-3739-4a74-a1e7-91b1cd456493',\n    'c462d1f8-b2ec-421a-95de-70feba82394e',\n]\nfor session_id in session_ids:\n    with urllib.request.urlopen(f'http://localhost:8565/api/v1/sessions/{session_id}/hydrate?history_limit=5') as response:\n        data = json.load(response)\n    snapshot = data['snapshot']\n    latest_job = snapshot.get('latest_composition_job') or {}\n    active_job = snapshot.get('active_composition_job') or {}\n    stale = [s['segment_index'] for s in snapshot.get('composition_segments', []) if s.get('is_stale')]\n    pending = [s['segment_index'] for s in snapshot.get('composition_segments', []) if s.get('pending_version_id')]\n    print({\n        'id': session_id,\n        'title': snapshot.get('display_title'),\n        'current_stage': snapshot.get('current_stage'),\n        'latest_job': {\n            'id': latest_job.get('id'),\n            'kind': latest_job.get('job_kind'),\n            'status': latest_job.get('status'),\n            'pending_review': latest_job.get('pending_review'),\n            'stale_from': latest_job.get('stale_from_segment_index'),\n            'stale_to': latest_job.get('stale_to_segment_index'),\n            'downstream_mode': latest_job.get('downstream_regeneration_mode'),\n        },\n        'active_job': {\n            'id': active_job.get('id'),\n            'kind': active_job.get('job_kind'),\n            'status': active_job.get('status'),\n        },\n        'segment_count': len(snapshot.get('composition_segments') or []),\n        'stale_segments': stale,\n        'pending_segments': pending,\n    })\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
