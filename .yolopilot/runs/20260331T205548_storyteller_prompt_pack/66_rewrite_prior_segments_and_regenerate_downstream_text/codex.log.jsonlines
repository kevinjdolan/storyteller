te-note {\n  margin: 0;\n  color: var(--color-ink-soft);\n}\n\n.composition-stage__archive-shell {\n  max-height: 19rem;\n  overflow: auto;\n  padding: 1rem 1.1rem;\n  border: 1px solid rgba(39, 69, 99, 0.09);\n  border-radius: var(--radius-lg);\n  background: linear-gradient(\n    180deg,\n    rgba(247, 249, 252, 0.98),\n    rgba(240, 244, 250, 0.92)\n  );\n}\n\n.composition-stage__archive-shell pre {\n  font-family: var(--font-family-body);\n  font-size: 0.98rem;\n  color: var(--color-ink-strong);\n}\n\n@keyframes composition-cursor-blink {\n  0%,\n  49% {\n    opacity: 1;\n  }\n\n  50%,\n  100% {\n    opacity: 0;\n  }\n}\n\n@keyframes composition-surface-sweep {\n","exit_code":0,"status":"completed"}}
