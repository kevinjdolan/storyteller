{"type":"item.started","item":{"id":"item_352","type":"command_execution","command":"/bin/zsh -lc \"docker compose -f infra/compose/docker-compose.yml exec -T backend python - <<'PY'\nfrom app.db import (\n    CompositionDownstreamMode,\n    CompositionJob,\n    CompositionJobKind,\n    CompositionSegment,\n    JobStatus,\n    SessionAsset,\n    StorySession,\n)\nfrom app.db.session import get_session_factory\nfrom app.models import WorkflowStage, WorkflowStageState\nfrom app.services import CompositionJobService, SessionService\nfrom app.settings import get_settings\nfrom app.storage import build_object_storage_service\nfrom tests.test_story_tools import RecordingCompositionWriter\n\nSESSION_ID = '3193b0ba-3739-4a74-a1e7-91b1cd456493'\nDRAFT_JOB_ID = '345b4be3-03f8-4798-af9f-c5b8f585e7fe'\n\nsession_factory = get_session_factory()\nsettings = get_settings()\nobject_storage = build_object_storage_service(settings)\n\nwith session_factory() as session:\n    story_session = session.get(StorySession, SESSION_ID)\n    if story_session is None:\n        raise RuntimeError(f'missing session {SESSION_ID}')\n    story_session.working_title = 'Prompt 66 Rewrite QA'\n\n    rewrite_job_ids = [\n        job.id\n        for job in session.query(CompositionJob)\n        .filter(\n            CompositionJob.session_id == SESSION_ID,\n            CompositionJob.job_kind == CompositionJobKind.REWRITE,\n        )\n        .all()\n    ]\n    if rewrite_job_ids:\n        rewrite_segment_ids = [\n            segment.id\n            for segment in session.query(CompositionSegment)\n            .filter(CompositionSegment.composition_job_id.in_(rewrite_job_ids))\n            .all()\n        ]\n        if rewrite_segment_ids:\n            session.query(SessionAsset).filter(\n                SessionAsset.composition_segment_id.in_(rewrite_segment_ids)\n            ).delete(synchronize_session=False)\n        session.query(SessionAsset).filter(\n            SessionAsset.composition_job_id.in_(rewrite_job_ids)\n        ).delete(synchronize_session=False)\n        session.query(CompositionSegment).filter(\n            CompositionSegment.composition_job_id.in_(rewrite_job_ids)\n        ).delete(synchronize_session=False)\n        session.query(CompositionJob).filter(\n            CompositionJob.id.in_(rewrite_job_ids)\n        ).delete(synchronize_session=False)\n\n    draft_job = session.get(CompositionJob, DRAFT_JOB_ID)\n    if draft_job is None:\n        raise RuntimeError(f'missing draft job {DRAFT_JOB_ID}')\n    draft_job.status = JobStatus.COMPLETED\n    draft_job.progress_percent = 100\n    draft_job.current_segment_index = 3\n    draft_job.error_message = None\n    draft_job.stop_reason = None\n\n    for segment in session.query(CompositionSegment).filter(\n        CompositionSegment.composition_job_id == DRAFT_JOB_ID\n    ):\n        segment.status = JobStatus.COMPLETED\n        segment.acceptance_state = 'accepted'\n        segment.is_stale = False\n        segment.stale_reason = None\n        segment.stale_at = None\n        segment.stale_by_job_id = None\n        segment.superseded_by_segment_id = None\n\n    SessionService(session).update_stage_state(\n        SESSION_ID,\n        stage=WorkflowStage.COMPOSITION,\n        status=WorkflowStageState.COMPLETED,\n    )\n    session.commit()\n\nwith session_factory() as session:\n    service = CompositionJobService(\n        session,\n        object_storage=object_storage,\n        writer=RecordingCompositionWriter(label='QA Rewrite'),\n    )\n    start_result = service.start_job(\n        SESSION_ID,\n        job_kind=CompositionJobKind.REWRITE,\n        start_segment_index=1,\n        end_segment_index=1,\n        downstream_regeneration_mode=CompositionDownstreamMode.REQUIRE_CONFIRMATION,\n        instructions='Soften the harbor opening and bring Pip into view immediately.',\n        cancel_reason=None,\n    )\n    run_result = service.run_job(start_result.job.id)\n    snapshot = SessionService(session).load_session_snapshot(SESSION_ID)\n    print({\n        'job_id': start_result.job.id,\n        'run_result': run_result,\n        'latest_status': snapshot.latest_composition_job.status if snapshot.latest_composition_job else None,\n        'pending_review': snapshot.latest_composition_job.pending_review if snapshot.latest_composition_job else None,\n        'pending_segments': [\n            segment.segment_index\n            for segment in snapshot.composition_segments or []\n            if segment.pending_version_id is not None\n        ],\n    })\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
