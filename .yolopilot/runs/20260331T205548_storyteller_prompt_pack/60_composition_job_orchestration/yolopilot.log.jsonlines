{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Finished", "message": "completed, exit 0: /bin/zsh -lc \"nl -ba backend/tests/test_story_tools.py | sed -n '720,940p'\"", "raw_event": {"item": {"aggregated_output": "   720\t    assert worker.run_once() is True\n   721\t\n   722\t    with session_factory() as session:\n   723\t        job = BackgroundJobService(session).get_job(queued.id)\n   724\t        snapshot = SessionService(session).load_session_snapshot(seeded[\"session_id\"])\n   725\t\n   726\t    assert job.status == JobStatus.COMPLETED\n   727\t    assert job.result_summary[\"tool_name\"] == \"update_setup_heuristics\"\n   728\t    assert snapshot.selected_story_setup is not None\n   729\t    assert snapshot.selected_story_setup.target_runtime_minutes == 7\n   730\t\n   731\t\n   732\tdef test_story_workflow_tool_service_queues_durable_composition_execution(\n   733\t    db_session,\n   734\t) -> None:\n   735\t    seeded = _seed_story_setup_session(db_session)\n   736\t\n   737\t    result = StoryWorkflowToolService(db_session).execute(\n   738\t        tool_name=StoryWorkflowToolName.COMPOSE_NEXT_SEGMENT,\n   739\t        session_id=seeded[\"session_id\"],\n   740\t        arguments={},\n   741\t    )\n   742\t\n   743\t    job = db_session.get(CompositionJob, result.composition_job_id)\n   744\t    segments = list(\n   745\t        db_session.execute(\n   746\t            select(CompositionSegment)\n   747\t            .where(CompositionSegment.composition_job_id == result.composition_job_id)\n   748\t            .order_by(CompositionSegment.segment_index.asc())\n   749\t        ).scalars()\n   750\t    )\n   751\t    queued_runtime_jobs = list(\n   752\t        db_session.execute(\n   753\t            select(BackgroundJob)\n   754\t            .where(BackgroundJob.job_type == COMPOSITION_RUNTIME_JOB_TYPE)\n   755\t            .order_by(BackgroundJob.created_at.asc())\n   756\t        ).scalars()\n   757\t    )\n   758\t\n   759\t    assert job is not None\n   760\t    assert job.status == JobStatus.QUEUED\n   761\t    assert job.current_segment_index == 1\n   762\t    assert job.metadata_json[\"total_segments\"] == 3\n   763\t    assert [segment.segment_index for segment in segments] == [1, 2, 3]\n   764\t    assert all(segment.status == JobStatus.QUEUED for segment in segments)\n   765\t    assert len(queued_runtime_jobs) == 1\n   766\t    assert queued_runtime_jobs[0].payload[\"composition_job_id\"] == result.composition_job_id\n   767\t\n   768\t\n   769\tdef test_composition_job_service_resume_does_not_duplicate_runtime_attempts(\n   770\t    db_session,\n   771\t) -> None:\n   772\t    seeded = _seed_story_setup_session(db_session)\n   773\t    result = StoryWorkflowToolService(db_session).execute(\n   774\t        tool_name=StoryWorkflowToolName.COMPOSE_NEXT_SEGMENT,\n   775\t        session_id=seeded[\"session_id\"],\n   776\t        arguments={},\n   777\t    )\n   778\t    service = CompositionJobService(db_session)\n   779\t\n   780\t    service.pause_job(seeded[\"session_id\"], result.composition_job_id)\n   781\t    service.resume_job(seeded[\"session_id\"], result.composition_job_id)\n   782\t\n   783\t    queued_runtime_jobs = list(\n   784\t        db_session.execute(\n   785\t            select(BackgroundJob)\n   786\t            .where(BackgroundJob.job_type == COMPOSITION_RUNTIME_JOB_TYPE)\n   787\t            .order_by(BackgroundJob.created_at.asc())\n   788\t        ).scalars()\n   789\t    )\n   790\t    pending_for_job = [\n   791\t        job\n   792\t        for job in queued_runtime_jobs\n   793\t        if isinstance(job.payload, dict)\n   794\t        and job.payload.get(\"composition_job_id\") == result.composition_job_id\n   795\t        and job.status == JobStatus.QUEUED\n   796\t    ]\n   797\t    composition_job = db_session.get(CompositionJob, result.composition_job_id)\n   798\t\n   799\t    assert composition_job is not None\n   800\t    assert composition_job.status == JobStatus.QUEUED\n   801\t    assert len(pending_for_job) == 1\n   802\t\n   803\t\n   804\tdef test_worker_completes_durable_composition_job_and_persists_story_text_asset(\n   805\t    tmp_path: Path,\n   806\t) -> None:\n   807\t    fake_gcs, client, object_storage = _build_test_object_storage()\n   808\t    session_factory = _build_session_factory(tmp_path)\n   809\t\n   810\t    try:\n   811\t        with session_factory() as session:\n   812\t            seeded = _seed_story_setup_session(session)\n   813\t            result = StoryWorkflowToolService(session).execute(\n   814\t                tool_name=StoryWorkflowToolName.COMPOSE_NEXT_SEGMENT,\n   815\t                session_id=seeded[\"session_id\"],\n   816\t                arguments={},\n   817\t            )\n   818\t\n   819\t        worker = JobWorker(\n   820\t            session_factory=session_factory,\n   821\t            registry=build_default_job_handler_registry(object_storage=object_storage),\n   822\t            worker_id=\"composition-worker\",\n   823\t            lease_duration=timedelta(seconds=30),\n   824\t            poll_interval_seconds=0.01,\n   825\t        )\n   826\t\n   827\t        processed_jobs = 0\n   828\t        while worker.run_once():\n   829\t            processed_jobs += 1\n   830\t            assert processed_jobs < 10\n   831\t\n   832\t        with session_factory() as session:\n   833\t            composition_job = session.get(CompositionJob, result.composition_job_id)\n   834\t            story_asset = session.execute(\n   835\t                select(SessionAsset).where(\n   836\t                    SessionAsset.composition_job_id == result.composition_job_id,\n   837\t                    SessionAsset.asset_kind == AssetKind.STORY_TEXT,\n   838\t                )\n   839\t            ).scalar_one_or_none()\n   840\t            segments = list(\n   841\t                session.execute(\n   842\t                    select(CompositionSegment)\n   843\t                    .where(CompositionSegment.composition_job_id == result.composition_job_id)\n   844\t                    .order_by(CompositionSegment.segment_index.asc())\n   845\t                ).scalars()\n   846\t            )\n   847\t\n   848\t        assert processed_jobs == 3\n   849\t        assert composition_job is not None\n   850\t        assert composition_job.status == JobStatus.COMPLETED\n   851\t        assert composition_job.progress_percent == 100\n   852\t        assert len(segments) == 3\n   853\t        assert all(segment.status == JobStatus.COMPLETED for segment in segments)\n   854\t        assert story_asset is not None\n   855\t        assert story_asset.status == AssetStatus.READY\n   856\t        story_text = object_storage.download_text(\n   857\t            StorageObjectLocation(\n   858\t                bucket=story_asset.storage_bucket,\n   859\t                key=story_asset.object_path,\n   860\t            )\n   861\t        )\n   862\t        assert \"Mira\" in story_text\n   863\t        assert \"The scene landed in visible calm\" in story_text\n   864\t        assert any(key.endswith(\"/segments/0001.md\") for _, key in fake_gcs.objects)\n   865\t    finally:\n   866\t        object_storage.close()\n   867\t        client.close()\n   868\t\n   869\t\n   870\tdef test_eval_prompt_exposes_story_tool_catalog_for_chat_translation() -> None:\n   871\t    prompt = render_intent_parser_prompt(\n   872\t        IntentParserPromptContext(\n   873\t            session_id=\"session-123\",\n   874\t            display_title=\"Moonlit Harbor\",\n   875\t            overall_status=WorkflowStageState.IN_PROGRESS,\n   876\t            resume_stage=WorkflowStage.BEATS,\n   877\t            stage_context=IntentParserStageContext(\n   878\t                current_stage=WorkflowStage.BEATS,\n   879\t                current_stage_label=\"Beat sheet\",\n   880\t                current_stage_description=(\n   881\t                    \"Store the accepted Save-the-Cat beat sheet for the session.\"\n   882\t                ),\n   883\t                current_stage_status=WorkflowStageState.IN_PROGRESS,\n   884\t                current_stage_detail=\"Refining the midpoint tension.\",\n   885\t            ),\n   886\t            session_summary=\"Selected tone: Hushed Wonder\",\n   887\t            user_message=\"make it shorter and gentler\",\n   888\t        )\n   889\t    )\n   890\t\n   891\t    assert \"Related backend tool registry\" in prompt\n   892\t    assert '\"tool_name\": \"generate_pitches\"' in prompt\n   893\t    assert '\"tool_name\": \"start_audio_generation\"' in prompt\n   894\t\n   895\t\n   896\tdef test_eval_registry_alignment_keeps_worker_and_prompt_catalogs_in_sync() -> None:\n   897\t    registry = get_story_workflow_tool_registry()\n   898\t    prompt_catalog_names = {item[\"tool_name\"] for item in registry.build_prompt_catalog()}\n   899\t    worker_job_types = set(build_default_job_handler_registry().registered_job_types())\n   900\t\n   901\t    assert prompt_catalog_names == {definition.name.value for definition in registry.list_tools()}\n   902\t    assert worker_job_types >= {definition.job_type for definition in registry.list_tools()}\n   903\t\n   904\t\n   905\tdef test_eval_background_tool_modes_cover_long_running_story_operations() -> None:\n   906\t    registry = get_story_workflow_tool_registry()\n   907\t    background_tools = {\n   908\t        definition.name\n   909\t        for definition in registry.list_tools()\n   910\t        if definition.execution_mode == StoryWorkflowToolExecutionMode.BACKGROUND\n   911\t    }\n   912\t\n   913\t    assert background_tools >= {\n   914\t        StoryWorkflowToolName.GENERATE_PITCHES,\n   915\t        StoryWorkflowToolName.GENERATE_CHARACTER_SHEETS,\n   916\t        StoryWorkflowToolName.GENERATE_BEAT_SHEET,\n   917\t        StoryWorkflowToolName.COMPOSE_NEXT_SEGMENT,\n   918\t        StoryWorkflowToolName.REWRITE_SEGMENTS,\n   919\