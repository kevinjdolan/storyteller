{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Started", "message": "in progress: /bin/zsh -lc \"python - <<'PY'\nfrom datetime import timedelta\nfrom pathlib import Path\nfrom tempfile import TemporaryDirectory\n\nfrom sqlalchemy import select\n\nfrom tests.test_story_tools import (\n    _build_session_factory,\n    _build_test_object_storage,\n    _seed_story_setup_session,\n)\nfrom app.db.models import AssetKind, CompositionJob, SessionAsset\nfrom app.services.story_tools import StoryWorkflowToolName, StoryWorkflowToolService\nfrom app.worker.default_handlers import build_default_job_handler_registry\nfrom app.worker.service import JobWorker\n\nwith TemporaryDirectory() as tmp:\n    fake_gcs, client, object_storage = _build_test_object_storage()\n    session_factory = _build_session_factory(Path(tmp))\n    try:\n        with session_factory() as session:\n            seeded = _seed_story_setup_session(session)\n            result = StoryWorkflowToolService(session).execute(\n                tool_name=StoryWorkflowToolName.COMPOSE_NEXT_SEGMENT,\n                session_id=seeded[\\\"session_id\\\"],\n                arguments={},\n            )\n            job_id = result.composition_job_id\n\n        worker = JobWorker(\n            session_factory=session_factory,\n            registry=build_default_job_handler_registry(object_storage=object_storage),\n            worker_id=\\\"evaluation-worker\\\",\n            lease_duration=timedelta(seconds=30),\n            poll_interval_seconds=0.01,\n        )\n        while worker.run_once():\n            pass\n\n        with session_factory() as session:\n            asset = session.execute(\n                select(SessionAsset).where(\n                    SessionAsset.composition_job_id == job_id,\n                    SessionAsset.asset_kind == AssetKind.STORY_TEXT,\n                )\n            ).scalar_one()\n            job = session.get(CompositionJob, job_id)\n            print({\n          