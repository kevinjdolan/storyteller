M_ACTOR,\n   770\t                )\n   771\t                self._sessions.update_stage_state(\n   772\t                    job.session_id,\n   773\t                    stage=WorkflowStage.COMPOSITION,\n   774\t                    status=WorkflowStageState.NEEDS_REGENERATION,\n   775\t                    detail=job.stop_reason or \"Writing was cancelled before the draft finished.\",\n   776\t                    actor=actor or DEFAULT_SYSTEM_ACTOR,\n   777\t                )\n   778\t                return {\n   779\t                    \"composition_job_id\": job.id,\n   780\t                    \"status\": job.status.value,\n   781\t                    \"action\": \"cancelled\",\n   782\t                }\n   783\t\n   784\t        current_segment.text_content = draft.full_text\n   785\t        current_segment.word_count = _count_words(draft.full_text)\n   786\t        current_segment.status = JobStatus.COMPLETED\n   787\t        current_segment.completed_at = utc_now()\n   788\t        self._storage().upload_text(\n   789\t            segment_storage_location,\n   790\t            draft.full_text,\n   791\t            content_type=\"text/markdown; charset=utf-8\",\n   792\t        )\n   793\t\n   794\t        next_segment = self._next_queued_segment(\n   795\t            job, after_segment_index=current_segment.segment_index\n   796\t        )\n   797\t        if next_segment is None:\n   798\t            story_text = self._compile_story_text(job.id)\n   799\t            story_location = _story_text_location(\n   800\t                self._storage(), session_id=job.session_id, job_id=job.id\n   801\t            )\n   802\t            story_metadata = self._storage().upload_text(\n   803\t                story_location,\n   804\t                story_text,\n   805\t                content_type=\"text/markdown; charset=utf-8\",\n   806\t            )\n   807\t            self._supersede_story_assets(job.session_id)\n   808\t            self._assets.save_asset_record(\n   809\t                session_id=job.session_id,\n   810\t                asset_kind=AssetKind.STORY_TEXT,\n   811\t                storage_bucket=story_location.bucket,\n   812\t                object_path=story_location.key,\n   813\t                mime_type=\"text/markdown\",\n   814\t                status=AssetStatus.READY,\n   815\t                composition_job_id=job.id,\n   816\t                segment_index=current_segment.segment_index,\n   817\t                byte_size=story_metadata.size_bytes,\n   818\t                metadata_json={\n   819\t                    \"orchestration_version\": \"composition_job.v1\",\n   820\t                    \"evaluation\": [\n   821\t                        {\n   822\t                            \"name\": criterion.name,\n   823\t                            \"passed\": criterion.passed,\n   824\t                            \"measured_value\": criterion.measured_value,\n   825\t                            \"detail\": criterion.detail,\n   826\t                        }\n   827\t                        for criterion in draft.evaluation.criteria\n   828\t                    ],\n   829\t                },\n   830\t            )\n   831\t            job.status = JobStatus.COMPLETED\n   832\t            job.progress_percent = 100\n   833\t            job.completed_at = utc_now()\n   834\t            job.metadata_json = {\n   835\t                **_read_metadata(job),\n   836\t                \"latest_partial_output\": story_text,\n   837\t                \"current_segment_id\": current_segment.id,\n   838\t            }\n   839\t            self._events.record_composition_progress(\n   840\t                job.session_id,\n", "command": "/bin/zsh -lc \"nl -ba backend/app/services/composition_jobs.py | sed -n '615,840p'\"", "exit_code": 0, "id": "item_204", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 412, "prompt_index": 61, "prompt_name": 