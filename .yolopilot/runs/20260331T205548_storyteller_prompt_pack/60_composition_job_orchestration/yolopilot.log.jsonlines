gment.segment_index,\n   695\t        )\n   696\t\n   697\t        chunk_count = max(len(draft.remaining_chunks), 1)\n   698\t        current_text = current_segment.text_content or \"\"\n   699\t        chunk_index = 0\n   700\t        for chunk in draft.remaining_chunks:\n   701\t            current_text += chunk\n   702\t            current_segment.text_content = current_text\n   703\t            current_segment.word_count = _count_words(current_text)\n   704\t            job.progress_percent = _segment_progress_percent(\n   705\t                job=job,\n   706\t                total_segments=total_segments,\n   707\t                chunk_position=chunk_index + 1,\n   708\t                total_chunks=chunk_count,\n   709\t            )\n   710\t            job.metadata_json = {\n   711\t                **_read_metadata(job),\n   712\t                \"latest_partial_output\": current_text,\n   713\t                \"current_segment_id\": current_segment.id,\n   714\t            }\n   715\t            self._storage().upload_text(\n   716\t                segment_storage_location,\n   717\t                current_text,\n   718\t                content_type=\"text/markdown; charset=utf-8\",\n   719\t            )\n   720\t            self._events.record_composition_progress(\n   721\t                job.session_id,\n   722\t                job_id=job.id,\n   723\t                status=JobStatus.IN_PROGRESS,\n   724\t                progress_percent=job.progress_percent,\n   725\t                current_segment_index=current_segment.segment_index,\n   726\t                total_segments=total_segments,\n   727\t                segment_id=current_segment.id,\n   728\t                actor=actor or DEFAULT_SYSTEM_ACTOR,\n   729\t            )\n   730\t            self._session.commit()\n   731\t            chunk_index += 1\n   732\t\n   733\t            self._session.refresh(job)\n   734\t            self._session.refresh(current_segment)\n   735\t            if job.