ionAction\",\nbackend/tests/test_composition_prompt_assembly.py:26:from app.services.composition_prompt_assembly import CompositionPromptAssemblyServiceError\nbackend/tests/test_composition_prompt_assembly.py:49:def test_composition_prompt_assembly_service_builds_structured_package(db_session) -> None:\nbackend/tests/test_composition_prompt_assembly.py:60:    assert package.assembly_version == \"composition_prompt_assembly.v1\"\nbackend/tests/test_composition_prompt_assembly.py:62:        package.system_instructions.writer_role == \"Backend-owned bedtime story composition engine\"\nbackend/tests/test_composition_prompt_assembly.py:64:    assert \"Stage focus for composition\" in package.system_instructions.bedtime_guidelines_fragment\nbackend/tests/test_composition_prompt_assembly.py:79:def test_composition_prompt_assembly_service_storage_payload_is_debuggable_and_safe(\nbackend/tests/test_composition_prompt_assembly.py:98:    assert payload[\"prompt_assembly_version\"] == \"composition_prompt_assembly.v1\"\nbackend/tests/test_composition_prompt_assembly.py:101:    assert payload[\"composition_prompt\"][\"dynamic_context\"][\"job_kind\"] == \"rewrite\"\nbackend/tests/test_composition_prompt_assembly.py:102:    assert payload[\"composition_prompt\"][\"dynamic_context\"][\"request_instructions\"] == instruction\nbackend/tests/test_composition_prompt_assembly.py:104:        payload[\"composition_prompt\"][\"debug_context\"][\"requested_instruction_excerpt\"]\nbackend/tests/test_composition_prompt_assembly.py:111:def test_eval_composition_prompt_package_covers_required_grounding_and_debug_signals(\nbackend/tests/test_composition_prompt_assembly.py:128:        \"composition_stage_guidelines_present\": (\nbackend/tests/test_composition_prompt_assembly.py:129:            \"Stage focus for composition\" in package.system_instructions.bedtime_guidelines_fragment\nbackend/tests/test_composition_prompt_assembly.py:154:def test_eval_composition_prompt_package_falls_back_when_outline_is_missing(db_session) -> None:\nbackend/tests/test_composition_prompt_assembly.py:178:def test_eval_composition_prompt_package_rejects_missing_selected_pitch(db_session) -> None:\nbackend/tests/test_composition_prompt_assembly.py:457:        progress_percent=100,\nbackend/tests/test_composition_prompt_assembly.py:467:            composition_job_id=previous_job.id,\ndocs/frontend-state-architecture.md:25:- The local runtime store keeps websocket/event-stream concerns separate from\ndocs/adr/0001-core-runtime-architecture.md:14:- composition and audio generation are too slow and failure-prone to run inside request threads\ndocs/adr/0001-core-runtime-architecture.md:15:- chat and direct UI actions both need an audit trail that can be replayed during resume\ndocs/adr/0001-core-runtime-architecture.md:24:All Gemini text, planning, composition, and narration calls belong behind backend-owned adapters and services.\ndocs/adr/0001-core-runtime-architecture.md:26:- The browser talks only to backend APIs and websocket streams.\ndocs/adr/0001-core-runtime-architecture.md:33:PostgreSQL owns the structured state required to resume a story session.\ndocs/adr/0001-core-runtime-architecture.md:45:- composition jobs and segment progress\ndocs/adr/0001-core-runtime-architecture.md:46:- audio jobs and segment progress\ndocs/adr/0001-core-runtime-architecture.md:49:Session resume should come from durable state, not browser cache. The event history is part of the product, not just an internal log, because it supports replay, auditability, and UI-to-chat echoes.\ndocs/adr/0001-core-runtime-architecture.md:56:- Story exports, intermediate composition files, narration segments, and final audio artifacts live in object storage.\ndocs/adr/0001-core-runtime-architecture.md:61:### 4. Live progress uses websocket delivery\ndocs/adr/0001-core-runtime-architecture.md:63:The browser needs live updates during composition and audio generation, and those updates need to remain tied to durable backend state.\ndocs/adr/0001-core-runtime-architecture.md:66:- WebSockets handle session progress, job status, and incremental event delivery.\ndocs/adr/0001-core-runtime-architecture.md:69:The websocket channel is a delivery mechanism, not the source of truth. If a socket drops, the session must still be recoverable from PostgreSQL and storage.\ndocs/adr/0001-core-runtime-architecture.md:71:### 5. Long-running generation runs in a separate worker process\ndocs/adr/0001-core-runtime-architecture.md:73:Composition and audio generation run in a worker process that is separate from the API process.\ndocs/adr/0001-core-runtime-architecture.md:77:- The API remains responsible for request handling, policy checks, and websocket fan-out.\ndocs/adr/0001-core-runtime-architecture.md:79:This separation keeps request latency predictable and makes pause, resume, retry, and interruption logic easier to reason about.\ndocs/adr/0001-core-runtime-architecture.md:85:- They guide pitch generation, beat planning, and composition prompts.\ndocs/adr/0001-core-runtime-architecture.md:86:- They should influence heuristics, summaries, warnings, and progress estimates.\ndocs/adr/0001-core-runtime-architecture.md:99:- Later prompts have a clear split between API responsibilities and worker responsibilities.\ndocs/adr/0001-core-runtime-architecture.md:104:- Websocket delivery and worker orchestration add coordination work that later prompts must implement carefully.\ndocs/adr/0001-core-runtime-architecture.md:109:- Put websocket endpoints under backend API ownership, not in the frontend dev server.\ndocs/adr/0001-core-runtime-architecture.md:110:- Treat the durable event history as product data that can be queried during session resume.\ndocs/README.md:13:- `story-workflow-tool-registry.md`: shared registry for story-operation tools, worker job types, and chat-action mappings\ndocs/README.md:19:- `system-diagram.md`: one-page runtime diagram for browser, API, worker, storage, and Gemini flows\ndocs/bedtime-guidelines.md:69:  `character`, `beat`, `composition`, and `audio`.\ndocs/bedtime-guidelines.md:110:    stage=\"composition\",\ndocs/frontend-design-foundation.md:27:- Progress bars expose `role=\"progressbar\"` plus value metadata.\nbackend/tests/test_chat_action_contracts.py:168:        match=\"pause_job target_stage must match the extracted job_kind\",\nbackend/tests/test_chat_action_contracts.py:176:                        \"action_type\": \"pause_job\",\nbackend/tests/test_chat_action_contracts.py:181:                            \"job_kind\": \"composition\",\nfrontend/src/api/sessions.ts:17:  in_progress_stages: number\nfrontend/src/api/sessions.ts:26:  resume_stage: WorkflowStageId\nfrontend/src/api/sessions.ts:34:  progress: SessionProgress\nfrontend/src/api/sessions.ts:333:  progress_percent: number\nfrontend/src/api/sessions.ts:456:  | 'pause_writing'\nfrontend/src/api/sessions.ts:457:  | 'resume_writing'\nfrontend/src/api/sessions.ts:524:  latest_composition_job?: CompositionJobView | null\nfrontend/src/api/sessions.ts:526:  active_composition_job?: CompositionJobView | null\ndocs/event-taxonomy.md:4:The goal is to make session history durable enough for replay, resume debugging,\ndocs/event-taxonomy.md:17:  - `system`: worker-owned or infrastructure-owned progress events.\ndocs/event-taxonomy.md:18:  - `service`: synchronous backend orchestration that is not best described as user or worker.\ndocs/event-taxonomy.md:31:| `content.user_edit.recorded` | Structured user-authored edits to durable planning or composition records. | `user` | stage-specific |\ndocs/event-taxonomy.md:34:| `composition.progress.recorded` | Durable composition job progress for replay and worker debugging. | `system` | `composition` |\ndocs/event-taxonomy.md:35:| `audio.progress.recorded` | Durable narration job progress for replay and worker debugging. | `system` | `audio` |\ndocs/event-taxonomy.md:57:  \"invalidated_stages\": [\"pitches\", \"characters\", \"beats\", \"composition\", \"audio\", \"finalize\"],\ndocs/event-taxonomy.md:59:  \"resume_stage\": \"pitches\",\ndocs/event-taxonomy.md:96:- `record_composition_progress(...)`\ndocs/event-taxonomy.md:97:- `record_audio_progress(...)`\ndocs/event-taxonomy.md:125:Record worker progress:\ndocs/event-taxonomy.md:128:event_log.record_composition_progress(\ndocs/event-taxonomy.md:130:    job_id=composition_job.id,\ndocs/event-taxonomy.md:131:    status=\"in_progress\",\ndocs/event-taxonomy.md:132:    progress_percent=62.5,\ndocs/product-brief.md:5:Storyteller is a session-based bedtime story creation studio. It helps a user move from a loose story idea to a finished written story and finished narration audio, with the ability to leave and come back later without losing progress.\ndocs/product-brief.md:7:The first meaningful screen is the sessions home. It must foreground past sessions, including both in-progress and completed stories, so resume and revisit are the default behaviors rather than an afterthought.\ndocs/product-brief.md:14:- Durable by default: progress survives refreshes, restarts, and long-running generation work.\ndocs/product-brief.md:28:8. Composition in segments with visible progress, typewriter-like output, and interruptibility.\ndocs/product-brief.md:38:- In-progress and completed sessions both appear on the home screen.\ndocs/product-brief.md:84:- resume work from prior sessions without losing context\ndocs/architecture-overview.md:11:Storyteller is a full-stack application with a browser client, a backend-owned workflow engine, durable relational state, durable object storage, and resumable background jobs.\ndocs/architecture-overview.md:21:        |         +--> AI adapters for planning, composition, and narration\ndocs/architecture-overview.md:25:        +--> background workers for composition and audio generation\ndocs/architecture-overview.md:40:The frontend should only call the backend's API and subscribe to backend-owned progress events.\ndocs/architecture-overview.md:46:- a user must be able to refresh the page or return later without losing progress\ndocs/architecture-overview.md:48:- progress updates need a single source of truth that both chat and UI can observe\ndocs/architecture-overview.md:49:- retries, cancellation, and resume logic need explicit job state rather than transient in-memory state\ndocs/architecture-overview.md:51:The durable model should include job records, segment records, asset metadata, and an event log that can reconstruct session progress after interruption.\ndocs/architecture-overview.md:57:- `api/`: HTTP routes and websocket endpoints\ndocs/architecture-overview.md:63:- `ai/`: Gemini planning, composition, and narration adapters\ndocs/architecture-overview.md:64:- `worker/`: background job execution for writing and audio\ndocs/architecture-overview.md:95:- `backend/app/worker/`: reserved home for background job runners\ndocs/architecture-overview.md:101:Background workers and most domain layers are still planned work. PostgreSQL and the file-backed GCS emulator are now available in the local Compose stack so later prompts can connect durable state and artifact storage without redefining the infrastructure contract.\ndocs/system-diagram.md:3:This diagram shows the intended runtime shape for Storyteller after the core session, worker, and realtime prompts are built. It documents where session resume, durable event history, realtime delivery, and long-running jobs belong.\ndocs/system-diagram.md:9:    WS[\"WebSocket session stream<br/>replay recent events + deliver live progress\"]\ndocs/system-diagram.md:10:    Worker[\"Worker process<br/>composition jobs, audio jobs, retries, interruption\"]\ndocs/system-diagram.md:13:    Gemini[\"Gemini adapters<br/>planning, composition, narration\"]\ndocs/system-diagram.md:16:    API -->|\"resume session snapshot\"| Browser\ndocs/system-diagram.md:28:    Worker -->|\"planning, composition, TTS calls\"| Gemini\ndocs/system-diagram.md:36:- WebSockets deliver progress, but durable state still lives in PostgreSQL and object storage.\ndocs/system-diagram.md:37:- Long-running generation belongs in the worker process, not inside request handlers.\nbackend/tests/test_session_beat_sheet_service.py:152:    assert result.snapshot.resume_stage == WorkflowStage.BEATS\nbackend/tests/test_session_beat_sheet_service.py:181:    assert result.snapshot.resume_stage == WorkflowStage.STORY_SETUP\nbackend/tests/test_session_beat_sheet_service.py:188:def test_refine_beat_sheet_creates_selected_revision_and_invalidates_composition(\nbackend/tests/test_session_beat_sheet_service.py:307:    assert \"Story setup and composition need refresh.\" in (\ndocs/contributing.md:31:- Treat the backend as the source of truth for workflow stage, job progress, and AI side effects. The browser reflects state; it does not own it.\nfrontend/src/app/router.test.tsx:12:    resume_stage: 'beats',\nfrontend/src/app/router.test.tsx:13:    overall_status: 'in_progress',\nfrontend/src/app/router.test.tsx:19:    progress: {\nfrontend/src/app/router.test.tsx:22:      in_progress_stages: 1,\nfrontend/src/app/router.test.tsx:33:  resume_stage: 'beats',\nfrontend/src/app/router.test.tsx:35:  overall_status: 'in_progress',\nfrontend/src/app/router.test.tsx:49:  progress: {\nfrontend/src/app/router.test.tsx:52:    in_progress_stages: 1,\nfrontend/src/app/router.test.tsx:69:      status: 'in_progress',\nfrontend/src/app/router.test.tsx:89:  active_composition_job: null,\nfrontend/src/shared/ui/primitives.test.tsx:53:  it('renders panel headings and progress bars with semantic metadata', () => {\nfrontend/src/shared/ui/primitives.test.tsx:61:          aria-label=\"Workflow progress\"\nfrontend/src/shared/ui/primitives.test.tsx:62:          label=\"Workflow progress\"\nfrontend/src/shared/ui/primitives.test.tsx:73:    const progress = screen.getByRole('progressbar', {\nfrontend/src/shared/ui/primitives.test.tsx:74:      name: 'Workflow progress',\nfrontend/src/share