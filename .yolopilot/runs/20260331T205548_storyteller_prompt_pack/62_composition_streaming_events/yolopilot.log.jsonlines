, 69, 99, 0.08);\n}\n\n.story-outline-stage__cards {\n  display: grid;\n  gap: var(--space-3);\n  margin: 0;\n  padding: 0;\n  list-style: none;\n}\n\n.story-outline-stage__editor {\n  display: grid;\n  grid-template-columns: minmax(0, 1.2fr) minmax(20rem, 0.95fr);\n  gap: var(--space-4);\n  align-items: start;\n}\n\n.story-outline-stage__card {\n  display: grid;\n  gap: var(--space-3);\n  padding: 1rem 1.05rem;\n  border-radius: var(--radius-lg);\n  background:\n    linear-gradient(\n      180deg,\n      rgba(255, 250, 242, 0.96),\n      rgba(255, 255, 255, 0.82)\n    ),\n    var(--color-surface-strong);\n  box-shadow:\n    inset 0 0 0 1px rgba(169, 116, 60, 0.12),\n    0 14px 32px rgba(39, 69, 99, 0.08);\n  transition:\n    transform 160ms ease,\n    box-shadow 160ms ease,\n    border-color 160ms ease;\n}\n\n.story-outline-stage__card--active {\n  transform: translateY(-2px);\n  box-shadow:\n    inset 0 0 0 1px rgba(169, 116, 60, 0.18),\n", "command": "/bin/zsh -lc \"sed -n '2260,2385p' frontend/src/styles/index.css\"", "exit_code": 0, "id": "item_259", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 564, "prompt_index": 63, "prompt_name": "62 \u2014 Composition Streaming Events", "prompt_total": 100}, "timestap": "2026-04-02T07:49:33-07:00"}
