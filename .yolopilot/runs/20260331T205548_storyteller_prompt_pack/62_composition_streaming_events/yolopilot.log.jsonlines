pace')\n    service.select_tone(session_id, tone_profile_slug='hushed-wonder', origin='workspace')\n    service.save_story_brief(\n        session_id,\n        raw_brief='A harbor child follows a drifting bell across moonlit water and brings the night back to calm.',\n        origin='workspace',\n    )\n    pitch_response = service.generate_pitches(\n        session_id,\n        candidate_count=3,\n        origin='workspace',\n        pitch_generation_service=PitchGenerationService(\n            adapter=StubPitchGenerationAdapter()\n        ),\n    )\n    pitch_id = pitch_response.snapshot.pitch_batches[0].pitches[0].id\n    service.select_pitch(session_id, pitch_id=pitch_id, origin='workspace')\n    character_response = service.generate_character_sheets(\n        session_id,\n        candidate_count=2,\n        origin='workspace',\n        character_generation_service=CharacterGenerationService(\n            adapter=StubCharacterGenerationAdapter()\n        ),\n    )\n    character_id = character_response.snapshot.character_sheet_batches[0].character_sheets[0].id\n    service.select_character_sheet(\n        session_id,\n        character_sheet_id=character_id,\n        origin='workspace',\n    )\n    beat_response = service.generate_beat_sheet(\n        session_id,\n        origin='workspace',\n        beat_sheet_generation_service=BeatSheetGenerationService(\n            adapter=StubBeatSheetGenerationAdapter()\n        ),\n    )\n    beat_id = beat_response.snapshot.beat_sheet_revisions[0].id\n    service.select_beat_sheet(session_id, beat_sheet_id=beat_id, origin='workspace')\n    StoryWorkflowToolService(session).execute(\n        tool_name=StoryWorkflowToolName.UPDATE_SETUP_HEURISTICS,\n        session_id=session_id,\n        arguments={\n            'target_word_count': 1800,\n            'target_runtime_minutes': 12,\n            'chapter_count': 3,\n            'approximate_scene_count': 8,\n            'guidance_notes': 'Let each chapter land calmer than 