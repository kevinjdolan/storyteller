ve feed idle').length).toBeGreaterThan(0)\n    expect(screen.getByTestId('live-feed-status')).toHaveTextContent('Idle')\n    expect(screen.getByRole('link', { name: 'Return home' })).toHaveAttribute(\n      'href',\n      '/',\n    )\n    expect(screen.getByRole('log')).toBeInTheDocument()\n    expect(\n      screen.getByRole('button', { name: 'Send message' }),\n    ).toBeInTheDocument()\n    expect(\n      screen.getByText(\n        'The current focus is softening the midpoint before composition starts.',\n      ),\n    ).toBeInTheDocument()\n    expect(\n      screen.getByRole('heading', {\n        level: 3,\n        name: 'Generate a beat sheet revision',\n      }),\n    ).toBeInTheDocument()\n    expect(\n      screen.getByRole('heading', { level: 3, name: 'Beat outline preview' }),\n", "command": "/bin/zsh -lc \"sed -n '3405,3485p' frontend/src/pages/session/SessionWorkspacePage.test.tsx\"", "exit_code": 0, "id": "item_239", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 524, "prompt_index": 63, "prompt_name": "62 \u2014 Composition Streaming Events", "prompt_total": 100}, "timestap": "2026-04-02T07:46:53-07:00"}
