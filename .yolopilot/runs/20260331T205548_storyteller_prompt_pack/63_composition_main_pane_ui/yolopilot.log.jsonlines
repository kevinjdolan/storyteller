{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Finished", "message": "completed, exit 0: /bin/zsh -lc \"nl -ba frontend/src/features/session/CompositionStage.test.tsx | sed -n '150,280p'\"", "raw_event": {"item": {"aggregated_output": "   150\t  totalSegments: 3,\n   151\t  storyText:\n   152\t    'Draft segment 1 settles the harbor.\\n\\nMira followed the bell toward the quieter cove.',\n   153\t  latestPartialOutput: 'Mira followed the bell toward the quieter cove.',\n   154\t  latestSegmentSummary: 'Segment 1 settled the harbor before the cove opened.',\n   155\t  lastChunkText: 'toward the quieter cove.',\n   156\t  source: 'live',\n   157\t  updatedAt: '2026-04-02T05:16:00Z',\n   158\t}\n   159\t\n   160\tdescribe('CompositionStage', () => {\n   161\t  it('renders the current segment focus, archive, and routes control requests through the callbacks', async () => {\n   162\t    const onCancelComposition = vi.fn().mockResolvedValue(undefined)\n   163\t    const onPauseComposition = vi.fn().mockResolvedValue(undefined)\n   164\t    const onRedirectComposition = vi.fn().mockResolvedValue(undefined)\n   165\t    const onResumeComposition = vi.fn().mockResolvedValue(undefined)\n   166\t    const onReturnToPlan = vi.fn().mockResolvedValue(undefined)\n   167\t    const onStartComposition = vi.fn().mockResolvedValue(undefined)\n   168\t\n   169\t    renderWithAppProviders(\n   170\t      <CompositionStage\n   171\t        composition={liveComposition}\n   172\t        connectionState=\"open\"\n   173\t        onCancelComposition={onCancelComposition}\n   174\t        onPauseComposition={onPauseComposition}\n   175\t        onRedirectComposition={onRedirectComposition}\n   176\t        onResumeComposition={onResumeComposition}\n   177\t        onReturnToPlan={onReturnToPlan}\n   178\t        onStartComposition={onStartComposition}\n   179\t        snapshot={sampleSnapshot}\n   180\t      />,\n   181\t    )\n   182\t\n   183\t    expect(screen.getByText('Writing segment 2 of 3')).toBeInTheDocument()\n   184\t    expect(screen.getAllByText('Lantern cove')).not.toHaveLength(0)\n   185\t    expect(screen.getByText('Earlier accepted manuscript')).toBeInTheDocument()\n   186\t    expect(screen.getByTestId('composition-current-surface')).toHaveTextContent(\n   187\t      'Mira followed the bell toward the quieter cove.',\n   188\t    )\n   189\t    expect(\n   190\t      screen.getByTestId('composition-current-surface'),\n   191\t    ).not.toHaveTextContent('Draft segment 1 settles the harbor.')\n   192\t    expect(\n   193\t      screen.getByTestId('composition-manuscript-archive'),\n   194\t    ).toHaveTextContent('Draft segment 1 settles the harbor.')\n   195\t    expect(screen.getByText('Live chunks')).toBeInTheDocument()\n   196\t    expect(\n   197\t      screen.getByRole('button', { name: 'Return to plan' }),\n   198\t    ).toBeInTheDocument()\n   199\t\n   200\t    fireEvent.click(screen.getByRole('button', { name: 'Pause writing' }))\n   201\t    await waitFor(() => {\n   202\t      expect(onPauseComposition).toHaveBeenCalledWith('composition-job-1')\n   203\t    })\n   204\t\n   205\t    fireEvent.change(screen.getByLabelText('Rewrite guidance'), {\n   206\t      target: {\n   207\t        value: 'Soften the midpoint and bring Pip into the scene earlier.',\n   208\t      },\n   209\t    })\n   210\t    fireEvent.click(screen.getByRole('button', { name: 'Request rewrite' }))\n   211\t\n   212\t    await waitFor(() => {\n   213\t      expect(onRedirectComposition).toHaveBeenCalledWith({\n   214\t        instructions:\n   215\t          'Soften the midpoint and bring Pip into the scene earlier.',\n   216\t        rewriteFromSegmentIndex: 2,\n   217\t      })\n   218\t    })\n   219\t\n   220\t    fireEvent.click(screen.getByRole('button', { name: 'Return to plan' }))\n   221\t    await waitFor(() => {\n   222\t      expect(onReturnToPlan).toHaveBeenCalledTimes(1)\n   223\t    })\n   224\t\n   225\t    expect(onCancelComposition).not.toHaveBeenCalled()\n   226\t    expect(onResumeComposition).not.toHaveBeenCalled()\n   227\t    expect(onStartComposition).not.toHaveBeenCalled()\n   228\t  })\n   229\t\n   230\t  it('shows a ready-to-write state without an archive before the first segment exists', () => {\n   231\t    const idleSnapshot: SessionSnapshot = {\n   232\t      ...sampleSnapshot,\n   233\t      latest_composition_job: null,\n   234\t      active_composition_job: null,\n   235\t    }\n   236\t    const idleComposition: SessionCompositionStreamState = {\n   237\t      jobId: null,\n   238\t      status: null,\n   239\t      currentSegmentId: null,\n   240\t      currentSegmentIndex: null,\n   241\t      totalSegments: null,\n   242\t      storyText: '',\n   243\t      latestPartialOutput: '',\n   244\t      latestSegmentSummary: null,\n   245\t      lastChunkText: null,\n   246\t      source: 'none',\n   247\t      updatedAt: null,\n   248\t    }\n   249\t\n   250\t    renderWithAppProviders(\n   251\t      <CompositionStage\n   252\t        composition={idleComposition}\n   253\t        connectionState=\"idle\"\n   254\t        onCancelComposition={vi.fn().mockResolvedValue(undefined)}\n   255\t        onPauseComposition={vi.fn().mockResolvedValue(undefined)}\n   256\t        onRedirectComposition={vi.fn().mockResolvedValue(undefined)}\n   257\t        onResumeComposition={vi.fn().mockResolvedValue(undefined)}\n   258\t        onReturnToPlan={vi.fn().mockResolvedValue(undefined)}\n   259\t        onStartComposition={vi.fn().mockResolvedValue(undefined)}\n   260\t        snapshot={idleSnapshot}\n   261\t      />,\n   262\t    )\n   263\t\n   264\t    expect(screen.getByText('Ready to write')).toBeInTheDocument()\n   265\t    expect(\n   266\t      screen.getByRole('button', { name: 'Start writing' }),\n   267\t    ).toBeInTheDocument()\n   268\t    expect(\n   269\t      screen.queryByTestId('composition-manuscript-archive'),\n   270\t    ).not.toBeInTheDocument()\n  