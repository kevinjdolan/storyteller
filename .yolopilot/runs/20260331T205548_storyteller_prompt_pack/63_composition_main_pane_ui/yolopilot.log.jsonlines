elected?: boolean\n  title: ReactNode\n}\n\nexport function SelectionCard({\n  children,\n  className,\n  description,\n  eyebrow,\n  footer,\n  leading,\n  meta,\n  selected = false,\n  title,\n  ...props\n}: SelectionCardProps) {\n  return (\n    <article\n      className={cx(\n        'selection-card',\n        selected && 'selection-card--selected',\n        className,\n      )}\n      {...props}\n    >\n      <header className=\"selection-card__header\">\n        {leading != null ? (\n          <div className=\"selection-card__leading\">{leading}</div>\n        ) : null}\n        <div className=\"selection-card__copy\">\n          {eyebrow != null ? (\n            <p className=\"selection-card__eyebrow\">{eyebrow}</p>\n          ) : null}\n          <h3 className=\"selection-card__title\">{title}</h3>\n          {description != null ? (\n            <p className=\"selection-card__description\">{description}</p>\n          ) : null}\n        </div>\n        {meta != null ? (\n          <div className=\"selection-card__meta\">{meta}</div>\n        ) : null}\n      </header>\n      {children != null ? (\n        <div className=\"selection-card__body\">{children}</div>\n      ) : null}\n      {footer != null ? (\n        <footer className=\"selection-card__footer\">{footer}</footer>\n      ) : null}\n    </article>\n  )\n}\n\ntype EmptyStateBlockProps = Omit<ComponentPropsWithoutRef<'div'>, 'title'> & {\n  action?: ReactNode\n  description: ReactNode\n  title: ReactNode\n}\n\nexport function EmptyStateBlock({\n  action,\n  className,\n  description,\n  title,\n  ...props\n}: EmptyStateBlockProps) {\n  return (\n    <div className={cx('empty-state-block', className)} {...props}>\n      <strong className=\"empty-state-block__title\">{title}</strong>\n      <p className=\"empty-state-block__description\">{description}</p>\n      {action != null ? (\n        <div className=\"empty-state-block__action\">{action}</div>\n      ) : null}\n    </div>\n  )\n}\n\ntype InlineHelpTone = 'info' | 'warning' | 'success'\n\ntype InlineHelpProps = Omit<ComponentPropsWithoutRef<'aside'>, 'title'> & {\n  title?: ReactNode\n  tone?: InlineHelpTone\n}\n\nexport function InlineHelp({\n  children,\n  className,\n  title,\n  tone = 'info',\n  ...props\n}: InlineHelpProps) {\n  return (\n    <aside\n      className={cx('inline-help', `inline-help--${tone}`, className)}\n      {...props}\n    >\n      {title != null ? (\n        <strong className=\"inline-help__title\">{title}</strong>\n      ) : null}\n      {children != null ? (\n        <div className=\"inline-help__body\">{children}</div>\n      ) : null}\n    </aside>\n  )\n}\n\ntype SummaryPanelTone = 'default' | 'accent'\n\ntype SummaryPanelProps = Omit<ComponentPropsWithoutRef<'article'>, 'title'> & {\n  description?: ReactNode\n  label?: ReactNode\n  sticky?: boolean\n  title?: ReactNode\n  tone?: SummaryPanelTone\n}\n\nexport function SummaryPanel({\n  children,\n  className,\n  description,\n  label,\n  sticky = false,\n  title,\n  tone = 'default',\n  ...props\n}: SummaryPanelProps) {\n  return (\n    <article\n      className={cx(\n        'summary-panel',\n        `summary-panel--${tone}`,\n        sticky && 'summary-panel--sticky',\n        className,\n      )}\n      {...props}\n    >\n", "command": "/bin/zsh -lc \"rg -n \\\"export function SummaryPanel|export function CardGrid\\\" -n frontend/src/shared/ui/workflow.tsx && sed -n '260,460p' frontend/src/shared/ui/workflow.tsx\"", "exit_code": 0, "id": "item_41", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 79, "prompt_index": 64, "prompt_name": "63 \u2014 Composition Main-Pane UI", "prompt_total": 100}, "timestap": "2026-04-02T08:17:33-07:00"}
