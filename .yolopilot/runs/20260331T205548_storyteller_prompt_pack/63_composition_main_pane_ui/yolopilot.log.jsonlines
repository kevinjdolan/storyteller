\n    46\t\n    47\t  if (status === 'failed' || status === 'cancelled') {\n    48\t    return 'danger'\n    49\t  }\n    50\t\n    51\t  if (status === 'paused') {\n    52\t    return 'warning'\n    53\t  }\n    54\t\n    55\t  if (status === 'queued' || status === 'in_progress') {\n    56\t    return 'brand'\n    57\t  }\n    58\t\n    59\t  return 'neutral'\n    60\t}\n    61\t\n    62\tfunction buildConnectionCopy(\n    63\t  connectionState: SessionFeedConnectionState,\n    64\t  composition: SessionCompositionStreamState,\n    65\t) {\n    66\t  if (connectionState === 'open') {\n    67\t    return composition.source === 'live'\n    68\t      ? 'Live chunks are arriving from the session feed.'\n    69\t      : 'Live updates are connected. The manuscript is showing the latest saved checkpoint.'\n    70\t  }\n    71\t\n    72\t  if (connectionState === 'connecting' || connectionState === 'reconnecting') {\n    73\t    return 'Reconnecting the live writing feed. The saved checkpoint remains visible.'\n    74\t  }\n    75\t\n    76\t  if (connectionState === 'error' || connectionState === 'closed') {\n    77\t    return 'Live updates are unavailable. The saved checkpoint stays readable until the feed returns.'\n    78\t  }\n    79\t\n    80\t  return 'The stage is ready to stream as soon as writing begins.'\n    81\t}\n    82\t\n    83\tfunction buildProgressTitle(options: {\n    84\t  currentSegmentIndex: number | null\n    85\t  stageStatus: string\n    86\t  storyText: string\n    87\t  totalSegments: number | null\n    88\t}) {\n    89\t  if (options.stageStatus === 'completed') {\n    90\t    return 'Story draft complete'\n    91\t  }\n    92\t\n    93\t  if (\n    94\t    options.currentSegmentIndex != null &&\n    95\t    options.totalSegments != null &&\n    96\t    options.totalSegments > 0\n    97\t  ) {\n    98\t    return `Writing segment ${options.currentSegmentIndex} of ${options.totalSegments}`\n    99\t  }\n   100\t\n   101\t  if (options.storyText.trim().length > 0) {\n   102\t    return 'Draft checkpoint recovered'\n   103\t  }\n   104\t\n   105\t  return 'Ready to write'\n   106\t}\n   107\t\n   108\tfunction resolveCurrentOutlineCard(\n   109\t  snapshot: SessionSnapshot,\n   110\t  currentSegmentIndex: number | null,\n   111\t) {\n   112\t  if (currentSegmentIndex == null) {\n   113\t    return null\n   114\t  }\n   115\t\n   116\t  return (\n   117\t    snapshot.selected_story_outline?.cards.find(\n   118\t      (card) => card.position === currentSegmentIndex,\n   119\t    ) ?? null\n   120\t  )\n   121\t}\n   122\t\n   123\tfunction buildCurrentSegmentTitle(\n   124\t  currentSegmentIndex: number | null,\n   125\t  totalSegments: number | null,\n   126\t  outlineCard: StoryOutlineCard | null,\n   127\t) {\n   128\t  if (outlineCard?.title) {\n   129\t    return outlineCard.title\n   130\t  }\n   131\t\n   132\t  if (\n   133\t    currentSegmentIndex != null &&\n   134\t    totalSegments != null &&\n   135\t    totalSegments > 0\n   136\t  ) {\n   137\t    return `Segment ${currentSegmentIndex} of ${totalSegments}`\n   138\t  }\n   139\t\n   140\t  return 'Awaiting first segment'\n   141\t}\n   142\t\n   143\tfunction buildCurrentSegmentDescription(options: {\n   144\t  currentSegmentIndex: number | null\n   145\t  outlineCard: StoryOutlineCard | null\n   146\t  totalSegments: number | null\n   147\t}) {\n   148\t  if (options.outlineCard?.summary) {\n   149\t    return options.outlineCard.summary\n   150\t  }\n   151\t\n   152\t  if (options.outlineCard?.purpose) {\n   153\t    return options.outlineCard.purpose\n   154\t  }\n   155\t\n   156\t  if (\n   157\t    options.currentSegmentIndex != null &&\n   158\t    options.totalSegments != null &&\n   159\t    options.totalSegments > 0\n   160\t  ) {\n   161\t    return `The manuscript is currently drafting segment ${options.currentSegmentIndex} of ${options.totalSegments}.`\n   162\t  }\n   163\t\n   164\t  return 'The first accepted outline card becomes the initial draft target once writing starts.'\n   165\t}\n   166\t\n   167\tfunction buildCurrentSegmentLabel(\n   168\t  currentSegmentIndex: number | null,\n   169\t  totalSegments: number | null,\n   170\t) {\n   171\t  if (\n   172\t    currentSegmentIndex != null &&\n   173\t    totalSegments != null &&\n   174\t    totalSegments > 0\n   175\t  ) {\n   176\t    return `Segment ${currentSegmentIndex} of ${totalSegments}`\n   177\t  }\n   178\t\n   179\t  return 'Awaiting first segment'\n   180\t}\n   181\t\n   182\tfunction buildBeatLabelCopy(outlineCard: StoryOutlineCard | null) {\n   183\t  if (outlineCard == null || outlineCard.beat_labels.length === 0) {\n   184\t    return null\n   185\t  }\n   186\t\n   187\t  return outlineCard.beat_labels.slice(0, 3)\n   188\t}\n   189\t\n   190\tfunction buildEarlierAcceptedText(\n   191\t  storyText: string,\n   192\t  recentSegmentText: string,\n   193\t) {\n   194\t  const normalizedStoryText = storyText.trimEnd()\n   195\t  const normalizedRecentSegmentText = recentSegmentText.trim()\n   196\t\n   197\t  if (\n   198\t    normalizedStoryText.length === 0 ||\n   199\t    normalizedRecentSegmentText.length === 0 ||\n   200\t    normalizedStoryText === normalizedRecentSegmentText ||\n   201\t    !normalizedStoryText.endsWith(normalizedRecentSegmentText)\n   202\t  ) {\n   203\t    return null\n   204\t  }\n   205\t\n   206\t  const prefix = normalizedStoryText\n   207\t    .slice(0, normalizedStoryText.length - normalizedRecentSegmentText.length)\n   208\t    .trimEnd()\n   209\t\n   210\t  return prefix.length > 0 ? prefix : null\n   211\t}\n   212\t\n   213\texport function CompositionStage({\n   214\t  composition,\n   215\t  connectionState,\n   216\t  onCancelComposition,\n   217\t  onPauseComposition,\n   218\t  onRedirectComposition,\n   219\t  onResumeComposition,\n   220\t  onReturnToPlan,\n   221\t  onStartComposition,\n   222\t  snapshot,\n   223\t}: CompositionStageProps) {\n   224\t  const [redirectInstructions, setRedirectInstructions] = useState('')\n   225\t  const [actionError, setActionError] = useState<string | null>(null)\n   226\t  const [activeAction, setActiveAction] = useState<\n   227\t    'cancel' | 'pause' | 'redirect' | 'resume' | 'returnToPlan' | 'start' | null\n   228\t  >(null)\n   229\t\n   230\t  const activeJob = snapshot.active_composition_job\n   231\t  const latestJob = snapshot.latest_composition_job ?? null\n   232\t  const compositionJob = activeJob ?? latestJob\n   233\t  const storyText =\n   234\t    composition.storyText ||\n   235\t    compositionJob?.accepted_story_so_far ||\n   236\t    compositionJob?.latest_partial_output ||\n   237\t    ''\n   238\t  const latestSegmentSummary =\n   239\t    composition.latestSegmentSummary ??\n   240\t    compositionJob?.latest_segment_summary ??\n   241\t    null\n   242\t  const latestPartialOutput =\n   243\t    composition.latestPartialOutput ||\n   244\t    compositionJob?.latest_partial_output ||\n   245\t    ''\n   246\t  const recentSegmentText = latestPartialOutput || storyText\n   247\t  const earlierAcceptedText = buildEarlierAcceptedText(\n   248\t    storyText,\n   249\t    recentSegmentText,\n   250\t  )\n   251\t  const progressPercent = compositionJob?.progress_percent ?? 0\n   252\t  const currentSegmentIndex =\n   253\t    composition.currentSegmentIndex ??\n   254\t    compositionJob?.current_segment_index ??\n   255\t    null\n   256\t  const totalSegments =\n   257\t    composition.totalSegments ?? compositionJob?.total_segments ?? null\n   258\t  const stageStatus = compositionJob?.status ?? 'draft'\n   259\t  const currentOutlineCard = resolveCurrentOutlineCard(\n   260\t    snapshot,\n", "command": "/bin/zsh -lc \"nl -ba frontend/src/features/session/CompositionStage.tsx | sed -n '1,260p'\"", "exit_code": 0, "id": "item_123", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 223, "prompt_index": 64,