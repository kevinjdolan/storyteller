r,\n  meta,\n  selected = false,\n  title,\n  ...props\n}: SplitCardProps) {\n  return (\n    <article\n      className={cx(\n        'split-card',\n        selected && 'split-card--selected',\n        className,\n      )}\n      {...props}\n    >\n      <div className=\"split-card__main\">\n        <header className=\"split-card__header\">\n          <div>\n            {eyebrow != null ? (\n              <p className=\"split-card__eyebrow\">{eyebrow}</p>\n            ) : null}\n            <h3 className=\"split-card__title\">{title}</h3>\n            {description != null ? (\n              <p className=\"split-card__description\">{description}</p>\n            ) : null}\n          </div>\n          {meta != null ? <div className=\"split-card__meta\">{meta}</div> : null}\n        </header>\n        {children != null ? (\n          <div className=\"split-card__body\">{children}</div>\n        ) : null}\n        {footer != null ? (\n", "command": "/bin/zsh -lc \"rg -n \\\"function InlineHelp|export function InlineHelp\\\" -n frontend/src/shared/ui/workflow.tsx && sed -n '420,520p' frontend/src/shared/ui/workflow.tsx\"", "exit_code": 0, "id": "item_108", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 219, "prompt_index": 52, "prompt_name": "51 \u2014 Correlation Heuristics for Word Count, Runtime, and Chapters", "prompt_total": 100}, "timestap": "2026-04-02T02:08:56-07:00"}
