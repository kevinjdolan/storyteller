<p className=\"field__description\" id={descriptionId}>\n          {description}\n        </p>\n      ) : null}\n      <input\n        aria-describedby={describedBy || undefined}\n        aria-invalid={error != null || undefined}\n        className={cx('text-input', inputClassName)}\n        id={inputId}\n        {...props}\n      />\n      {error != null ? (\n        <p className=\"field__error\" id={errorId} role=\"alert\">\n          {error}\n        </p>\n      ) : null}\n    </div>\n  )\n}\n\ntype TextAreaProps = Omit<\n  TextareaHTMLAttributes<HTMLTextAreaElement>,\n  'rows'\n> & {\n  className?: string\n  description?: ReactNode\n  error?: ReactNode\n  hideLabel?: boolean\n  label: ReactNode\n  rows?: number\n}\n\nexport function TextArea({\n  'aria-describedby': ariaDescribedBy,\n", "command": "/bin/zsh -lc \"rg -n \\\"export function TextInput\\\" -n frontend/src/shared/ui/primitives.tsx && sed -n '240,340p' frontend/src/shared/ui/primitives.tsx\"", "exit_code": 0, "id": "item_101", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 208, "prompt_index": 52, "prompt_name": "51 \u2014 Correlation Heuristics for Word Count, Runtime, and Chapters", "prompt_total": 100}, "timestap": "2026-04-02T02:07:22-07:00"}
