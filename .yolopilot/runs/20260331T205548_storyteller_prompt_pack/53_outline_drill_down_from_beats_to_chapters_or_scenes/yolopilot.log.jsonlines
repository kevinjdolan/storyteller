{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Started", "message": "in progress: /bin/zsh -lc \"python - <<'PY'\nimport json, urllib.request\nfrom urllib.request import Request\nsession_id='8155bbd7-2de7-4d4c-a961-d35485225ed0'\nurl=f'http://127.0.0.1:8565/api/v1/sessions/{session_id}/story-setup'\npayload=json.dumps({\n    'target_word_count':1800,\n    'target_runtime_minutes':14,\n    'chapter_count':4,\n    'approximate_scene_count':10,\n    'guidance_notes':'Keep each chapter ending calmer than it began.',\n    'origin':'workspace',\n}).encode()\nreq=Request(url, data=payload, headers={'Content-Type':'application/json'}, method='POST')\nwith urllib.request.urlopen(req) as r:\n    data=json.load(r)\nsnap=data['snapshot']\noutline=snap.get('selected_story_outline')\nprint('outline exists:', outline is not None)\nif outline:\n    print('outline id:', outline['id'])\n    print('revision:', outline['revision_number'])\n    print('kind:', outline['outline_kind'])\n    print('summary:', outline['summary'])\n    print('cards:', len(outline['cards']))\n    for card in outline['cards'][:3]:\n        print(card['card_key'], '|', card['title'])\nprint('event summary:', data['event']['summary'])\nPY\"", "raw_event": {"item": {"aggregated_output": "", "command": "/bin/zsh -lc \"python - <<'PY'\nimport json, urllib.request\nfrom urllib.request import Request\nsession_id='8155bbd7-2de7-4d4c-a961-d35485225ed0'\nurl=f'http://127.0.0.1:8565/api/v1/sessions/{session_id}/story-setup'\npayload=json.dumps({\n    'target_word_count':1800,\n    'target_runtime_minutes':14,\n    'chapter_count':4,\n    'approximate_scene_count':10,\n    'guidance_notes':'Keep each chapter ending calmer than it began.',\n    'origin':'workspace',\n}).encode()\nreq=Request(url, data=payload, headers={'Content-Type':'application/json'}, method='POST')\nwith urllib.request.urlopen(req) as r:\n    data=json.load(r)\nsnap=data['snapshot']\noutline=snap.get('selected_story_outline')\nprint(