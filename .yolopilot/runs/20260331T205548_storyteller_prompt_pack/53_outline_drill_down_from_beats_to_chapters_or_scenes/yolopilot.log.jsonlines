{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Started", "message": "in progress: /bin/zsh -lc \"docker compose -f infra/compose/docker-compose.yml exec -T browser node --input-type=module - <<'EOF'\nimport fs from 'node:fs/promises';\nimport puppeteer from 'puppeteer';\n\nconst sessionId = '8155bbd7-2de7-4d4c-a961-d35485225ed0';\nconst route = \"'`http://frontend:8566/sessions/${sessionId}?stage=story_setup`;\nconst desktopOutline = '\"'/workspace/.artifacts/webapp-qa/prompt-53-outline-desktop-viewport.png';\nconst desktopEditor = '/workspace/.artifacts/webapp-qa/prompt-53-outline-editor-desktop-viewport.png';\nconst mobileOutline = '/workspace/.artifacts/webapp-qa/prompt-53-outline-mobile-viewport.png';\n\nawait fs.mkdir('/workspace/.artifacts/webapp-qa', { recursive: true });\n\nconst browser = await puppeteer.launch({\n  executablePath: process.env.PUPPETEER_EXECUTABLE_PATH,\n  headless: true,\n  args: ['--no-sandbox', '--disable-setuid-sandbox'],\n});\n\nasync function scrollToHeading(page, headingText) {\n  await page.waitForFunction(\n    (expected) => Array.from(document.querySelectorAll('h3')).some((node) => node.textContent?.includes(expected)),\n    {},\n    headingText,\n  );\n  await page.evaluate((expected) => {\n    const node = Array.from(document.querySelectorAll('h3')).find((item) => item.textContent?.includes(expected));\n    node?.scrollIntoView({ block: 'start', behavior: 'instant' });\n  }, headingText);\n  await new Promise((resolve) => setTimeout(resolve, 500));\n}\n\ntry {\n  const page = await browser.newPage();\n  await page.setViewport({ width: 1440, height: 960 });\n  page.setDefaultTimeout(30000);\n  await page.goto(route, { waitUntil: 'networkidle2' });\n  await scrollToHeading(page, 'Draftable outline');\n  await page.screenshot({ path: desktopOutline, fullPage: false });\n  await scrollToHeading(page, 'Outline editor');\n  await page.screenshot({ path: desktopEditor, fullPage: false });\n\n  const mobile = await br