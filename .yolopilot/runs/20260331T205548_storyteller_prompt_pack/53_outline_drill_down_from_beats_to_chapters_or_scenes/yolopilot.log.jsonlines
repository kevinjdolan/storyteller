position_job or aggregate.latest_composition_job\n\n\ndef _resolve_audio_resume_job(aggregate: SessionAggregate):\n    return aggregate.active_audio_job or aggregate.latest_audio_job\n\n\ndef _find_stage_state(aggregate: SessionAggregate, stage):\n    for item in aggregate.session.workflow_stage_states:\n        if item.stage == stage:\n            return item\n\n    return _FallbackStageState()\n\n\ndef _build_latest_detail_summary(aggregate: SessionAggregate) -> str | None:\n", "command": "/bin/zsh -lc \"sed -n '360,420p' backend/app/services/conversation_memory.py\"", "exit_code": 0, "id": "item_97", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "task_display_context": {"event_number": 196, "prompt_index": 54, "prompt_name": "53 \u2014 Outline Drill-Down From Beats to Chapters or Scenes", "prompt_total": 100}, "timestap": "2026-04-02T02:44:01-07:00"}
