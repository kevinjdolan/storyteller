{"type":"item.completed","item":{"id":"item_19","type":"command_execution","command":"/bin/zsh -lc \"sed -n '260,760p' frontend/src/styles/index.css\"","aggregated_output":".panel__actions {\n  display: inline-flex;\n  align-items: start;\n  justify-content: end;\n  gap: var(--space-3);\n  flex-shrink: 0;\n}\n\n.panel-heading {\n  display: grid;\n  gap: var(--space-2);\n  margin-bottom: var(--space-6);\n}\n\n.panel-heading h2 {\n  margin: 0;\n  font-size: 1.6rem;\n  color: var(--color-ink-strong);\n}\n\n.button {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  gap: var(--space-2);\n  min-height: 2.85rem;\n  padding: 0.72rem 1.08rem;\n  border: 1px solid transparent;\n  border-radius: var(--radius-pill);\n  font-weight: 700;\n  text-decoration: none;\n  transition:\n    transform 160ms ease,\n    box-shadow 160ms ease,\n    background-color 160ms ease,\n    color 160ms ease,\n    border-color 160ms ease;\n}\n\n.button:hover {\n  transform: translateY(-1px);\n}\n\n.button:disabled {\n  opacity: 0.72;\n  transform: none;\n  cursor: wait;\n}\n\n.button--primary {\n  color: #fbf7f1;\n  background: var(--color-brand);\n  box-shadow: var(--shadow-button);\n}\n\n.button--secondary {\n  color: var(--color-brand);\n  background: rgba(39, 69, 99, 0.08);\n  border-color: rgba(39, 69, 99, 0.12);\n}\n\n.button--ghost {\n  color: var(--color-brand);\n  background: rgba(255, 255, 255, 0.74);\n  border-color: var(--color-border-soft);\n}\n\n.button--compact {\n  min-height: 2.45rem;\n  padding-inline: 0.95rem;\n  font-size: 0.95rem;\n}\n\n.button--regular {\n  min-height: 2.85rem;\n}\n\n.button--full-width {\n  width: 100%;\n}\n\n.badge {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-height: 2rem;\n  padding: 0.4rem 0.78rem;\n  border-radius: var(--radius-pill);\n  font-size: 0.84rem;\n  font-weight: 700;\n  white-space: nowrap;\n}\n\n.badge--neutral {\n  color: var(--color-ink-soft);\n  background: rgba(35, 49, 64, 0.08);\n}\n\n.badge--brand {\n  color: var(--color-brand);\n  background: var(--color-brand-soft);\n}\n\n.badge--accent {\n  color: var(--color-rose);\n  background: var(--color-rose-soft);\n}\n\n.badge--success {\n  color: var(--color-moss);\n  background: var(--color-moss-soft);\n}\n\n.badge--warning {\n  color: var(--color-attention);\n  background: var(--color-attention-soft);\n}\n\n.badge--danger {\n  color: var(--color-rose);\n  background: rgba(160, 97, 85, 0.18);\n}\n\n.progress {\n  display: grid;\n  gap: var(--space-3);\n}\n\n.progress__meta {\n  display: flex;\n  align-items: baseline;\n  justify-content: space-between;\n  gap: var(--space-3);\n}\n\n.progress__label,\n.progress__value {\n  font-weight: 700;\n}\n\n.progress__label {\n  color: var(--color-ink-strong);\n}\n\n.progress__value,\n.progress__hint {\n  color: var(--color-ink-soft);\n}\n\n.progress__hint {\n  margin: 0;\n}\n\n.progress__track {\n  overflow: hidden;\n  height: 0.72rem;\n  border-radius: var(--radius-pill);\n  background: rgba(39, 69, 99, 0.09);\n}\n\n.progress__fill {\n  display: block;\n  height: 100%;\n  border-radius: inherit;\n  background: linear-gradient(90deg, var(--color-gold), var(--color-brand));\n}\n\n.progress--moss .progress__fill {\n  background: linear-gradient(90deg, var(--color-moss), var(--color-brand));\n}\n\n.progress--accent .progress__fill {\n  background: linear-gradient(90deg, var(--color-rose), var(--color-gold));\n}\n\n.stacked-list,\n.session-card-list,\n.workspace-stage-grid,\n.workspace-chat-list {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n}\n\n.stacked-list {\n  display: grid;\n  gap: var(--space-3);\n}\n\n.stacked-list__item {\n  padding: var(--space-4);\n  border: 1px solid rgba(39, 69, 99, 0.08);\n  border-radius: var(--radius-lg);\n  background: var(--color-surface-muted);\n  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.35);\n}\n\n.stacked-list__item--brand {\n  box-shadow:\n    inset 3px 0 0 var(--color-brand-soft),\n    inset 0 1px 0 rgba(255, 255, 255, 0.35);\n}\n\n.stacked-list__item--accent {\n  box-shadow:\n    inset 3px 0 0 var(--color-attention-soft),\n    inset 0 1px 0 rgba(255, 255, 255, 0.35);\n}\n\n.stacked-list__item--success {\n  box-shadow:\n    inset 3px 0 0 var(--color-moss-soft),\n    inset 0 1px 0 rgba(255, 255, 255, 0.35);\n}\n\n.field {\n  display: grid;\n  gap: var(--space-2);\n}\n\n.field__label {\n  color: var(--color-ink-strong);\n  font-weight: 700;\n}\n\n.field__description,\n.field__error {\n  margin: 0;\n  font-size: 0.94rem;\n}\n\n.field__description {\n  color: var(--color-ink-soft);\n}\n\n.field__error {\n  color: var(--color-rose);\n}\n\n.text-input {\n  min-height: 3rem;\n  padding: 0.8rem 0.95rem;\n  border: 1px solid var(--color-border-soft);\n  border-radius: var(--radius-md);\n  color: var(--color-ink-strong);\n  background: rgba(255, 255, 255, 0.82);\n  transition:\n    border-color 160ms ease,\n    box-shadow 160ms ease,\n    background-color 160ms ease;\n}\n\n.text-input::placeholder {\n  color: var(--color-ink-muted);\n}\n\n.text-input:hover {\n  border-color: var(--color-border-strong);\n}\n\n.field--error .text-input {\n  border-color: rgba(160, 97, 85, 0.35);\n}\n\n.app-shell {\n  position: relative;\n  min-height: 100vh;\n  overflow: hidden;\n  padding: 2rem 1.5rem 3.5rem;\n}\n\n.app-frame {\n  position: relative;\n  z-index: 1;\n  width: min(1180px, 100%);\n  margin: 0 auto;\n}\n\n.app-shell__glow {\n  position: absolute;\n  width: 24rem;\n  height: 24rem;\n  border-radius: 999px;\n  filter: blur(38px);\n  opacity: 0.45;\n  pointer-events: none;\n}\n\n.app-shell__glow--left {\n  top: -6rem;\n  left: -5rem;\n  background: var(--color-page-glow-left);\n}\n\n.app-shell__glow--right {\n  right: -7rem;\n  bottom: -8rem;\n  background: var(--color-page-glow-right);\n}\n\n.app-header {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) auto minmax(16rem, 22rem);\n  align-items: end;\n  gap: var(--space-5);\n  margin-bottom: var(--space-5);\n}\n\n.app-header__brand-block {\n  min-width: 0;\n}\n\n.app-brand {\n  display: block;\n  margin-top: 0.35rem;\n  font-size: clamp(2rem, 3vw, 2.8rem);\n  color: var(--color-brand);\n}\n\n.app-brand-link {\n  color: inherit;\n  text-decoration: none;\n}\n\n.app-nav {\n  display: inline-flex;\n  align-items: center;\n  justify-self: center;\n  gap: var(--space-2);\n  padding: var(--space-2);\n  border: 1px solid var(--color-border-soft);\n  border-radius: var(--radius-pill);\n  background: rgba(255, 252, 247, 0.74);\n  box-shadow: var(--shadow-surface-md);\n  backdrop-filter: blur(14px);\n}\n\n.app-nav__link {\n  padding: 0.7rem 1rem;\n  border-radius: var(--radius-pill);\n  color: var(--color-ink-soft);\n  text-decoration: none;\n  font-weight: 700;\n  transition:\n    background-color 160ms ease,\n    color 160ms ease,\n    transform 160ms ease;\n}\n\n.app-nav__link:hover {\n  color: var(--color-brand);\n  transform: translateY(-1px);\n}\n\n.app-nav__link--muted {\n  opacity: 0.72;\n}\n\n.app-nav__link--active {\n  color: var(--color-brand);\n  background: rgba(39, 69, 99, 0.1);\n}\n\n.app-caption {\n  margin: 0;\n  max-width: 24rem;\n  justify-self: end;\n  text-align: right;\n  color: var(--color-ink-soft);\n}\n\n.app-main {\n  display: grid;\n  gap: var(--space-5);\n}\n\n.app-utility-bar {\n  display: grid;\n  grid-template-columns: 1.05fr 0.95fr;\n  gap: var(--space-5);\n  margin-bottom: var(--space-5);\n}\n\n.connection-indicator,\n.toast-region {\n  min-height: 100%;\n}\n\n.connection-indicator__message {\n  margin-top: var(--space-3);\n  font-weight: 700;\n  color: var(--color-brand);\n}\n\n.toast-region__list strong,\n.workspace-chat-footer strong,\n.workspace-stage-card__header strong,\n.session-summary-card strong,\n.session-card__meta dd,\n.workspace-summary-card strong {\n  color: var(--color-ink-strong);\n}\n\n.toast-region__item strong {\n  display: block;\n  margin-bottom: var(--space-1);\n}\n\n.sessions-home,\n.workspace-page {\n  display: grid;\n  gap: var(--space-5);\n}\n\n.sessions-home__hero {\n  display: grid;\n  gap: var(--space-6);\n}\n\n.sessions-home__hero .panel__title {\n  margin-top: 0.2rem;\n  font-size: clamp(2.9rem, 6vw, 4.5rem);\n}\n\n.lede {\n  margin: 0;\n  max-width: 20ch;\n  font-size: clamp(1.1rem, 2.4vw, 1.45rem);\n  color: var(--color-brand);\n}\n\n.session-summary-grid {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: var(--space-3);\n}\n\n.session-summary-card,\n.session-group,\n.session-card,\n.session-card__meta div,\n.workspace-topbar__status-card,\n.workspace-summary-card,\n.workspace-chat-footer,\n.workspace-stage-card {\n  border: 1px solid rgba(39, 69, 99, 0.08);\n  background: var(--color-surface-muted);\n}\n\n.session-summary-card {\n  padding: var(--space-4) var(--space-5);\n  border-radius: var(--radius-lg);\n}\n\n.session-summary-card strong {\n  display: block;\n  margin-bottom: 0.3rem;\n  font-size: 1.85rem;\n  color: var(--color-brand);\n}\n\n.sessions-panel {\n  display: grid;\n  gap: var(--space-5);\n}\n\n.session-group {\n  padding: var(--space-5);\n  border-radius: var(--radius-xl);\n}\n\n.session-group__header,\n.session-card__header,\n.session-card__title-row,\n.pane-heading {\n  display: flex;\n  align-items: start;\n  justify-content: space-between;\n  gap: var(--space-3);\n}\n\n.session-group__header {\n  margin-bottom: var(--space-4);\n}\n\n.session-group__header h3,\n.session-card h4 {\n  margin: 0;\n  color: var(--color-ink-strong);\n}\n\n.session-card-list {\n  display: grid;\n  gap: var(--space-3);\n}\n\n.session-card {\n  padding: var(--space-5);\n  border-radius: var(--radius-xl);\n}\n\n","exit_code":0,"status":"completed"}}
