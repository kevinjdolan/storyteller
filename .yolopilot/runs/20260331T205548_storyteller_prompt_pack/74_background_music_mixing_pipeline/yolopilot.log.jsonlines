{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Started", "message": "in progress: /bin/zsh -lc \"docker compose -f infra/compose/docker-compose.yml exec -T backend python - <<'PY'\nimport tempfile, subprocess\nfrom pathlib import Path\nfrom app.models.audio_settings import AudioMusicProfile, AudioSettingsView\nfrom app.services.audio_jobs import build_wav_bytes\nfrom app.services.audio_music import build_audio_mix_plan, get_background_music_track\npcm = (b'\\\\x08\\\\x00' * 24000) + (b'\\\\x04\\\\x00' * 24000)\nwav_bytes = build_wav_bytes(pcm, sample_rate_hz=24000, channel_count=1, sample_width_bytes=2)\ntrack = get_background_music_track(AudioMusicProfile.LULLABY_PIANO)\nplan = build_audio_mix_plan(AudioSettingsView(include_background_music=True, music_profile=AudioMusicProfile.LULLABY_PIANO, narration_volume=92, music_volume=24))\nwith tempfile.TemporaryDirectory() as temp_dir:\n    temp = Path(temp_dir)\n    narration = temp / 'narration.wav'\n    mixed = temp / 'mixed.wav'\n    narration.write_bytes(wav_bytes)\n    filter_complex = \\\"[0:a]aresample=24000,aformat=sample_fmts=s16:channel_layouts=mono,atrim=0:2.000,volume=-23.4dB,afade=t=out:st=0.000:d=6[music];[1:a]aresample=24000,aformat=sample_fmts=s16:channel_layouts=mono,volume=-0.7dB[voice];[music][voice]sidechaincompress=threshold=0.045:ratio=10.0:attack=35:release=360[ducked];[voice][ducked]amix=inputs=2:duration=first:dropout_transition=0[out]\\\"\n    cmd = ['ffmpeg','-hide_banner','-loglevel','error','-y','-stream_loop','-1','-i',str(track.asset_path),'-i',str(narration),'-filter_complex',filter_complex,'-map','[out]','-c:a','pcm_s16le',str(mixed)]\n    completed = subprocess.run(cmd, capture_output=True, timeout=15)\n    print({'returncode': completed.returncode, 'stderr': completed.stderr.decode('utf-8', 'replace'), 'stdout': completed.stdout.decode('utf-8', 'replace'), 'exists': mixed.exists(), 'size': mixed.stat().st_size if mixed.exists() else None})\nPY\"", "raw_event": {"item"