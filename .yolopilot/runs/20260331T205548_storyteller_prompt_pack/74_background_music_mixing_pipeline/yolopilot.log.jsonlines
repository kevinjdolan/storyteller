{"color": "cyan", "emoji": "\ud83d\udee0", "event_type": "Command Started", "message": "in progress: /bin/zsh -lc \"docker compose -f infra/compose/docker-compose.yml exec -T backend python - <<'PY'\nimport tempfile, subprocess, wave\nfrom pathlib import Path\nfrom app.models.audio_settings import AudioMusicProfile\nfrom app.services.audio_jobs import build_wav_bytes\nfrom app.services.audio_music import get_background_music_track\npcm = (b'\\\\x08\\\\x00' * 24000) + (b'\\\\x04\\\\x00' * 24000)\nwav_bytes = build_wav_bytes(pcm, sample_rate_hz=24000, channel_count=1, sample_width_bytes=2)\ntrack = get_background_music_track(AudioMusicProfile.LULLABY_PIANO)\nvariants = {\n 'acompressor': '[0:a]aresample=24000,aformat=sample_fmts=s16:channel_layouts=mono,atrim=0:2.000,volume=-23.4dB[music];[1:a]aresample=24000,aformat=sample_fmts=s16:channel_layouts=mono,volume=-0.7dB[voice];[voice][music]amix=inputs=2:duration=first:dropout_transition=0,acompressor=threshold=0.08:ratio=2.5:attack=20:release=200,atrim=0:2.000[out]',\n 'sidechain_gate': '[0:a]aresample=24000,aformat=sample_fmts=s16:channel_layouts=mono,atrim=0:2.000,volume=-23.4dB[music];[1:a]aresample=24000,aformat=sample_fmts=s16:channel_layouts=mono,volume=-0.7dB,asplit=2[voice_mix][voice_sc];[music][voice_sc]sidechaingate=threshold=0.045:range=0.2:attack=35:release=360[ducked];[voice_mix][ducked]amix=inputs=2:duration=longest:dropout_transition=0,atrim=0:2.000[out]'\n}\nwith tempfile.TemporaryDirectory() as temp_dir:\n    temp = Path(temp_dir)\n    narration = temp / 'narration.wav'\n    narration.write_bytes(wav_bytes)\n    for name, filter_complex in variants.items():\n        mixed = temp / f'{name}.wav'\n        cmd = ['ffmpeg','-hide_banner','-loglevel','error','-y','-stream_loop','-1','-i',str(track.asset_path),'-i',str(narration),'-filter_complex',filter_complex,'-map','[out]','-c:a','pcm_s16le',str(mixed)]\n        completed = subprocess.run(cmd, capture_output=True, timeout=15)\n        if completed.returncode \"'!= 0:\n            print(name, {'\"'returncode': completed.returncode, 'stderr': completed.stderr.decode('utf-8','replace')})\n            continue\n        with wave.open(str(mixed), 'rb') as wav_file:\n            duration = wav_file.getnframes() / wav_file.getframerate()\n        print(name, {'size': mixed.stat().st_size, 'duration': round(duration, 3)})\nPY\"", "raw_event": {"item": {"aggregated_output": "", "command": "/bin/zsh -lc \"docker compose -f infra/compose/docker-compose.yml exec -T backend python - <<'PY'\nimport tempfile, subprocess, wave\nfrom pathlib import Path\nfrom app.models.audio_settings import AudioMusicProfile\nfrom app.services.audio_jobs import build_wav_bytes\nfrom app.services.audio_music import get_background_music_track\npcm = (b'\\\\x08\\\\x00' * 24000) + (b'\\\\x04\\\\x00' * 24000)\nwav_bytes = build_wav_bytes(pcm, sample_rate_hz=24000, channel_count=1, sample_width_bytes=2)\ntrack = get_background_music_track(AudioMusicProfile.LULLABY_PIANO)\nvariants = {\n 'acompressor': '[0:a]aresample=24000,aformat=sample_fmts=s16:channel_layouts=mono,atrim=0:2.000,volume=-23.4dB[music];[1:a]aresample=24000,aformat=sample_fmts=s16:channel_layouts=mono,volume=-0.7dB[voice];[voice][music]amix=inputs=2:duration=first:dropout_transition=0,acompressor=threshold=0.08:ratio=2.5:attack=20:release=200,atrim=0:2.000[out]',\n 'sidechain_gate': '[0:a]aresample=24000,aformat=sample_fmts=s16:channel_layouts=mono,atrim=0:2.000,volume=-23.4dB[music];[1:a]aresample=24000,aformat=sample_fmts=s16:channel_layouts=mono,volume=-0.7dB,asplit=2[voice_mix][voice_sc];[music][voice_sc]sidechaingate=threshold=0.045:range=0.2:attack=35:release=360[ducked];[voice_mix][ducked]amix=inputs=2:duration=longest:dropout_transition=0,atrim=0:2.000[out]'\n}\nwith tempfile.TemporaryDirectory() as temp_dir:\n    temp = Path(temp_dir)\n    narration = temp / 'narration.wav'\n    narration.write_bytes(wav_bytes)\n    for name, filter_complex in variants.items():\n        mixed = t