{"type":"item.started","item":{"id":"item_168","type":"command_execution","command":"/bin/zsh -lc \"STORYTELLER_SECRETS_FILE='' STORYTELLER_GEMINI_API_KEY='test-gemini-key' STORYTELLER_GCS_ENDPOINT='http://localhost:8568' STORYTELLER_GCS_PROJECT_ID='storyteller-local' STORYTELLER_GCS_PUBLIC_URL='http://localhost:8568' STORYTELLER_GCS_SESSIONS_BUCKET_NAME='storyteller-sessions' STORYTELLER_GCS_AUDIO_BUCKET_NAME='storyteller-audio' STORYTELLER_GCS_EXPORTS_BUCKET_NAME='storyteller-exports' STORYTELLER_DATABASE_URL='sqlite+pysqlite:////Users/kevin/code/storyteller/.artifacts/webapp-qa/prompt77.db' python - <<'PY'\nfrom pathlib import Path\nfrom sqlalchemy.orm import sessionmaker\n\nfrom app.db import AssetKind, AssetStatus, AudioJob, Base, JobStatus, StorySession, make_engine\nfrom app.db.base import utc_now\nfrom app.db.models import SessionAsset\nfrom app.models import WorkflowStage, WorkflowStageState\nfrom app.services.sessions import SessionService\n\nDB_URL = 'sqlite+pysqlite:////Users/kevin/code/storyteller/.artifacts/webapp-qa/prompt77.db'\nPath('/Users/kevin/code/storyteller/.artifacts/webapp-qa').mkdir(parents=True, exist_ok=True)\nengine = make_engine(DB_URL)\nBase.metadata.drop_all(engine)\nBase.metadata.create_all(engine)\nSessionLocal = sessionmaker(bind=engine, autoflush=False, expire_on_commit=False)\n\nwith SessionLocal() as session:\n    service = SessionService(session)\n    snapshot = service.create_session(working_title='QA Final Audio Assembly')\n    for stage in (\n        WorkflowStage.GENRE,\n        WorkflowStage.TONE,\n        WorkflowStage.BRIEF,\n        WorkflowStage.PITCHES,\n        WorkflowStage.CHARACTERS,\n        WorkflowStage.BEATS,\n        WorkflowStage.STORY_SETUP,\n        WorkflowStage.COMPOSITION,\n    ):\n        service.update_stage_state(\n            snapshot.id,\n            stage=stage,\n            status=WorkflowStageState.COMPLETED,\n            detail=f'Completed {stage.value}.',\n        )\n    service.update_stage_state(\n        snapshot.id,\n        stage=WorkflowStage.AUDIO,\n        status=WorkflowStageState.IN_PROGRESS,\n        detail='Rendering replacement narration while the prior master stays available.',\n    )\n    service.update_stage_state(\n        snapshot.id,\n        stage=WorkflowStage.FINALIZE,\n        status=WorkflowStageState.NEEDS_REGENERATION,\n        detail='Waiting for the replacement narration master.',\n    )\n\n    story_session = session.get(StorySession, snapshot.id)\n    assert story_session is not None\n    story_session.audio_voice_key = 'hearthside'\n    story_session.audio_narration_style = 'warm'\n    story_session.audio_playback_speed = 0.9\n    story_session.audio_include_background_music = False\n    story_session.audio_music_profile = 'lullaby_piano'\n    story_session.audio_narration_volume = 88\n    story_session.audio_music_volume = 18\n\n    prior_job = AudioJob(\n        session_id=snapshot.id,\n        status=JobStatus.COMPLETED,\n        voice_key='moonbeam',\n        playback_speed=0.95,\n        include_background_music=False,\n        music_profile='lullaby_piano',\n        completed_at=utc_now(),\n        config_json={\n            'progress_percent': 100.0,\n            'current_step': 'Narration finished and the final audio asset is ready.',\n            'latest_asset_kind': AssetKind.FINAL_AUDIO.value,\n        },\n    )\n    active_job = AudioJob(\n        session_id=snapshot.id,\n        status=JobStatus.IN_PROGRESS,\n        voice_key='hearthside',\n        playback_speed=0.9,\n        include_background_music=False,\n        music_profile='lullaby_piano',\n        estimated_duration_seconds=780,\n        current_segment_index=2,\n        config_json={\n            'progress_percent': 68.0,\n            'current_step': 'Rendering narration segment 2 of 3.',\n            'current_step_index': 2,\n            'total_steps': 6,\n            'completed_segments': 1,\n            'total_segments': 3,\n            'latest_asset_kind': AssetKind.AUDIO_SEGMENT.value,\n        },\n    )\n    session.add_all([prior_job, active_job])\n    session.flush()\n\n    prior_asset = SessionAsset(\n        session_id=snapshot.id,\n        audio_job_id=prior_job.id,\n        asset_kind=AssetKind.FINAL_AUDIO,\n        status=AssetStatus.READY,\n        storage_bucket='storyteller-audio',\n        object_path=f'sessions/{snapshot.id}/audio/jobs/{prior_job.id}/final/story.wav',\n        mime_type='audio/wav',\n        byte_size=2048,\n        metadata_json={\n            'duration_seconds': 812.0,\n            'generation': {'voice_key': 'moonbeam'},\n            'mix': {'applied': False},\n        },\n        ready_at=utc_now(),\n    )\n    session.add(prior_asset)\n    session.commit()\n    print(snapshot.id)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
