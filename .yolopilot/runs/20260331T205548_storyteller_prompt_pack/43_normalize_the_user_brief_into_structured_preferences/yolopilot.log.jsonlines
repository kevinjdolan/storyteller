essions.py:936:    return changed_fields or [\"raw_brief\"]\nbackend/app/services/sessions.py:945:        \"story_idea\": story_brief.story_idea,\nbackend/app/services/sessions.py:946:        \"desired_themes\": story_brief.desired_themes,\nbackend/app/services/sessions.py:950:        \"raw_brief\": story_brief.raw_brief,\nbackend/app/services/sessions.py:951:        \"normalized_summary\": story_brief.normalized_summary,\nbackend/app/services/sessions.py:952:        \"planning_notes\": story_brief.planning_notes,\nbackend/app/services/event_log.py:71:        normalized_summary = summary.strip()\nbackend/app/services/event_log.py:72:        if not normalized_summary:\nbackend/app/services/event_log.py:80:            summary=normalized_summary,\nbackend/tests/test_story_tools.py:345:        raw_brief=\"A harbor fox follows a silver clue and returns home calm.\",\nbackend/tests/test_story_tools.py:346:        normalized_summary=\"A bedtime harbor mystery with a gentle emotional repair.\",\nbackend/tests/test_story_tools.py:347:        planning_notes=\"Keep the midpoint safe and sleepy.\",\nbackend/tests/test_conversation_memory_evals.py:113:        raw_brief=\"A harbor fox follows moonlight across quiet docks.\",\nbackend/tests/test_conversation_memory_evals.py:114:        normalized_summary=\"A sleepy harbor mystery with a safe return home.\",\nbackend/tests/test_conversation_memory_evals.py:364:        raw_brief=\"A rabbit courier crosses a lantern path at dusk.\",\nbackend/tests/test_conversation_memory_evals.py:365:        normalized_summary=\"A rabbit courier helps the village settle for sleep.\",\nbackend/tests/test_session_service.py:180:        story_idea=\"A young fox rows across a moonlit lake.\",\nbackend/tests/test_session_service.py:181:        desired_themes=\"quiet courage, wonder, coming home soothed\",\nbackend/tests/test_session_service.py:185:        raw_brief=\"A young fox rows across a moonlit lake.\",\nbackend/tests/test_session_service.py:186:  