tSize({ width: 1440, height: 900 });\n  await page.goto('http://127.0.0.1:8566/sessions/' + sessionId + '?stage=finalize');\n  await expect(page.getByText('Final review')).toBeVisible();\n  await expect(page.getByRole('heading', { name: 'Chapter 1' })).toBeVisible();\n  await page.screenshot({ path: '/tmp/storyteller-finalize-read-desktop.png' });\n});\n\ntest('desktop listen mode screenshot', async ({ page }) => {\n  await wireMocks(page);\n  await page.setViewportSize({ width: 1440, height: 900 });\n  await page.goto('http://127.0.0.1:8566/sessions/' + sessionId + '?stage=finalize');\n  await expect(page.getByRole('heading', { name: 'Chapter 1' })).toBeVisible();\n  await page.getByRole('tab', { name: 'Listen back' }).click();\n  await expect(page.getByRole('heading', { name: 'Compiled narration' })).toBeVisible();\n  await page.screenshot({ path: '/tmp/storyteller-finalize-listen-desktop.png' });\n});\n\ntest('mobile listen mode screenshot', async ({ page }) => {\n  await wireMocks(page);\n  await page.setViewportSize({ width: 430, height: 932 });\n  await page.goto('http://127.0.0.1:8566/sessions/' + sessionId + '?stage=finalize');\n  await expect(page.getByRole('heading', { name: 'Chapter 1' })).toBeVisible();\n  await page.getByRole('tab', { name: 'Listen back' }).click();\n  await expect(page.getByRole('heading', { name: 'Compiled narration' })).toBeVisible();\n  await page.screenshot({ path: '/tmp/storyteller-finalize-listen-mobile.png' });\n});\nEOF\nnpx playwright test /tmp/storyteller-finalize-qa.spec.mjs --reporter=line\"", "event_type": "shell.script_execution_started", "event_version": "0.0", "raw_event": {"event_type": "codex.raw.script_execution_started", "event_version": "0.0", "raw_event": {"item": {"aggregated_output": "", "command": "/bin/zsh -lc \"cat > /tmp/storyteller-finalize-qa.spec.mjs <<'EOF'\nimport { test, expect } from '@playwright/test';\n\nconst sessionId = 'session-finalize-qa';\nconst storyAssetInlinePath = '/api/v1/sessions/' + ses