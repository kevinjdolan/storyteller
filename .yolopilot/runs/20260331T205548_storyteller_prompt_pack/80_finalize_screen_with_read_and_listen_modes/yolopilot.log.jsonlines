{"aggregated_output": "}\n\n.feedback-banner__icon {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.feedback-banner strong {\n  color: var(--color-ink-strong);\n}\n\n.blocking-feedback {\n  display: grid;\n  gap: var(--space-5);\n}\n\n.blocking-feedback .panel__header {\n  margin-bottom: 0;\n}\n\n.field {\n  display: grid;\n  gap: var(--space-2);\n}\n\n.field__header {\n  display: flex;\n  align-items: baseline;\n  justify-content: space-between;\n  gap: var(--space-3);\n}\n\n.field__label {\n  color: var(--color-ink-strong);\n  font-weight: 700;\n}\n\n.field__value {\n  color: var(--color-brand);\n  font-size: 0.95rem;\n  font-weight: 700;\n}\n\n.field__description,\n.field__error {\n  margin: 0;\n  font-size: 0.94rem;\n}\n\n.field__description {\n  color: var(--color-ink-soft);\n}\n\n.field__error {\n  color: var(--color-rose);\n}\n\n.text-input,\n.text-area,\n.select-input {\n  min-height: 3rem;\n  padding: 0.8rem 0.95rem;\n  border: 1px solid var(--color-border-soft);\n  border-radius: var(--radius-md);\n  color: var(--color-ink-strong);\n  background: rgba(255, 255, 255, 0.82);\n  transition:\n    border-color 160ms ease,\n    box-shadow 160ms ease,\n    background-color 160ms ease;\n}\n\n.text-input::placeholder,\n.text-area::placeholder {\n  color: var(--color-ink-muted);\n}\n\n.text-input:hover,\n.text-area:hover,\n.select-input:hover {\n  border-color: var(--color-border-strong);\n}\n\n.text-area {\n  min-height: 6.75rem;\n  resize: vertical;\n}\n\n.field--error .text-input,\n.field--error .text-area,\n.field--error .select-input,\n.field--error .toggle-field {\n  border-color: rgba(160, 97, 85, 0.35);\n}\n\n.select-input {\n  width: 100%;\n}\n\n.range-input {\n  width: 100%;\n  margin: 0;\n  accent-color: var(--color-brand);\n}\n\n.range-input::-webkit-slider-runnable-track {\n  height: 0.72rem;\n  border-radius: var(--radius-pill);\n  background: rgba(39, 69, 99, 0.12);\n}\n\n.range-input::-webkit-slider-thumb {\n  wid