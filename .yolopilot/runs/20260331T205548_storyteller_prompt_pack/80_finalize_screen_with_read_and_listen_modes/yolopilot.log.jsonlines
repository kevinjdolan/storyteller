sionRuntimeSelector((state) => state.eventStream)\n}\n\nexport function useSessionRuntimeActions() {\n  const { runtimeStore } = useSessionWorkspaceContext()\n\n  return runtimeStore\n}\n", "command": "/bin/zsh -lc \"sed -n '1,260p' frontend/src/features/session/sessionWorkspaceContext.ts\"", "exit_code": 0, "id": "item_154", "status": "completed", "type": "command_execution"}, "type": "item.completed"}, "run_id": "852e59ae-7e3c-580a-9c17-7f38e0f42b62", "timestamp": "2026-04-02T20:08:05.135424-07:00"}, "run_id": "852e59ae-7e3c-580a-9c17-7f38e0f42b62", "status": "completed", "timestamp": "2026-04-02T20:08:05.135424-07:00"}
