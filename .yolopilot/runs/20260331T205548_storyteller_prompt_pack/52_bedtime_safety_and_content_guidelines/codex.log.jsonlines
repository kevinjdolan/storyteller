.py:198:                f\"composition job {composition_job_id!r} does not belong to session {session_id!r}\"\nbackend/app/services/assets.py:200:        return composition_job\nbackend/app/services/assets.py:202:    def _validate_composition_segment(\nbackend/app/services/assets.py:205:        composition_segment_id: str | None,\nbackend/app/services/assets.py:207:        if composition_segment_id is None:\nbackend/app/services/assets.py:210:        composition_segment = self._session.get(CompositionSegment, composition_segment_id)\nbackend/app/services/assets.py:211:        if composition_segment is None or composition_segment.session_id != session_id:\nbackend/app/services/assets.py:213:                f\"composition segment {composition_segment_id!r} does not belong to session \"\nbackend/app/services/assets.py:216:        return composition_segment\nbackend/app/services/assets.py:218:    def _validate_audio_job(self, session_id: str, audio_job_id: str | None) -> AudioJob | None:\nbackend/app/services/assets.py:219:        if audio_job_id is None:\nbackend/app/services/assets.py:222:        audio_job = self._session.get(AudioJob, audio_job_id)\nbackend/app/services/assets.py:223:        if audio_job is None or audio_job.session_id != session_id:\nbackend/app/services/assets.py:225:                f\"audio job {audio_job_id!r} does not belong to session {session_id!r}\"\nbackend/app/services/assets.py:227:        return audio_job\nbackend/app/services/assets.py:233:        composition_job: CompositionJob | None,\nbackend/app/services/assets.py:234:        composition_segment: CompositionSegment | None,\nbackend/app/services/assets.py:235:        audio_job: AudioJob | None,\nbackend/app/services/assets.py:237:        if composition_segment is not None and composition_job is not None:\nbackend/app/services/assets.py:238:            if composition_segment.composition_job_id != composition_job.id:\nbackend/app/services/assets.py:240:                    \"composition_