eneration.py:268:            passed=descriptive_conflicts == len(pitches),\nbackend/app/services/pitch_generation.py:274:            passed=grounded_fit_notes == len(pitches),\nbackend/app/services/pitch_generation.py:276:            detail=\"Fit notes should explicitly explain the bedtime match.\",\nbackend/app/services/pitch_generation.py:286:def build_pitch_model_output(result: PitchGenerationResult) -> dict[str, Any]:\nbackend/app/services/pitch_generation.py:294:    if result.prompt_version is not None:\nbackend/app/services/pitch_generation.py:295:        payload[\"prompt_version\"] = result.prompt_version\nbackend/app/services/pitch_generation.py:307:    pitches = _build_heuristic_pitches(context)\nbackend/app/services/pitch_generation.py:308:    evaluation = evaluate_pitch_batch(\nbackend/app/services/pitch_generation.py:309:        pitches,\nbackend/app/services/pitch_generation.py:322:        pitches=pitches,\nbackend/app/services/pitch_generation.py:328:def _build_heuristic_pitches(\nbackend/app/services/pitch_generation.py:331:    if context.generation_goal == \"refinement\" and context.selected_pitch is not None:\nbackend/app/services/pitch_generation.py:332:        return _build_heuristic_refined_pitches(context)\nbackend/app/services/pitch_generation.py:338:        or \"A gentle bedtime hero\"\nbackend/app/services/pitch_generation.py:392:def _build_heuristic_refined_pitches(\nbackend/app/services/pitch_generation.py:395:    assert context.selected_pitch is not None\nbackend/app/services/pitch_generation.py:397:    source_pitch = context.selected_pitch\nbackend/app/services/pitch_generation.py:398:    guidance = context.guidance or \"Keep the pitch bedtime-safe while preserving its core premise.\"\nbackend/app/services/pitch_generation.py:403:        or \"A gentle bedtime hero\"\nbackend/app/services/pitch_generation.py:410:    source_title_core = re.sub(r\"^The\\s+\", \"\", source_pitch.title).strip()\nbackend/app/services/pitch_generation.py:418:   